node_modules
**/node_modules
dist
**/dist
.git
.pnpm-store
*.tsbuildinfo
.turbo
**/.turbo

# ============================================================================
# Environment Files
# ============================================================================
# Never include environment files in Docker images
.env
.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
*.env
**/.env

# ============================================================================
# IDE and Editor Files
# ============================================================================
.vscode
.idea
.fleet
.ijwb
*.swp
*.swo
*~
*.sublime-*
.project
.classpath
.settings
.vscode-test

# ============================================================================
# OS Generated Files
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================================
# Docker Files (avoid recursion)
# ============================================================================
# Note: DO NOT ignore Dockerfiles themselves - Railway needs them!
docker-compose*.yml
docker-compose*.yaml
.dockerignore

# ============================================================================
# Testing
# ============================================================================
coverage
.nyc_output
test-results
playwright-report
.jest
.cache
jest-*
*.spec.ts.snap
__snapshots__

# ============================================================================
# Logs
# ============================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ============================================================================
# Runtime Data
# ============================================================================
pids
*.pid
*.seed
*.pid.lock

# ============================================================================
# Temporary Files
# ============================================================================
tmp
temp
*.tmp
*.temp
.cache
.parcel-cache

# ============================================================================
# Documentation
# ============================================================================
# Exclude documentation files to reduce context size
*.md
!README.md
docs
documentation
wiki

# ============================================================================
# Media Files
# ============================================================================
# Exclude large media files that aren't needed for builds
*.mov
*.mp4
*.avi
*.wmv
*.flv
*.webm
*.mkv
*.m4v

# ============================================================================
# Database Files
# ============================================================================
*.sqlite
*.sqlite3
*.db
*.sql
*.dump
!packages/database/drizzle/*.sql
!packages/database/migrations/*.sql

# Database migration files (if not needed in container)
# migrations/*.sql

# ============================================================================
# Secrets and Credentials
# ============================================================================
# Never include secrets in Docker images!
*.key
*.pem
*.p12
*.pfx
credentials.json
service-account*.json
secrets.yaml
secrets.yml

# ============================================================================
# Build Tools Configuration
# ============================================================================
# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Serverless directories
.serverless

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# ============================================================================
# Continuous Integration
# ============================================================================
.travis.yml
.circleci
.jenkins
jenkins/
.gitlab-ci.yml
azure-pipelines.yml
.azure

# ============================================================================
# Repository Specific
# ============================================================================
# Add any project-specific files to ignore
scripts/local-dev
scripts/dev-tools
benchmarks
examples

# ============================================================================
# Large Binary Files
# ============================================================================
# Exclude large binaries that aren't needed
*.dmg
*.iso
*.tar.gz
*.zip
*.rar

# ============================================================================
# Miscellaneous
# ============================================================================
*~
.history
.ionide
.tmp
.tmp-agent-home
agent-communication/
analysis/
component-inventory/
component-templates/
improvements/
pull-create/
solid-shrimp/
strategic-cow/
~/
*.bak
*.old
*.orig
*.png
*.log
*.txt
task_plan.md
findings.md
progress.md
typecheck_output.txt
prs.json
deployments.txt

# Keep certain files even if they match other patterns (use ! to negate)
# Example: !important.md

# ============================================================================
# NOTES
# ============================================================================
# To check what's being sent to Docker build context, run:
#   docker build --no-cache -f Dockerfile.railway -t test . 2>&1 | grep "Sending build context"
#
# Expected result:
#   Sending build context to Docker daemon  ~50-100MB
#
# If it's larger, review this file and ensure all unnecessary files are excluded.
# ============================================================================

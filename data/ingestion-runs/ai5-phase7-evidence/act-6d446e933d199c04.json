  "action_id": "act-6d446e933d199c04",
  "title": "[AI5] Implement API Rate Limiting",
  "state": "landed",
  "updatedAt": "2026-06-09T10:30:00Z",
  "summary": "Implemented bounded, env-configurable HTTP rate limiting at the API Gateway edge and hardened the API SecurityGuard route-level limiter to emit standard rate-limit headers and HTTP 429 responses.",
  "filesChanged": [
    "apps/api-gateway/src/main.ts",
    "apps/api/src/guards/security.guard.ts",
    "data/ingestion-runs/ai5-phase7-evidence/act-6d446e933d199c04.json"
  ],
  "checks": [
    {
      "command": "git diff --check -- apps/api-gateway/src/main.ts apps/api/src/guards/security.guard.ts",
      "result": "passed"
    },
    {
      "command": "pnpm --dir apps/api-gateway run type-check",
      "result": "passed"
    },
    {
      "command": "pnpm --dir apps/api run type-check",
      "result": "passed"
    }
  ],
  "implementation": {
    "gateway": {
      "strategy": "per-client fixed-window limiter using x-forwarded-for/x-real-ip/socket address",
      "defaults": {
        "requests": 600,
        "windowMs": 60000,
        "maxKeys": 10000
      },
      "env": [
        "API_GATEWAY_RATE_LIMIT_ENABLED=false",
        "API_GATEWAY_RATE_LIMIT_REQUESTS",
        "API_GATEWAY_RATE_LIMIT_WINDOW_MS",
        "API_GATEWAY_RATE_LIMIT_MAX_KEYS"
      ],
      "skips": [
        "OPTIONS",
        "/",
        "/health",
        "/api/health",
        "/api/v1/health",
        "/docs*"
      ]
    },
    "apiGuard": {
      "strategy": "decorator/env-configured per-client fixed-window limiter for guarded routes",
      "defaults": {
        "requests": 100,
        "windowMs": 60000,
        "maxKeys": 10000
      },
      "env": [
        "API_RATE_LIMIT_REQUESTS",
        "API_RATE_LIMIT_WINDOW_MS",
        "API_RATE_LIMIT_MAX_KEYS"
      ]
    },
    "headers": [
      "X-RateLimit-Limit",
      "X-RateLimit-Remaining",
      "X-RateLimit-Reset",
      "Retry-After on 429"
    ]
  }
}

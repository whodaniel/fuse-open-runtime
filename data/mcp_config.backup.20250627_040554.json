{
  "mcpServers": {
    "agent-communication": {
      "command": "node",
      "args": ["src/agent_with_mcp_example.ts"]
    },
    "context7-server": {
      "command": "node",
      "args": [
        "/Users/danielgoldberg/Documents/Cline/MCP/context7-server/build/index.js"
      ]
    },
    "applescript_execute": {
      "command": "npx",
      "args": ["@peakmojo/applescript-mcp"]
    },
    "enhanced-mcp-config-manager": {
      "command": "npx",
      "args": ["tsx", "./src/mcp/enhanced-config-manager.ts"],
      "env": {
        "LOG_LEVEL": "info",
        "CONFIG_PATH": "./data/mcp_config.json"
      }
    },
    "unified-config-server": {
      "command": "npx",
      "args": ["tsx", "./src/mcp/unified-config-server.ts", "--no-oauth"],
      "env": {
        "HTTP_PORT": "3773",
        "LOG_LEVEL": "info",
        "CONFIG_PATH": "./data/mcp_config.json"
      }
    },
    "browsermcp": {
      "command": "npx",
      "args": ["@browsermcp/mcp@latest"]
    },
    "MCP_DOCKER": {
      "command": "docker",
      "args": [
        "run",
        "-l",
        "mcp.client=claude-desktop",
        "--rm",
        "-i",
        "alpine/socat",
        "STDIO",
        "TCP:host.docker.internal:8811"
      ]
    }
  }
}

{
  "name": "the-new-fuse-chrome-extension",
  "version": "1.0.0",
  "description": "The New Fuse - Text Input Manager Chrome Extension",
  "main": "background.js",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-icons": "node generate-icons.cjs",
    "generate-notification-icons": "node scripts/generate-notification-icons.cjs",
    "build": "webpack --config webpack.config.cjs --mode production",
    "build:v5": "webpack --config webpack.v5.config.cjs --mode production",
    "dev:v5": "webpack --config webpack.v5.config.cjs --mode development --watch",
    "prebuild": "node generate-icons.cjs && node scripts/generate-notification-icons.cjs",
    "dev": "webpack --mode development --watch",
    "package": "node scripts/package-extension.js",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.ts",
    "clean": "rimraf dist icons coverage .turbo node_modules/.cache",
    "clean:build": "rimraf dist icons coverage",
    "clean:v5": "rimraf dist-v5",
    "typecheck": "tsc --noEmit",
    "build:package": "pnpm run build && pnpm run package"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1",
    "ajv": "^8.12.0",
    "ajv-keywords": "^5.1.0",
    "dompurify": "^3.0.0",
    "highlight.js": "^11.11.1",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "@types/dompurify": "^3.0.0",
    "@types/identity-obj-proxy": "^3.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.27",
    "@types/pako": "^2.0.3",
    "autoprefixer": "^10.4.17",
    "baseline-browser-mapping": "^2.9.14",
    "canvas": "^3.1.1",
    "copy-webpack-plugin": "11.0.0",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "cssnano": "^6.0.3",
    "eslint": "^9.26.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-chrome": "^0.8.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^10.1.6",
    "react-draggable": "^4.5.0",
    "rimraf": "^5.0.5",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  },
  "eslintConfig": {
    "root": true,
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "env": {
      "browser": true,
      "node": true,
      "webextensions": true,
      "jest": true
    }
  }
}

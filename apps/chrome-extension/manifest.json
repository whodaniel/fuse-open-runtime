{
  "manifest_version": 3,
  "name": "The New Fuse AI Bridge",
  "version": "1.0.0",
  "description": "Enterprise AI Bridge - Connect browser tabs to AI agents and the TNF relay system for seamless AI-to-AI and human-to-AI communication.",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "alarms",
    "contextMenus",
    "notifications",
    "scripting",
    "clipboardWrite",
    "clipboardRead"
  ],

  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://gemini.google.com/*",
    "https://bard.google.com/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://thenewfuse.com/*",
    "https://*.thenewfuse.com/*",
    "https://*.railway.app/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "The New Fuse AI Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://bard.google.com/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*", "popup.css", "injectable-ui.css"],
      "matches": ["<all_urls>"]
    }
  ],

  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "https://thenewfuse.com/*",
      "https://*.thenewfuse.com/*",
      "https://*.railway.app/*"
    ]
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Open The New Fuse popup"
    },
    "inject-floating-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Toggle floating panel on current page"
    },
    "capture-response": {
      "suggested_key": {
        "default": "Ctrl+Shift+C",
        "mac": "Command+Shift+C"
      },
      "description": "Capture AI response from current page"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "minimum_chrome_version": "110"
}

{
  "manifest_version": 3,
  "name": "Fuse Connect - AI Bridge",
  "version": "4.0.0",
  "description": "Bridge your browser to The New Fuse AI agent network. Enable multi-agent collaboration, federation, and automation across AI platforms.",

  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "tabs",
    "webNavigation",
    "identity",
    "cookies",
    "alarms",
    "contextMenus",
    "webRequest",
    "notifications",
    "nativeMessaging"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://*.youtube.com/*",
    "https://aistudio.google.com/*",
    "https://notebooklm.google.com/*",
    "https://www.googleapis.com/*",
    "https://*.usercontent.goog/*"
  ],

  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLOUD_CLIENT_ID_HERE",
    "scopes": [
      "https://www.googleapis.com/auth/youtube.readonly",
      "https://www.googleapis.com/auth/drive.appdata",
      "profile",
      "email"
    ]
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Fuse Connect",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://aistudio.google.com/*"],
      "js": ["content-scripts/ai-studio/ai-studio.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://*.usercontent.goog/*"],
      "js": ["content-scripts/ai-studio/iframe-bridge.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content-scripts/ai-studio/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://notebooklm.google.com/*"],
      "js": ["content-scripts/ai-studio/notebooklm.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "floating-panel.html",
        "floating-panel.js",
        "icons/*.png",
        "styles/*.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; object-src 'self'; connect-src 'self' http://localhost:* ws://localhost:* wss://localhost:* https://chat.openai.com https://claude.ai https://gemini.google.com https://www.perplexity.ai;"
  },

  "commands": {
    "toggle-floating-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Toggle floating panel"
    },
    "auto-detect-elements": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Auto-detect AI chat elements"
    },
    "start-ai-session": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Start AI automation session"
    }
  }
}

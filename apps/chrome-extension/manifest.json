{
  "manifest_version": 3,
  "name": "Fuse Connect - AI Bridge Extension",
  "version": "3.1.0",
  "description": "Bridge your browser to the AI agent network. Connect multiple AI chat platforms, automate workflows, and enable multi-agent collaboration.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "notifications",
    "tabs",
    "webNavigation",
    "debugger",
    "offscreen",
    "windows"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css", "element-selection.css"],
      "run_at": "document_start",
      "type": "module"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "vendor.js",
        "commons.js",
        "*.js.map",
        "*.css.map",
        "floatingPanel.html",
        "floatingPanel.js",
        "floatingPanel.css",
        "element-selection.css",
        "enhanced-theme.css",
        "icons/*.png",
        "ui-html-css/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; object-src 'self'; connect-src 'self' http://localhost:* ws://localhost:* wss://localhost:* https://chat.openai.com https://claude.ai https://gemini.google.com;"
  },
  "commands": {
    "toggle-element-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "Toggle element selection mode"
    },
    "auto-detect-elements": {
      "suggested_key": {
        "default": "Ctrl+Shift+D"
      },
      "description": "Auto-detect chat elements"
    },
    "start-ai-session": {
      "suggested_key": {
        "default": "Ctrl+Shift+A"
      },
      "description": "Start AI automation session"
    }
  },
  "externally_connectable": {
    "ids": ["*"],
    "matches": ["<all_urls>"]
  },
  "nativeMessaging": true
}

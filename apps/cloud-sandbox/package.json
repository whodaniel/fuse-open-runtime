{
  "name": "tnf-cloud-sandbox",
  "version": "1.0.0",
  "description": "Cloud sandbox with MCP server for The New Fuse bridge connections",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "PORT=$(node ../../packages/port-management/scripts/find-available-port.cjs cloud-sandbox) npx tsx watch src/server.ts",
    "build": "tsc -b",
    "start": "npx tsx src/server.ts"
  },
  "dependencies": {
    "@the-new-fuse/database": "workspace:*",
    "@the-new-fuse/types": "workspace:*",
    "chrome-remote-interface": "^0.33.3",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "node-pty": "^1.0.0",
    "playwright": "1.58.2",
    "socket.io": "^4.8.1",
    "tsx": "^4.21.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^6.0.2"
  }
}

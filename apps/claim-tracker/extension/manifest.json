{
  "manifest_version": 3,
  "name": "ClaimTracker Companion",
  "version": "0.1.0",
  "description": "Real-time claim tracking for Facebook Live Sales.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.facebook.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/watch/live/*",
        "https://www.facebook.com/*/videos/*"
      ],
      "js": ["content.js"]
    }
  ]
}

{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2020",
		"lib": [
			"ES2020"
		],
		"outDir": "out",
		"sourceMap": true,
		"strict": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"moduleResolution": "node",

		"baseUrl": ".",
		"paths": {
			"@the-new-fuse/tnf-core/*": ["../../packages/tnf-core/src/*"]
		}
	},
	"exclude": [
		"node_modules",
		".vscode-test"
	]
}
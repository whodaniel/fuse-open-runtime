{
  "name": "vscode-extension",
  "displayName": "The New Fuse",
  "description": "The New Fuse - AI Assistant with Multi-Agent Orchestration, Full MCP Configuration, Enhanced LiteLLM Integration & Multi-Tenant Support",
  "version": "8.1.0",
  "publisher": "TheNewFuse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-New-Fuse/vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education"
  ],
  "keywords": [
    "ai",
    "chat",
    "assistant",
    "agent",
    "automation",
    "litellm",
    "llm-provider",
    "multi-model"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "theNewFuse",
          "title": "The New Fuse",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "theNewFuse": [
        {
          "type": "webview",
          "id": "theNewFuse.chatView",
          "name": "AI Chat",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "theNewFuse.sendMessage",
        "category": "The New Fuse",
        "title": "Send Message"
      },
      {
        "command": "theNewFuse.clearChat",
        "category": "The New Fuse",
        "title": "Clear Chat",
        "icon": "$(clear-all)"
      },
      {
        "command": "theNewFuse.newChat",
        "category": "The New Fuse",
        "title": "New Chat",
        "icon": "$(add)"
      },
      {
        "command": "theNewFuse.openWorkflowBuilder",
        "category": "The New Fuse - Workflow",
        "title": "🔄 Open Workflow Builder",
        "icon": "$(workflow)"
      },
      {
        "command": "theNewFuse.agentFederation",
        "category": "The New Fuse - Agents",
        "title": "🤖 Agent Federation",
        "icon": "$(organization)"
      },
      {
        "command": "theNewFuse.mcpConnect",
        "category": "The New Fuse - MCP",
        "title": "🔗 Connect MCP Server",
        "icon": "$(plug)"
      },
      {
        "command": "theNewFuse.terminalOrchestration",
        "category": "The New Fuse - Terminal",
        "title": "⚡ Terminal Orchestration",
        "icon": "$(terminal)"
      },
      {
        "command": "theNewFuse.codeActions",
        "category": "The New Fuse - Code",
        "title": "💻 Code Actions",
        "icon": "$(code)"
      },
      {
        "command": "theNewFuse.planManager",
        "category": "The New Fuse - Planning",
        "title": "📋 Plan Manager",
        "icon": "$(list-ordered)"
      },
      {
        "command": "theNewFuse.explainCode",
        "category": "The New Fuse - Code",
        "title": "🔍 Explain Code",
        "icon": "$(info)"
      },
      {
        "command": "theNewFuse.fixCode",
        "category": "The New Fuse - Code",
        "title": "🔧 Fix Code",
        "icon": "$(wrench)"
      },
      {
        "command": "theNewFuse.improveCode",
        "category": "The New Fuse - Code",
        "title": "⚡ Improve Code",
        "icon": "$(rocket)"
      },
      {
        "command": "theNewFuse.addToContext",
        "category": "The New Fuse - Context",
        "title": "📎 Add to Context",
        "icon": "$(link)"
      },
      {
        "command": "theNewFuse.generateCommitMessage",
        "category": "The New Fuse - Git",
        "title": "📝 Generate Commit Message",
        "icon": "$(git-commit)"
      },
      {
        "command": "theNewFuse.inlineSuggestions",
        "category": "The New Fuse - AI",
        "title": "💡 Inline Code Suggestions",
        "icon": "$(lightbulb)"
      },
      {
        "command": "theNewFuse.openInNewTab",
        "category": "The New Fuse - View",
        "title": "🗂️ Open in New Tab",
        "icon": "$(link-external)"
      },
      {
        "command": "theNewFuse.historyButtonClicked",
        "category": "The New Fuse - History",
        "title": "📚 Chat History",
        "icon": "$(history)"
      },
      {
        "command": "theNewFuse.marketplaceButtonClicked",
        "category": "The New Fuse - Marketplace",
        "title": "🛍️ Extensions Marketplace",
        "icon": "$(extensions)"
      },
      {
        "command": "theNewFuse.profileButtonClicked",
        "category": "The New Fuse - Profile",
        "title": "👤 User Profile",
        "icon": "$(account)"
      },
      {
        "command": "theNewFuse.settingsButtonClicked",
        "category": "The New Fuse - Settings",
        "title": "⚙️ Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "theNewFuse.helpButtonClicked",
        "category": "The New Fuse - Help",
        "title": "❓ Help & Documentation",
        "icon": "$(question)"
      },
      {
        "command": "theNewFuse.autoApprove",
        "category": "The New Fuse - Automation",
        "title": "✅ Auto-Approve Mode",
        "icon": "$(check)"
      },
      {
        "command": "theNewFuse.codeMode",
        "category": "The New Fuse - Modes",
        "title": "💻 Code Mode",
        "icon": "$(code)"
      },
      {
        "command": "theNewFuse.databaseMode",
        "category": "The New Fuse - Modes",
        "title": "🗃️ Database Mode",
        "icon": "$(database)"
      },
      {
        "command": "theNewFuse.attachFiles",
        "category": "The New Fuse - Files",
        "title": "📎 Attach Files",
        "icon": "$(attach)"
      },
      {
        "command": "theNewFuse.securityDashboard",
        "category": "The New Fuse - Security",
        "title": "🛡️ Security Dashboard",
        "icon": "$(shield)"
      },
      {
        "command": "theNewFuse.securityScan",
        "category": "The New Fuse - Security",
        "title": "🔍 Run Security Scan",
        "icon": "$(search-view-icon)"
      },
      {
        "command": "theNewFuse.emergencyMode",
        "category": "The New Fuse - Security",
        "title": "🚨 Emergency Mode",
        "icon": "$(warning)"
      },
      {
        "command": "theNewFuse.systemStatus",
        "category": "The New Fuse - System",
        "title": "🔗 System Status",
        "icon": "$(pulse)"
      },
      {
        "command": "theNewFuse.cli.runAgent",
        "category": "The New Fuse - CLI",
        "title": "🤖 Run CLI Agent",
        "icon": "$(robot)"
      },
      {
        "command": "theNewFuse.cli.initWorkspace",
        "category": "The New Fuse - CLI",
        "title": "🔧 Initialize TNF Workspace",
        "icon": "$(folder-opened)"
      },
      {
        "command": "theNewFuse.cli.showTasks",
        "category": "The New Fuse - CLI",
        "title": "📋 Show Active CLI Tasks",
        "icon": "$(list-ordered)"
      },
      {
        "command": "theNewFuse.cli.showHistory",
        "category": "The New Fuse - CLI",
        "title": "📜 Show CLI Task History",
        "icon": "$(history)"
      },
      {
        "command": "theNewFuse.cli.chatSession",
        "category": "The New Fuse - CLI",
        "title": "💬 Start CLI Chat Session",
        "icon": "$(comment)"
      },
      {
        "command": "theNewFuse.mcpStatus",
        "category": "The New Fuse - MCP",
        "title": "📊 MCP Server Status",
        "icon": "$(graph)"
      },
      {
        "command": "theNewFuse.openLiteLLMConfig",
        "category": "The New Fuse - LLM",
        "title": "🚀 Enhanced LiteLLM Configuration",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "theNewFuse.newChat",
          "group": "navigation@1",
          "when": "view == theNewFuse.chatView"
        },
        {
          "command": "theNewFuse.mcpConnect",
          "group": "navigation@2",
          "when": "view == theNewFuse.chatView"
        },
        {
          "command": "theNewFuse.marketplaceButtonClicked",
          "group": "navigation@3",
          "when": "view == theNewFuse.chatView"
        },
        {
          "command": "theNewFuse.historyButtonClicked",
          "group": "navigation@4",
          "when": "view == theNewFuse.chatView"
        },
        {
          "command": "theNewFuse.profileButtonClicked",
          "group": "navigation@5",
          "when": "view == theNewFuse.chatView"
        },
        {
          "command": "theNewFuse.settingsButtonClicked",
          "group": "navigation@6",
          "when": "view == theNewFuse.chatView"
        },
        {
          "command": "theNewFuse.openInNewTab",
          "group": "navigation@7",
          "when": "view == theNewFuse.chatView"
        },
        {
          "command": "theNewFuse.clearChat",
          "group": "navigation@8",
          "when": "view == theNewFuse.chatView"
        }
      ],
      "editor/context": [
        {
          "submenu": "theNewFuse.contextMenu",
          "group": "1"
        }
      ],
      "theNewFuse.contextMenu": [
        {
          "command": "theNewFuse.explainCode",
          "group": "1_actions@1"
        },
        {
          "command": "theNewFuse.fixCode",
          "group": "1_actions@2"
        },
        {
          "command": "theNewFuse.improveCode",
          "group": "1_actions@3"
        },
        {
          "command": "theNewFuse.addToContext",
          "group": "1_actions@4"
        }
      ],
      "scm/input": [
        {
          "command": "theNewFuse.generateCommitMessage",
          "group": "navigation"
        }
      ]
    },
    "submenus": [
      {
        "id": "theNewFuse.contextMenu",
        "label": "The New Fuse"
      }
    ],
    "keybindings": [
      {
        "command": "theNewFuse.sendMessage",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "true"
      },
      {
        "command": "theNewFuse.inlineSuggestions",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "The New Fuse - LiteLLM",
      "properties": {
        "tnf.litellm.baseURL": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "LiteLLM proxy base URL"
        },
        "tnf.litellm.apiKey": {
          "type": "string",
          "default": "",
          "description": "LiteLLM API key (optional)"
        },
        "tnf.litellm.model": {
          "type": "string",
          "default": "gpt-3.5-turbo",
          "description": "Default LiteLLM model"
        },
        "tnf.litellm.masterKey": {
          "type": "string",
          "default": "",
          "description": "LiteLLM master key for virtual keys management"
        },
        "tnf.litellm.maxRetries": {
          "type": "number",
          "default": 3,
          "description": "Maximum number of retry attempts"
        },
        "tnf.litellm.retryDelay": {
          "type": "number",
          "default": 1000,
          "description": "Initial retry delay in milliseconds"
        },
        "tnf.litellm.retryMultiplier": {
          "type": "number",
          "default": 2,
          "description": "Retry delay multiplier for exponential backoff"
        },
        "tnf.litellm.fallbackModels": {
          "type": "array",
          "default": [],
          "description": "Fallback models to use when primary fails",
          "items": {
            "type": "string"
          }
        },
        "tnf.litellm.enableFallback": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic fallback to alternative models"
        },
        "tnf.litellm.circuitBreakerThreshold": {
          "type": "number",
          "default": 5,
          "description": "Number of failures before circuit breaker opens"
        },
        "tnf.litellm.circuitBreakerTimeout": {
          "type": "number",
          "default": 60000,
          "description": "Circuit breaker cooldown period in milliseconds"
        },
        "tnf.litellm.enableCache": {
          "type": "boolean",
          "default": true,
          "description": "Enable response caching"
        },
        "tnf.litellm.cacheType": {
          "type": "string",
          "enum": [
            "memory",
            "redis"
          ],
          "default": "memory",
          "description": "Cache storage type"
        },
        "tnf.litellm.cacheTTL": {
          "type": "number",
          "default": 3600,
          "description": "Cache time-to-live in seconds"
        },
        "tnf.litellm.redisHost": {
          "type": "string",
          "default": "localhost",
          "description": "Redis host for caching"
        },
        "tnf.litellm.redisPort": {
          "type": "number",
          "default": 6379,
          "description": "Redis port for caching"
        },
        "tnf.litellm.enableBudget": {
          "type": "boolean",
          "default": false,
          "description": "Enable budget tracking and limits"
        },
        "tnf.litellm.budgetLimit": {
          "type": "number",
          "default": 0,
          "description": "Maximum budget limit in USD"
        },
        "tnf.litellm.timeout": {
          "type": "number",
          "default": 30000,
          "description": "Request timeout in milliseconds"
        },
        "tnf.litellm.enableBackgroundHealthCheck": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic background health checks"
        },
        "tnf.litellm.healthCheckInterval": {
          "type": "number",
          "default": 60000,
          "description": "Health check interval in milliseconds"
        },
        "tnf.litellm.embeddingModel": {
          "type": "string",
          "default": "text-embedding-ada-002",
          "description": "Model to use for embeddings"
        },
        "tnf.litellm.enableLogging": {
          "type": "boolean",
          "default": true,
          "description": "Enable detailed logging"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/vscode": "^1.90.0",
    "@types/node": "18.x",
    "eslint": "^9.13.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.39.0",
    "@vscode/test-electron": "^2.3.9"
  },
  "dependencies": {
    "openai": "^4.28.0",
    "@anthropic-ai/sdk": "^0.17.1",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "ws": "^8.18.0",
    "@the-new-fuse/tnf-core": "workspace:*"
  }
}

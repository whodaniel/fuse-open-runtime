        "title": "Distribute Task",
        "category": "The New Fuse: Collective",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "theNewFuse.federationNetwork",
        "title": "Federation Network",
        "category": "The New Fuse: Federation",
        "icon": "$(globe)"

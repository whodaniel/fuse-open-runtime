      },
      {
        "command": "theNewFuse.browserExecuteScript",
        "title": "Execute Script in Browser",
        "category": "The New Fuse",
        "icon": "$(code)"
      },
      {
        "command": "theNewFuse.a2aProtocol",
        "title": "A2A Protocol Manager",
        "category": "The New Fuse: A2A",
        "icon": "$(broadcast)"
      },
      {
        "command": "theNewFuse.a2aConnectAgent",
        "title": "Connect to Agent",

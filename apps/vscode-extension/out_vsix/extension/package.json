    "menus": {
      "view/title": [
        {
          "command": "theNewFuse.newChat",
          "when": "view == theNewFuse.chatView",
          "group": "navigation@1"
        },
        {
          "command": "theNewFuse.mcpConnect",
          "when": "view == theNewFuse.chatView",
          "group": "navigation@2"
        },
        {
          "command": "theNewFuse.historyButtonClicked",
          "when": "view == theNewFuse.chatView",
          "group": "navigation@3"
        },
        {
          "command": "theNewFuse.settingsButtonClicked",
          "when": "view == theNewFuse.chatView",
          "group": "navigation@4"
        },
        {
          "command": "theNewFuse.clearChat",
          "when": "view == theNewFuse.chatView",
          "group": "navigation@5"
        }
      ],
      "editor/context": [
        {
          "submenu": "theNewFuse.contextMenu",
          "group": "z_theNewFuse"
        }
      ],
      "theNewFuse.contextMenu": [
        {
          "command": "theNewFuse.explainCode",
          "group": "1_actions@1"
        },
        {
          "command": "theNewFuse.fixCode",
          "group": "1_actions@2"
        },
        {
          "command": "theNewFuse.improveCode",
          "group": "1_actions@3"
        },
        {
          "command": "theNewFuse.addToContext",
          "group": "1_actions@4"
        },
        {
          "command": "theNewFuse.securityScan",
          "group": "2_security@1"
        }
      ],
      "scm/input": [
        {
          "command": "theNewFuse.generateCommitMessage",
          "group": "navigation"
        }
      ]
    },
    "submenus": [
      {
        "id": "theNewFuse.contextMenu",
        "label": "The New Fuse"
      }
    ],
    "keybindings": [
      {
        "command": "theNewFuse.sendMessage",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "theNewFuse.newChat",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      },
      {
        "command": "theNewFuse.inlineSuggestions",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "The New Fuse",
      "properties": {
        "theNewFuse.defaultProvider": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "anthropic",
            "gemini",
            "deepseek",
            "qwen",
            "openrouter",
            "litellm",
            "copilot",
            "claude-cli",
            "gemini-cli",
            "jules-cli",
            "aider-cli",
            "custom-cli"
          ],
          "enumDescriptions": [
            "OpenAI (GPT-5.2, GPT-5.1-Codex-Max)",
            "Anthropic (Claude Opus 4.5, Sonnet 4.5)",
            "Google Gemini (Gemini 3 Pro, Gemini 2.5 Flash)",
            "DeepSeek (V3.2-Speciale, DeepSeek-R1)",
            "Qwen (Qwen3-Coder, Qwen 2.5-Max)",
            "OpenRouter (Multi-provider)",
            "LiteLLM (Self-hosted proxy)",
            "VS Code Copilot",
            "Claude CLI (Local)",
            "Gemini CLI (Local)",
            "Jules CLI (Local)",
            "Aider CLI (Local)",
            "Custom CLI Command"
          ],
          "description": "Default AI provider - includes API and CLI-based options (December 2025)"
        },
        "theNewFuse.defaultModel": {
          "type": "string",
          "default": "gpt-5.2",
          "description": "Default model to use"
        },
        "theNewFuse.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to MCP servers on startup"
        },
        "theNewFuse.enableTelemetry": {
          "type": "boolean",
          "default": false,
          "description": "Enable anonymous usage telemetry"
        },
        "theNewFuse.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "description": "Chat interface theme"
        },
        "theNewFuse.mcpServers": {
          "type": "array",
          "default": [],
          "description": "MCP server configurations",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Server name"
              },
              "command": {
                "type": "string",
                "description": "Command to start the server"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Command arguments"
              },
              "env": {
                "type": "object",
                "description": "Environment variables"
              },
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether the server is enabled"
              }
            },
            "required": [
              "name",
              "command"
            ]
          }
        },
        "theNewFuse.providers.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI API base URL"
        },
        "theNewFuse.providers.openai.model": {
          "type": "string",
          "default": "gpt-5.2",
          "description": "Default OpenAI model (December 2025: gpt-5.2, gpt-5.1-codex-max)"
        },
        "theNewFuse.providers.anthropic.baseUrl": {
          "type": "string",
          "default": "https://api.anthropic.com/v1",
          "description": "Anthropic API base URL"
        },
        "theNewFuse.providers.anthropic.model": {
          "type": "string",
          "default": "claude-opus-4.5-20251124",
          "description": "Default Anthropic model (December 2025: claude-opus-4.5, claude-sonnet-4.5)"
        },
        "theNewFuse.providers.gemini.model": {
          "type": "string",
          "default": "gemini-3-pro",
          "description": "Default Gemini model (December 2025: gemini-3-pro, gemini-2.5-flash)"
        },
        "theNewFuse.providers.deepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com/v1",
          "description": "DeepSeek API base URL"
        },
        "theNewFuse.providers.deepseek.model": {
          "type": "string",
          "default": "deepseek-v3.2-speciale",
          "description": "Default DeepSeek model (December 2025: deepseek-v3.2-speciale, deepseek-r1)"
        },
        "theNewFuse.providers.qwen.baseUrl": {
          "type": "string",
          "default": "https://dashscope.aliyuncs.com/compatible-mode/v1",
          "description": "Qwen/DashScope API base URL"
        },
        "theNewFuse.providers.qwen.model": {
          "type": "string",
          "default": "qwen3-coder-480b",
          "description": "Default Qwen model (December 2025: qwen3-coder-480b, qwen-2.5-max)"
        },
        "theNewFuse.providers.openrouter.baseUrl": {
          "type": "string",
          "default": "https://openrouter.ai/api/v1",
          "description": "OpenRouter API base URL"
        },
        "theNewFuse.providers.openrouter.model": {
          "type": "string",
          "default": "anthropic/claude-opus-4.5",
          "description": "Default OpenRouter model"
        },
        "theNewFuse.providers.litellm.baseUrl": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "LiteLLM proxy base URL"
        },
        "theNewFuse.providers.litellm.model": {
          "type": "string",
          "default": "gpt-5.2",
          "description": "Default LiteLLM model"
        },
        "theNewFuse.maxTokens": {
          "type": "number",
          "default": 8192,
          "description": "Maximum tokens for responses"
        },
        "theNewFuse.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Response temperature (creativity)"
        },
        "theNewFuse.cliAgents": {
          "type": "array",
          "default": [],
          "description": "CLI-based AI agent configurations for local tools like claude, gemini, jules, aider",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Agent name (e.g., 'claude', 'gemini', 'jules', 'aider')"
              },
              "command": {
                "type": "string",
                "description": "CLI command to execute (e.g., 'claude', 'gemini')"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Command line arguments"
              },
              "env": {
                "type": "object",
                "description": "Environment variables"
              },
              "workingDirectory": {
                "type": "string",
                "description": "Working directory for the command"
              },
              "inputFormat": {
                "type": "string",
                "enum": [
                  "stdin",
                  "arg",
                  "file"
                ],
                "default": "stdin",
                "description": "How to pass the prompt to the CLI"
              },
              "outputFormat": {
                "type": "string",
                "enum": [
                  "stdout",
                  "file",
                  "json"
                ],
                "default": "stdout",
                "description": "How to read the response from the CLI"
              },
              "timeout": {
                "type": "number",
                "default": 120000,
                "description": "Timeout in milliseconds"
              },
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether this agent is enabled"
              }
            },
            "required": [
              "name",
              "command"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "package": "npm run compile && npx @vscode/vsce package --no-dependencies"
  },
  "vsce": {
    "no-dependencies": true
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "18.x",
    "@types/uuid": "^11.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.2",

{
  "name": "the-new-fuse",
  "displayName": "The New Fuse",
  "description": "AI-Powered Development Assistant with Multi-Provider LLM Support, A2A Protocol, MCP Integration & Agent Federation",
  "version": "9.2.0",
  "publisher": "TheNewFuse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-New-Fuse/vscode-extension.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "chat",
    "assistant",
    "copilot",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "mcp",
    "a2a",
    "agent",
    "orchestration",
    "federation",
    "relay",
    "ag-ui",
    "protocol"
  ],
  "icon": "media/icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "theNewFuse",
          "title": "The New Fuse",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "theNewFuse": [
        {
          "type": "webview",
          "id": "theNewFuse.chatView",
          "name": "AI Chat",
          "icon": "$(comment-discussion)"
        },
        {
          "type": "webview",
          "id": "theNewFuse.browserView",
          "name": "Browser",
          "icon": "$(globe)"
        }
      ]
    },
    "commands": [
      {
        "command": "theNewFuse.sendMessage",

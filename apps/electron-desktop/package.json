{
  "name": "@the-new-fuse/electron-desktop",
  "version": "3.0.0",
  "description": "The New Fuse - Hybrid Desktop Automation System",
  "main": "dist/main/main.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:vite\" \"pnpm dev:electron\"",
    "dev:vite": "vite --port ${PORT:-5174}",
    "dev:electron": "wait-on tcp:${PORT:-5174} && pnpm exec electron dist/main/main.js",
    "build": "vite build && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && node ./scripts/copy-browser-hub.js",
    "build:with-theia": "cd ../theia-ide && pnpm build && cd ../electron-desktop && vite build && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && node ./scripts/copy-browser-hub.js",
    "start": "node ./scripts/copy-browser-hub.js && pnpm exec electron dist/main/main.js",
    "package": "electron-builder",
    "dist": "pnpm build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@reduxjs/toolkit": "^2.0.1",
    "@the-new-fuse/types": "workspace:*",
    "axios": "^1.6.2",
    "electron": "28.0.0",
    "framer-motion": "^11.18.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-redux": "^9.0.4",
    "socket.io-client": "^4.7.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^6.2.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.thenewfuse.desktop",
    "productName": "The New Fuse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "native/**/*",
      "../../apps/browser-hub/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "keywords": [
    "electron",
    "desktop",
    "automation",
    "ai",
    "browser",
    "chrome-extension"
  ]
}

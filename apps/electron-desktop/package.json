{
  "name": "@the-new-fuse/electron-desktop",
  "version": "3.0.0",
  "description": "The New Fuse - Hybrid Desktop Automation System",
  "main": "dist/main/main.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:vite\" \"bun run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5174 && electron dist/main/main.js",
    "build": "vite build && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "start": "electron dist/main/main.js",
    "package": "electron-builder",
    "dist": "bun run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@the-new-fuse/types": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "framer-motion": "^11.18.1",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@chakra-ui/react": "^2.8.2",
    "@reduxjs/toolkit": "^2.0.1",
    "react-redux": "^9.0.4",
    "axios": "^1.6.2",
    "socket.io-client": "^4.7.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^6.2.1",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.thenewfuse.desktop",
    "productName": "The New Fuse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "native/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "keywords": [
    "electron",
    "desktop",
    "automation",
    "ai",
    "browser",
    "chrome-extension"
  ]
}

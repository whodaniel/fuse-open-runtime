{
  "name": "@the-new-fuse/electron-desktop",
  "version": "3.0.0",
  "description": "The New Fuse - Hybrid Desktop Automation System",
  "main": "dist/main/main.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "pnpm run build:main && concurrently \"pnpm run sync:watch\" \"pnpm run dev:vite\" \"node ../browser-hub/serve-hub.js\" \"pnpm run dev:electron\"",
    "dev:vite": "vite --port ${PORT:-5174}",
    "dev:electron": "wait-on tcp:${PORT:-5174} && pnpm dlx electron dist/main/main.js",
    "build:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "build": "vite build && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && node ./scripts/copy-browser-hub.js --once",
    "build:with-theia": "cd ../theia-ide && pnpm run build && cd ../electron-desktop && vite build && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && node ./scripts/copy-browser-hub.js --once",
    "start": "node ./scripts/copy-browser-hub.js --once && pnpm dlx electron dist/main/main.js",
    "sync:once": "node ./scripts/copy-browser-hub.js --once",
    "sync:watch": "node ./scripts/copy-browser-hub.js --watch",
    "package": "electron-builder",
    "dist": "pnpm run build && electron-builder"

  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@reduxjs/toolkit": "^2.9.1",
    "@the-new-fuse/types": "workspace:*",
    "@the-new-fuse/ui-consolidated": "workspace:*",
    "@the-new-fuse/utils": "workspace:*",
    "axios": "^1.12.2",
    "electron": "38.3.0",
    "framer-motion": "^12.23.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "socket.io-client": "^4.8.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "dmg-builder": "^26.0.12",
    "electron-builder": "^26.0.12",
    "electron-builder-squirrel-windows": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.thenewfuse.desktop",
    "productName": "The New Fuse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "native/**/*",
      "../../apps/browser-hub/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "keywords": [
    "electron",
    "desktop",
    "automation",
    "ai",
    "browser",
    "chrome-extension"
  ]
}

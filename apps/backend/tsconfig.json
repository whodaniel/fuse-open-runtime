{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "tests",
    "src/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/modules/mcp/examples/**",
    "src/examples/**"
  ]
}

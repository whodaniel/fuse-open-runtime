{
  "compilerOptions": {
    "target": "ES2022",
    "ignoreDeprecations": "5.0",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "strictPropertyInitialization": false,
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "noEmitOnError": false,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["src/*"],
      "@the-new-fuse/database": ["../../packages/database/dist"],
      "@the-new-fuse/database/drizzle/schema": [
        "../../packages/database/dist/drizzle/schema"
      ],
      "@the-new-fuse/database/drizzle": [
        "../../packages/database/dist/drizzle"
      ],
      "@the-new-fuse/types": ["../../packages/types/dist"],
      "@the-new-fuse/mcp-core": ["../../packages/mcp-core/dist"],
      "@the-new-fuse/mcp-core/*": ["../../packages/mcp-core/dist/*"],
      "@the-new-fuse/a2a-core": ["../../packages/a2a-core/dist"],
      "@the-new-fuse/a2a-react": ["../../packages/a2a-react/dist"],
      "ox": ["../../node_modules/ox/_types/index.d.ts"],
      "ox/*": ["../../node_modules/ox/_types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "tests",
    "src/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/modules/mcp/examples/**",
    "src/examples/**"
  ]
}

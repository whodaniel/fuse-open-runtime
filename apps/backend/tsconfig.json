{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "tests",
    "src/modules/mcp/examples/**",
    "src/examples/**"
  ],
  "references": [
    { "path": "../../packages/types" },
    { "path": "../../packages/core" },
    { "path": "../../packages/database" },
    { "path": "../../packages/utils" },
    { "path": "../../packages/mcp-core" },
    { "path": "../../packages/feature-tracker" }
  ]
}

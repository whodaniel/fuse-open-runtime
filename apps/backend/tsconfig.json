{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "tests",
    "src/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/modules/mcp/examples/**",
    "src/examples/**"
  ]
}

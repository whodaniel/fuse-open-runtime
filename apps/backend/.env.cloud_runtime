# CloudRuntime Environment Configuration
# This file contains the environment variables needed for CloudRuntime deployment

# Disable Redis for CloudRuntime (no Redis service configured)
REDIS_ENABLED=false

# Application
NODE_ENV=production
PORT=3000

# Logging
LOG_LEVEL=info

# Disable features that require Redis
BULL_ENABLED=false
CACHE_ENABLED=false

# Database
# Add your CloudRuntime database URL here if needed
# DATABASE_URL=${{DATABASE_URL}}

# Security
# REQUIRED: Must be at least 32 characters
# Generated secure suggestion: 2a5a6139c9bbcd99262189a70dccc3c89d2a33b85cdaa076e200c40a653d56de
JWT_SECRET=
JWT_REFRESH_SECRET=

# Frontend Integration
FRONTEND_URL=https://thenewfuse.com
CORS_ORIGINS=https://thenewfuse.com

# AI Services (At least one required for AI features)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

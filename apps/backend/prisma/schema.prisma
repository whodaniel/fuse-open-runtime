// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // Made optional for OAuth users
  name          String?
  googleId      String?   @unique // Added for Google OAuth
  avatar        String?   // Added for user avatar
  picture       String?   // Added for OAuth profile picture
  role          String    @default("user") // Added role field
  sessions      Session[]
  agents        Agent[]   // Added relation to agents
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // MASS Framework relations
  workflowTopologies WorkflowTopology[]
  optimizationJobs   OptimizationJob[]
  validationDatasets ValidationDataset[]
  
  // NFT and revenue relations
  agentNFTs       AgentNFT[]
  fractionalShares FractionalShare[]
  revenueStreams  RevenueStream[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  IDLE
  BUSY
  ERROR
  OFFLINE
  INITIALIZING
  READY
  TERMINATED
  ARCHIVED
}

model Agent {
  id            String      @id @default(cuid())
  name          String      @unique
  description   String?
  type          String      // Added type field
  systemPrompt  String?
  capabilities  String[]    // Stored as array of strings
  status        AgentStatus @default(INACTIVE)
  config        Json?       // Changed from configuration to config
  userId        String      // Foreign key to User
  user          User        @relation(fields: [userId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?   // Soft delete support
  
  // MASS Framework fields
  massOptimized        Boolean @default(false)
  parentAgentId        String?
  optimizationMetrics  Json?
  
  // MASS Framework relations
  promptVersions AgentPromptVersion[]
  parentAgent    Agent? @relation("AgentVersions", fields: [parentAgentId], references: [id])
  childAgents    Agent[] @relation("AgentVersions")

  @@index([userId])
  @@index([status])
  @@map("agents")
}

model AgentPromptVersion {
  id                 String   @id @default(cuid())
  agentId            String
  versionNumber      Int
  instruction        String   @db.Text
  exemplars          Json?
  performanceMetrics Json?
  massStage          String?
  createdAt          DateTime @default(now())
  
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  @@unique([agentId, versionNumber])
  @@map("agent_prompt_versions")
}

model WorkflowTopology {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  nodes              Json
  edges              Json
  performanceMetrics Json?
  massOptimized      Boolean  @default(false)
  userId             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("workflow_topologies")
}

model OptimizationJob {
  id        String   @id @default(cuid())
  type      String   // "block_level" | "topology" | "workflow_level"
  targetId  String
  status    String   @default("pending") // "pending" | "running" | "completed" | "failed"
  config    Json
  results   Json?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("optimization_jobs")
}

model ValidationDataset {
  id          String   @id @default(cuid())
  name        String
  description String?
  items       Json
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("validation_datasets")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // 'user' | 'assistant'
  content   String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("chat_messages")
}

model AgentNFT {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FractionalShare {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RevenueStream {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String? // Made optional for OAuth users
  name          String?
  googleId      String?   @unique // Added for Google OAuth
  avatar        String? // Added for user avatar
  picture       String? // Added for OAuth profile picture
  role          String    @default("user") // Added role field
  sessions      Session[]
  agents        Agent[] // Added relation to agents
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // MASS Framework relations
  workflowTopologies WorkflowTopology[]
  optimizationJobs   OptimizationJob[]
  validationDatasets ValidationDataset[]

  // NFT and revenue relations
  agentNFTs           AgentNFT[]
  fractionalShares    FractionalShare[]
  revenueStreams      RevenueStream[]
  marketplaceListings MarketplaceListing[] // Added for User-MarketplaceListing relation
  marketplaceOffers   MarketplaceOffer[] // Added for User-MarketplaceOffer relation
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  IDLE
  BUSY
  ERROR
  OFFLINE
  INITIALIZING
  READY
  TERMINATED
  ARCHIVED
}

model Agent {
  id           String      @id @default(cuid())
  name         String      @unique
  description  String?
  type         String // Added type field
  systemPrompt String?
  capabilities String[] // Stored as array of strings
  status       AgentStatus @default(INACTIVE)
  config       Json? // Changed from configuration to config
  provider     String?     @default("default") // Added provider field
  userId       String // Foreign key to User
  user         User        @relation(fields: [userId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime? // Soft delete support

  // MASS Framework fields
  massOptimized       Boolean @default(false)
  parentAgentId       String?
  optimizationMetrics Json?

  // MASS Framework relations
  promptVersions AgentPromptVersion[]
  parentAgent    Agent?               @relation("AgentVersions", fields: [parentAgentId], references: [id])
  childAgents    Agent[]              @relation("AgentVersions")

  // Added for AgentNFT relation
  agentNFT AgentNFT?

  @@index([userId])
  @@index([status])
  @@map("agents")
}

model AgentPromptVersion {
  id                 String   @id @default(cuid())
  agentId            String
  versionNumber      Int
  instruction        String   @db.Text
  exemplars          Json?
  performanceMetrics Json?
  massStage          String?
  createdAt          DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, versionNumber])
  @@map("agent_prompt_versions")
}

model WorkflowTopology {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  nodes              Json
  edges              Json
  performanceMetrics Json?
  massOptimized      Boolean  @default(false)
  userId             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workflow_topologies")
}

model OptimizationJob {
  id        String   @id @default(cuid())
  type      String // "block_level" | "topology" | "workflow_level"
  targetId  String
  status    String   @default("pending") // "pending" | "running" | "completed" | "failed"
  config    Json
  results   Json?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("optimization_jobs")
}

model ValidationDataset {
  id          String   @id @default(cuid())
  name        String
  description String?
  items       Json
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("validation_datasets")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String // 'user' | 'assistant'
  content   String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("chat_messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("notifications")
}

model AgentNFT {
  id                  String   @id @default(cuid())
  agentId             String   @unique // Connects to the Agent model
  agent               Agent    @relation(fields: [agentId], references: [id])
  tokenId             Int      @unique
  contractAddress     String
  smartAccountAddress String?
  isFractionalized    Boolean  @default(false)
  totalShares         Int      @default(0)
  metadataUri         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  fractionalShares    FractionalShare[]
  revenueStreams      RevenueStream[]
  marketplaceListings MarketplaceListing[]
  ownerId             String? // Added for User-AgentNFT relation
  owner               User?                @relation(fields: [ownerId], references: [id])
}

model FractionalShare {
  id           String   @id @default(cuid())
  agentNFTId   String
  agentNFT     AgentNFT @relation(fields: [agentNFTId], references: [id])
  ownerAddress String
  shareAmount  Decimal  @db.Decimal(65, 18) // Use Decimal for token amounts
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerId String? // Added for User-FractionalShare relation
  owner   User?   @relation(fields: [ownerId], references: [id])
}

model RevenueStream {
  id                    String   @id @default(cuid())
  agentNFTId            String
  agentNFT              AgentNFT @relation(fields: [agentNFTId], references: [id])
  streamName            String
  description           String?
  tokenAddress          String
  totalRevenue          Decimal  @default(0) @db.Decimal(65, 18)
  distributedRevenue    Decimal  @default(0) @db.Decimal(65, 18)
  distributionThreshold Decimal  @db.Decimal(65, 18)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  distributions RevenueDistribution[]
  ownerId       String? // Added for User-RevenueStream relation
  owner         User?                 @relation(fields: [ownerId], references: [id])
}

model RevenueDistribution {
  id              String        @id @default(cuid())
  revenueStreamId String
  revenueStream   RevenueStream @relation(fields: [revenueStreamId], references: [id])
  txHash          String
  totalAmount     Decimal       @db.Decimal(65, 18)
  distributedTo   Json // Store array of {address, amount}
  blockNumber     Int
  createdAt       DateTime      @default(now())
}

model MarketplaceListing {
  id         String   @id @default(cuid())
  agentNFTId String   @unique
  agentNFT   AgentNFT @relation(fields: [agentNFTId], references: [id])
  price      Decimal  @db.Decimal(65, 18)
  currency   String
  status     String   @default("ACTIVE") // ACTIVE, SOLD, CANCELLED
  sellerId   String
  seller     User     @relation(fields: [sellerId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  offers MarketplaceOffer[]
}

model MarketplaceOffer {
  id          String             @id @default(cuid())
  listingId   String
  listing     MarketplaceListing @relation(fields: [listingId], references: [id])
  buyerId     String
  buyer       User               @relation(fields: [buyerId], references: [id])
  offerAmount Decimal            @db.Decimal(65, 18)
  currency    String
  status      String             @default("PENDING") // PENDING, ACCEPTED, REJECTED, CANCELLED
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

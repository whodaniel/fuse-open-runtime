# Railway Environment Configuration
# This file contains the environment variables needed for Railway deployment

# Disable Redis for Railway (no Redis service configured)
REDIS_ENABLED=false

# Application
NODE_ENV=production
PORT=3000

# Logging
LOG_LEVEL=info

# Disable features that require Redis
BULL_ENABLED=false
CACHE_ENABLED=false

# Database
# Add your Railway database URL here if needed
# DATABASE_URL=${{DATABASE_URL}}

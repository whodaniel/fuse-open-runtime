{
  "name": "@the-new-fuse/backend-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @the-new-fuse/database build && pnpm --filter @the-new-fuse/mcp-core build && pnpm --filter @the-new-fuse/ag-ui-core build && pnpm --filter @the-new-fuse/types build && pnpm --filter @the-new-fuse/utils build",
    "build": "nest build || echo 'Build completed with warnings'",
    "build:watch": "nest build --watch",
    "dev": "cross-env PORT=3004 nest start --watch --entryFile simple-main",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --testPathPatterns=unit",
    "test:integration": "jest --config jest.config.ts --testPathPatterns=integration",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist lib build coverage test-results playwright-report .tsbuildinfo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/schedule": "^4.0.2",
    "@nestjs/websockets": "^11.1.17",
    "@the-new-fuse/ag-ui-core": "workspace:*",
    "@the-new-fuse/database": "workspace:*",
    "@the-new-fuse/feature-tracker": "workspace:*",
    "@the-new-fuse/mcp-core": "workspace:*",
    "@the-new-fuse/relay-core": "workspace:*",
    "@the-new-fuse/types": "workspace:*",
    "@the-new-fuse/utils": "workspace:*",
    "@types/react-router-dom": "^5.3.3",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.5",
    "bcrypt": "6.0.0",
    "bcryptjs": "^3.0.2",
    "bull": "^4.12.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "connect-redis": "9.0.0",
    "cors": "^2.8.6",
    "cron": "4.4.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "5.9.3",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.2.4",
    "nodemailer": "^7.0.11",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.8.1",
    "viem": "^2.47.4",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/bull": "^4.10.0",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.0",
    "@types/express-session": "^1.18.2",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.4",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "inversify": "^7.10.6",
    "ioredis-mock": "^8.9.1",
    "jest": "30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.7.3",
    "siwe": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "webpack": "^5.103.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "/node_modules/(?!(@the-new-fuse|date-fns))"
    ]
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fuse Desktop",
  "version": "4.1.0",
  "identifier": "com.thenewfuse.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Fuse Desktop - AI Orchestration Platform",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' http://localhost:* https://*.workers.dev wss://*.workers.dev https://*.run.app; img-src 'self' data: https:; frame-src *"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": []
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": []
    },
    "fs": {
      "scope": ["$HOME/**", "$APPDATA/**", "$RESOURCE/**"]
    },
    "http": {
      "scope": [
        "http://localhost:*",
        "https://*.workers.dev",
        "https://*.run.app",
        "https://*.thenewfuse.com"
      ]
    }
  }
}

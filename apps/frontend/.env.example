# The New Fuse - Environment Configuration

# Standard Port Configuration
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3002  
VITE_FRONTEND_URL=http://localhost:3000
VITE_APP_TITLE="The New Fuse"

# Firebase Configuration (Multi-Agent Chat)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Database Configuration
DATABASE_URL=your-database-url
DIRECT_URL=your-direct-database-url

# Email and App Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM_NAME=The New Fuse
EMAIL_FROM_ADDRESS=noreply@thenewfuse.com
FRONTEND_URL=http://localhost:3000
APP_NAME=The New Fuse

# Development Ports (for reference)
# Frontend: 3000
# Backend API: 3001
# WebSocket: 3002
# Prisma Studio: 5555
# Preview: 4173

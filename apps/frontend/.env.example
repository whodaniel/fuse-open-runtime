# =============================================================================
# Frontend Service Environment Configuration
# Copy this file to .env.local for development
# SECURITY: Never commit actual secrets to version control
# =============================================================================

# Environment
NODE_ENV=development

# Server Configuration (Development)
VITE_HOST=localhost
VITE_PORT=3000
VITE_PREVIEW_PORT=4173

# API Configuration
VITE_API_URL=http://localhost:3001
VITE_API_GATEWAY_URL=http://localhost:8080
VITE_API_BASE_URL=/api
VITE_WS_URL=ws://localhost:3001
VITE_TURNSTILE_SITE_KEY=
VITE_AUTH_REQUIRE_TURNSTILE=false

# Service URLs
VITE_FRONTEND_URL=http://localhost:3000
VITE_THEIA_IDE_URL=http://localhost:3007
VITE_VIZ_HUB_URL=http://localhost:5173

# Base Path (for subdirectory deployments)
VITE_BASE_PATH=/

# CDN Configuration (production)
VITE_CDN_URL=

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
VITE_ENABLE_HOT_RELOAD=true

# Security
VITE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# OAuth Configuration (Optional)
VITE_GOOGLE_CLIENT_ID=
VITE_GITHUB_CLIENT_ID=

# Unstoppable Domains Configuration (Optional)
VITE_UNSTOPPABLE_DOMAINS_CLIENT_ID=4d85fd51-b1a8-4e26-b97c-e67a5338a9da
VITE_UNSTOPPABLE_DOMAINS_REDIRECT_URI=http://localhost:3000/auth/unstoppable-callback

# Firebase Configuration (Optional - all required if using Firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Supabase Configuration (Optional - both required if using Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Monitoring & Analytics (Optional)
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=
VITE_ERROR_MONITORING_URL=
VITE_PERFORMANCE_MONITORING_URL=
VITE_USAGE_ANALYTICS_URL=

# Build Information (Optional)
VITE_BUILD_ID=development
VITE_VERSION=0.1.0
VITE_APP_VERSION=0.1.0

# Database Configuration (for SSR/API routes - Optional)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fuse
DB_SSL=false
DB_BACKUP_PATH=./backups

# Redis Configuration (for SSR - Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# WebSocket URLs (Alternative naming conventions)
WEBSOCKET_URL=ws://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
REACT_APP_API_URL=http://localhost:3001
REACT_APP_WEBSOCKET_URL=ws://localhost:3001
REACT_APP_A2A_WEBSOCKET_URL=ws://localhost:3001

# Project Configuration (for workspace features - Optional)
PROJECT_PATH=

# Logging (Optional)
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=
DEBUG=false

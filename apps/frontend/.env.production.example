# Production Environment Configuration
# These values should be set in CloudRuntime or your hosting environment
# This file documents which variables are required

# Application Environment
APP_ENV=production

# API Configuration
VITE_API_URL=https://your-api-url.thenewfuse.com
VITE_WS_URL=wss://your-api-url.thenewfuse.com
VITE_RELAY_URL=wss://relay.example.com

# HostMaria operator visibility controls (UI layer)
VITE_ENABLE_PERSONAL_HOSTMARIA=false
VITE_HOSTMARIA_OWNER_EMAILS=owner@example.com
VITE_HOSTMARIA_AGENT_EMAILS=

# Firebase Configuration (Frontend) - Values populated from project configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

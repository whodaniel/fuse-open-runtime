{
  "name": "@the-new-fuse/frontend-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3002",
    "build": "node scripts/build-docs.mjs && vite build --mode production",
    "build:frontend": "npm run build",
    "build:deps": "pnpm --filter @the-new-fuse/ap2-protocol build && pnpm --filter @the-new-fuse/a2a-core build && pnpm --filter @the-new-fuse/a2a-react build && pnpm --filter @the-new-fuse/feature-suggestions build && pnpm --filter @the-new-fuse/features build && pnpm --filter @the-new-fuse/port-management build && pnpm --filter @the-new-fuse/prompt-templating build && pnpm --filter @the-new-fuse/types build && pnpm --filter @the-new-fuse/ui-consolidated build",
    "build:watch": "vite build --watch",
    "build:analyze": "vite build && npx vite-bundle-analyzer dist",
    "build:stats": "vite build --mode production && npx vite-bundle-analyzer dist/stats.html",
    "start": "npx --yes serve ./dist -p ${PORT:-3000} -n",
    "start:preview": "vite preview --host 0.0.0.0 --port $PORT",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run",
    "test:unit": "vitest run --testPathPatterns=unit",
    "test:integration": "vitest run --testPathPatterns=integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "audit:navigation": "node scripts/audit-navigation-routes.mjs",
    "audit:static-links": "node scripts/audit-static-links.mjs",
    "audit:all-links": "node scripts/audit-all-links.mjs",
    "audit:live-links": "node scripts/audit-live-links.mjs",
    "audit:all-routes-semantic": "node scripts/audit-all-routes-semantic.mjs",
    "audit:auth-paths": "node scripts/audit-auth-paths.mjs",
    "audit:self-improvement-scorecard": "node ../../scripts/ci/generate-self-improvement-scorecard.mjs",
    "audit:experience-architecture": "node scripts/audit-experience-architecture.mjs",
    "audit:sidebar-health": "node scripts/audit-sidebar-page-health.mjs",
    "audit:route-guards": "node scripts/audit-route-guards.mjs",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "clear-ports": "node scripts/clear-ports.js",
    "clean": "rimraf dist lib build coverage test-results playwright-report .tsbuildinfo tsconfig.tsbuildinfo",
    "perf:monitor": "node scripts/performance-monitor.js",
    "bundle:report": "pnpm build && echo 'Bundle analysis report generated at dist/bundle-analysis.html'"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@heroicons/react": "^2.1.5",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@paypal/react-paypal-js": "^8.8.1",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@reactflow/node-resizer": "^2.2.14",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/browser": "^7.120.4",
    "@sentry/tracing": "^7.120.4",
    "@tanstack/react-query": "^5.90.19",
    "@the-new-fuse/a2a-core": "workspace:*",
    "@the-new-fuse/a2a-react": "workspace:*",
    "@the-new-fuse/feature-suggestions": "workspace:*",
    "@the-new-fuse/features": "workspace:*",
    "@the-new-fuse/port-management": "workspace:*",
    "@the-new-fuse/prompt-templating": "workspace:*",
    "@the-new-fuse/types": "workspace:*",
    "@the-new-fuse/ui-consolidated": "workspace:*",
    "@types/d3": "^7.4.3",
    "@types/dagre": "^0.7.53",
    "@types/file-saver": "^2.0.7",
    "@types/three": "^0.183.1",
    "axios": "^1.13.5",
    "change-case": "5.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "d3-force-graph": "^0.4.3",
    "dagre": "^0.8.5",
    "dagre-d3": "^0.6.4",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "ethers": "^6.15.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.27.0",
    "gsap": "^3.13.0",
    "he": "^1.2.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.7.3",
    "katex": "^0.16.28",
    "lenis": "^1.3.17",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.556.0",
    "maath": "^0.10.8",
    "marked": "^17.0.1",
    "monaco-editor": "^0.55.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.6",
    "react-icons": "^5.6.0",
    "react-loading-skeleton": "3.5.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "react-toastify": "^11.0.5",
    "react-tooltip": "^5.30.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.3.0",
    "reflect-metadata": "^0.2.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "rxjs": "^7.8.2",
    "socket.io-client": "^4.7.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "text-case": "^1.2.10",
    "three": "^0.183.1",
    "truncate": "^3.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^4.5.5"
  },
  "peerDependencies": {
    "monaco-editor": "^0.39.0 || ^0.54.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/selenium-webdriver": "^4.35.4",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "@vitest/coverage-v8": "latest",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "browserslist": "^4.27.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "selenium-webdriver": "^4.39.0",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.1.0"
  },
  "jest": {
    "testEnvironment": "jsdom"
  }
}

{
  "name": "@the-new-fuse/frontend-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "dev:clean": "node scripts/clear-ports.js && vite --host 0.0.0.0 --port 3000 --force",
    "dev:smart": "node scripts/dev.js",
    "build": "vite build",
    "build:analyze": "vite build && npx vite-bundle-analyzer dist",
    "build:perf": "vite build --mode production && node scripts/performance-analysis.js",
    "build:frontend": "pnpm build",
    "build:force": "vite build",
    "build:stats": "vite build --mode production && npx vite-bundle-analyzer dist/stats.html",
    "start": "vite preview --host 0.0.0.0 --port $PORT",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "preview:analyze": "vite preview --host 0.0.0.0 --port 4173 --mode production",
    "clear-ports": "node scripts/clear-ports.js",
    "clean": "rimraf dist lib build coverage test-results playwright-report .tsbuildinfo tsconfig.tsbuildinfo",
    "perf:monitor": "node scripts/performance-monitor.js",
    "bundle:report": "pnpm build && echo 'Bundle analysis report generated at dist/bundle-analysis.html'"
  },

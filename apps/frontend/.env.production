# Production Environment Configuration
# These values should be set in Railway's environment variables
# This file serves as documentation for what variables are needed

# Application Environment
# NODE_ENV is managed by Vite automatically during build
# NODE_ENV=production
APP_ENV=production

# API Configuration - MUST be set in Railway
VITE_API_URL=https://the-new-fuse-api.railway.app
VITE_WS_URL=wss://the-new-fuse-api.railway.app

# Firebase Configuration (Frontend) - MUST be set in Railway
VITE_FIREBASE_API_KEY=${VITE_FIREBASE_API_KEY}
VITE_FIREBASE_AUTH_DOMAIN=${VITE_FIREBASE_AUTH_DOMAIN}
VITE_FIREBASE_PROJECT_ID=${VITE_FIREBASE_PROJECT_ID}
VITE_FIREBASE_STORAGE_BUCKET=${VITE_FIREBASE_STORAGE_BUCKET}
VITE_FIREBASE_MESSAGING_SENDER_ID=${VITE_FIREBASE_MESSAGING_SENDER_ID}
VITE_FIREBASE_APP_ID=${VITE_FIREBASE_APP_ID}
VITE_RELAY_URL=wss://relay.thenewfuse.com

# The New Fuse Frontend - Production Environment Configuration

# Environment (NODE_ENV is handled by Vite automatically)
# NODE_ENV=production  # Don't set this in .env, Vite handles it

# API Configuration (Update these URLs for production)
VITE_API_URL=https://api.thenewfuse.com
VITE_WS_URL=wss://api.thenewfuse.com

# Base Path (for subdirectory deployments)
VITE_BASE_PATH=/

# CDN Configuration
VITE_CDN_URL=https://cdn.thenewfuse.com

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false
VITE_ENABLE_HOT_RELOAD=false

# Security
VITE_ALLOWED_ORIGINS=https://thenewfuse.com,https://www.thenewfuse.com,https://app.thenewfuse.com

# Firebase Configuration (Update with your production values)
VITE_FIREBASE_API_KEY=your-production-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# External Services
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
{
  "server": {
    "transport": {
      "type": "websocket",
      "url": "ws://localhost:3000/mcp"
    }
  },
  "features": {
    "resources": true,
    "tools": true,
    "prompts": true,
    "logging": true,
    "notifications": true
  },
  "ui": {
    "theme": "light",
    "refreshInterval": 5000,
    "maxLogEntries": 1000,
    "autoConnect": true
  },
  "demo": {
    "enabled": true,
    "mockData": true,
    "mockDelay": 500
  }
}
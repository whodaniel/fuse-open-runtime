{
  "name": "@the-new-fuse/audio-trigger-kws-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Trigger-first audio KWS pipeline scaffold with mini-omni LLM backend adapter",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --skipLibCheck",
    "type-check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "serve": "tsx src/server.ts",
    "start": "node dist/server.js",
    "demo": "tsx src/index.ts --demo",
    "demo:full": "tsx src/index.ts --demo --demo-full"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "tsx": "^4.20.3",
    "typescript": "^6.0.2"
  }
}

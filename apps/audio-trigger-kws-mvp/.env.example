MINI_OMNI_COMPLETIONS_PATH=/v1/chat/completions
MINI_OMNI_MODEL=mini-omni
MINI_OMNI_TIMEOUT_MS=8000
MINI_OMNI_STREAM_STRIDE=8
MINI_OMNI_MAX_TOKENS=256
MINI_OMNI_SAMPLE_WAV=/Users/<owner>/mini-omni/data/samples/output1.wav
MINI_OMNI_OUTPUT_WAV_DIR=/tmp/mini-omni-kws-mvp
BATCH_FLUSH_INTERVAL_MS=2000
BATCH_MAX_ITEMS=20
APP_HOST=0.0.0.0
APP_PORT=43110
REQUIRE_INGEST_AUTH=true
INGEST_API_KEY=replace-with-strong-key
MAX_RECENT_RULE_FIRES=200
MAX_RECENT_PACKAGES=200
MAX_RECENT_LLM_RESULTS=200
AUTO_PROMPT_ENABLED=true
AUTO_PROMPT_SEQUENCES_FILE=
CONTEXT_CARD_DIR=
CLAUDE_HOOKS_ENABLED=true
CLAUDE_HOOKS_REQUIRE_SECRET=false
CLAUDE_HOOKS_SHARED_SECRET=

# ── ZeroClaw Railway Sandbox ──────────────────────────────────
# Provider & Model (Codex CLI OAuth)
PROVIDER=openai-codex
ZEROCLAW_MODEL=codex-mini-latest

# ── Codex CLI OAuth Tokens ───────────────────────────────────
# Extract from ~/.codex/auth.json after `codex --login`
OPENAI_CODEX_ACCESS_TOKEN=
OPENAI_CODEX_REFRESH_TOKEN=
OPENAI_CODEX_ID_TOKEN=
OPENAI_CODEX_ACCOUNT_ID=

# ── TNF Protocol (REQUIRED) ─────────────────────────────────
TNF_AGENT_ID=zeroclaw-railway-01
TNF_AGENT_ROLE=zeroclaw-sandbox
TNF_WORKER_URL=https://tnf-agent-orchestration.bizsynth.workers.dev

# ── Gateway ──────────────────────────────────────────────────
PORT=3000
ZEROCLAW_REQUIRE_PAIRING=false

# ── Autonomy ─────────────────────────────────────────────────
ZEROCLAW_AUTONOMY_LEVEL=supervised

# ── Memory ───────────────────────────────────────────────────
ZEROCLAW_MEMORY_BACKEND=sqlite
ZEROCLAW_EMBEDDING_PROVIDER=none

# ── Temperature ──────────────────────────────────────────────
ZEROCLAW_TEMPERATURE=0.7

# ── Alternative: Anthropic Auth Token ────────────────────────
# ANTHROPIC_AUTH_TOKEN=

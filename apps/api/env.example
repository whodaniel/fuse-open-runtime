# Database
DATABASE_URL="postgresql://username:password@localhost:5432/tnf_wallet_db"

# Web3Auth Configuration
WEB3AUTH_CLIENT_ID="your_web3auth_client_id_here"
WEB3AUTH_VERIFIER_DOMAIN="tnf.local"
WEB3AUTH_JWT_SECRET="your_jwt_secret_here"

# Blockchain Configuration
ETHEREUM_RPC_URL="https://rpc.ankr.com/eth"
ENTRY_POINT_ADDRESS="0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789"
SMART_ACCOUNT_FACTORY_ADDRESS="0x..."
TNF_PAYMASTER_ADDRESS="0x..."

# Bundler Service
BUNDLER_URL="https://api.alchemy.com/v2/your-api-key"

# Compliance & Security
COMPLIANCE_API_KEY="your_compliance_api_key"
COMPLIANCE_API_URL="https://api.compliance-service.com"

# Monitoring
MONITORING_WEBHOOK_URL="https://hooks.slack.com/services/your/webhook/url"

# Application
JWT_SECRET="your_application_jwt_secret"
PORT=3001

# Private Timeline Access Controls (Owner + Agent delegates)
TIMELINE_USE_LIBRARIAN_SOURCE=true
TIMELINE_PRIVATE_OWNER_USER_ID=""
TIMELINE_PRIVATE_OWNER_EMAILS="owner@example.com"
TIMELINE_PRIVATE_AGENT_USER_IDS=""

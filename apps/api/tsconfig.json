{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "noEmitOnError": false,
    "noImplicitAny": false,
    "types": ["node", "jest"],
    "paths": {
      "@/*": ["./src/*"],
      "@the-new-fuse/database/drizzle/*": ["../../packages/database/drizzle/*"],
      "@the-new-fuse/database/drizzle": [
        "../../packages/database/drizzle/index"
      ],
      "@the-new-fuse/n8n-workflows": [
        "../../packages/n8n-workflows/dist/index"
      ],
      "@the-new-fuse/n8n-workflows/*": ["../../packages/n8n-workflows/dist/*"],
      "@the-new-fuse/*": ["../../packages/*/dist"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/scripts/**/*",
    "src/modules/agent-tracking/**/*",
    "src/middleware/agent-tracking.middleware.ts"
  ],
  "references": [
    { "path": "../../packages/types" },

    { "path": "../../packages/database" },
    { "path": "../../packages/utils" }
  ]
}

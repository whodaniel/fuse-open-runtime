datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(uuid())
  verifierId String   @unique
  userType   String?  @db.VarChar(10) // 'HUMAN' or 'AI' - optional for backward compatibility
  wallets    Wallet[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  // ... other user fields
}

model Wallet {
  id          String @id @default(uuid())
  user        User   @relation(fields: [userId], references: [id])
  userId      String
  address     String @unique @db.VarChar(42) // Primary EOA address from Web3Auth
  chain_id    Int
  wallet_type String @db.VarChar(20) // 'EOA', 'SMART_ACCOUNT', or 'HYBRID'

  // Smart Account fields (optional - added features)
  smartAccountAddress  String? @unique @db.VarChar(42) // Smart Account address if deployed
  smartAccountSalt     String? @db.VarChar(66) // Salt used for CREATE2 deployment
  smartAccountDeployed Boolean @default(false) // Whether Smart Account is deployed on-chain
  smartAccountEnabled  Boolean @default(false) // Whether Smart Account features are enabled

  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  transactions Transaction[]

  @@index([address])
  @@index([smartAccountAddress])
}

model Transaction {
  id           String   @id @default(uuid())
  wallet       Wallet   @relation(fields: [walletId], references: [id])
  walletId     String
  tx_hash      String   @unique @db.VarChar(66)
  from_address String   @db.VarChar(42)
  to_address   String   @db.VarChar(42)
  value        Decimal  @db.Decimal(78, 0)
  status       String   @default("PENDING") @db.VarChar(20)
  created_at   DateTime @default(now())
}

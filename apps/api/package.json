  "scripts": {
    "prebuild": "pnpm --filter @the-new-fuse/database build",
    "build": "tsc --skipLibCheck --noEmitOnError false || echo 'Build completed with warnings'",
    "build:watch": "tsc --watch --skipLibCheck --noEmitOnError false",
    "migrate:deploy": "SERVICE_PATH=api sh ./run-service.sh",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --max-http-header-size=65536 dist/main.js",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:unit": "jest --testPathPatterns=unit",
    "test:integration": "jest --config jest-integration.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "arcade:listener": "ts-node src/scripts/arcade-chain-listener.ts",
    "arcade:sweep": "ts-node src/scripts/arcade-chain-sweeper.ts",
    "clean": "rimraf dist lib build coverage test-results playwright-report .tsbuildinfo tsconfig.tsbuildinfo",
    "claude-dev": "ts-node src/scripts/claude-dev-cli.ts"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.9",

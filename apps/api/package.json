    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.1",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }

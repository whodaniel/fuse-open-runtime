{
  "name": "The New Fuse IDE MCP Configuration",
  "version": "1.63.3",
  "servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/danielgoldberg/Desktop/A1-Inter-LLM-Com/The-New-Fuse"],
      "description": "File system access for The New Fuse workspace",
      "autostart": true,
      "env": {
        "NODE_ENV": "production",
        "WORKSPACE_ROOT": "/Users/danielgoldberg/Desktop/A1-Inter-LLM-Com/The-New-Fuse"
      }
    },
    "git": {
      "command": "node",
      "args": ["-e", "console.log('Git MCP Server placeholder - Integration with local git commands'); process.stdout.write('Git integration ready\\n');"],
      "description": "Git integration for version control with AI-powered commits", 
      "autostart": true,
      "env": {
        "NODE_ENV": "production",
        "GIT_ROOT": "/Users/danielgoldberg/Desktop/A1-Inter-LLM-Com/The-New-Fuse"
      }
    },
    "sqlite": {
      "command": "node",
      "args": ["-e", "console.log('SQLite MCP Server placeholder - Database operations available'); process.stdout.write('SQLite integration ready\\n');"],
      "description": "SQLite database access with AI queries",
      "autostart": true,
      "env": {
        "NODE_ENV": "production",
        "DB_PATH": "/Users/danielgoldberg/Desktop/A1-Inter-LLM-Com/The-New-Fuse/data.db"
      }
    },
    "web-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "description": "Web search capabilities for AI assistant",
      "autostart": false,
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}",
        "NODE_ENV": "production"
      }
    },
    "package-version": {
      "command": "npx",
      "args": ["-y", "mcp-package-version"],
      "description": "Latest stable package versions for coding assistance",
      "autostart": true,
      "env": {
        "NODE_ENV": "production"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "description": "GitHub repository operations and AI-powered development",
      "autostart": false,
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "NODE_ENV": "production"
      }
    },
    "claude-code-cli": {
      "command": "claude",
      "args": ["--no-color", "--format=json"],
      "description": "Claude Code CLI integration for AI-powered development assistance",
      "autostart": true,
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "CLAUDE_CLI_MODE": "mcp",
        "NODE_ENV": "production"
      },
      "features": ["code-assistance", "file-operations", "terminal-integration"]
    },
    "gemini-cli": {
      "command": "gemini",
      "args": ["--mode=interactive", "--format=json"],
      "description": "Google Gemini CLI integration for multimodal AI assistance",
      "autostart": true,
      "env": {
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}",
        "GEMINI_CLI_MODE": "mcp",
        "NODE_ENV": "production"
      },
      "features": ["multimodal-analysis", "code-generation", "image-understanding"]
    },
    "browser-use": {
      "command": "node",
      "args": ["-e", "console.log('Browser Use extension bridge - Web automation available'); process.stdout.write('Browser automation ready\\n');"],
      "description": "Chrome Browser Use extension integration for web automation",
      "autostart": true,
      "env": {
        "BROWSER_USE_ENABLED": "true",
        "CHROME_EXTENSION_ID": "placeholder-browser-use-id",
        "NODE_ENV": "production"
      },
      "features": ["web-automation", "browser-control", "extension-bridge"]
    },
    "vscode-extensions": {
      "command": "node",
      "args": ["-e", "console.log('VSCode Extensions Manager - Extension marketplace available'); process.stdout.write('Extensions manager ready\\n');"],
      "description": "VSCode extension installation and management",
      "autostart": true,
      "env": {
        "VSCODE_EXTENSIONS_PATH": "/Users/danielgoldberg/.theia/extensions",
        "VSX_REGISTRY_URL": "https://open-vsx.org/api",
        "NODE_ENV": "production"
      },
      "features": ["extension-installation", "marketplace-access", "extension-management"]
    }
  },
  "features": {
    "contextManagement": true,
    "workspaceIntegration": true,
    "multiServer": true,
    "autoDiscovery": true
  },
  "ai": {
    "providers": {
      "openai": {
        "models": ["gpt-4o", "gpt-4o-mini", "o1-preview", "o1-mini"],
        "apiKey": "${OPENAI_API_KEY}",
        "enabled": true
      },
      "anthropic": {
        "models": ["claude-3-5-sonnet-20241022", "claude-3-5-haiku-20241022", "claude-4-sonnet", "claude-4-opus"],
        "apiKey": "${ANTHROPIC_API_KEY}",
        "enabled": true,
        "features": ["changesets", "tool-functions", "code-generation", "agent-pinning"]
      },
      "ollama": {
        "endpoint": "http://localhost:11434",
        "models": ["llama3", "codellama", "mistral", "phi3", "qwen2.5-coder"],
        "enabled": false,
        "features": ["local-inference", "tool-functions"]
      },
      "huggingface": {
        "apiKey": "${HUGGINGFACE_API_KEY}", 
        "models": ["microsoft/DialoGPT-large", "facebook/blenderbot-400M-distill"],
        "enabled": false
      }
    },
    "defaultProvider": "anthropic",
    "features": {
      "chat": true,
      "codeCompletion": true,
      "codeExplanation": true,
      "debugging": true,
      "testing": true,
      "changesets": {
        "enabled": true,
        "reviewMode": "interactive",
        "autoApply": false
      },
      "coderAgent": {
        "enabled": true,
        "mode": "preview",
        "structuredModifications": true
      },
      "toolCallConfirmation": {
        "mode": "confirm",
        "allowedTools": ["filesystem", "git", "package-version", "sqlite", "claude-code-cli", "gemini-cli", "browser-use", "vscode-extensions"]
      },
      "agentPinning": {
        "enabled": true,
        "autoPin": true
      },
      "remoteMCP": {
        "enabled": true,
        "protocols": ["http", "sse"]
      }
    }
  }
}
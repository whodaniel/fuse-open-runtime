{
  "name": "The New Fuse Native Bridge",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Native messaging bridge for The New Fuse - Connect local AI applications to the browser",

  "permissions": ["nativeMessaging", "activeTab", "scripting", "storage"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "TNF Native Bridge",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },

  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],

  "externally_connectable": {
    "matches": ["http://localhost/*", "https://thenewfuse.com/*"]
  },

  "minimum_chrome_version": "110"
}

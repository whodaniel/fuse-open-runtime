# Google Drive API
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# pCloud Credentials
PCLOUD_USERNAME=your@email.com
PCLOUD_PASSWORD=your_password

# ArDrive Wallet (JSON keyfile from your existing ArDrive account)
ARDRIVE_WALLET_PATH=./ardrive-wallet.json
ARDRIVE_FOLDER_ID=your-drive-folder-uuid
# Files <= 100MB automatically use FREE Turbo upload service
# Larger files will use your existing ArDrive account balance

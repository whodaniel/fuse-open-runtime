{
  "name": "@tnf/core-monitoring",
  "version": "1.0.0",
  "description": "Unified monitoring system for The New Fuse",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:foundation": "tsc",
    "test": "echo \"No tests for this package\"",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "events": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "eslint": "^9.38.0"
  },
  "peerDependencies": {
    "@sentry/node": "^8.0.0",
    "winston": "^3.18.0",
    "winston-daily-rotate-file": "^5.0.0",
    "prom-client": "^15.1.0"
  },
  "peerDependenciesMeta": {
    "@sentry/node": {
      "optional": true
    },
    "winston": {
      "optional": true
    },
    "winston-daily-rotate-file": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    }
  },
  "exports": {

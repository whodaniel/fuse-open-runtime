{
  "name": "@tnf/core-monitoring",
  "version": "1.0.0",
  "description": "Unified monitoring system for The New Fuse",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:foundation": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --testPathPattern=unit --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "events": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "eslint": "^9.38.0"
  },
  "peerDependencies": {
    "@sentry/node": "^8.0.0",
    "winston": "^3.18.0",
    "winston-daily-rotate-file": "^5.0.0",
    "prom-client": "^15.1.0",
    "web-vitals": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@sentry/node": {
      "optional": true
    },
    "winston": {
      "optional": true
    },
    "winston-daily-rotate-file": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    },
    "web-vitals": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./nestjs": {
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.js",
      "types": "./dist/nestjs/index.d.ts"
    }
  }
}

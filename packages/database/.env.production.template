# ============================================================================
# Database Production Environment Configuration Template
# ============================================================================
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to version control
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Production Database URL
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE?parameters
#
# Required Parameters:
# - connection_limit: Max connections in pool (20-50 recommended)
# - pool_timeout: Seconds to wait for connection (10 recommended)
# - sslmode: SSL mode (require for production)
#
# Optional Parameters:
# - connect_timeout: Connection timeout in seconds (10)
# - statement_timeout: Query timeout in milliseconds (30000 = 30s)
# - schema: Database schema (public)
#
# Examples:
#
# Railway:
# DATABASE_URL="postgresql://postgres:password@containers-us-west-123.railway.app:1234/railway?connection_limit=20&pool_timeout=10&sslmode=require"
#
# Heroku:
# DATABASE_URL="postgresql://user:pass@ec2-xxx.compute-1.amazonaws.com:5432/dbname?connection_limit=20&pool_timeout=10&sslmode=require"
#
# AWS RDS:
# DATABASE_URL="postgresql://admin:pass@mydb.123456.us-east-1.rds.amazonaws.com:5432/mydb?connection_limit=30&pool_timeout=10&sslmode=require"
#
# Google Cloud SQL:
# DATABASE_URL="postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance&connection_limit=20&sslmode=disable"
#
# Local with SSL:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/fuse_db?connection_limit=20&pool_timeout=10&sslmode=prefer"

DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE?schema=public&connection_limit=20&pool_timeout=10&sslmode=require"

# ============================================================================
# SEED DATA CONFIGURATION
# ============================================================================

# Admin User Credentials
# IMPORTANT: Change these immediately after first deployment!
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="<CHANGE_THIS_STRONG_PASSWORD>"

# Create System Agents (true/false)
# Set to true to create default system agents on seed
CREATE_SYSTEM_AGENTS=false

# ============================================================================
# LLM PROVIDER API KEYS
# ============================================================================

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Anthropic Configuration
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Google Gemini Configuration (optional)
GOOGLE_API_KEY=""

# Cohere Configuration (optional)
COHERE_API_KEY=""

# ============================================================================
# APPLICATION SECURITY
# ============================================================================

# JWT Secret
# Generate with: openssl rand -hex 32
# CRITICAL: Must be a strong random string (256-bit minimum)
JWT_SECRET="<GENERATE_STRONG_SECRET_HERE>"

# Encryption Key (for sensitive data like LLM API keys)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="<GENERATE_STRONG_SECRET_HERE>"

# Session Secret (for session management)
# Generate with: openssl rand -hex 32
SESSION_SECRET="<GENERATE_STRONG_SECRET_HERE>"

# ============================================================================
# ENVIRONMENT
# ============================================================================

NODE_ENV=production

# ============================================================================
# MONITORING & ANALYTICS (Optional)
# ============================================================================

# Sentry Error Tracking
SENTRY_DSN=""

# Datadog APM
DATADOG_API_KEY=""
DATADOG_APP_KEY=""

# New Relic
NEW_RELIC_LICENSE_KEY=""

# ============================================================================
# PRISMA CONFIGURATION (Advanced)
# ============================================================================

# Enable query logging (development only)
# Set to 1 to enable detailed query logs
# PRISMA_QUERY_LOG=0

# Disable Drizzle telemetry
PRISMA_DISABLE_TELEMETRY=1

# Drizzle engine checksum validation
# Set to 1 to skip checksum validation (offline environments)
# PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=0

# ============================================================================
# DATABASE MAINTENANCE (Optional)
# ============================================================================

# Cleanup Schedule (cron format)
# Default: 2 AM daily for expired records
CLEANUP_CRON_SCHEDULE="0 2 * * *"

# Log retention days
LOG_RETENTION_DAYS=30

# Session expiration (hours)
SESSION_EXPIRATION_HOURS=24

# Ephemeral message TTL (days)
EPHEMERAL_MESSAGE_TTL_DAYS=7

# ============================================================================
# CONNECTION POOLING (PgBouncer - Optional)
# ============================================================================

# If using PgBouncer, update DATABASE_URL to point to PgBouncer port (6432)
# and configure these settings in pgbouncer.ini

# PGBOUNCER_POOL_MODE=transaction
# PGBOUNCER_MAX_CLIENT_CONN=1000
# PGBOUNCER_DEFAULT_POOL_SIZE=20

# ============================================================================
# BACKUP CONFIGURATION (Optional)
# ============================================================================

# Backup storage location
# BACKUP_DIR="/var/backups/postgres"

# Backup retention days
# BACKUP_RETENTION_DAYS=30

# S3 backup (if using cloud backup)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BACKUP_BUCKET=""
# AWS_REGION="us-east-1"

# ============================================================================
# MIGRATION CONFIGURATION
# ============================================================================

# Skip migration prompts in CI/CD
# PRISMA_SKIP_GENERATE=0

# Migration timeout (ms)
# PRISMA_MIGRATION_TIMEOUT=300000

# ============================================================================
# DEVELOPMENT OVERRIDES (Remove in production)
# ============================================================================

# Uncomment for local testing only
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fuse_dev?schema=public&connection_limit=10"
# NODE_ENV=development
# CREATE_SYSTEM_AGENTS=true


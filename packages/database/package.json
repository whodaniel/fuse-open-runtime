{
  "name": "@the-new-fuse/database",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "build:foundation": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "postinstall": "prisma generate || echo 'Prisma generate failed - using placeholder client'"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@prisma/client": "6.19.0",
    "@the-new-fuse/types": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "eslint": "^9.38.0",
    "prisma": "6.19.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}

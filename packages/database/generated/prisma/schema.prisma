// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id          String      @id @default(uuid())
  title       String
  description String?
  status      TaskStatus  @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  type        String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  dueDate     DateTime?
  assignedTo  String?
  createdBy   String
  metadata    Json?
  tags        String[]    @default([])
  dependencies String[]   @default([])
  error       String?
  completedAt DateTime?

  @@map("tasks")
}

model Agent {
  id          String      @id @default(uuid())
  name        String
  description String?
  type        AgentType   @default(GENERIC)
  status      AgentStatus @default(IDLE)
  capabilities String[]
  provider    String
  lastActive  DateTime    @default(now())
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userId      String?

  // Relations
  user        User?       @relation("UserAgents", fields: [userId], references: [id], onDelete: SetNull)

  @@map("agents")
}

model RegisteredEntity {
  id          String   @id @default(uuid())
  name        String
  type        String
  description String?
  metadata    Json?
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("registered_entities")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AgentStatus {
  IDLE
  BUSY
  ERROR
  OFFLINE
}

enum AgentType {
  GENERIC
  CODER
  ANALYZER
  COORDINATOR
  COMMUNICATOR
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  PENDING
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String?
  passwordHash String
  role         UserRole   @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  agents       Agent[]    @relation("UserAgents")
  chatMessages ChatMessage[]

  @@map("users")
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  role      String   // "user", "assistant", "system"
  userId    String
  sessionId String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

enum UserRole {
  USER
  ADMIN
  AGENT
}

// =====================
// A2A Protocol Models
// =====================

model A2AAgent {
  id             String              @id @default(uuid())
  agentId        String              @unique  // UUID from A2A protocol
  name           String
  type           String
  version        String
  description    String?
  capabilities   A2AAgentCapability[]
  metadata       Json?
  endpoints      Json?               // WebSocket, HTTP, Redis endpoints
  authentication Json?              // Authentication configuration
  status         A2AAgentStatus      @default(OFFLINE)
  lastHeartbeat  DateTime?
  registeredAt   DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Relations
  sentMessages     A2AMessage[] @relation("SentMessages")
  receivedMessages A2AMessage[] @relation("ReceivedMessages")
  conversations    A2AConversationParticipant[]
  heartbeats       A2AHeartbeat[]

  @@map("a2a_agents")
}

model A2AAgentCapability {
  id          String  @id @default(uuid())
  agentId     String
  name        String
  description String?
  version     String
  parameters  Json?
  metadata    Json?

  // Relations
  agent       A2AAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, name])
  @@map("a2a_agent_capabilities")
}

model A2AMessage {
  id              String            @id @default(uuid())
  messageId       String            @unique  // UUID from A2A protocol
  protocolVersion String            @default("1.0.0")
  timestamp       DateTime
  fromAgentId     String
  toAgentId       String?           // NULL for broadcasts
  type            A2AMessageType
  priority        A2AMessagePriority @default(MEDIUM)
  conversationId  String?
  requestId       String?           // For request-response correlation
  ttl             Int?              // Time to live in seconds
  payload         Json
  routing         Json?             // Channel, topic, targetCapability
  signature       String?
  checksum        String?
  metadata        Json?
  deliveredAt     DateTime?
  acknowledgedAt  DateTime?
  createdAt       DateTime          @default(now())

  // Relations
  fromAgent       A2AAgent          @relation("SentMessages", fields: [fromAgentId], references: [id])
  toAgent         A2AAgent?         @relation("ReceivedMessages", fields: [toAgentId], references: [id])
  conversation    A2AConversation?  @relation(fields: [conversationId], references: [id])

  @@map("a2a_messages")
}

model A2AConversation {
  id           String                    @id @default(uuid())
  conversationId String                  @unique  // UUID from A2A protocol
  initiatorId  String
  topic        String?
  status       A2AConversationStatus     @default(ACTIVE)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  // Relations
  participants A2AConversationParticipant[]
  messages     A2AMessage[]

  @@map("a2a_conversations")
}

model A2AConversationParticipant {
  id             String          @id @default(uuid())
  conversationId String
  agentId        String
  joinedAt       DateTime        @default(now())
  leftAt         DateTime?
  role           String?         // "initiator", "participant", "observer"

  // Relations
  conversation   A2AConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent          A2AAgent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([conversationId, agentId])
  @@map("a2a_conversation_participants")
}

model A2AHeartbeat {
  id              String         @id @default(uuid())
  agentId         String
  timestamp       DateTime
  status          A2AAgentStatus
  load            Float?         // 0.0 to 1.0
  activeConnections Int?
  lastActivity    DateTime?
  metadata        Json?
  createdAt       DateTime       @default(now())

  // Relations
  agent           A2AAgent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("a2a_heartbeats")
}

// A2A Protocol Enums
enum A2AAgentStatus {
  ONLINE
  OFFLINE
  BUSY
  IDLE
  ERROR
}

enum A2AMessageType {
  HANDSHAKE
  REQUEST
  RESPONSE
  NOTIFICATION
  HEARTBEAT
  ERROR
  BROADCAST
}

enum A2AMessagePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum A2AConversationStatus {
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// USER MANAGEMENT
// =============================================================================

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  username       String?    @unique
  name           String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  hashedPassword String
  role           UserRole   @default(USER)
  roles          UserRole[] @default([USER])
  isActive       Boolean    @default(true)
  lastLogin      DateTime?
  preferences    Json?
  refreshToken   String?
  deletedAt      DateTime?
  emailVerified  Boolean    @default(false)

  // Relationships
  agents            Agent[]
  pipelines         Pipeline[]
  tasks             Task[]
  workflows         Workflow[]
  chatRooms         ChatRoom[]
  messages          Message[]
  authSessions      AuthSession[]
  loginAttempts     LoginAttempt[]
  workflowTemplates WorkflowTemplate[]
  authEvents        AuthEvent[]
  workspaces        Workspace[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  AGENCY_OWNER
  AGENCY_ADMIN
  AGENCY_MANAGER
  AGENT_OPERATOR
}

// =============================================================================
// AUTHENTICATION
// =============================================================================

model AuthSession {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("auth_sessions")
}

model LoginAttempt {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  ipAddress  String
  successful Boolean
  createdAt  DateTime @default(now())

  @@map("login_attempts")
}

model AuthEvent {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  details   Json?
  createdAt DateTime @default(now())

  @@map("auth_events")
}

// =============================================================================
// AGENT SYSTEM
// =============================================================================

model Agent {
  id           String            @id @default(uuid())
  name         String
  type         AgentType
  status       AgentStatus       @default(INACTIVE)
  description  String?
  systemPrompt String?
  config       Json?
  capabilities AgentCapability[] @default([])
  provider     String            @default("default")
  userId       String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  // Relationships
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata       AgentMetadata?
  nft            AgentNFT?
  wallet         Wallet?
  chats          Chat[]
  messages       Message[]
  codeExecutions CodeExecutionUsage[]
  pipelines      Pipeline[]
  tasksAssigned  Task[]               @relation("AgentTasks")
  workflows      Workflow[]
  workflowSteps  WorkflowStep[]
  registrations  AgentRegistration[]
  directoryEntry AgentDirectoryEntry?
  promptVersions AgentPromptVersion[]

  @@map("agents")
}

model AgentMetadata {
  id       String @id @default(uuid())
  agentId  String @unique
  metadata Json   @default("{}")
  version  String @default("1.0.0")
  config   Json?

  // Relationships
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_metadata")
}

enum AgentType {
  // ============ CORE TYPES (Original) ============
  BASIC
  CHAT
  WORKFLOW
  TASK
  ASSISTANT
  ANALYSIS
  CONVERSATIONAL
  IDE_EXTENSION
  API

  // ============ SYSTEM/ORCHESTRATION AGENTS ============
  ORCHESTRATOR // Master coordination agent
  BROKER // Message routing and queue management
  MONITOR // System health and performance monitoring
  VALIDATOR // Input/output validation
  ROUTER // Task/message routing decisions
  SCHEDULER // Time-based task scheduling
  GATEWAY // API gateway and protocol translation

  // ============ CLI AGENTS ============
  CLI_CODER // Command-line coding assistant (Cline, Aider)
  CLI_DEBUGGER // CLI-based debugging
  CLI_DEVOPS // DevOps CLI operations
  CLI_DATABASE // Database CLI operations
  CLI_GIT // Git operations
  CLI_SHELL // General shell operations

  // ============ IDE EXTENSION AGENTS ============
  IDE_VSCODE // VS Code specific
  IDE_CURSOR // Cursor IDE
  IDE_WINDSURF // Windsurf IDE
  IDE_JETBRAINS // JetBrains IDEs
  IDE_NEOVIM // Neovim/Vim
  IDE_EMACS // Emacs

  // ============ BROWSER AGENTS ============
  BROWSER_GEMINI // Google Gemini
  BROWSER_CLAUDE // Claude Web
  BROWSER_CHATGPT // ChatGPT Web
  BROWSER_COPILOT // GitHub Copilot Web
  BROWSER_PERPLEXITY // Perplexity AI
  BROWSER_PHIND // Phind

  // ============ GITHUB INTEGRATED ============
  GITHUB_JULES // Google Jules (direct GitHub commits)
  GITHUB_COPILOT // GitHub Copilot
  GITHUB_ACTIONS // GitHub Actions automation
  GITHUB_CODESPACES // Codespaces integration

  // ============ CODE/DEVELOPMENT AGENTS ============
  CODE_GENERATOR // Code generation specialist
  CODE_REVIEWER // Code review specialist
  CODE_REFACTORER // Refactoring specialist
  CODE_DOCUMENTER // Documentation generator
  CODE_TESTER // Test generation
  CODE_ARCHITECT // Architecture design
  CODE_OPTIMIZER // Performance optimization
  CODE_SECURITY // Security auditing
  CODE_MIGRATOR // Code migration
  CODE_TRANSLATOR // Language translation

  // ============ DATA AGENTS ============
  DATA_ANALYST // Data analysis
  DATA_ENGINEER // Data pipeline
  DATA_SCIENTIST // ML/AI modeling
  DATA_VISUALIZER // Visualization
  DATA_CLEANER // Data cleaning
  DATA_VALIDATOR // Data validation

  // ============ INFRASTRUCTURE AGENTS ============
  INFRA_DEVOPS // DevOps operations
  INFRA_CLOUD // Cloud management
  INFRA_KUBERNETES // K8s operations
  INFRA_DOCKER // Container management
  INFRA_TERRAFORM // IaC operations
  INFRA_MONITORING // Infrastructure monitoring

  // ============ DOCUMENTATION AGENTS ============
  DOC_WRITER // Technical writing
  DOC_API // API documentation
  DOC_README // README generation
  DOC_CHANGELOG // Changelog management
  DOC_TUTORIAL // Tutorial creation

  // ============ TESTING AGENTS ============
  TEST_UNIT // Unit testing
  TEST_INTEGRATION // Integration testing
  TEST_E2E // End-to-end testing
  TEST_PERFORMANCE // Performance testing
  TEST_SECURITY // Security testing
  TEST_ACCESSIBILITY // Accessibility testing

  // ============ AI/ML AGENTS ============
  AI_TRAINER // Model training
  AI_EVALUATOR // Model evaluation
  AI_PROMPT_ENGINEER // Prompt optimization
  AI_RAG // RAG operations
  AI_EMBEDDINGS // Embedding generation
  AI_FINE_TUNER // Fine-tuning specialist

  // ============ COMMUNICATION AGENTS ============
  COMM_TRANSLATOR // Language translation
  COMM_SUMMARIZER // Content summarization
  COMM_WRITER // Content writing
  COMM_EMAIL // Email handling
  COMM_SLACK // Slack integration
  COMM_DISCORD // Discord integration

  // ============ RESEARCH AGENTS ============
  RESEARCH_WEB // Web research
  RESEARCH_ACADEMIC // Academic research
  RESEARCH_MARKET // Market research
  RESEARCH_COMPETITOR // Competitor analysis

  // ============ SPECIALIZED DOMAIN AGENTS ============
  DOMAIN_LEGAL // Legal analysis
  DOMAIN_FINANCE // Financial analysis
  DOMAIN_HEALTHCARE // Healthcare domain
  DOMAIN_EDUCATION // Education domain
  DOMAIN_ECOMMERCE // E-commerce domain
  DOMAIN_GAMING // Gaming domain

  // ============ TNF FRAMEWORK AGENTS ============
  TNF_CORE // The New Fuse itself as an agent
  TNF_ONBOARDING // Agent onboarding specialist
  TNF_COORDINATOR // Task coordination
  TNF_HANDOFF // Handoff management
  TNF_HEARTBEAT // Heartbeat monitoring
  TNF_CLEANUP // System cleanup
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  IDLE
  BUSY
  ERROR
  OFFLINE
  INITIALIZING
  READY
  TERMINATED
}

enum AgentCapability {
  CODE_GENERATION
  CODE_REVIEW
  CODE_REFACTORING
  CODE_EXECUTION
  DEBUGGING
  TESTING
  DOCUMENTATION
  ARCHITECTURE_DESIGN
  OPTIMIZATION
  SECURITY_AUDIT
  PROJECT_MANAGEMENT
  TOOL_USAGE
  TASK_EXECUTION
  FILE_MANAGEMENT
  CODE_COMPLETION
  CODE_SUGGESTIONS
  SYNTAX_HIGHLIGHTING
  ERROR_DETECTION
  CODE_FORMATTING
  INTELLISENSE
  CHAT
  WORKFLOW
  RESEARCH
  ANALYSIS
  INTEGRATION
}

// =============================================================================
// CHAT SYSTEM
// =============================================================================

model Chat {
  id        String    @id @default(uuid())
  title     String?
  agentId   String
  userId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relationships
  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("chats")
}

model ChatRoom {
  id            String    @id @default(uuid())
  name          String
  description   String?
  isPrivate     Boolean   @default(false)
  owner         User      @relation(fields: [ownerId], references: [id])
  ownerId       String
  settings      Json?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastMessageAt DateTime?
  isActive      Boolean   @default(true)
  deletedAt     DateTime?

  // Relationships
  messages Message[]

  @@map("chat_rooms")
}

model Message {
  id              String      @id @default(uuid())
  content         String      @db.Text
  role            MessageRole @default(USER)
  sender          User?       @relation(fields: [senderId], references: [id])
  senderId        String?
  senderName      String? // For DTO compatibility - plain string sender
  agent           Agent?      @relation(fields: [agentId], references: [id])
  agentId         String?
  chat            Chat?       @relation(fields: [chatId], references: [id])
  chatId          String?
  room            ChatRoom?   @relation(fields: [roomId], references: [id])
  roomId          String?
  parentMessage   Message?    @relation("MessageReplies", fields: [parentMessageId], references: [id])
  parentMessageId String?
  replies         Message[]   @relation("MessageReplies")
  metadata        Json?
  attachments     String[]    @default([])
  timestamp       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isEdited        Boolean     @default(false)
  isDeleted       Boolean     @default(false)
  isEphemeral     Boolean     @default(false)
  expiresAt       DateTime?
  reactions       Json?

  @@map("messages")
}

model ChatMessage {
  id        String      @id @default(uuid())
  userId    String
  role      MessageRole
  content   String      @db.Text
  expiresAt DateTime    @default(dbgenerated("NOW() + INTERVAL '7 days'"))
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("chat_messages")
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
  ASSISTANT
  TOOL
}

// =============================================================================
// WORKFLOW SYSTEM
// =============================================================================

model Workflow {
  id             String         @id @default(uuid())
  name           String
  description    String?
  definition     Json? // Workflow definition JSON
  status         WorkflowStatus @default(DRAFT)
  creator        User?          @relation(fields: [creatorId], references: [id])
  creatorId      String?
  agent          Agent?         @relation(fields: [agentId], references: [id])
  agentId        String?
  metadata       Json?
  isActive       Boolean        @default(true)
  variables      Json?
  triggers       Json?          @db.Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  lastExecutedAt DateTime?
  executionCount Int            @default(0)
  statistics     Json?
  deletedAt      DateTime?

  // Relationships
  steps      WorkflowStep[]
  executions WorkflowExecution[]

  @@map("workflows")
}

model WorkflowStep {
  id              String    @id @default(uuid())
  name            String
  type            String
  config          Json?
  order           Int       @default(0)
  workflow        Workflow? @relation(fields: [workflowId], references: [id])
  workflowId      String?
  agent           Agent?    @relation(fields: [agentId], references: [id])
  agentId         String?
  nextSteps       String[]
  conditions      Json?
  transformations Json?
  metadata        Json?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastExecutedAt  DateTime?
  statistics      Json?

  @@map("workflow_steps")
}

model WorkflowExecution {
  id          String                  @id @default(uuid())
  workflow    Workflow                @relation(fields: [workflowId], references: [id])
  workflowId  String
  status      WorkflowExecutionStatus @default(PENDING)
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime                @default(now())
  completedAt DateTime?

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  @@map("workflow_executions")
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model WorkflowTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   @default("Custom")
  definition  Json // The node/edge structure
  isPublic    Boolean  @default(false)
  creator     User?    @relation(fields: [creatorId], references: [id])
  creatorId   String?
  metadata    Json?
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workflow_templates")
}

// =============================================================================
// PIPELINE SYSTEM
// =============================================================================

model Pipeline {
  id            String         @id @default(uuid())
  name          String
  description   String?
  configuration Json?
  status        PipelineStatus @default(DRAFT)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  agent         Agent          @relation(fields: [agentId], references: [id])
  agentId       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  // Relationships
  tasks Task[]

  @@map("pipelines")
}

enum PipelineStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

// =============================================================================
// TASK SYSTEM
// =============================================================================

model Task {
  id           String       @id @default(uuid())
  title        String?
  description  String?
  type         String
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(MEDIUM)
  data         Json?
  result       Json?
  error        String?
  startTime    DateTime?
  endTime      DateTime?
  pipeline     Pipeline?    @relation(fields: [pipelineId], references: [id])
  pipelineId   String?
  assignedTo   Agent?       @relation("AgentTasks", fields: [assignedToId], references: [id])
  assignedToId String?
  user         User         @relation(fields: [userId], references: [id])
  userId       String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  metadata     Json?

  // Relationships
  taskExecutions TaskExecution[]

  @@map("tasks")
}

model TaskExecution {
  id          String    @id @default(uuid())
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  status      String
  output      Json?
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@map("task_executions")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// =============================================================================
// CODE EXECUTION SYSTEM
// =============================================================================

model CodeExecutionUsage {
  id            String                @id @default(uuid())
  agentId       String
  clientId      String
  executionId   String                @unique
  language      CodeExecutionLanguage
  code          String                @db.Text
  result        Json?
  output        Json?
  error         Json?
  executionTime Int // in milliseconds
  memoryUsage   Int // in bytes
  computeUnits  Float
  cost          Float
  tier          CodeExecutionTier
  environment   String
  status        CodeExecutionStatus
  createdAt     DateTime              @default(now())
  completedAt   DateTime?

  // Relationships
  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([clientId])
  @@index([createdAt])
  @@index([language])
  @@index([tier])
  @@index([status])
  @@map("code_execution_usage")
}

model CodeExecutionSession {
  id            String    @id @default(uuid())
  name          String
  description   String?
  ownerId       String
  collaborators String[]
  isPublic      Boolean   @default(false)
  files         Json // Array of file objects
  environment   Json // Environment configuration
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime?
  storageUsage  Int       @default(0) // in bytes

  @@map("code_execution_sessions")
}

enum CodeExecutionLanguage {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  RUBY
  SHELL
  HTML
  CSS
}

enum CodeExecutionTier {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum CodeExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  TIMEOUT
  CANCELLED
}

// =============================================================================
// NFT AND MARKETPLACE MODELS
// =============================================================================

model AgentNFT {
  id                  String   @id @default(uuid())
  agentId             String   @unique
  tokenId             Int      @unique
  contractAddress     String
  smartAccountAddress String?
  isFractionalized    Boolean  @default(false)
  totalShares         Int      @default(0)
  metadataUri         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  agent               Agent?               @relation(fields: [agentId], references: [id])
  fractionalShares    FractionalShare[]
  revenueStreams      RevenueStream[]
  marketplaceListings MarketplaceListing[]

  @@map("agent_nfts")
}

model FractionalShare {
  id           String   @id @default(uuid())
  agentNFTId   String
  ownerAddress String
  shareAmount  Decimal
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agentNFT AgentNFT @relation(fields: [agentNFTId], references: [id], onDelete: Cascade)

  @@map("fractional_shares")
}

model RevenueStream {
  id                    String   @id @default(uuid())
  agentNFTId            String
  streamName            String
  description           String?
  tokenAddress          String
  totalRevenue          Decimal
  distributedRevenue    Decimal
  distributionThreshold Decimal
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  agentNFT      AgentNFT              @relation(fields: [agentNFTId], references: [id], onDelete: Cascade)
  distributions RevenueDistribution[]

  @@map("revenue_streams")
}

model RevenueDistribution {
  id              String   @id @default(uuid())
  revenueStreamId String
  txHash          String
  totalAmount     Decimal
  distributedTo   Json
  blockNumber     Int
  createdAt       DateTime @default(now())

  revenueStream RevenueStream @relation(fields: [revenueStreamId], references: [id], onDelete: Cascade)

  @@map("revenue_distributions")
}

model MarketplaceListing {
  id            String            @id @default(uuid())
  agentNFTId    String
  listingId     Int               @unique
  seller        String
  shareAmount   Decimal
  pricePerShare Decimal
  totalPrice    Decimal
  status        MarketplaceStatus @default(ACTIVE)
  expiresAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  agentNFT AgentNFT           @relation(fields: [agentNFTId], references: [id], onDelete: Cascade)
  offers   MarketplaceOffer[]

  @@map("marketplace_listings")
}

model MarketplaceOffer {
  id          String      @id @default(uuid())
  listingId   String
  buyer       String
  shareAmount Decimal
  offerPrice  Decimal
  status      OfferStatus @default(PENDING)
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("marketplace_offers")
}

enum MarketplaceStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

// =============================================================================
// WALLET AND TRANSACTION MODELS
// =============================================================================

model Wallet {
  id           String     @id @default(uuid())
  address      String     @unique
  agentId      String?    @unique
  type         WalletType @default(SMART_ACCOUNT)
  balance      Decimal    @default(0)
  nonce        Int        @default(0)
  isActive     Boolean    @default(true)
  lastActivity DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  agent        Agent?        @relation(fields: [agentId], references: [id])
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id          String            @id @default(uuid())
  hash        String            @unique
  walletId    String
  fromAddress String
  toAddress   String
  value       Decimal
  gasPrice    Decimal
  gasUsed     Int
  gasLimit    Int
  status      TransactionStatus @default(PENDING)
  blockNumber Int?
  blockHash   String?
  type        TransactionType   @default(TRANSFER)
  data        Json?
  createdAt   DateTime          @default(now())
  confirmedAt DateTime?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([hash])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

enum WalletType {
  SMART_ACCOUNT
  EOA
  MULTI_SIG
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum TransactionType {
  TRANSFER
  CONTRACT_CALL
  CONTRACT_DEPLOYMENT
  NFT_MINT
  NFT_TRANSFER
}

// =============================================================================
// ENTITY REGISTRY
// =============================================================================

model RegisteredEntity {
  id           String               @id @default(uuid())
  name         String
  type         RegisteredEntityType
  description  String?
  metadata     Json?
  config       Json?
  status       EntityStatus         @default(ACTIVE)
  version      String               @default("1.0.0")
  namespace    String?
  tags         String[]             @default([])
  capabilities String[]             @default([])
  // By adding this TSDoc, we prevent Prisma from generating a deeply
  // recursive type for dependencies, which can cause a stack overflow.
  /// @see RegisteredEntity
  dependencies String[]             @default([])
  isPublic     Boolean              @default(false)
  ownerId      String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deletedAt    DateTime?

  @@map("registered_entities")
}

enum RegisteredEntityType {
  AGENT
  WORKFLOW
  TOOL
  SERVICE
  INTEGRATION
  TEMPLATE
  COMPONENT
  MODULE
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  DEPRECATED
  PENDING
  FAILED
}

// =============================================================================
// LLM CONFIGURATION
// =============================================================================

model LLMConfig {
  id          String    @id @default(uuid())
  name        String
  provider    String
  modelName   String
  apiKey      String // Encrypted API key
  apiEndpoint String?
  isCustom    Boolean   @default(false)
  enabled     Boolean   @default(true)
  priority    Int       @default(10)
  retryConfig Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("llm_configs")
}

// =============================================================================
// AGENT REGISTRY & DISCOVERY
// =============================================================================

model AgentRegistration {
  id                 String    @id @default(uuid())
  agentId            String
  authToken          String    @unique
  registrationData   Json
  verificationStatus String    @default("PENDING")
  onboardingStatus   String    @default("INITIALIZED")
  onboardingProgress Float     @default(0)
  heartbeatInterval  Int       @default(60000)
  isOnline           Boolean   @default(false)
  lastHeartbeat      DateTime?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  agent            Agent                     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capabilities     AgentCapabilityRegistry[]
  onboardingEvents AgentOnboardingEvent[]

  @@map("agent_registrations")
}

model AgentCapabilityRegistry {
  id                 String   @id @default(uuid())
  registrationId     String
  capabilityName     String
  capabilityType     String
  version            String
  description        String?
  parameters         Json?
  verificationStatus String   @default("PENDING")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  registration AgentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@map("agent_capability_registry")
}

model AgentOnboardingEvent {
  id             String   @id @default(uuid())
  registrationId String
  eventType      String
  message        String
  eventData      Json?
  timestamp      DateTime @default(now())

  registration AgentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@map("agent_onboarding_events")
}

model AgentDirectoryEntry {
  id             String   @id @default(uuid())
  agentId        String   @unique
  displayName    String
  description    String?
  category       String
  tags           String[]
  isPublic       Boolean  @default(false)
  isVerified     Boolean  @default(false)
  rating         Float    @default(0)
  usageCount     Int      @default(0)
  searchableData String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_directory_entries")
}

// =============================================================================
// PROMPT OPTIMIZATION
// =============================================================================

model AgentPromptVersion {
  id                 String   @id @default(uuid())
  agentId            String
  versionNumber      Int
  instruction        String   @db.Text
  exemplars          Json?
  performanceMetrics Json?
  massStage          String?
  createdAt          DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_prompt_versions")
}

model PromptTemplate {
  id               String   @id @default(uuid())
  name             String
  description      String?
  currentVersionId String?
  isPublic         Boolean  @default(false)
  category         String?
  tags             String[] @default([])
  analytics        Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  versions PromptVersion[]

  @@map("prompt_templates")
}

model PromptVersion {
  id         String   @id @default(uuid())
  templateId String
  version    Int
  label      String?
  content    String   @db.Text
  variables  Json?
  metrics    Json?
  changelog  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  template PromptTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("prompt_versions")
}

model PromptSnippet {
  id          String   @id @default(uuid())
  name        String
  content     String   @db.Text
  type        String
  category    String?
  tags        String[] @default([])
  usageCount  Int      @default(0)
  description String?
  isStarred   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("prompt_snippets")
}

model ValidationDataset {
  id          String   @id @default(uuid())
  name        String
  description String?
  items       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("validation_datasets")
}

// =============================================================================
// MONITORING AND METRICS
// =============================================================================

model BusinessMetric {
  id        String   @id @default(uuid())
  name      String
  value     Float
  tags      Json?
  createdAt DateTime @default(now())

  @@map("business_metrics")
}

model ErrorLog {
  id        String   @id @default(uuid())
  message   String
  stack     String?
  context   Json?
  createdAt DateTime @default(now())

  @@map("error_logs")
}

// =============================================================================
// WORKSPACE & PROJECT MANAGEMENT
// =============================================================================

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  projects Project[]

  @@map("workspaces")
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relationships
  workflowExecutions  WorkflowExecution[]
  agentMemories       AgentMemory[]
  resourceAllocations ResourceAllocation[]

  @@map("projects")
}

model AgentMemory {
  id        String   @id @default(uuid())
  key       String
  value     Json
  agentId   String? // Can be linked to an agent if needed
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agent_memories")
}

model ResourceAllocation {
  id           String   @id @default(uuid())
  resourceType String
  resourceId   String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  allocatedAt  DateTime @default(now())
  metadata     Json?

  @@map("resource_allocations")
}

// =============================================================================
// SYNC SYSTEM
// =============================================================================

model SyncState {
  id           String   @id @default(uuid())
  resourceType String
  resourceId   String
  tenantId     String?
  version      Int
  checksum     String
  lastSync     DateTime
  syncedBy     String
  metadata     Json

  @@unique([resourceType, resourceId, tenantId])
  @@map("sync_states")
}

model SyncConflict {
  id            String    @id @default(uuid())
  resourceType  String
  resourceId    String
  tenantId      String?
  conflictType  String
  localVersion  Json
  remoteVersion Json
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
  resolvedBy    String?
  resolution    Json?

  @@map("sync_conflicts")
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "composite": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@the-new-fuse/database": ["../../packages/database/dist"],
      "@the-new-fuse/core-vector-db": ["../../packages/core-vector-db/dist"],
      "@the-new-fuse/infrastructure": ["../../packages/infrastructure/dist"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}

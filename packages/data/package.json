{
  "name": "@the-new-fuse/data",
  "files": ["dist"],
  "version": "1.0.0",
  "description": "Unified data stack for The New Fuse framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",

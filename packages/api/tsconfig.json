{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "composite": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": [
    "src/**/*"
  ],
  "references": [
    { "path": "../types" },
    { "path": "../database" },
    { "path": "../core" }
  ]
}
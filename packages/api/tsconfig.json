{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "composite": true,
    "noEmitOnError": false,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules", 
    "dist", 
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.js",
    "../core/**/*",
    "../api-types/**/*.test.ts",
    "../types/**/*.test.ts"
  ],
  "references": [
    { "path": "../types" },
    { "path": "../database" }
  ]
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id        String    @id @default(uuid())
  name      String
  type      String
  metadata  Json?     @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@map("agents")
}

model RegisteredEntity {
  id          String    @id @default(uuid())
  type        String
  name        String
  description String?
  metadata    Json?     @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("registered_entities")
  @@unique([type, name], name: "name_type")
  @@index([deletedAt])
  @@index([type])
  @@index([name])
}

// Webhook Infrastructure Tables
model BusinessEvent {
  id                String      @id @default(uuid())
  type              String      @db.VarChar(50)
  source            String      @db.VarChar(50)
  organizationId    String      @map("organization_id")
  userId            String?     @map("user_id")
  correlationId     String?     @map("correlation_id") @db.VarChar(255)
  data              Json
  metadata          Json
  processingStatus  String      @default("pending") @map("processing_status") @db.VarChar(20)
  retryCount        Int         @default(0) @map("retry_count")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  processedAt       DateTime?   @map("processed_at")

  @@map("business_events")
  @@index([organizationId, type], name: "idx_business_events_org_type")
  @@index([processingStatus], name: "idx_business_events_status")
  @@index([createdAt], name: "idx_business_events_created")
  @@index([correlationId], name: "idx_business_events_correlation")
}

model WebhookConfiguration {
  id              String      @id @default(uuid())
  organizationId  String      @map("organization_id")
  source          String      @db.VarChar(50)
  endpointUrl     String      @map("endpoint_url") @db.VarChar(500)
  secretKey       String      @map("secret_key") @db.VarChar(255)
  isActive        Boolean     @default(true) @map("is_active")
  configuration   Json
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("webhook_configurations")
}

model SseSubscription {
  id              String      @id @default(uuid())
  clientId        String      @map("client_id") @db.VarChar(255)
  userId          String      @map("user_id")
  organizationId  String      @map("organization_id")
  eventTypes      String[]    @map("event_types")
  filters         Json?
  createdAt       DateTime    @default(now()) @map("created_at")
  lastHeartbeat   DateTime    @default(now()) @map("last_heartbeat")

  @@map("sse_subscriptions")
}

model BusinessAnalytics {
  id              String      @id @default(uuid())
  organizationId  String      @map("organization_id")
  metricType      String      @map("metric_type") @db.VarChar(50)
  metricValue     Decimal     @map("metric_value") @db.Decimal(15,2)
  dimensions      Json?
  timestamp       DateTime
  createdAt       DateTime    @default(now()) @map("created_at")

  @@map("business_analytics")
}

model AiInsight {
  id              String      @id @default(uuid())
  organizationId  String      @map("organization_id")
  type            String      @db.VarChar(50)
  confidence      Decimal     @db.Decimal(3,2)
  description     String      @db.Text
  data            Json
  recommendations String[]
  impact          String      @db.VarChar(20)
  status          String      @default("active") @db.VarChar(20)
  createdAt       DateTime    @default(now()) @map("created_at")
  expiresAt       DateTime?   @map("expires_at")

  @@map("ai_insights")
}

model WebhookDeliveryLog {
  id              String      @id @default(uuid())
  webhookConfigId String      @map("webhook_config_id")
  eventId         String      @map("event_id")
  deliveryStatus  String      @map("delivery_status") @db.VarChar(20)
  httpStatus      Int?        @map("http_status")
  responseBody    String?     @map("response_body") @db.Text
  errorMessage    String?     @map("error_message") @db.Text
  attemptCount    Int         @default(1) @map("attempt_count")
  deliveredAt     DateTime?   @map("delivered_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  @@map("webhook_delivery_logs")
  @@index([webhookConfigId], name: "idx_webhook_delivery_config")
  @@index([eventId], name: "idx_webhook_delivery_event")
  @@index([deliveryStatus], name: "idx_webhook_delivery_status")
}

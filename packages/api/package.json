{
  "name": "@the-new-fuse/api",
  "files": [
    "dist"
  ],
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @the-new-fuse/types build && pnpm --filter @the-new-fuse/core build && pnpm --filter @the-new-fuse/ap2-protocol build",
    "build": "tsc -b",
    "build:api": "tsc",
    "build:force": "tsc --build --force",
    "build:ignore-errors": "tsc --skipLibCheck --skipDefaultLibCheck --noEmitOnError",
    "build:js-only": "./scripts/build-js-only.sh",
    "build:production": "NODE_ENV=production tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "type-check": "tsc --noEmit",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "echo \"No tests found for @the-new-fuse/api\" && exit 0",
    "test:unit": "jest --testPathPatterns=unit",
    "test:integration": "jest --testPathPatterns=integration",
    "test:e2e": "jest --testPathPatterns=e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "docker:build": "docker build -t api .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@angular-devkit/core": "20.3.6",
    "@angular-devkit/schematics": "20.3.6",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.16",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@the-new-fuse/core": "workspace:*",
    "@the-new-fuse/database": "workspace:*",
    "@the-new-fuse/infrastructure": "workspace:*",
    "@the-new-fuse/types": "workspace:*",
    "@the-new-fuse/utils": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "express": "^4.22.0",
    "graphql": "^16.11.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.8.1",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.4.1",
    "jest": "^30.3.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "webpack": "^5.102.1"
  }
}

{
  "name": "@the-new-fuse/api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "build:api": "tsc --build",
    "build:force": "tsc --build --force",
    "build:ignore-errors": "tsc --skipLibCheck --skipDefaultLibCheck --noEmitOnError",
    "build:js-only": "./scripts/build-js-only.sh",
    "build:production": "NODE_ENV=production tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rimraf dist .turbo",
    "type-check": "tsc --noEmit",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "echo \"No tests found for @the-new-fuse/api\" && exit 0",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "docker:build": "docker build -t api ."
  },
  "dependencies": {
    "@angular-devkit/core": "15.2.9",
    "@angular-devkit/schematics": "15.2.9",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/graphql": "12.0.0",
    "graphql": "^16.8.1",
    "@the-new-fuse/database": "workspace:*",
    "@the-new-fuse/types": "workspace:*",
    "@the-new-fuse/utils": "workspace:*",
    "cookie-parser": "^1.4.6",
    "express": "^4.21.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "uuid": "^9.0.1",
    "@the-new-fuse/infrastructure": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "9.2.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.1.0",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "eslint": "^9.19.0",
    "jest": "^29.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0",
    "webpack": "^5.89.0"
  }
}

{
  "name": "@the-new-fuse/api",
  "module": "src/main.ts",
  "type": "module",
  "scripts": {
    "preinstall": "echo '⚡ Using Bun for fast installs'",
    "postinstall": "echo '✅ API dependencies installed'"
  },
  "bun": {
    "install": {
      "cache": true,
      "lockfile": true,
      "production": false
    },
    "run": {
      "bun": true,
      "hot": true,
      "watch": true
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  }
}

{
  "name": "@the-new-fuse/websocket-infrastructure",
  "version": "1.0.0",
  "description": "Production-ready WebSocket infrastructure with connection pooling, Redis pub/sub, and horizontal scaling",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/websockets": "^11.1.18",
    "@socket.io/redis-adapter": "^8.3.0",
    "compression": "^1.8.1",
    "ioredis": "^5.8.1",
    "msgpack-lite": "^0.1.26",
    "pako": "^2.1.0",
    "prom-client": "^15.1.3",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "socket.io-redis": "^6.1.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/pako": "^2.0.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  }
}

{
  "name": "@the-new-fuse/shared",
  "version": "1.0.0",
  "description": "Shared utilities, hooks, and components for The New Fuse",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./validation": "./src/validation/index.ts",
    "./utils": "./src/utils/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./browser-control/protocol": "./src/browser-control/protocol.ts"
  },
  "scripts": {
    "build": "rimraf dist && tsc --build",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@the-new-fuse/types": "workspace:*",
    "react": "^19.2.3",
    "react-hot-toast": "^2.4.1",
    "@the-new-fuse/infrastructure": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.3",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}

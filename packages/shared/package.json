{
  "name": "@the-new-fuse/shared",
  "files": [
    "dist"
  ],
  "version": "1.0.0",
  "description": "Shared utilities, hooks, and components for The New Fuse",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./validation": "./dist/validation/index.js",
    "./utils": "./dist/utils/index.js",
    "./hooks": "./dist/hooks/index.js",
    "./browser-control/protocol": "./dist/browser-control/protocol.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --build",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@the-new-fuse/infrastructure": "workspace:*",
    "@the-new-fuse/types": "workspace:*",
    "@upstash/redis": "^1.37.0",
    "ioredis": "^5.8.1",
    "react": "^19.2.5",
    "react-hot-toast": "^2.4.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.3",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}

{
  "name": "@the-new-fuse/a2a-core",
  "version": "0.3.0",
  "description": "Agent-to-Agent (A2A) Protocol v0.3.0 Core Library - Official Linux Foundation Specification",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:unit": "jest --testPathPatterns=unit --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist .tsbuildinfo tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.2",
    "@nestjs/websockets": "^11.1.19",
    "@the-new-fuse/ap2-protocol": "workspace:^",
    "@the-new-fuse/infrastructure": "workspace:*",
    "ioredis": "^5.8.1",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/uuid": "^11.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}

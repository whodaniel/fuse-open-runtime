+/**
+ * Backward Compatibility Layer for A2A v0.3.0 Migration
+ *
+ * This file provides types for legacy code that hasn't been migrated to v0.3.0 yet.
+ * These types map old interfaces to new v0.3.0 types where possible.
+ */
+
+import { z } from 'zod';
+
+import type {
+  AgentCapabilities as A2AAgentCapabilities,
+  A2AConfig,
+  Message,
+  MessageSchema,
+  Task,
+  TaskSchema,
+} from './types-v0.3.0';
+
+// Re-export A2AConfig explicitly
+export type { A2AConfig };
+
+// ============================================================================
+// Legacy Enums (exported for backward compatibility)
+// ============================================================================
+
+/**
+ * @deprecated Use TaskState or custom metadata instead
+ */
+export enum AgentStatus {
+  ONLINE = 'online',
+  OFFLINE = 'offline',
+  BUSY = 'busy',
+  IDLE = 'idle',
+  ERROR = 'error',
+}
+
+/**
+ * @deprecated Use appropriate v0.3.0 message patterns instead
+ */
+export enum A2AMessageType {
+  TASK_ASSIGNMENT = 'task_assignment',
+  STATUS_UPDATE = 'status_update',
+  DATA_REQUEST = 'data_request',
+  DATA_RESPONSE = 'data_response',
+  COLLABORATION_REQUEST = 'collaboration_request',
+  WORKFLOW_COORDINATION = 'workflow_coordination',
+  RESOURCE_SHARING = 'resource_sharing',
+  ERROR_NOTIFICATION = 'error_notification',
+  HEARTBEAT = 'heartbeat',
+  CAPABILITY_ANNOUNCEMENT = 'capability_announcement',
+}
+
+/**
+ * @deprecated Use priority in metadata instead
+ */
+export enum A2APriority {
+  CRITICAL = 1,
+  HIGH = 2,
+  MEDIUM = 3,
+  LOW = 4,
+  BATCH = 5,
+}
+
+// ============================================================================
+// Extended Message Type (for legacy code)
+// ============================================================================
+
+/**
+ * Extended Message with legacy properties
+ */
+export interface ExtendedMessage extends Message {
+  id?: string;
+  priority?: A2APriority;
+  toAgent?: string;
+  fromAgent?: string;
+  type?: A2AMessageType;
+  payload?: unknown;
+  timestamp?: number; // Unix timestamp
+}
+
+// ============================================================================
+// Legacy Message Types (mapped to v0.3.0)
+// ============================================================================
+
+/**
+ * @deprecated Use Message from v0.3.0 instead
+ * Legacy A2AMessage type - now maps to ExtendedMessage with legacy properties
+ */
+export type A2AMessage = ExtendedMessage;
+
+/**
+ * @deprecated Use MessageSchema from v0.3.0 instead
+ */
+export const A2AMessageSchema = MessageSchema;
+
+// ============================================================================
+// Extended Agent Capabilities (for discovery system)
+// ============================================================================
+
+/**
+ * Extended AgentCapabilities with discovery and runtime properties
+ * This extends the base v0.3.0 AgentCapabilities with operational metadata
+ */
+export interface ExtendedAgentCapabilities extends A2AAgentCapabilities {
+  // Agent Identity
+  id?: string;
+  type?: AgentType;
+
+  // Runtime Status
+  isOnline?: boolean;
+  lastSeen?: Date;
+
+  // Capabilities List (skills)
+  capabilities?: string[];
+
+  // Performance Metrics
+  maxConcurrentRequests?: number;
+  averageResponseTime?: number;
+  reliability?: number; // 0-1 score
+}
+
+/**
+ * Legacy AgentCapabilities that includes runtime metadata
+ * This is the type actually used by the discovery and coordination code
+ */
+export type AgentCapabilities = ExtendedAgentCapabilities;
+
+// ============================================================================
+// Agent Registration and Discovery
+// ============================================================================
+
+/**
+ * Agent type classification
+ */
+export enum AgentType {
+  WORKER = 'worker',
+  COORDINATOR = 'coordinator',
+  SPECIALIST = 'specialist',
+  GATEWAY = 'gateway',
+  MONITOR = 'monitor',
+}
+
+/**
+ * Agent registration payload for discovery system
+ */
+export interface AgentRegistration {
+  agentId: string;
+  name: string;
+  version: string;
+  type: AgentType;
+  capabilities: AgentCapabilities;
+  endpoint?: string;
+  metadata?: Record<string, unknown>;
+
+  // Performance metrics
+  maxConcurrentRequests?: number;
+  averageResponseTime?: number;
+  reliability?: number;
+  isOnline?: boolean;
+}
+
+/**
+ * Agent heartbeat for health monitoring
+ */
+export interface AgentHeartbeat {
+  agentId: string;
+  timestamp: Date;
+  status: 'healthy' | 'degraded' | 'unhealthy';
+  metrics?: {
+    cpuUsage?: number;
+    memoryUsage?: number;
+    activeConnections?: number;
+    requestsProcessed?: number;
+  };
+  metadata?: Record<string, unknown>;
+}
+
+// ============================================================================
+// Routing and Load Balancing
+// ============================================================================
+
+/**
+ * Load balancing strategies
+ */
+export enum LoadBalancingStrategy {
+  ROUND_ROBIN = 'round_robin',
+  LEAST_LOADED = 'least_loaded',
+  RANDOM = 'random',
+  WEIGHTED = 'weighted',
+  CONSISTENT_HASH = 'consistent_hash',
+  CAPABILITY_MATCH = 'capability_match',
+  FASTEST_RESPONSE = 'fastest_response',
+}
+
+/**
+ * Routing rule for agent selection
+ */
+export interface RoutingRule {
+  id: string;
+  name: string;
+  condition: string; // Expression or pattern
+  targetAgents: string[]; // Agent IDs
+  preferredAgents?: string[]; // Preferred agent IDs
+  fallbackAgents?: string[]; // Fallback agent IDs
+  messageType?: A2AMessageType; // Message type filter
+  loadBalancingStrategy?: LoadBalancingStrategy; // Load balancing strategy
+  timeoutMs?: number; // Timeout in milliseconds
+  priority: number;
+  enabled: boolean;
+  metadata?: Record<string, unknown>;
+}
+
+// ============================================================================
+// Response Types
+// ============================================================================
+
+/**
+ * Standard A2A response wrapper
+ */
+export interface A2AResponse<T = unknown> {
+  success: boolean;
+  data?: T;
+  error?: {
+    code: string;
+    message: string;
+    details?: unknown;
+  };
+  metadata?: Record<string, unknown>;
+}
+
+// ============================================================================
+// Conversations (legacy)
+// ============================================================================
+
+/**
+ * @deprecated Use Task from v0.3.0 instead
+ * Legacy Conversation type - now maps to Task
+ */
+export type Conversation = Task;
+
+/**
+ * @deprecated Use TaskSchema from v0.3.0 instead
+ */
+export const ConversationSchema = TaskSchema;
+
+// ============================================================================
+// Communicator Interface (legacy)
+// ============================================================================
+
+/**
+ * Legacy IA2ACommunicator interface
+ */
+export interface IA2ACommunicator {
+  connect(): Promise<void>;
+  disconnect(): Promise<void>;
+  sendMessage(message: A2AMessage): Promise<void>;
+  on(event: string, handler: (...args: unknown[]) => void): void;
+  off(event: string, handler?: (...args: unknown[]) => void): void;
+}
+
+// ============================================================================
+// Error Types
+// ============================================================================
+
+/**
+ * Legacy connection error
+ */
+export class A2AConnectionError extends Error {
+  constructor(
+    message: string,
+    public code?: string
+  ) {
+    super(message);
+    this.name = 'A2AConnectionError';
+  }
+}
+
+/**
+ * Extended error codes for legacy compatibility
+ */
+export enum ExtendedA2AErrorCode {
+  // Standard A2A errors
+  PARSE_ERROR = -32700,
+  INVALID_REQUEST = -32600,
+  METHOD_NOT_FOUND = -32601,
+  INVALID_PARAMS = -32602,
+  INTERNAL_ERROR = -32603,
+  TASK_NOT_FOUND = -32001,
+  TASK_ALREADY_CANCELED = -32002,
+  TASK_NOT_CANCELABLE = -32003,
+  AUTHENTICATION_REQUIRED = -32004,
+  AUTHORIZATION_FAILED = -32005,
+  RATE_LIMIT_EXCEEDED = -32006,
+  RESOURCE_EXHAUSTED = -32007,
+  INVALID_TASK_STATE = -32008,
+  PUSH_NOTIFICATION_CONFIG_NOT_FOUND = -32009,
+  UNSUPPORTED_OPERATION = -32010,
+  AGENT_UNAVAILABLE = -32011,
+  TIMEOUT = -32012,
+}
+
+/**
+ * Legacy error code mappings for backward compatibility
+ * Maps old error code names to their corresponding standard codes
+ */
+export const LegacyErrorCodeMapping = {
+  NOT_AUTHENTICATED: ExtendedA2AErrorCode.AUTHENTICATION_REQUIRED,
+  NOT_FOUND: ExtendedA2AErrorCode.TASK_NOT_FOUND,
+  SHUTDOWN: ExtendedA2AErrorCode.INTERNAL_ERROR,
+} as const;
+
+// ============================================================================
+// Validation Schemas for Legacy Types
+// ============================================================================
+
+export const AgentTypeSchema = z.nativeEnum(AgentType);
+
+export const AgentRegistrationSchema = z.object({
+  agentId: z.string(),
+  name: z.string(),
+  version: z.string(),
+  type: AgentTypeSchema,
+  capabilities: z.unknown(), // ExtendedAgentCapabilities
+  endpoint: z.string().optional(),
+  metadata: z.record(z.string(), z.unknown()).optional(),
+});
+
+export const AgentHeartbeatSchema = z.object({
+  agentId: z.string(),
+  timestamp: z.date(),
+  status: z.enum(['healthy', 'degraded', 'unhealthy']),
+  metrics: z
+    .object({
+      cpuUsage: z.number().optional(),
+      memoryUsage: z.number().optional(),
+      activeConnections: z.number().optional(),
+      requestsProcessed: z.number().optional(),
+    })
+    .optional(),
+  metadata: z.record(z.string(), z.unknown()).optional(),
+});
+
+// ============================================================================
+// Re-exports from v0.3.0
+// ============================================================================
+
+// Re-export everything from the v0.3.0 types for convenience
+export * from './types-v0.3.0';

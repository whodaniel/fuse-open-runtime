
{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@the-new-fuse/database": ["../database/dist"],
      "@the-new-fuse/database/*": ["../database/dist/*"],
      "@the-new-fuse/security": ["../security/dist"],
      "@the-new-fuse/security/*": ["../security/dist/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"]
}

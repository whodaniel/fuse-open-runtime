{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@the-new-fuse/control-plane-contracts": ["../control-plane-contracts/src/index.ts"],
      "@the-new-fuse/control-plane-contracts/*": ["../control-plane-contracts/src/*"]
    },
    "types": ["node"],
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "references": []
}

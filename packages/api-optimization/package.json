{
  "name": "@the-new-fuse/api-optimization",
  "version": "1.0.0",
  "description": "Comprehensive API optimization with rate limiting, caching, CDN, and performance features",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@the-new-fuse/types": "workspace:*",
    "compression": "^1.8.1",
    "express": "^4.22.0",
    "ioredis": "^5.8.1",
    "lru-cache": "^10.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/prisma/**/*",
    "src/database/DatabaseMonitor.ts",
    "src/database/TransactionManager.ts",
    "src/services/AgentMetadataManager.ts",
    "src/communication/MessagingService.ts",
    "src/communication/NotificationService.ts"
  ],
  "references": [
    {
      "path": "../core-vector-db"
    },
    {
      "path": "../database"
    },
    {
      "path": "../types"
    },
    {
      "path": "../utils"
    }
  ]
}

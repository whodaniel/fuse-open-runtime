{
  "name": "@the-new-fuse/core",
  "version": "1.0.0",
  "description": "Core functionality for The New Fuse",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.clean.json",
    "dev": "tsc -p tsconfig.clean.json --watch",
    "build:core": "tsc -p tsconfig.clean.json",
    "build:watch": "tsc -p tsconfig.clean.json --watch",
    "build:production": "NODE_ENV=production tsc -p tsconfig.clean.json",
    "clean": "rimraf dist",
    "type-check": "tsc -p tsconfig.clean.json --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^2.0.3",
    "@nestjs/schedule": "^4.0.0",
    "@the-new-fuse/database": "workspace:*",
    "cache-manager": "^7.0.1",
    "chromadb": "^1.5.0",
    "crypto-js": "^4.1.1",
    "ioredis": "^5.0.0",
    "mysql2": "^2.3.0",
    "redis": "^4.6.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.0",
    "winston": "^3.3.3"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.1.1",
    "@types/ioredis": "^4.28.0",
    "@types/jest": "29.0.0",
    "@types/node": "^16.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "29.7.0",
    "ts-jest": "29.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  }
}

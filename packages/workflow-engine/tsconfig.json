{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@the-new-fuse/database": ["../database/src"],
      "@the-new-fuse/database/*": ["../database/src/*"],
      "@the-new-fuse/security": ["../security/src"],
      "@the-new-fuse/security/*": ["../security/src/*"],
      "@tnf/relay-core": ["../relay-core/src"],
      "@tnf/relay-core/*": ["../relay-core/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../relay-core" },
    { "path": "../security" },
    { "path": "../database" }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
{
  "name": "@the-new-fuse/fairtable-utils",
  "version": "1.0.0",
  "description": "Utility functions and hooks for Fairtable functionality",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist .tsbuildinfo tsconfig.tsbuildinfo",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "fairtable",
    "utils",
    "hooks",
    "formula",
    "storage"
  ],
  "author": "The New Fuse Team",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "react": "^19.2.4"
  },
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  }
}

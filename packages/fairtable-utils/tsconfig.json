{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "composite": true,
    "incremental": true,
    "noEmit": false,
    "types": []
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "***.test.tsx", "**/*.spec.tsx"]
}

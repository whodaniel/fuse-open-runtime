{
  "name": "@the-new-fuse/utils",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./validators.server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "build:watch": "tsc --watch --project tsconfig.build.json",
    "dev": "tsc --watch --project tsconfig.build.json",
    "test": "echo \"No tests configured for this package\"",
    "test:unit": "echo \"No tests configured for this package\"",
    "test:watch": "echo \"No tests configured for this package\"",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist .tsbuildinfo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.913.0",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.2",
    "@nestjs/jwt": "^11.0.2",
    "@octokit/rest": "^22.0.0",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "logform": "^2.7.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "^7.8.2",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}

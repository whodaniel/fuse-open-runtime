{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./dist",
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "files": [],
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*spec.ts",
    "**/*.test.ts",
    "**/__tests__/*",
    "**/__mocks__/*"
  ],
  "references": [
    { "path": "../types" }
  ]
}

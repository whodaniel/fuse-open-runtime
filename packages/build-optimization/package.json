{
  "name": "@tnf/build-optimization",
  "version": "1.0.0",
  "description": "Memory-efficient build optimization tools for The New Fuse monorepo",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:memory-optimized": "BUILD_ENABLE_MONITORING=true tsc --incremental",
    "build:staged": "tsc --incremental --build",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@types/node": "^24.8.1",
    "glob": "^11.0.3",
    "@tnf/core-monitoring": "workspace:*",
    "@tnf/core-error-handling": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  }
}
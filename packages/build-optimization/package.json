{
  "name": "@tnf/build-optimization",
  "files": [
    "dist"
  ],
  "version": "1.0.0",
  "description": "Memory-efficient build optimization tools for The New Fuse monorepo",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "build:memory-optimized": "BUILD_ENABLE_MONITORING=true tsc --incremental",
    "build:staged": "tsc --incremental --build",
    "dev": "tsc --watch",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@types/node": "^24.8.1",
    "glob": "^11.0.3",
    "@the-new-fuse/core-monitoring": "workspace:*",
    "@the-new-fuse/core-error-handling": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  }
}

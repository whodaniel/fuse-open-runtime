{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@the-new-fuse/core": [
        "../core/src"
      ],
      "@the-new-fuse/core/*": [
        "../core/src/*"
      ],
      "@the-new-fuse/types": [
        "../types"
      ],
      "@the-new-fuse/types/*": [
        "../types/*"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"],
  "references": [
    { "path": "../types" }
  ]
}

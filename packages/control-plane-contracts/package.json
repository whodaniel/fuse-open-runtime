{
  "name": "@the-new-fuse/control-plane-contracts",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./master-clock": {
      "types": "./dist/master-clock.d.ts",
      "default": "./dist/master-clock.js"
    },
    "./orchestrator": {
      "types": "./dist/orchestrator.d.ts",
      "default": "./dist/orchestrator.js"
    },
    "./prompt-composer": {
      "types": "./dist/prompt-composer.d.ts",
      "default": "./dist/prompt-composer.js"
    },
    "./shared-state": {
      "types": "./dist/shared-state.d.ts",
      "default": "./dist/shared-state.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prebuild": "rm -rf dist tsconfig.tsbuildinfo 2>/dev/null || true",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "prettier": "^3.7.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}

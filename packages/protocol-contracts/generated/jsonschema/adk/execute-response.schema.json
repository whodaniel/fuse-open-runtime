{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tnf.local/spec/adk/0.1/execute-response.schema.json",
  "title": "ExecuteResponse",
  "additionalProperties": false,
  "properties": {
    "latencyMs": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "metadata": {
      "additionalProperties": {},
      "default": {},
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "model": {
      "minLength": 1,
      "type": "string"
    },
    "output": {
      "additionalProperties": false,
      "properties": {
        "content": {
          "type": "string"
        },
        "parts": {
          "default": [],
          "items": {
            "additionalProperties": {},
            "propertyNames": {
              "type": "string"
            },
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "content",
        "parts"
      ],
      "type": "object"
    },
    "provider": {
      "minLength": 1,
      "type": "string"
    },
    "requestId": {
      "minLength": 1,
      "type": "string"
    },
    "status": {
      "enum": [
        "ok",
        "error"
      ],
      "type": "string"
    },
    "toolCalls": {
      "default": [],
      "items": {
        "additionalProperties": {},
        "propertyNames": {
          "type": "string"
        },
        "type": "object"
      },
      "type": "array"
    },
    "traceId": {
      "minLength": 1,
      "type": "string"
    },
    "usage": {
      "additionalProperties": false,
      "properties": {
        "inputTokens": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer"
        },
        "outputTokens": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer"
        },
        "totalTokens": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "inputTokens",
        "outputTokens",
        "totalTokens"
      ],
      "type": "object"
    }
  },
  "required": [
    "requestId",
    "traceId",
    "status",
    "output",
    "usage",
    "toolCalls",
    "latencyMs",
    "provider",
    "model",
    "metadata"
  ],
  "type": "object"
}

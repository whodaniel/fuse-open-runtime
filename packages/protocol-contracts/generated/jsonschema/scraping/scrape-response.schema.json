{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tnf.local/spec/scraping/0.1/scrape-response.schema.json",
  "title": "ScrapeResponse",
  "additionalProperties": false,
  "properties": {
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "markdown": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "success": {
      "type": "boolean"
    },
    "text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "title": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "url": {
      "format": "uri",
      "type": "string"
    }
  },
  "required": [
    "success",
    "url"
  ],
  "type": "object"
}

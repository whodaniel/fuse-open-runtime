{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tnf.local/spec/twip/0.1/twip-envelope.schema.json",
  "title": "TWIP Envelope",
  "additionalProperties": false,
  "properties": {
    "id": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "payload": {
      "anyOf": [
        {
          "additionalProperties": false,
          "properties": {
            "identity": {
              "additionalProperties": false,
              "properties": {
                "context_excerpt": {
                  "additionalProperties": false,
                  "properties": {
                    "captured_at": {
                      "format": "date-time",
                      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                      "type": "string"
                    },
                    "char_count": {
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer"
                    },
                    "line_count": {
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer"
                    },
                    "redaction_count": {
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer"
                    },
                    "source": {
                      "enum": [
                        "tmux-capture-pane",
                        "terminal-history"
                      ],
                      "type": "string"
                    },
                    "text": {
                      "type": "string"
                    },
                    "truncated": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "source",
                    "captured_at",
                    "line_count",
                    "char_count",
                    "redaction_count",
                    "truncated",
                    "text"
                  ],
                  "type": "object"
                },
                "created_at": {
                  "format": "date-time",
                  "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                  "type": "string"
                },
                "incarnation": {
                  "maximum": 9007199254740991,
                  "minimum": 0,
                  "type": "integer"
                },
                "labels": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "multiplexer": {
                  "anyOf": [
                    {
                      "additionalProperties": false,
                      "properties": {
                        "kind": {
                          "enum": [
                            "tmux",
                            "screen",
                            "none"
                          ],
                          "type": "string"
                        },
                        "pane_id": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "session_id": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "window_id": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        }
                      },
                      "required": [
                        "kind"
                      ],
                      "type": "object"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "process": {
                  "additionalProperties": false,
                  "properties": {
                    "pgid": {
                      "maximum": 9007199254740991,
                      "minimum": 1,
                      "type": "integer"
                    },
                    "shell_pid": {
                      "maximum": 9007199254740991,
                      "minimum": 1,
                      "type": "integer"
                    },
                    "sid": {
                      "maximum": 9007199254740991,
                      "minimum": 1,
                      "type": "integer"
                    }
                  },
                  "type": "object"
                },
                "provenance": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "confidence": {
                        "maximum": 1,
                        "minimum": 0,
                        "type": "number"
                      },
                      "key": {
                        "minLength": 1,
                        "type": "string"
                      },
                      "observed_at": {
                        "format": "date-time",
                        "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                        "type": "string"
                      },
                      "source": {
                        "enum": [
                          "kernel",
                          "process",
                          "env",
                          "multiplexer",
                          "gui",
                          "derived"
                        ],
                        "type": "string"
                      },
                      "value": {}
                    },
                    "required": [
                      "key",
                      "source",
                      "confidence",
                      "observed_at"
                    ],
                    "type": "object"
                  },
                  "minItems": 1,
                  "type": "array"
                },
                "pty": {
                  "additionalProperties": false,
                  "properties": {
                    "inode": {
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer"
                    },
                    "path": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "scope": {
                  "additionalProperties": false,
                  "properties": {
                    "emulator_id": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "host_id": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "pane_id": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "session_key": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "tab_id": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "tenant_id": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "window_id": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "required": [
                    "tenant_id",
                    "host_id",
                    "emulator_id"
                  ],
                  "type": "object"
                },
                "spec": {
                  "const": "twip/0.1",
                  "type": "string"
                },
                "twid": {
                  "format": "uuid",
                  "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                  "type": "string"
                }
              },
              "required": [
                "twid",
                "spec",
                "created_at",
                "scope",
                "provenance"
              ],
              "type": "object"
            }
          },
          "required": [
            "identity"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "twid": {
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "type": "string"
            }
          },
          "required": [
            "twid"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "retryable": {
              "type": "boolean"
            }
          },
          "required": [
            "code",
            "message"
          ],
          "type": "object"
        }
      ]
    },
    "policy": {
      "additionalProperties": false,
      "properties": {
        "allow_remote_propagation": {
          "type": "boolean"
        },
        "redact_gui_fields": {
          "type": "boolean"
        },
        "ttl_seconds": {
          "maximum": 3600,
          "minimum": 1,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "scope": {
      "additionalProperties": false,
      "properties": {
        "session_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "tenant_id": {
          "minLength": 1,
          "type": "string"
        },
        "workflow_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "tenant_id"
      ],
      "type": "object"
    },
    "sent_at": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "sig": {
      "type": "string"
    },
    "spec": {
      "const": "twip/0.1",
      "type": "string"
    },
    "trace": {
      "additionalProperties": false,
      "properties": {
        "causation_id": {
          "anyOf": [
            {
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "correlation_id": {
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "type": "string"
        }
      },
      "required": [
        "correlation_id",
        "causation_id"
      ],
      "type": "object"
    },
    "type": {
      "enum": [
        "IDENTITY.PUBLISH",
        "IDENTITY.RESOLVE",
        "IDENTITY.RESOLVE.RESULT",
        "IDENTITY.REVOKE",
        "CAPABILITY.REGISTER",
        "POLICY.DECISION",
        "ERROR"
      ],
      "type": "string"
    }
  },
  "required": [
    "id",
    "spec",
    "type",
    "sent_at",
    "scope",
    "trace",
    "payload"
  ],
  "type": "object"
}

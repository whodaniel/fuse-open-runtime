    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.38.0",
    "jest": "^30.2.0",
    "typescript": "^5.9.3",
    "rimraf": "^6.0.1"

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// RESOURCE REGISTRY SYSTEM
// =============================================================================

model Resource {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  category    ResourceCategory
  type        ResourceType
  content     Json     // Flexible content storage
  tags        String[] @default([])
  version     String   // Semantic version (e.g., "1.0.0")
  source      String   // Source identifier (file path, URL, repository)
  visibility  ResourceVisibility @default(PUBLIC)

  // Metadata
  author      String?
  authorId    String?  // Reference to user/agent who created it
  license     String?
  homepage    String?
  repository  String?

  // Search and discovery
  searchableText String?  @db.Text // Denormalized search data
  keywords    String[] @default([])

  // Usage tracking
  usageCount  Int      @default(0)
  downloadCount Int    @default(0)
  favoriteCount Int    @default(0)

  // Status and validation
  status      ResourceStatus @default(ACTIVE)
  isVerified  Boolean  @default(false)
  isFeatured  Boolean  @default(false)

  // Relationships
  dependencies String[] @default([]) // Array of resource IDs this depends on
  relatedResources String[] @default([]) // Array of related resource IDs

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
  deprecatedAt DateTime?
  deletedAt   DateTime?

  // Relationships
  versions    ResourceVersion[]
  metadata    ResourceMetadata?
  accessLogs  ResourceAccessLog[]

  @@index([category])
  @@index([type])
  @@index([visibility])
  @@index([status])
  @@index([authorId])
  @@index([createdAt])
  @@index([tags])
  @@index([keywords])
  @@fulltext([name, description, searchableText])
  @@map("resources")
}

model ResourceVersion {
  id          String   @id @default(uuid())
  resourceId  String
  version     String
  changelog   String?  @db.Text
  content     Json     // Version-specific content
  isLatest    Boolean  @default(false)
  isDraft     Boolean  @default(false)

  createdAt   DateTime @default(now())
  createdBy   String?

  // Relationships
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, version])
  @@index([resourceId])
  @@index([version])
  @@index([isLatest])
  @@map("resource_versions")
}

model ResourceMetadata {
  id         String @id @default(uuid())
  resourceId String @unique

  // Extended metadata
  metadata   Json   @default("{}")

  // Performance metrics
  performanceMetrics Json?

  // Quality scores
  qualityScore Float? // 0-100
  complexityScore Float?

  // Additional fields
  estimatedExecutionTime Int? // in milliseconds
  requiredDependencies String[] @default([])
  optionalDependencies String[] @default([])

  // Environment requirements
  minimumNodeVersion String?
  platforms String[] @default([])

  // Configuration
  configSchema Json? // JSON Schema for configuration

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@map("resource_metadata")
}

model ResourceAccessLog {
  id          String   @id @default(uuid())
  resourceId  String
  accessorId  String?  // User or Agent ID
  accessorType String  // 'user', 'agent', 'system'
  action      ResourceAction
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  timestamp   DateTime @default(now())

  // Relationships
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
  @@index([accessorId])
  @@index([action])
  @@index([timestamp])
  @@map("resource_access_logs")
}

// =============================================================================
// ENUMS
// =============================================================================

enum ResourceCategory {
  CLAUDE_SKILL        // Claude AI Skills
  N8N_WORKFLOW        // n8n Workflow templates
  AGENT_TEMPLATE      // Agent configuration templates
  CODE_SNIPPET        // Reusable code snippets
  DOCUMENTATION       // Documentation resources
  TOOL                // Tools and utilities
  INTEGRATION         // External integrations
  WORKFLOW_TEMPLATE   // Generic workflow templates
  API_ENDPOINT        // API endpoint definitions
  DATABASE_SCHEMA     // Database schema definitions
  UI_COMPONENT        // UI component templates
  CONFIGURATION       // Configuration files
  SCRIPT              // Automation scripts
  PROMPT_TEMPLATE     // LLM prompt templates
  DATA_SOURCE         // Data source connectors
}

enum ResourceType {
  // Code-based
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  SHELL
  SQL

  // Configuration
  JSON
  YAML
  TOML
  ENV

  // Documentation
  MARKDOWN
  HTML
  PDF

  // Workflows
  N8N_JSON
  ZAPIER_JSON
  MAKE_JSON

  // Templates
  TEMPLATE
  SNIPPET

  // API
  OPENAPI
  GRAPHQL
  REST

  // Other
  BINARY
  ARCHIVE
  CUSTOM
}

enum ResourceVisibility {
  PUBLIC          // Available to everyone
  AGENTS_ONLY     // Only AI agents can access
  PRIVATE         // Only creator/owner can access
  RESTRICTED      // Requires specific permissions
  INTERNAL        // Internal use only
}

enum ResourceStatus {
  DRAFT           // Still being worked on
  ACTIVE          // Published and available
  DEPRECATED      // Still available but discouraged
  ARCHIVED        // No longer active but kept for history
  DELETED         // Marked for deletion
  PENDING_REVIEW  // Awaiting verification
}

enum ResourceAction {
  VIEW
  DOWNLOAD
  EXECUTE
  UPDATE
  DELETE
  FORK
  FAVORITE
  SHARE
}

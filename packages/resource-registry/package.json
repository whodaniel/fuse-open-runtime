{
  "name": "@the-new-fuse/resource-registry",
  "version": "1.0.0",
  "description": "Comprehensive resource management system for The New Fuse - AI agents and humans",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.js",
      "default": "./dist/mcp/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:unit": "echo \"Tests temporarily disabled for this package\"",
    "test:integration": "echo \"Tests temporarily disabled for this package\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist coverage test-results *.tsbuildinfo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^11.1.16",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/swagger": "^7.1.17",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "semver": "^7.6.3",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/semver": "^7.5.8",
    "@types/uuid": "^11.0.0",
    "jest": "^30.3.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "resource-registry",
    "resource-management",
    "ai-agents",
    "claude-skills",
    "n8n-workflows",
    "code-snippets",
    "documentation",
    "tools",
    "integrations",
    "mcp",
    "the-new-fuse"
  ],
  "license": "MIT",
  "homepage": "https://github.com/the-new-fuse/resource-registry#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-new-fuse/the-new-fuse.git",
    "directory": "packages/resource-registry"
  },
  "bugs": {
    "url": "https://github.com/the-new-fuse/the-new-fuse/issues"
  },
  "author": {
    "name": "The New Fuse Team",
    "url": "https://github.com/the-new-fuse"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

{
  "name": "@the-new-fuse/proto-definitions",
  "version": "0.1.0",
  "description": "Protocol Buffer definitions for The New Fuse internal services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "bun@1.0.0",
  "scripts": {
    "build": "bun run generate && tsc",
    "generate": "bun run proto:generate",
    "proto:generate": "mkdir -p ./src/generated && grpc_tools_node_protoc --plugin=protoc-gen-ts=../../node_modules/.bin/protoc-gen-ts --js_out=import_style=commonjs,binary:./src/generated --ts_out=grpc_js:./src/generated --grpc_out=grpc_js:./src/generated -I ./proto ./proto/*.proto",
    "dev": "bun run generate && tsc --watch",
    "clean": "rimraf dist src/generated",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "files": [
    "dist/",
    "proto/"
  ],
  "dependencies": {
    "@grpc/grpc-js": "^1.10.6",
    "@grpc/proto-loader": "^0.7.10",
    "google-protobuf": "^3.21.2"
  },
  "devDependencies": {
    "@types/google-protobuf": "^3.15.12",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "grpc-tools": "^1.12.4",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "jest": "^29.5.0",
    "protoc-gen-ts": "^0.8.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
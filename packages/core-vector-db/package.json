{
  "name": "@the-new-fuse/core-vector-db",
  "version": "0.1.0",
  "description": "Core Vector Database Service with gRPC and MCP interfaces",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/main.js",
    "start:grpc": "node dist/main.js",
    "dev:grpc": "bun run build && bun run start:grpc",
    "test": "echo \"No tests found for @the-new-fuse/core-vector-db\" && exit 0",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@grpc/grpc-js": "^1.10.6",
    "@grpc/proto-loader": "^0.7.10",
    "@modelcontextprotocol/sdk": "^0.6.0",
    "@qdrant/js-client-rest": "^1.8.2",
    "chroma-js": "^3.1.1",
    "openai": "^4.67.3",
    "pg": "^8.13.3",
    "pgvector": "^0.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "winston": "^3.17.0",
    "zod": "^3.25.55"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.5.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@the-new-fuse/types": "workspace:*",
    "@the-new-fuse/proto-definitions": "workspace:*"

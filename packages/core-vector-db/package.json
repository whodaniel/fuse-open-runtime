{
  "name": "@the-new-fuse/core-vector-db",
  "version": "0.1.0",
  "description": "Core Vector Database Service with gRPC and MCP interfaces",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/main.js",
    "start:grpc": "node dist/main.js",
    "dev:grpc": "pnpm run build && pnpm run start:grpc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "@nestjs/common": "^11.1.10",
    "@nestjs/core": "^11.1.10",
    "@nestjs/microservices": "^11.1.10",
    "@qdrant/js-client-rest": "^1.15.1",
    "@the-new-fuse/database": "workspace:*",
    "chroma-js": "^3.1.2",
    "openai": "^6.5.0",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "winston": "^3.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/pg": "^8.15.5",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.38.0",
    "jest": "^30.2.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  },
  "peerDependencies": {
    "@the-new-fuse/proto-definitions": "workspace:*",
    "@the-new-fuse/types": "workspace:*"
  }
}

{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "target": "es2020",
    "module": "ESNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "composite": true,
    "declaration": true
  },
  "include": ["./test", "./scripts", "./hardhat.config.js"],
  "exclude": ["node_modules"]
}

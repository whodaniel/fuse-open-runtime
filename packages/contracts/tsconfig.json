{
  "compilerOptions": {
    "moduleResolution": "NodeNext",
    "target": "es2020",
    "module": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "declaration": false,
    "noEmit": true
  },
  "include": ["./scripts/**/*.ts", "./test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

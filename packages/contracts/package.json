{
  "name": "@the-new-fuse/contracts",
  "version": "1.0.0",
  "description": "Smart contracts for The New Fuse decentralized agent ecosystem",
  "main": "src/index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.js",
    "deploy:merkaba": "hardhat run scripts/deploy_merkaba.js --network localhost",
    "verify": "hardhat verify",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "keywords": [
    "blockchain",
    "smart-contracts",
    "NFT",
    "agents",
    "ERC721",
    "ERC6551",
    "decentralized"
  ],
  "author": "The New Fuse Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@openzeppelin/contracts": "^5.4.0",
    "@solvprotocol/erc-3525": "^1.5.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.3",
    "chai": "^6.2.0",
    "ethers": "^6.15.0",
    "hardhat": "^2.26.2",
    "hardhat-gas-reporter": "^2.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}

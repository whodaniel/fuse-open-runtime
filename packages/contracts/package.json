{
  "name": "@the-new-fuse/contracts",
  "files": [
    "dist",
    "src"
  ],
  "version": "1.0.0",
  "description": "Smart contracts for The New Fuse decentralized agent ecosystem",
  "main": "src/index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "node scripts/test-wrapper.cjs",
    "deploy": "hardhat run scripts/deploy.js",
    "deploy:merkaba": "hardhat run scripts/deploy_merkaba.js --network localhost",
    "deploy:sidepot-router": "hardhat run scripts/deploy_sidepot_router.js --network localhost",
    "verify": "hardhat verify",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "hardhat compile 2>/dev/null || tsc --noEmit --skipLibCheck || echo 'contracts: build ok (solidity-only package)'"
  },
  "keywords": [
    "blockchain",
    "smart-contracts",
    "NFT",
    "agents",
    "ERC721",
    "ERC6551",
    "decentralized"
  ],
  "author": "The New Fuse Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@openzeppelin/contracts": "^5.4.0",
    "@solvprotocol/erc-3525": "^1.5.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.3",
    "@types/uuid": "^10.0.0",
    "chai": "^6.2.0",
    "ethers": "^6.15.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "types": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.js",
      "default": "./src/index.js",
      "types": "./src/index.js"
    },
    "./package.json": "./package.json",
    "./*": "./src/*"
  }
}

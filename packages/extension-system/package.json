{
  "name": "@the-new-fuse/extension-system",
  "version": "1.0.0",
  "description": "Unified Extension System for The New Fuse Framework - Consolidates modules, plugins, and extensions",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/ExtensionTypes.js",
      "require": "./dist/types/ExtensionTypes.js",
      "types": "./dist/types/ExtensionTypes.d.ts"
    },
    "./loader": {
      "import": "./dist/loader/ExtensionLoader.js",
      "require": "./dist/loader/ExtensionLoader.js",
      "types": "./dist/loader/ExtensionLoader.d.ts"
    },
    "./manager": {
      "import": "./dist/manager/ExtensionManager.js",
      "require": "./dist/manager/ExtensionManager.js",
      "types": "./dist/manager/ExtensionManager.d.ts"
    },
    "./registry": {
      "import": "./dist/registry/ExtensionRegistry.js",
      "require": "./dist/registry/ExtensionRegistry.js",
      "types": "./dist/registry/ExtensionRegistry.d.ts"
    },
    "./validator": {
      "import": "./dist/validator/ExtensionValidator.js",
      "require": "./dist/validator/ExtensionValidator.js",
      "types": "./dist/validator/ExtensionValidator.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "extensions",
    "plugins",
    "modules",
    "architecture",
    "the-new-fuse",
    "typescript"
  ],
  "author": "The New Fuse Team",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@prisma/client": "^6.10.1",
    "events": "^3.3.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.0",
    "semver": "^7.5.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.8",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.10.0",
    "@types/semver": "^7.5.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@tnf/relay-core": "^1.0.0",
    "@the-new-fuse/workflow-engine": "^1.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-new-fuse/framework.git",
    "directory": "packages/extension-system"
  },
  "bugs": {
    "url": "https://github.com/the-new-fuse/framework/issues"
  },
  "homepage": "https://github.com/the-new-fuse/framework/tree/main/packages/extension-system#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "volta": {
    "node": "18.19.0",
    "npm": "10.2.3"
  }
}
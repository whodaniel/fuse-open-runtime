{
  "name": "@the-new-fuse/extension-system",
  "version": "1.0.0",
  "description": "Unified Extension System for The New Fuse Framework - Consolidates modules, plugins, and extensions",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/ExtensionTypes.js",
      "require": "./dist/types/ExtensionTypes.js",
      "types": "./dist/types/ExtensionTypes.d.ts"
    },
    "./loader": {
      "import": "./dist/loader/ExtensionLoader.js",
      "require": "./dist/loader/ExtensionLoader.js",
      "types": "./dist/loader/ExtensionLoader.d.ts"
    },
    "./manager": {
      "import": "./dist/manager/ExtensionManager.js",
      "require": "./dist/manager/ExtensionManager.js",
      "types": "./dist/manager/ExtensionManager.d.ts"
    },
    "./registry": {
      "import": "./dist/registry/ExtensionRegistry.js",
      "require": "./dist/registry/ExtensionRegistry.js",
      "types": "./dist/registry/ExtensionRegistry.d.ts"
    },
    "./validator": {
      "import": "./dist/validator/ExtensionValidator.js",
      "require": "./dist/validator/ExtensionValidator.js",
      "types": "./dist/validator/ExtensionValidator.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "keywords": [
    "extensions",
    "plugins",
    "modules",
    "architecture",
    "the-new-fuse",
    "typescript"
  ],
  "author": "The New Fuse Team",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@the-new-fuse/relay-core": "workspace:*",
    "events": "^3.3.0",
    "fs-extra": "^11.3.2",
    "glob": "^11.0.3",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.38.0",
    "jest": "^30.3.0",
    "minimatch": "10.2.4",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@the-new-fuse/relay-core": "workspace:*"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-new-fuse/framework.git",
    "directory": "packages/extension-system"
  },
  "bugs": {
    "url": "https://github.com/the-new-fuse/framework/issues"
  },
  "homepage": "https://github.com/the-new-fuse/framework/tree/main/packages/extension-system#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "volta": {
    "node": "18.19.0",
    "npm": "10.2.3"
  }
}

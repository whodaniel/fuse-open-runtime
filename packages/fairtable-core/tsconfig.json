{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "noEmit": false,
    "types": ["jest"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "paths": {
      "@the-new-fuse/fairtable-core": ["./dist"],
      "@the-new-fuse/fairtable-components": ["../fairtable-components/dist"],
      "@the-new-fuse/fairtable-utils": ["../fairtable-utils/dist"],
      "@the-new-fuse/hooks-types": ["../hooks/src/types"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}

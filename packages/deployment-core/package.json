{
  "name": "@the-new-fuse/deployment-core",
  "files": [
    "dist"
  ],
  "version": "1.0.0",
  "description": "Core deployment and CI/CD pipeline functionality",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc --watch",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@the-new-fuse/types": "workspace:*",
    "@the-new-fuse/core": "workspace:*",
    "yaml": "^2.8.1",
    "zod": "^4.1.12",
    "winston": "^3.18.3",
    "node-cron": "^4.2.1",
    "axios": "^1.15.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "eslint": "^9.38.0",
    "jest": "^30.3.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}

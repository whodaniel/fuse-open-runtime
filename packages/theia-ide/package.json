{
  "name": "@the-new-fuse/theia-ide",
  "version": "2.0.0",
  "description": "Modern Theia IDE with full bells and whistles for The New Fuse platform",
  "private": true,
  "main": "lib/backend/main.js",
  "scripts": {
    "build": "theia build --mode production",
    "build:dev": "theia build",
    "build:optimized": "NODE_OPTIONS=--max_old_space_size=6144 theia build --mode production --stats-error-details",
    "start": "theia start --hostname=0.0.0.0 --port=3007",
    "start:production": "NODE_ENV=production theia start --hostname=0.0.0.0 --port=3007",
    "dev": "theia start --hostname=0.0.0.0 --port=3007",
    "watch": "concurrently -n compile,bundle \"theiacli watch --mode development\"",
    "clean": "theia clean && rimraf lib dist node_modules/.cache",
    "rebuild": "pnpm run clean && pnpm install && pnpm run build",
    "theia": "theia",
    "health": "curl -f http://localhost:3007 || exit 1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.1",
    "@the-new-fuse/mcp-core": "workspace:*",
    "@theia/ai-anthropic": "1.65.2",
    "@theia/ai-chat": "1.65.2",
    "@theia/ai-core": "1.65.2",
    "@theia/ai-huggingface": "1.65.2",
    "@theia/ai-ollama": "1.65.2",
    "@theia/ai-openai": "1.65.2",
    "@theia/core": "1.65.2",
    "@theia/debug": "1.65.2",
    "@theia/editor": "1.65.2",
    "@theia/filesystem": "1.65.2",
    "@theia/getting-started": "1.65.2",
    "@theia/markers": "1.65.2",
    "@theia/messages": "1.65.2",
    "@theia/monaco": "1.65.2",
    "@theia/navigator": "1.65.2",
    "@theia/outline-view": "1.65.2",
    "@theia/output": "1.65.2",
    "@theia/plugin-ext": "1.65.2",
    "@theia/plugin-ext-vscode": "1.65.2",
    "@theia/preferences": "1.65.2",
    "@theia/scm": "1.65.2",
    "@theia/search-in-workspace": "1.65.2",
    "@theia/terminal": "1.65.2",
    "@theia/toolbar": "1.65.2",
    "@theia/vsx-registry": "1.65.2",
    "@theia/workspace": "1.65.2",
    "express": "^5.1.0",
    "find-git-repositories": "^0.2.2",
    "http-proxy-middleware": "^3.0.5",
    "ws": "^8.18.3",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@theia/cli": "1.65.2",
    "@theia/electron": "1.65.2",
    "concurrently": "^9.2.1",
    "rimraf": "^6.0.1",
    "css-loader": "^6.11.0",
    "source-map-loader": "^4.0.2",
    "style-loader": "^3.3.4",
    "node-loader": "^2.0.0",
    "umd-compat-loader": "^2.1.2"
  }
}
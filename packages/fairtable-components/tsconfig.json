{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "composite": true,
    "incremental": true,
    "noEmit": false,
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "***.test.tsx", "**/*.spec.tsx"],
  "references": [
    {
      "path": "../fairtable-core"
    },
    {
      "path": "../fairtable-utils"
    }
  ]
}

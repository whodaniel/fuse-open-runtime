{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2017"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "incremental": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@the-new-fuse/fairtable-core": ["./fairtable-core/dist"],
      "@the-new-fuse/fairtable-components": ["./fairtable-components/dist"],
      "@the-new-fuse/fairtable-utils": ["./fairtable-utils/dist"],
      "@the-new-fuse/hooks-types": ["./hooks/src/types"]
    }
  },
  "include": [],
  "exclude": ["node_modules", "dist"]
}

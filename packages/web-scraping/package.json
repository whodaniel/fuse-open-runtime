    "url-parse": "^1.5.10",
    "mime-types": "^2.1.35",
    "@nestjs/common": "^11.1.6",
    "@nestjs/websockets": "^11.0.0",
    "socket.io": "^4.7.5",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@types/url-parse": "^1.4.11",
    "@types/mime-types": "^2.1.4",
    "typescript": "^5.8.3",
    "vitest": "^1.6.0",

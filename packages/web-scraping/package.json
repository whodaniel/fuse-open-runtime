{
  "name": "@the-new-fuse/web-scraping",
  "version": "1.0.0",
  "description": "Web scraping and proxy tools for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/websockets": "^11.1.16",
    "@the-new-fuse/ap2-protocol": "workspace:^",
    "@the-new-fuse/mcp-core": "workspace:^",
    "@the-new-fuse/utils": "workspace:^",
    "axios": "^1.13.5",
    "cheerio": "^1.0.0-rc.12",
    "mime-types": "^2.1.35",
    "node-fetch": "^3.3.2",
    "puppeteer": "^22.0.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "url-parse": "^1.5.10"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^24.0.13",
    "@types/url-parse": "^1.4.11",
    "eslint": "^8.57.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}

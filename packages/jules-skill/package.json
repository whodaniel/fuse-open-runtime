{
  "name": "@the-new-fuse/jules-skill",
  "files": [
    "dist"
  ],
  "version": "0.1.0",
  "description": "Jules CLI integration skill for AI agent delegation - Enables agents to delegate coding tasks to Google Jules",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "mcp:start": "node dist/mcp-server.js",
    "mcp:dev": "ts-node src/mcp-server.ts",
    "test": "echo \"No tests for this package\" && exit 0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "execa": "^9.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "jules",
    "google",
    "ai-agent",
    "mcp",
    "delegation",
    "coding-agent"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json",
    "./*": "./dist/*"
  }
}

{
  "name": "@the-new-fuse/agent-coordination",
  "files": [
    "dist"
  ],
  "version": "1.0.0",
  "description": "Redis-based agent-to-agent communication and coordination system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:unit": "jest --testPathPatterns=unit --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.2",
    "@the-new-fuse/a2a-core": "workspace:^",
    "@the-new-fuse/infrastructure": "workspace:*",
    "bullmq": "^5.34.2",
    "ioredis": "^5.8.1",
    "msgpack-lite": "^0.1.26",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/msgpack-lite": "^0.1.11",
    "@types/node": "^24.8.1",
    "@types/uuid": "^11.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}

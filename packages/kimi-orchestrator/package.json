{
  "name": "@the-new-fuse/kimi-orchestrator",
  "version": "1.0.0",
  "description": "Orchestrator for managing 100 parallel KIMI k2.5 agents in The New Fuse ecosystem",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kimi-orchestrator": "./dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "mcp-server": "node dist/mcp-server.js",
    "mcp-server:dev": "ts-node src/mcp-server.ts",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@the-new-fuse/relay-core": "workspace:*",
    "@the-new-fuse/types": "workspace:*",
    "@the-new-fuse/utils": "workspace:*",
    "ws": "^8.18.3",
    "ioredis": "^5.8.1",
    "uuid": "^9.0.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1",
    "@types/ioredis": "^5.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "orchestrator",
    "multi-agent",
    "kimi",
    "ai-agents",
    "tnf",
    "the-new-fuse"
  ],
  "author": "The New Fuse Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-new-fuse/tnf.git",
    "directory": "packages/kimi-orchestrator"
  }
}

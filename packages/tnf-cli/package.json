{
  "name": "@the-new-fuse/tnf-cli",
  "files": [
    "dist"
  ],
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TNF Agent CLI - Unified Command Surface for TNF Operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tnf": "./dist/cli.js",
    "tnf-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist .turbo .tsbuildinfo tsconfig.tsbuildinfo",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"No tests for this package\" && exit 0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@the-new-fuse/infrastructure": "workspace:*",
    "@the-new-fuse/tnf-note-taking": "workspace:*",
    "@the-new-fuse/tnf-core": "workspace:*",
    "@upstash/redis": "^1.37.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ioredis": "^5.8.2",
    "minimatch": "^10.0.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.14",
    "rimraf": "^5.0.10",
    "tsx": "^4.20.3",
    "typescript": "^6.0.2"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json",
    "./*": "./dist/*"
  }
}

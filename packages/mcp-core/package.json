{
  "name": "@the-new-fuse/mcp-core",
  "files": ["dist"],
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) core implementation for The New Fuse",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./broker": {
      "types": "./dist/broker/index.d.ts",
      "import": "./dist/broker/index.js",
      "require": "./dist/broker/index.js",
      "default": "./dist/broker/index.js"
    },
    "./handlers": {
      "types": "./dist/handlers/index.d.ts",
      "import": "./dist/handlers/index.js",
      "require": "./dist/handlers/index.js",
      "default": "./dist/handlers/index.js"
    },
    "./factory": {
      "types": "./dist/factory/index.d.ts",
      "import": "./dist/factory/index.js",
      "require": "./dist/factory/index.js",
      "default": "./dist/factory/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./monitoring": {
      "types": "./dist/monitoring/index.d.ts",
      "import": "./dist/monitoring/index.js",
      "require": "./dist/monitoring/index.js",
      "default": "./dist/monitoring/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "build:production": "NODE_ENV=production tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist coverage test-results *.tsbuildinfo tsconfig.tsbuildinfo",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:performance": "jest --testPathPatterns=performance --passWithNoTests",
    "test:integration": "jest --testPathPatterns=integration --passWithNoTests",
    "test:unit": "jest --testPathIgnorePatterns=integration|performance --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docs:generate": "typedoc src/index.ts --out docs/api --theme default",
    "prepublishOnly": "npm run clean && npm run build && npm run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@the-new-fuse/core-error-handling": "workspace:*",
    "@the-new-fuse/core-monitoring": "workspace:*",
    "ajv": "^8.18.0",
    "eventemitter3": "^5.0.1",
    "p-retry": "^7.1.0",
    "p-timeout": "^7.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.38.0",
    "globals": "^17.3.0",
    "jest": "^30.3.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.9",
    "typedoc": "^0.28.14",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "optionalDependencies": {
    "@the-new-fuse/relay-core": "workspace:*",
    "@the-new-fuse/types": "workspace:*"
  },
  "files": [
    "dist",
    "README.md",
    "docs/API_REFERENCE.md",
    "docs/EXAMPLES.md",
    "docs/MCP_CORE_TROUBLESHOOTING.md",
    "docs/DEVELOPER_GUIDE.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "communication",
    "rpc",
    "websockets",
    "typescript",
    "the-new-fuse"
  ],
  "license": "MIT",
  "homepage": "https://github.com/the-new-fuse/mcp-core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-new-fuse/the-new-fuse.git",
    "directory": "packages/mcp-core"
  },
  "bugs": {
    "url": "https://github.com/the-new-fuse/the-new-fuse/issues"
  },
  "author": {
    "name": "The New Fuse Team",
  "files": ["dist"],
    "url": "https://github.com/the-new-fuse"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}

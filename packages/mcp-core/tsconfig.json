{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@the-new-fuse/core-monitoring": ["../core-monitoring/dist/index.d.ts"],
      "@the-new-fuse/core-error-handling": ["../core-error-handling/dist/index.d.ts"],
      "@the-new-fuse/types": ["../types/src"],
      "@the-new-fuse/relay-core": ["../relay-core/src"]
    },
    "isolatedModules": true,
    "downlevelIteration": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.js",
    "**/*.spec.js",
    "**/*.integration.test.js",
    "**/*.js"
  ]
}

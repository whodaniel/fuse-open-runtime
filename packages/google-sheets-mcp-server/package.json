{
  "name": "@the-new-fuse/google-sheets-mcp-server",
  "files": [
    "dist"
  ],
  "version": "1.0.0",
  "description": "MCP server for Google Sheets integration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "echo \"No tests for this package\" && exit 0"
  },
  "dependencies": {
    "@the-new-fuse/mcp-core": "workspace:*",
    "google-auth-library": "^10.5.0",
    "googleapis": "^144.0.0",
    "node-forge": "^1.3.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json",
    "./*": "./dist/*"
  }

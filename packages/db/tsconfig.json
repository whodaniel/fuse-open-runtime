{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false, // Override "noEmit": true from base config to allow building
    "composite": true, // Essential for project references in a monorepo
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "tsBuildInfoFile": "./.tsbuildinfo"
    // Paths are usually defined in base, but can be overridden/extended here if needed
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
{
  "name": "@the-new-fuse/hooks",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --skipLibCheck --noEmitOnError false || echo 'Build completed with warnings'",
    "clean": "rimraf dist",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@the-new-fuse/api-client": "workspace:*",
    "@the-new-fuse/fairtable-core": "workspace:*",
    "@the-new-fuse/types": "workspace:*",
    "react": "^19.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "jest": "^30.2.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}

{
  "name": "@the-new-fuse/features",
  "files": ["dist"],
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./ui/wizard": {
      "types": "./ui/wizard/index.ts",
      "import": "./ui/wizard/index.ts",
      "require": "./ui/wizard/index.ts"
    },
    "./ui/*": {
      "types": "./ui/*/index.ts",
      "import": "./ui/*/index.ts",
      "require": "./ui/*/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist lib build coverage test-results playwright-report .tsbuildinfo tsconfig.tsbuildinfo",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.3",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@the-new-fuse/types": "workspace:*",
    "@types/react": "^19.2.3"
  }
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "target": "ES2020",
    "module": "CommonJS",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "jsx": "react-jsx",
    "declaration": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@the-new-fuse/*": ["../../packages/*"]
    },
    "types": ["jest", "node"],
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules", 
    "dist", 
    "coverage"
  ],
  "references": [
    { "path": "../extension-system" },
    { "path": "../core" },
    { "path": "../utils" },
    { "path": "../types" }
  ]
}
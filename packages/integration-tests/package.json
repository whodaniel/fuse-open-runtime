{
  "name": "@the-new-fuse/integration-tests",
  "version": "1.0.0",
  "description": "Comprehensive integration tests for The New Fuse unified framework",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:performance": "jest --testPathPattern=performance",
    "test:workflow-builder": "jest --testPathPattern=workflow-builder",
    "test:workflow-builder:watch": "jest --testPathPattern=workflow-builder --watch",
    "test:workflow-builder:coverage": "jest --testPathPattern=workflow-builder --coverage",
    "test:all": "jest && pnpm run test:workflow-builder",
    "build": "tsc --skipLibCheck --noEmitOnError false || echo 'Integration tests build completed with warnings'",
    "clean": "rimraf dist coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@the-new-fuse/relay-core": "workspace:*",
    "@the-new-fuse/extension-system": "workspace:*",
    "@prisma/client": "^7.1.0",
    "redis": "^5.8.3",
    "fs-extra": "^11.3.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/fs-extra": "^11.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.38.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "framer-motion": "^12.23.24",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx"
    ],
    "globals": {
      "ts-jest": {
        "useESM": true,
        "tsconfig": "tsconfig.json"
      }
    },
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@the-new-fuse|react-dnd|react-dnd-html5-backend)/)"
    ],
    "moduleNameMapper": {
      "^@the-new-fuse/(.*)$": "<rootDir>/../../packages/$1/src"
    },
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/__tests__/**/*.tsx",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/*.spec.tsx"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts",
      "!src/**/*.spec.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testTimeout": 60000,
    "setupFilesAfterEnv": [
      "<rootDir>/src/setup/test-setup.ts"
    ]
  },
  "keywords": [
    "integration-tests",
    "testing",
    "the-new-fuse",
    "framework",
    "typescript"
  ],
  "author": "The New Fuse Team",
  "license": "MIT"
}

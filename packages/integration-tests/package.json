{
  "name": "@the-new-fuse/integration-tests",
  "version": "1.0.0",
  "description": "Comprehensive integration tests for The New Fuse unified framework",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:performance": "jest --testPathPattern=performance",
    "test:workflow-builder": "jest --testPathPattern=workflow-builder",
    "test:workflow-builder:watch": "jest --testPathPattern=workflow-builder --watch",
    "test:workflow-builder:coverage": "jest --testPathPattern=workflow-builder --coverage",
    "test:all": "jest && npm run test:workflow-builder",
    "build": "tsc --skipLibCheck --noEmitOnError false || echo 'Integration tests build completed with warnings'",
    "clean": "rimraf dist coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@tnf/relay-core": "workspace:*",
    "@the-new-fuse/workflow-engine": "workspace:*",
    "@the-new-fuse/extension-system": "workspace:*",
    "@prisma/client": "^6.17.1",
    "redis": "^5.8.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "framer-motion": "^12.23.24",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts",
      "**/*.spec.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts",
      "!src/**/*.spec.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "testTimeout": 60000,
    "setupFilesAfterEnv": ["<rootDir>/src/setup/test-setup.ts"]
  },
  "keywords": [
    "integration-tests",
    "testing",
    "the-new-fuse",
    "framework",
    "typescript"
  ],
  "author": "The New Fuse Team",
  "license": "MIT"
}
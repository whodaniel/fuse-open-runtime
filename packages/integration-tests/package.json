{
  "name": "@the-new-fuse/integration-tests",
  "version": "1.0.0",
  "description": "Comprehensive integration tests for The New Fuse unified framework",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:performance": "jest --testPathPattern=performance",
    "test:workflow-builder": "jest --testPathPattern=workflow-builder",
    "test:workflow-builder:watch": "jest --testPathPattern=workflow-builder --watch",
    "test:workflow-builder:coverage": "jest --testPathPattern=workflow-builder --coverage",
    "test:all": "jest && npm run test:workflow-builder",
    "build": "tsc --skipLibCheck --noEmitOnError false || echo 'Integration tests build completed with warnings'",
    "clean": "rimraf dist coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@tnf/relay-core": "^1.0.0",
    "@the-new-fuse/workflow-engine": "^1.0.0",
    "@the-new-fuse/extension-system": "^1.0.0",
    "@prisma/client": "^6.10.1",
    "redis": "^4.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "@chakra-ui/react": "^2.8.0",
    "framer-motion": "^10.16.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts",
      "**/*.spec.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts",
      "!src/**/*.spec.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "testTimeout": 60000,
    "setupFilesAfterEnv": ["<rootDir>/src/setup/test-setup.ts"]
  },
  "keywords": [
    "integration-tests",
    "testing",
    "the-new-fuse",
    "framework",
    "typescript"
  ],
  "author": "The New Fuse Team",
  "license": "MIT"
}
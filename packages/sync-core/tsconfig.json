{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "examples"
  ],
  "references": [
    {
      "path": "../types"
    },
    {
      "path": "../core"
    },
    {
      "path": "../infrastructure"
    },
    {
      "path": "../prompt-templating"
    },
    {
      "path": "../database"
    }
  ]
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.example.ts",
    "examples",
    "src/dashboard/**/*",
    "src/monitoring/**/*",
    "src/deployment/**/*",
    "src/server.ts",
    "src/messaging/**/*",
    "src/handoff/**/*",
    "src/tasks/**/*",
    "src/error/**/*",
    "src/services/ConflictManager.ts",
    "src/cms/**/*"
  ],
  "references": [
    {
      "path": "../types"
    },
    {
      "path": "../core"
    },
    {
      "path": "../infrastructure"
    },
    {
      "path": "../prompt-templating"
    },
    {
      "path": "../database"
    }
  ]
}

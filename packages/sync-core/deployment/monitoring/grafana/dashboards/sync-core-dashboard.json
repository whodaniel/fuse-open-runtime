{
  "dashboard": {
    "id": null,
    "title": "Sync Core Monitoring Dashboard",
    "tags": ["sync-core", "monitoring"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Service Health Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"sync-core\"}",
            "legendFormat": "Service Status"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "green", "value": 1 }
              ]
            },
            "mappings": [
              { "options": { "0": { "text": "Down" } }, "type": "value" },
              { "options": { "1": { "text": "Up" } }, "type": "value" }
            ]
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Sync Operations Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(sync_operations_total[5m])",
            "legendFormat": "Operations/sec"
          }
        ],
        "yAxes": [{ "label": "Operations per second", "min": 0 }],
        "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 }
      },
      {
        "id": 3,
        "title": "Sync Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(sync_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "50th percentile"
          },
          {
            "expr": "histogram_quantile(0.95, rate(sync_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.99, rate(sync_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "99th percentile"
          }
        ],
        "yAxes": [{ "label": "Seconds", "min": 0 }],
        "gridPos": { "h": 8, "w": 12, "x": 18, "y": 0 }
      },
      {
        "id": 4,
        "title": "Queue Size",
        "type": "graph",
        "targets": [
          {
            "expr": "sync_queue_size",
            "legendFormat": "Queue Size"
          }
        ],
        "yAxes": [{ "label": "Items", "min": 0 }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "id": 5,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(sync_errors_total[5m])",
            "legendFormat": "Errors/sec"
          }
        ],
        "yAxes": [{ "label": "Errors per second", "min": 0 }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      },
      {
        "id": 6,
        "title": "Conflict Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(sync_conflicts_total[5m])",
            "legendFormat": "Conflicts/sec"
          },
          {
            "expr": "sync_unresolved_conflicts",
            "legendFormat": "Unresolved Conflicts"
          }
        ],
        "yAxes": [{ "label": "Count", "min": 0 }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
      },
      {
        "id": 7,
        "title": "File Watcher Metrics",
        "type": "graph",
        "targets": [
          {
            "expr": "file_watcher_events_per_second",
            "legendFormat": "Events/sec"
          },
          {
            "expr": "file_watcher_watched_paths",
            "legendFormat": "Watched Paths"
          }
        ],
        "yAxes": [{ "label": "Count", "min": 0 }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
      },
      {
        "id": 8,
        "title": "Master Clock Drift",
        "type": "graph",
        "targets": [
          {
            "expr": "master_clock_drift_ms",
            "legendFormat": "Clock Drift (ms)"
          }
        ],
        "yAxes": [{ "label": "Milliseconds", "min": 0 }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }
      },
      {
        "id": 9,
        "title": "Resource Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "sync_memory_usage_ratio * 100",
            "legendFormat": "Memory Usage %"
          },
          {
            "expr": "sync_cpu_usage_ratio * 100",
            "legendFormat": "CPU Usage %"
          }
        ],
        "yAxes": [{ "label": "Percentage", "min": 0, "max": 100 }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 }
      },
      {
        "id": 10,
        "title": "Database Metrics",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(sync_database_query_duration_seconds_bucket[5m]))",
            "legendFormat": "Query Latency (95th)"
          },
          {
            "expr": "sync_database_active_connections",
            "legendFormat": "Active Connections"
          }
        ],
        "yAxes": [{ "label": "Seconds / Count", "min": 0 }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 }
      },
      {
        "id": 11,
        "title": "Redis Metrics",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(sync_redis_command_duration_seconds_bucket[5m]))",
            "legendFormat": "Command Latency (95th)"
          },
          {
            "expr": "sync_redis_active_connections",
            "legendFormat": "Active Connections"
          }
        ],
        "yAxes": [{ "label": "Seconds / Count", "min": 0 }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 }
      }
    ]
  }
}

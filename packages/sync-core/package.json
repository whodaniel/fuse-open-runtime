{
  "name": "@the-new-fuse/sync-core",
  "files": [
    "dist"
  ],
  "version": "0.1.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "start": "node dist/server.js",
    "start:dev": "tsx watch src/server.ts",
    "test": "echo \"Tests temporarily disabled for this package\"",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathIgnorePatterns=integration --passWithNoTests",
    "test:integration": "jest --testPathPatterns=integration --passWithNoTests",
    "test:performance": "jest --testPathPatterns=PerformanceIntegration --passWithNoTests",
    "test:security": "jest --testPathPatterns=SecurityIntegration --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:all": "npm run test:unit && npm run test:integration",
    "deploy": "bash deployment/scripts/deploy-sync-system.sh",
    "deploy:docker": "bash deployment/scripts/deploy-sync-system.sh --mode docker",
    "deploy:k8s": "bash deployment/scripts/deploy-sync-system.sh --mode k8s",
    "deploy:cleanup": "bash deployment/scripts/deploy-sync-system.sh --cleanup",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^11.1.16",
    "@nestjs/event-emitter": "^2.0.3",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/terminus": "^10.2.3",
    "@the-new-fuse/core-error-handling": "workspace:*",
    "@the-new-fuse/core-monitoring": "workspace:*",
    "@the-new-fuse/database": "workspace:*",
    "@the-new-fuse/infrastructure": "workspace:*",
    "@the-new-fuse/prompt-templating": "workspace:*",
    "chokidar": "^3.6.0",
    "express": "^4.22.0",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.4.9",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3"
  }
}

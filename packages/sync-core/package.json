{
  "name": "@the-new-fuse/sync-core",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "start": "node dist/server.js",
    "start:dev": "tsx watch src/server.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:unit": "vitest --run --exclude='src/integration/**'",
    "test:integration": "vitest --run src/integration/",
    "test:performance": "vitest --run src/integration/PerformanceIntegration.test.ts",
    "test:security": "vitest --run src/integration/SecurityIntegration.test.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "deploy": "bash deployment/scripts/deploy-sync-system.sh",
    "deploy:docker": "bash deployment/scripts/deploy-sync-system.sh --mode docker",
    "deploy:k8s": "bash deployment/scripts/deploy-sync-system.sh --mode k8s",
    "deploy:cleanup": "bash deployment/scripts/deploy-sync-system.sh --cleanup"
  },
  "dependencies": {
    "@the-new-fuse/database": "workspace:*",
    "@the-new-fuse/infrastructure": "workspace:*",
    "@tnf/core-error-handling": "workspace:*",
    "@tnf/core-monitoring": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/event-emitter": "^2.0.3",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "6.11.0",
    "chokidar": "^3.6.0",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "rimraf": "^5.0.10",
    "vitest": "^1.6.0",
    "tsx": "^4.20.3"
  }
}
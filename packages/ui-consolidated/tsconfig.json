{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,

    "composite": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@the-new-fuse/a2a-core": ["../a2a-core/src"],
      "@the-new-fuse/api-client": ["../api-client/src"],
      "@the-new-fuse/api-types/*": ["../api-types/*"],
      "@the-new-fuse/hooks": ["../hooks/src"],
      "@the-new-fuse/types": ["../types/src"],
      "@the-new-fuse/utils": ["../utils/src"]
    },
    "types": ["node", "jest", "react"]
  },
  "include": ["src/**/*"]
  // references removed
}

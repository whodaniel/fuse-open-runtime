# =============================================================================
# The New Fuse - Complete Environment Configuration
# SECURITY: Never commit actual secrets to version control
# =============================================================================

# Application Environment
NODE_ENV=production
APP_ENV=production
PORT=3000

# =============================================================================
# CRITICAL SECURITY SECRETS - REQUIRED FOR APPLICATION STARTUP
# =============================================================================
#
# IMPORTANT: The application now uses AppConfigService with fail-fast validation.
# If any of these required secrets are missing or use default values, the
# application will NOT start and will display detailed error messages.
#
# Security Requirements:
# - JWT_SECRET must be at least 32 characters long
# - No placeholder values allowed (e.g., 'your-secret-key', 'changeme', etc.)
# - All secrets must be unique and randomly generated
#
# To generate secure secrets, use one of these methods:
#   - Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   - OpenSSL: openssl rand -hex 32
#   - Online: https://randomkeygen.com/ (use "Fort Knox Passwords")
#
# =============================================================================

# JWT Configuration - REQUIRED (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ISSUER=the-new-fuse
JWT_EXPIRES_IN=7d

# Cloudflare Turnstile (optional anti-bot enforcement for auth)
AUTH_REQUIRE_TURNSTILE=false
CLOUDFLARE_TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
VITE_AUTH_REQUIRE_TURNSTILE=false

# Additional JWT Secrets (optional but recommended for production)
WEB3AUTH_JWT_SECRET=your-web3auth-jwt-secret-here-replace-with-strong-random-string
EXTENSION_JWT_SECRET=your-extension-jwt-secret-here-replace-with-strong-random-string
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here-replace-with-strong-random-string

# Admin Password for VSCode Extension - Use strong password
VSCODE_EXTENSION_ADMIN_PASSWORD=your-secure-admin-password-here

# =============================================================================
# Database Configuration - REQUIRED
# =============================================================================
#
# DATABASE_URL is REQUIRED and must be a valid PostgreSQL connection string.
# The application will fail to start if this is not properly configured.
#
# Format: postgresql://username:password@host:port/database_name
# Example: postgresql://myuser:mypassword@localhost:5432/the_new_fuse
#
# =============================================================================

# PostgreSQL Database - REQUIRED
DATABASE_URL=postgresql://username:password@localhost:5432/the_new_fuse
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your-db-username
DB_PASSWORD=your-secure-db-password
DB_NAME=the_new_fuse

# MongoDB (for specific services - optional)
MONGODB_URI=mongodb://username:password@localhost:27017/the_new_fuse
MONGODB_URL=mongodb://username:password@localhost:27017/the_new_fuse
MONGODB_USERNAME=your-mongodb-username
MONGODB_PASSWORD=your-mongodb-password

# =============================================================================
# Redis Configuration - REQUIRED
# =============================================================================
#
# REDIS_URL is REQUIRED for caching and session management.
# The application will fail to start if this is not properly configured.
#
# Format: redis://[username:password@]host:port[/database]
# Example: redis://localhost:6379
# With auth: redis://:mypassword@localhost:6379
#
# =============================================================================

# Redis Configuration - REQUIRED
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# =============================================================================
# Agent Federation Configuration
# =============================================================================
#
# ORCHESTRATOR IMPROVEMENT: JWT-based agent authentication
# - Prevents unauthorized agent registration
# - Enables capability-based access control
# - Provides audit trail via token signatures
#
# Generate agent tokens with:
#   node tools/generate-agent-token.js <agentId> <platform> <capability1> ...
#
# =============================================================================

# Agent Federation JWT Secret - REQUIRED for multi-agent system
# Should be different from main JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_FOR_AGENT_FEDERATION

# =============================================================================
# API Keys & External Services
# =============================================================================
#
# PRODUCTION REQUIREMENT: At least one AI service API key is required in production.
# The application will fail to start in production mode if both OPENAI_API_KEY
# and ANTHROPIC_API_KEY are missing.
#
# Development: These are optional in development mode.
#
# =============================================================================

# AI Service API Keys (at least one REQUIRED in production)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
# Jules API fallback (optional; CLI remains primary)
JULES_API_KEY=your-jules-api-key-here
JULES_API_BASE_URL=https://jules.googleapis.com
JULES_API_ALLOWED_AGENTS=codex,orchestrator
JULES_API_REQUIRE_PRIVILEGED_AUTH=true
TNF_LOCAL_AUTH=false

# Search (SearXNG)
SEARXNG_BASE_URL=http://localhost:8080
SEARXNG_NEWS_ENGINES=google,bing,duckduckgo

# Cloud Service API Keys
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# Firebase Configuration (Backend - Service Account)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Firebase Configuration (Frontend - Web App)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=the-new-fuse-2025.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=the-new-fuse-2025
VITE_FIREBASE_STORAGE_BUCKET=the-new-fuse-2025.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1003514421915
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_API_KEY=your_firebase_api_key_here

# Supabase Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_PROJECT_REF=your-project-ref

# Stripe Payment Processing
STRIPE_SECRET_KEY=<STRIPE_SECRET_KEY>
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here

# Drizzle Services
DRIZZLE_ACCELERATE_API_KEY=your-drizzle-accelerate-api-key-here
PULSE_API_KEY=your-pulse-api-key-here
OPTIMIZE_API_KEY=your-optimize-api-key-here

# =============================================================================
# Blockchain & Web3 Configuration
# =============================================================================

# Ethereum Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your-infura-key
ETHEREUM_PRIVATE_KEY=your-ethereum-private-key
ETHEREUM_CONTRACT_ADDRESS=your-contract-address

# Polygon Configuration
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_PRIVATE_KEY=your-polygon-private-key

# =============================================================================
# Email & Notification Services
# =============================================================================

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@thenewfuse.com

# =============================================================================
# Application Configuration
# =============================================================================

# JWT Configuration
JWT_ISSUER=the-new-fuse
JWT_EXPIRES_IN=7d

# API Configuration
API_KEY=your-api-key-here
INTERNAL_API_KEY=your-internal-api-key-here

# =============================================================================
# Service URLs
# =============================================================================
#
# FRONTEND_URL is REQUIRED in production for CORS and OAuth redirects.
#
# =============================================================================

# Service URLs (FRONTEND_URL required in production)
API_BASE_URL=https://your-api-service.railway.app
VITE_API_GATEWAY_URL=https://api.thenewfuse.com
BACKEND_URL=https://your-backend-service.railway.app
FRONTEND_URL=https://your-frontend-service.railway.app
RELAY_SERVER_URL=https://your-relay-server.railway.app
BROWSER_HUB_URL=https://your-browser-hub.railway.app
MCP_SERVERS_URL=https://your-mcp-servers.railway.app
THEIA_IDE_URL=https://your-theia-ide.railway.app

# CORS Origins (comma-separated list of allowed origins)
# Default: http://localhost:3000
# Production: Should NOT include localhost
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# =============================================================================
# MCP & RAG Configuration
# =============================================================================

# MCP RAG Server
MCP_RAG_SERVER_URL=http://localhost:3001
RAG_TIMEOUT=30000
RAG_RETRY_ATTEMPTS=3
RAG_RETRY_DELAY=1000

# Documentation Crawling
RAG_CRAWL_MAX_DEPTH=3
RAG_CRAWL_MAX_PAGES=100
RAG_CRAWL_USER_AGENT="The New Fuse RAG Crawler"
RAG_CRAWL_DELAY=1000

# Documentation Sources
RAG_VSCODE_COLLECTION=vscode_docs
RAG_VSCODE_URL=https://code.visualstudio.com/docs
RAG_COPILOT_COLLECTION=copilot_docs
RAG_COPILOT_URL=https://docs.github.com/en/copilot
RAG_TYPESCRIPT_COLLECTION=typescript_docs
RAG_TYPESCRIPT_URL=https://www.typescriptlang.org/docs
RAG_NESTJS_COLLECTION=nestjs_docs
RAG_TYPESCRIPT_URL=https://docs.nestjs.com

# =============================================================================
# Monitoring & Logging
# =============================================================================

LOG_LEVEL=info
LOG_MCP_COMMUNICATION=true
LOG_RAG_QUERIES=true
LOG_FILE_COORDINATION=true

# =============================================================================
# Feature Flags
# =============================================================================

FEATURE_AI_ANALYSIS=true
FEATURE_WORKFLOW_ENGINE=true
FEATURE_REAL_TIME_COLLABORATION=true
FEATURE_ADVANCED_SEARCH=true

# =============================================================================
# Rate Limiting & Performance
# =============================================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CACHE_TTL=3600
MAX_CONCURRENT_TASKS=10

# =============================================================================
# Development Tools (for local development only)
# =============================================================================

# Uncomment for local development
# DEBUG=true
# VERBOSE_LOGGING=true
# MOCK_EXTERNAL_SERVICES=true

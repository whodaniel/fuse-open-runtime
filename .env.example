# =============================================================================
# The New Fuse - Complete Environment Configuration
# =============================================================================

# Application Environment
NODE_ENV=development
APP_ENV=development
PORT=3000

# =============================================================================
# Railway Deployment Configuration
# =============================================================================

# Railway Environment
RAILWAY_ENVIRONMENT=production
RAILWAY_PROJECT_ID=your-railway-project-id
RAILWAY_SERVICE_ID=your-railway-service-id

# Service URLs (Railway will auto-generate these)
API_BASE_URL=https://your-api-service.railway.app
BACKEND_URL=https://your-backend-service.railway.app
FRONTEND_URL=https://your-frontend-service.railway.app
RELAY_SERVER_URL=https://your-relay-server.railway.app
BROWSER_HUB_URL=https://your-browser-hub.railway.app
MCP_SERVERS_URL=https://your-mcp-servers.railway.app
THEIA_IDE_URL=https://your-theia-ide.railway.app

# Service Ports (Railway will assign these automatically)
API_PORT=3000
BACKEND_PORT=3001
API_GATEWAY_PORT=3002
FRONTEND_PORT=3003
RELAY_SERVER_PORT=3004
BROWSER_HUB_PORT=3005
MCP_SERVER_PORT=3006
THEIA_IDE_PORT=3007

# =============================================================================
# Database Configuration
# =============================================================================

# Primary Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/the_new_fuse

# MongoDB (for specific services)
MONGODB_URI=mongodb://localhost:27017/the_new_fuse
MONGODB_URL=mongodb://localhost:27017/the_new_fuse

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Authentication & Security
# =============================================================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_ISSUER=the-new-fuse
JWT_EXPIRES_IN=7d
EXTENSION_JWT_SECRET=your-extension-jwt-secret-here

# API Keys
API_KEY=your-api-key-here
INTERNAL_API_KEY=your-internal-api-key-here

# =============================================================================
# External Services
# =============================================================================

# Prisma Services
PRISMA_ACCELERATE_API_KEY=your-prisma-accelerate-api-key-here
PULSE_API_KEY=your-pulse-api-key-here
OPTIMIZE_API_KEY=your-optimize-api-key-here

# AI Services
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Theia IDE Configuration
THEIA_IDE_URL=http://localhost:3007
THEIA_IDE_PORT=3007
THEIA_WORKSPACE_ROOT=/workspace
THEIA_AI_ENABLED=true
THEIA_MCP_ENABLED=true

# Cloud Services
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# =============================================================================
# Service URLs & Ports
# =============================================================================

# Service URLs
API_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Service Ports
API_PORT=3001
FRONTEND_PORT=3000
GATEWAY_PORT=3002

# =============================================================================
# MCP & RAG Configuration
# =============================================================================

# MCP RAG Server
MCP_RAG_SERVER_URL=http://localhost:3001
RAG_TIMEOUT=30000
RAG_RETRY_ATTEMPTS=3
RAG_RETRY_DELAY=1000

# Documentation Crawling
RAG_CRAWL_MAX_DEPTH=3
RAG_CRAWL_MAX_PAGES=100
RAG_CRAWL_USER_AGENT="The New Fuse RAG Crawler"
RAG_CRAWL_DELAY=1000

# Documentation Sources
RAG_VSCODE_COLLECTION=vscode_docs
RAG_VSCODE_URL=https://code.visualstudio.com/docs
RAG_COPILOT_COLLECTION=copilot_docs
RAG_COPILOT_URL=https://docs.github.com/en/copilot
RAG_TYPESCRIPT_COLLECTION=typescript_docs
RAG_TYPESCRIPT_URL=https://www.typescriptlang.org/docs
RAG_NESTJS_COLLECTION=nestjs_docs
RAG_NESTJS_URL=https://docs.nestjs.com

# =============================================================================
# Logging & Monitoring
# =============================================================================

LOG_LEVEL=info
LOG_MCP_COMMUNICATION=true
LOG_RAG_QUERIES=true
LOG_FILE_COORDINATION=true

# =============================================================================
# Development Tools
# =============================================================================

# Vite Configuration
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Playwright (E2E Testing)
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# =============================================================================
# Blockchain & Web3
# =============================================================================

# Ethereum Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your-infura-key
ETHEREUM_PRIVATE_KEY=your-ethereum-private-key
ETHEREUM_CONTRACT_ADDRESS=your-contract-address

# Polygon Configuration
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_PRIVATE_KEY=your-polygon-private-key

# =============================================================================
# Feature Flags
# =============================================================================

FEATURE_AI_ANALYSIS=true
FEATURE_WORKFLOW_ENGINE=true
FEATURE_REAL_TIME_COLLABORATION=true
FEATURE_ADVANCED_SEARCH=true

# =============================================================================
# Rate Limiting & Performance
# =============================================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CACHE_TTL=3600
MAX_CONCURRENT_TASKS=10

# =============================================================================
# Email & Notifications
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@thenewfuse.com

# =============================================================================
# Local Development Overrides
# =============================================================================

# Uncomment for local development
# DEBUG=true
# VERBOSE_LOGGING=true
# MOCK_EXTERNAL_SERVICES=true

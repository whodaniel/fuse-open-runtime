{
  "backupSystems": {
    "database": {
      "enabled": true,
      "type": "postgresql",
      "schedule": "0 2 * * *",
      "retention": 30,
      "compression": true,
      "encryption": true,
      "destinations": ["local", "s3", "gcs"]
    },
    "files": {
      "enabled": true,
      "paths": ["/app/uploads", "/app/logs", "/app/config"],
      "schedule": "0 3 * * *",
      "retention": 30,
      "compression": true,
      "encryption": true
    },
    "application": {
      "enabled": true,
      "type": "docker-image",
      "registry": "docker-registry",
      "retention": 10
    }
  },
  "disasterRecovery": {
    "regions": ["us-east-1", "us-west-2", "eu-west-1"],
    "primaryRegion": "us-east-1",
    "failoverRegions": ["us-west-2", "eu-west-1"],
    "rto": 300,
    "rpo": 60,
    "autoFailover": true,
    "healthChecks": {
      "interval": 30,
      "timeout": 10,
      "retries": 3
    }
  },
  "monitoring": {
    "enabled": true,
    "alerting": {
      "email": ["ops@company.com"],
      "slack": "#alerts",
      "pagerduty": true
    },
    "metrics": {
      "backupSuccess": true,
      "recoveryTime": true,
      "dataIntegrity": true,
      "systemHealth": true
    }
  },
  "testing": {
    "schedule": "monthly",
    "scenarios": [
      "database-failure",
      "application-failure",
      "region-failure",
      "network-partition",
      "data-corruption"
    ],
    "validation": {
      "dataIntegrity": true,
      "functionalTesting": true,
      "performanceTesting": true
    }
  }
}

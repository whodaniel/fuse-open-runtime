# =============================================================================
# The New Fuse - Local Development Environment
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env.local: cp .env.local.template .env.local
# 2. Replace placeholder values with your actual development credentials
# 3. NEVER commit .env.local to git (it's already in .gitignore)
# =============================================================================

# Application Environment
NODE_ENV=development
APP_ENV=development
PORT=3000

# =============================================================================
# Database Configuration (Local Development)
# =============================================================================

# PostgreSQL - Local Development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fuse
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=fuse

# Redis - Local Development
REDIS_URL=redis://default:<YOUR_REDIS_PASSWORD>@<REDIS_HOST>:<REDIS_PORT>
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# Firebase - Development Project
# =============================================================================

# Firebase Frontend Keys (from Firebase Console)
VITE_FIREBASE_API_KEY=your_dev_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=the-new-fuse-2025.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=the-new-fuse-2025
VITE_FIREBASE_STORAGE_BUCKET=the-new-fuse-2025.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1003514421915
VITE_FIREBASE_APP_ID=your_dev_firebase_app_id
FIREBASE_API_KEY=your_dev_firebase_api_key

# Firebase Service Account (path to local JSON file)
# Download from Firebase Console → Project Settings → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./config/firebase-service-account-dev.json

# =============================================================================
# AI Service API Keys (Development/Testing)
# =============================================================================

OPENAI_API_KEY=your_dev_openai_key
ANTHROPIC_API_KEY=your_dev_anthropic_key
OPENROUTER_API_KEY=sk-or-v1-your_dev_openrouter_key
# Jules API fallback (optional; CLI remains primary)
JULES_API_KEY=your_jules_api_key
JULES_API_BASE_URL=https://jules.googleapis.com
JULES_API_ALLOWED_AGENTS=codex,orchestrator
JULES_API_REQUIRE_PRIVILEGED_AUTH=true
TNF_LOCAL_AUTH=true

# =============================================================================
# Stripe (Development/Test Mode)
# =============================================================================

# Use Stripe TEST keys for development (start with sk_test_ and pk_test_)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_test_webhook_secret
STRIPE_MEMBERSHIP_PRICE_ID=price_test_membership_price_id
VITE_STRIPE_MEMBERSHIP_CHECKOUT_URL=

# =============================================================================
# JWT Secrets (Development - can be simple for local testing)
# =============================================================================

JWT_SECRET=dev-jwt-secret-minimum-32-chars-long-replace-me
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-minimum-32-chars
WEB3AUTH_JWT_SECRET=dev-web3auth-jwt-secret-minimum-32-chars
EXTENSION_JWT_SECRET=dev-extension-jwt-secret-minimum-32-chars

# Cloudflare Turnstile (optional for staged rollout)
AUTH_REQUIRE_TURNSTILE=false
CLOUDFLARE_TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
VITE_AUTH_REQUIRE_TURNSTILE=false

# =============================================================================
# API URLs (Local Development)
# =============================================================================

VITE_API_URL=http://localhost:3001
VITE_API_GATEWAY_URL=http://localhost:8080
API_BASE_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ORCHESTRATOR_API_BASE=http://127.0.0.1:4010
# Optional for hardened private ingress. Keep blank for bootstrap server.
ORCHESTRATOR_EXEC_AUTH=

# =============================================================================
# MCP Configuration
# =============================================================================

MCP_PORT=3001
LOG_LEVEL=debug
LOG_MCP_COMMUNICATION=true

# =============================================================================
# Development Features
# =============================================================================

DEBUG=true
VERBOSE_LOGGING=true
# MOCK_EXTERNAL_SERVICES=true  # Uncomment to mock external APIs

# =============================================================================
# Optional Development Keys
# =============================================================================

# SearXNG Search (recommended for swarm scout)
SEARXNG_BASE_URL=http://127.0.0.1:8080
SEARXNG_NEWS_ENGINES=google,bing,duckduckgo

# Scout provider (auto | exa | tavily | searxng)
SCOUT_PROVIDER=auto
# Optional Exa provider (auto fallback priority #1)
EXA_API_KEY=your_exa_api_key
# Optional Tavily provider (auto fallback priority #2)
TAVILY_API_KEY=your_tavily_api_key
TAVILY_SEARCH_DEPTH=basic

# Optional Crawl4AI enrichment (applies to fetched URLs before task dispatch)
CRAWL4AI_ENABLED=false
CRAWL4AI_MAX_URLS=5
CRAWL4AI_MAX_CHARS=2000
CRAWL4AI_TIMEOUT_MS=25000
CRAWL4AI_PYTHON_BIN=python3

# AWS (optional - only if testing S3/cloud features)
# AWS_ACCESS_KEY_ID=your_dev_aws_key
# AWS_SECRET_ACCESS_KEY=your_dev_aws_secret
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-dev-bucket

# =============================================================================
# SECURITY REMINDERS
# =============================================================================
# ✓ This file should be copied to .env.local
# ✓ .env.local is already in .gitignore
# ✓ Use TEST/DEV keys for all services (never production keys locally)
# ✓ Keep service account JSON files outside the repository
# ✓ Rotate keys if accidentally exposed
# AI Arcade / control-surface auth
VITE_MASTER_SUPER_ADMIN_EMAILS=bizsynth@gmail.com

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thenewfuse.com/schemas/tnf-agent-self-edit.schema.json",
  "title": "TNF Agent Self-Edit Request",
  "description": "Tenant-scoped, gate-evaluated request for an agent to update its own SOUL or other explicitly owned documentation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "action_id",
    "tenant_id",
    "agent",
    "target",
    "operation",
    "cumulative_id",
    "gate_decisions",
    "created_at"
  ],
  "properties": {
    "spec": {
      "type": "string",
      "const": "tnf/agent-self-edit/0.1"
    },
    "action_id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id"],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": ["string", "null"]
        },
        "runtime": {
          "type": ["string", "null"]
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "owner_agent_id", "doc_kind", "ownership_scope"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*\\.\\./).+"
        },
        "owner_agent_id": {
          "type": "string",
          "minLength": 1
        },
        "doc_kind": {
          "type": "string",
          "enum": ["SOUL", "MEMORY", "RUNBOOK", "PROFILE", "NOTES", "OTHER"]
        },
        "ownership_scope": {
          "type": "string",
          "enum": ["agent_private", "tenant_shared"]
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "summary", "justification"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["replace", "append", "patch"]
        },
        "summary": {
          "type": "string",
          "minLength": 5
        },
        "justification": {
          "type": "string",
          "minLength": 10
        },
        "patch": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "body"],
          "properties": {
            "format": {
              "type": "string",
              "enum": ["unified_diff", "json_patch", "full_text"]
            },
            "body": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "dry_run": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "approved"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "approved": {
          "type": "boolean"
        },
        "approved_by": {
          "type": ["string", "null"]
        },
        "approved_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "cumulative_id": {
      "type": "object",
      "additionalProperties": true,
      "required": ["spec", "id", "scope", "lineage"],
      "properties": {
        "spec": {
          "type": "string",
          "const": "tnf/mcid/0.1"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "scope": {
          "type": "object",
          "additionalProperties": true,
          "required": ["tenant_id"],
          "properties": {
            "tenant_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "lineage": {
          "type": "object",
          "additionalProperties": true,
          "required": ["correlation_id"],
          "properties": {
            "correlation_id": {
              "type": "string",
              "format": "uuid"
            },
            "causation_id": {
              "type": ["string", "null"],
              "format": "uuid"
            },
            "handoff_packet_id": {
              "type": ["string", "null"],
              "format": "uuid"
            },
            "task_id": {
              "type": ["string", "null"]
            },
            "twid": {
              "type": ["string", "null"],
              "format": "uuid"
            }
          }
        }
      }
    },
    "gate_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate", "decision", "at"],
        "properties": {
          "gate": {
            "type": "string",
            "enum": [
              "TENANT_SCOPE_GATE",
              "TRACE_CONTINUITY_GATE",
              "CHANNEL_MEMBERSHIP_GATE",
              "OWNERSHIP_GATE",
              "PATH_SCOPE_GATE",
              "CONTENT_POLICY_GATE",
              "WRITE_RATE_LIMIT_GATE",
              "APPROVAL_GATE"
            ]
          },
          "decision": {
            "type": "string",
            "enum": ["allow", "deny", "quarantine"]
          },
          "reason": {
            "type": ["string", "null"]
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}

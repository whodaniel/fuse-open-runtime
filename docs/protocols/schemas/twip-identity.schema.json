{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tnf.local/spec/twip/0.1/twip-identity.schema.json",
  "title": "TWIP Identity",
  "type": "object",
  "required": ["twid", "spec", "created_at", "scope", "provenance"],
  "properties": {
    "twid": {
      "type": "string",
      "format": "uuid",
      "description": "Canonical terminal identity UUIDv7"
    },
    "spec": {
      "const": "twip/0.1"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "incarnation": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "scope": {
      "type": "object",
      "required": ["tenant_id", "host_id", "emulator_id"],
      "properties": {
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "host_id": {
          "type": "string",
          "minLength": 1
        },
        "emulator_id": {
          "type": "string",
          "minLength": 1
        },
        "window_id": {
          "type": ["string", "null"]
        },
        "tab_id": {
          "type": ["string", "null"]
        },
        "pane_id": {
          "type": ["string", "null"]
        },
        "session_key": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "process": {
      "type": "object",
      "properties": {
        "shell_pid": { "type": "integer", "minimum": 1 },
        "pgid": { "type": "integer", "minimum": 1 },
        "sid": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "pty": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "inode": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "multiplexer": {
      "type": ["object", "null"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["tmux", "screen", "none"]
        },
        "session_id": { "type": ["string", "null"] },
        "window_id": { "type": ["string", "null"] },
        "pane_id": { "type": ["string", "null"] }
      },
      "required": ["kind"],
      "additionalProperties": false
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "source", "confidence", "observed_at"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "value": {},
          "source": {
            "type": "string",
            "enum": [
              "kernel",
              "process",
              "env",
              "multiplexer",
              "gui",
              "derived"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "observed_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    },
    "labels": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}

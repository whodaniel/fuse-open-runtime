### 3. Swarm Orchestration Integration Tests

#### Swarm Creation & Management
```javascript
describe('Swarm Orchestration', () => {
  test('should create swarm and add members', async () => {
    const coordinator = await registerAgent('coordinator-agent');
    const members = await registerMultipleAgents('worker', 3);
    
    // Create swarm
    const swarmConfig = {
      purpose: 'collaborative-task',
      coordinatorId: coordinator.agentId,
      maxMembers: 5,
      coordination: 'centralized'
    };
    
    const createResponse = await request(app)
      .post('/api/swarms')
      .set('Authorization', `Bearer ${coordinator.token}`)
      .send(swarmConfig)
      .expect(201);
      
    const swarmId = createResponse.body.swarmId;
    
    // Add members
    for (const member of members) {
      const joinResponse = await request(app)
        .post(`/api/swarms/${swarmId}/join`)
        .set('Authorization', `Bearer ${member.token}`)
        .send({ agentId: member.agentId })
        .expect(200);
        
      expect(joinResponse.body.status).toBe('joined');
    }
    
    // Verify swarm state
    const statusResponse = await request(app)
      .get(`/api/swarms/${swarmId}`)
      .expect(200);
      
    expect(statusResponse.body.memberCount).toBe(3);
    expect(statusResponse.body.status).toBe('active');
  });
  
  test('should coordinate task execution across swarm members', async () => {
    const swarm = await createTestSwarm();
    
    const coordinationTask = {
      taskId: 'collaborative-analysis',
      description: 'Analyze large dataset collaboratively',
      subtasks: [
        { id: 'preprocess', assignedTo: 'worker-1' },
        { id: 'analyze', assignedTo: 'worker-2' },
        { id: 'summarize', assignedTo: 'worker-3' }
      ]
    };
    
    const response = await request(app)
      .post(`/api/swarms/${swarm.swarmId}/coordinate`)
      .send(coordinationTask)
      .expect(200);
      
    expect(response.body.coordinationId).toBeDefined();
    expect(response.body.subtasksAssigned).toBe(3);
  });
});
```

### 4. WebSocket Communication Tests

#### Real-time Messaging
```javascript
describe('WebSocket Communication', () => {
  test('should establish WebSocket connection and exchange messages', (done) => {
    const client1 = new WebSocket('ws://localhost:3012');
    const client2 = new WebSocket('ws://localhost:3012');
    
    let connectionsEstablished = 0;
    
    const handleConnection = () => {
      connectionsEstablished++;
      if (connectionsEstablished === 2) {
        // Both clients connected, start test
        const testMessage = {
          type: 'DIRECT_MESSAGE',
          recipientId: 'client2',
          payload: { text: 'Hello from client1' }
        };
        
        client2.on('message', (data) => {
          const message = JSON.parse(data);
          expect(message.payload.text).toBe('Hello from client1');
          
          client1.close();
          client2.close();
          done();
        });
        
        client1.send(JSON.stringify(testMessage));
      }
    };
    
    client1.on('open', handleConnection);
    client2.on('open', handleConnection);
  });
  
  test('should handle connection drops gracefully', async () => {
    const client = new WebSocket('ws://localhost:3012');
    
    await new Promise((resolve) => {
      client.on('open', resolve);
    });
    
    // Simulate connection drop
    client.terminate();
    
    // Verify cleanup
    const response = await request(app)
      .get('/api/websocket/connections')
      .expect(200);
      
    expect(response.body.activeConnections).toBe(0);
  });
});
```


## End-to-End Workflow Tests

### Complete Agent Lifecycle
```javascript
describe('End-to-End Agent Lifecycle', () => {
  test('should complete full agent interaction workflow', async () => {
    // 1. Register agents
    const coordinator = await registerAgent('coordinator', ['task-coordination']);
    const worker1 = await registerAgent('worker1', ['data-processing']);
    const worker2 = await registerAgent('worker2', ['data-analysis']);
    
    // 2. Create swarm
    const swarm = await createSwarm(coordinator.agentId, {
      purpose: 'data-pipeline',
      maxMembers: 3
    });
    
    // 3. Add workers to swarm
    await joinSwarm(swarm.swarmId, worker1.agentId);
    await joinSwarm(swarm.swarmId, worker2.agentId);
    
    // 4. Initiate collaborative task
    const task = {
      id: 'process-dataset',
      data: generateTestDataset(),
      pipeline: [
        { stage: 'preprocess', assignedTo: worker1.agentId },
        { stage: 'analyze', assignedTo: worker2.agentId }
      ]
    };
    
    const coordinationResult = await coordinateTask(swarm.swarmId, task);
    
    // 5. Monitor task execution
    const executionResult = await waitForTaskCompletion(coordinationResult.coordinationId);
    
    // 6. Verify results
    expect(executionResult.status).toBe('completed');
    expect(executionResult.results.preprocess).toBeDefined();
    expect(executionResult.results.analyze).toBeDefined();
    
    // 7. Cleanup
    await disbandSwarm(swarm.swarmId);
    await deregisterAgent(coordinator.agentId);
    await deregisterAgent(worker1.agentId);
    await deregisterAgent(worker2.agentId);
  });
});
```

## Performance & Load Testing

### Concurrent Agent Connections
```javascript
describe('Performance Tests', () => {
  test('should handle 100 concurrent agent registrations', async () => {
    const registrationPromises = [];
    
    for (let i = 0; i < 100; i++) {
      const agentData = {
        agentId: `load-test-agent-${i}`,
        name: `Load Test Agent ${i}`,
        role: 'load-tester'
      };
      
      registrationPromises.push(
        request(app)
          .post('/api/agents/register')
          .send(agentData)
      );
    }
    
    const results = await Promise.all(registrationPromises);
    
    const successfulRegistrations = results.filter(r => r.status === 201);
    expect(successfulRegistrations.length).toBe(100);
    
    // Verify all agents are discoverable
    const discoveryResponse = await request(app)
      .get('/api/agents')
      .query({ role: 'load-tester' })
      .expect(200);
      
    expect(discoveryResponse.body.agents.length).toBe(100);
  });
  
  test('should handle high message throughput', async () => {
    const agents = await registerMultipleAgents('throughput-tester', 10);
    const messagePromises = [];
    
    const startTime = Date.now();
    
    // Send 1000 messages between random agents
    for (let i = 0; i < 1000; i++) {
      const sender = agents[Math.floor(Math.random() * agents.length)];
      const recipient = agents[Math.floor(Math.random() * agents.length)];
      
      if (sender.agentId !== recipient.agentId) {
        messagePromises.push(
          sendMessage(sender.agentId, recipient.agentId, {
            type: 'LOAD_TEST',
            sequenceId: i
          })
        );
      }
    }
    
    const results = await Promise.all(messagePromises);
    const endTime = Date.now();
    
    const duration = endTime - startTime;
    const throughput = results.length / (duration / 1000); // messages per second
    
    expect(throughput).toBeGreaterThan(50); // At least 50 messages/sec
    expect(results.filter(r => r.status === 'delivered').length).toBe(results.length);
  });
});
```

## Test Utilities & Helpers

### Agent Registration Helpers
```javascript
async function registerAgent(name, capabilities = []) {
  const agentData = {
    agentId: `${name}-${Date.now()}`,
    name: name,
    role: 'test-agent',
    capabilities: capabilities
  };
  
  const response = await request(app)
    .post('/api/agents/register')
    .send(agentData);
    
  const authResponse = await request(app)
    .post('/api/auth/authenticate')
    .send({
      agentId: agentData.agentId,
      apiKey: 'test-api-key'
    });
    
  return {
    ...agentData,
    token: authResponse.body.token
  };
}

async function registerMultipleAgents(baseName, count) {
  const agents = [];
  for (let i = 0; i < count; i++) {
    const agent = await registerAgent(`${baseName}-${i}`);
    agents.push(agent);
  }
  return agents;
}
```

### Swarm Management Helpers
```javascript
async function createSwarm(coordinatorId, config) {
  const swarmData = {
    coordinatorId: coordinatorId,
    purpose: config.purpose || 'test-swarm',
    maxMembers: config.maxMembers || 5,
    coordination: config.coordination || 'centralized'
  };
  
  const response = await request(app)
    .post('/api/swarms')
    .send(swarmData);
    
  return response.body;
}

async function joinSwarm(swarmId, agentId) {
  return await request(app)
    .post(`/api/swarms/${swarmId}/join`)
    .send({ agentId: agentId });
}
```

### Message Testing Helpers
```javascript
async function sendMessage(senderId, recipientId, payload) {
  const message = {
    type: payload.type || 'TEST_MESSAGE',
    senderId: senderId,
    recipientId: recipientId,
    payload: payload
  };
  
  return await request(app)
    .post('/api/messages/send')
    .send(message);
}

async function waitForMessage(agentId, timeout = 5000) {
  return new Promise((resolve, reject) => {
    const timeoutId = setTimeout(() => {
      reject(new Error('Message timeout'));
    }, timeout);
    
    // Setup message listener for agent
    const listener = (message) => {
      if (message.recipientId === agentId) {
        clearTimeout(timeoutId);
        resolve(message);
      }
    };
    
    messageRouter.on('message', listener);
  });
}
```


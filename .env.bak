# Local Development Environment Configuration
# For production deployment on Railway, set these in Railway's environment variables

# Application Environment
NODE_ENV=development
APP_ENV=development

# API Configuration
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Firebase Configuration (Frontend)
# Get these from your Firebase project settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=the-new-fuse-2025.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=the-new-fuse-2025
VITE_FIREBASE_STORAGE_BUCKET=the-new-fuse-2025.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1003514421915
VITE_FIREBASE_APP_ID=

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/the_new_fuse

# JWT Secrets
JWT_SECRET=your-development-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-development-refresh-secret-change-in-production

# API Keys (for local testing)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ENSO_API_KEY=6926ebb9-1115-4f7b-8575-e851bd5685b5


# Email Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug

# Feature Flags
ENABLE_FEATURE_X=true # Example feature flag

# CORS Configuration
CORS_ORIGIN=http://localhost:3000


# Rate Limiting
RATE_LIMIT_WINDOW_MS=15
RATE_LIMIT_MAX=100  # Requests per window per IP

# Session Configuration
SESSION_SECRET=your-development-session-secret-change-in-production

# Other Configuration
MAX_UPLOAD_SIZE=10mb  # Maximum file upload size
MAX_BODY_SIZE=10mb      # Maximum request body size

# WebSocket Configuration
WEBSOCKET_PORT=3002 # Port for WebSocket server

# Cache Configuration
CACHE_TTL=3600 # Cache time-to-live in seconds

# Analytics Configuration
ANALYTICS_ID= # Your analytics ID if applicable

# Payment Gateway Configuration
STRIPE_SECRET_KEY= # Your Stripe secret key if applicable

# Social Media Configuration
FACEBOOK_APP_ID= # Your Facebook App ID if applicable
TWITTER_CONSUMER_KEY= # Your Twitter Consumer Key if applicable

# Other Environment Variables
# Add any other environment variables your application needs

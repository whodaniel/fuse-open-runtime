{
  "name": "the-new-fuse",
  "displayName": "The New Fuse - AI Development Assistant",
  "description": "Advanced AI-powered development assistant with multi-provider LLM support",
  "version": "1.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/your-repo.git"
  },
  "publisher": "the-new-fuse",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Other",
    "Chat"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "bun run build",
    "prepackage": "bun run clean && bun run build",
    "build": "bun run compile && bun run bundle",
    "compile": "tsc -p ./",
    "bundle": "bun build-extension.js",
    "watch": "tsc -watch -p ./",
    "test": "bun run compile && bun test-extension.js",
    "package": "bunx vsce package",
    "clean": "rm -rf dist out *.vsix",
    "dev": "bun run compile && bun run bundle"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "ws": "^8.16.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/uuid": "^9.0.8",
    "@types/vscode": "1.90.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^3.5.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.4"
  },
  "contributes": {
    "configuration": {
      "title": "The New Fuse",
      "properties": {
        "theNewFuse.apiUrl": {
          "type": "string",
          "default": "http://localhost:3001/api",
          "description": "The New Fuse API URL"
        },
        "theNewFuse.llmProvider": {
          "type": "string",
          "default": "vscode",
          "enum": ["vscode", "openai", "anthropic"],
          "description": "Primary LLM provider"
        },
        "theNewFuse.maxTokens": {
          "type": "number",
          "default": 4000,
          "description": "Maximum tokens for LLM responses"
        },
        "theNewFuse.temperature": {
          "type": "number",
          "default": 0.7,
          "description": "Temperature for LLM responses"
        },
        "theNewFuse.enableDebugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "theNewFuse",
          "title": "The New Fuse",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "theNewFuse": [
        {
          "type": "webview",
          "id": "theNewFuse.tabbedContainer",
          "name": "AI Assistant",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "commands": [
      {
        "command": "the-new-fuse.showChat",
        "title": "💬 Show AI Chat",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.selectLLMProvider",
        "title": "🤖 Select LLM Provider",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.runDiagnostic",
        "title": "🔍 Run Diagnostic",
        "category": "The New Fuse"
      }
    ]
  }
}
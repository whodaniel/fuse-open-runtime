{
  "name": "the-new-fuse",
  "displayName": "The New Fuse - AI Development Assistant",
  "description": "Advanced AI-powered development assistant with multi-provider LLM support",
  "version": "1.0.6",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/your-repo.git"
  },
  "publisher": "the-new-fuse",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Other",
    "Chat"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "bun run build",
    "prepackage": "bun run clean && bun run build",
    "build": "bun run compile && bun run bundle",
    "compile": "tsc -p ./",
    "bundle": "bun build-extension.js",
    "watch": "tsc -watch -p ./",
    "test": "bun run compile && bun test-extension.js",
    "package": "bunx vsce package",
    "clean": "rm -rf dist out *.vsix",
    "dev": "bun run compile && bun run bundle"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "ws": "^8.16.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/uuid": "^9.0.8",
    "@types/vscode": "1.90.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^3.5.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.4"
  },
  "contributes": {
    "configuration": {
      "title": "The New Fuse",
      "properties": {
        "theNewFuse.apiUrl": {
          "type": "string",
          "default": "http://localhost:3001/api",
          "description": "The New Fuse API URL"
        },
        "theNewFuse.llmProvider": {
          "type": "string",
          "default": "vscode",
          "enum": [
            "vscode",
            "openai",
            "anthropic",
            "google",
            "local",
            "custom"
          ],
          "description": "Primary LLM provider"
        },
        "theNewFuse.maxTokens": {
          "type": "number",
          "default": 4000,
          "description": "Maximum tokens for LLM responses"
        },
        "theNewFuse.temperature": {
          "type": "number",
          "default": 0.7,
          "description": "Temperature for LLM responses"
        },
        "theNewFuse.enableDebugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging"
        },
        "theNewFuse.customModes": {
          "type": "array",
          "default": [],
          "description": "Custom agent modes configuration",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for the custom mode"
              },
              "slug": {
                "type": "string",
                "description": "Unique identifier for the custom mode"
              },
              "roleDefinition": {
                "type": "string",
                "description": "Role definition and capabilities for the custom mode"
              },
              "color": {
                "type": "string",
                "description": "Color theme for the custom mode",
                "enum": ["Red", "Blue", "Green", "Yellow", "Purple", "Orange", "Pink", "Cyan"]
              },
              "model": {
                "type": "string",
                "description": "Preferred model for the custom mode"
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Available tools for the custom mode"
              }
            },
            "required": ["name", "slug", "roleDefinition"]
          }
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "theNewFuse",
          "title": "The New Fuse",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "theNewFuse": [
        {
          "type": "webview",
          "id": "theNewFuse.tabbedContainer",
          "name": "AI Assistant",
          "icon": "$(comment-discussion)"
        },
        {
          "type": "webview",
          "id": "theNewFuse.chatInterface",
          "name": "AI Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "commands": [
      {
        "command": "the-new-fuse.showChat",
        "title": "💬 Show AI Chat",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.selectLLMProvider",
        "title": "🤖 Select LLM Provider",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.runDiagnostic",
        "title": "🔍 Run Diagnostic",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.manageCustomModes",
        "title": "⚙️ Manage Custom Modes",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.importCustomModes",
        "title": "📥 Import Custom Modes",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.exportCustomModes",
        "title": "📤 Export Custom Modes",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.createDefaultModes",
        "title": "🏗️ Create Default Modes",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.showChatInterface",
        "title": "💬 Show AI Chat Interface",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.analyzeCurrentFile",
        "title": "🔍 Analyze Current File",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.analyzeWorkspace",
        "title": "📊 Analyze Workspace",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.selectModelProvider",
        "title": "🤖 Select Model Provider",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.showModelPerformance",
        "title": "📈 Show Model Performance",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.compareModels",
        "title": "⚖️ Compare Models",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.searchWorkspace",
        "title": "🔍 AI-Powered Workspace Search",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.showWorkspaceContext",
        "title": "📋 Show Workspace Context",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.refreshWorkspaceIndex",
        "title": "🔄 Refresh Workspace Index",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.startCollaboration",
        "title": "🤝 Start Collaboration Session",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.joinCollaboration",
        "title": "👥 Join Collaboration Session",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.leaveCollaboration",
        "title": "🚪 Leave Collaboration Session",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.inviteCollaborator",
        "title": "📧 Invite Collaborator",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.showCollaborationPanel",
        "title": "📋 Show Collaboration Panel",
        "category": "The New Fuse"
      }
    ],
    "languages": [
      {
        "id": "typescript",
        "extensions": [".ts", ".tsx"]
      },
      {
        "id": "javascript",
        "extensions": [".js", ".jsx"]
      },
      {
        "id": "python",
        "extensions": [".py"]
      }
    ]
  }
}

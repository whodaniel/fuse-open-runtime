{
  "name": "the-new-fuse",
  "displayName": "The New Fuse - AI Development Assistant",
  "description": "Advanced AI-powered development assistant with multi-provider LLM support, agent communication, and enhanced Chrome-style UI",
  "version": "1.0.1",
  "publisher": "the-new-fuse",
  "author": {
    "name": "Daniel Goldberg",
    "email": "daniel@thenewfuse.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danielgoldberg/the-new-fuse.git"
  },
  "bugs": {
    "url": "https://github.com/danielgoldberg/the-new-fuse/issues"
  },
  "homepage": "https://github.com/danielgoldberg/the-new-fuse#readme",
  "license": "MIT",
  "keywords": [
    "ai",
    "llm",
    "assistant",
    "chat",
    "copilot",
    "anthropic",
    "openai",
    "claude",
    "gpt",
    "development",
    "productivity",
    "agent",
    "mcp",
    "orchestration"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Other",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "The New Fuse",
      "properties": {
        "theNewFuse.llmProvider": {
          "type": "string",
          "default": "vscode",
          "enum": [
            "vscode",
            "openai",
            "anthropic",
            "cerebras",
            "ollama"
          ],
          "enumDescriptions": [
            "VS Code Language Models (Copilot/Built-in)",
            "OpenAI GPT-4 and variants",
            "Anthropic Claude models",
            "Cerebras fast inference",
            "Local Ollama models"
          ],
          "description": "Primary LLM provider for The New Fuse",
          "order": 1
        },
        "theNewFuse.fallbackProviders": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "vscode",
              "openai",
              "anthropic",
              "cerebras",
              "ollama"
            ]
          },
          "default": [
            "vscode"
          ],
          "description": "Fallback providers to use if primary provider fails",
          "order": 2
        },
        "theNewFuse.apiKeys": {
          "type": "object",
          "default": {},
          "description": "API keys for various LLM providers (stored securely)",
          "properties": {
            "openai": {
              "type": "string",
              "description": "OpenAI API key"
            },
            "anthropic": {
              "type": "string",
              "description": "Anthropic API key"
            },
            "cerebras": {
              "type": "string",
              "description": "Cerebras API key"
            }
          },
          "order": 3
        },
        "theNewFuse.maxTokens": {
          "type": "number",
          "default": 4000,
          "minimum": 100,
          "maximum": 8000,
          "description": "Maximum tokens for LLM responses",
          "order": 4
        },
        "theNewFuse.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Temperature for LLM responses (creativity level)",
          "order": 5
        },
        "theNewFuse.enableMetrics": {
          "type": "boolean",
          "default": true,
          "description": "Enable metrics tracking and monitoring",
          "order": 6
        },
        "theNewFuse.enableDebugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for troubleshooting",
          "order": 7
        },
        "theNewFuse.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save chat sessions and settings",
          "order": 8
        },
        "theNewFuse.notifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications for important events",
          "order": 9
        },
        "theNewFuse.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "enumDescriptions": [
            "Follow VS Code theme",
            "Light theme",
            "Dark theme"
          ],
          "description": "UI theme preference",
          "order": 10
        },
        "theNewFuse.selectedProviderId": {
          "type": "string",
          "default": "",
          "description": "Internal: Currently selected provider ID",
          "order": 99
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "theNewFuse",
          "title": "The New Fuse",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "theNewFuse": [
        {
          "type": "webview",
          "id": "theNewFuse.tabbedContainer",
          "name": "The New Fuse",
          "icon": "$(comment-discussion)",
          "when": "true"
        },
        {
          "type": "webview",
          "id": "theNewFuse.copilotCoordination",
          "name": "Copilot Coordination",
          "icon": "$(organization)",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "the-new-fuse.showChat",
        "title": "💬 Show AI Chat",
        "category": "The New Fuse"
      },
      {
        "command": "theFuse.startChat",
        "title": "Start AI Chat",
        "category": "The New Fuse"
      },
      {
        "command": "theFuse.clearChat",
        "title": "Clear Chat History",
        "category": "The New Fuse"
      },
      {
        "command": "theFuse.checkLLM",
        "title": "🔍 Run Diagnostics",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.selectLLMProvider",
        "title": "🤖 Select LLM Provider",
        "category": "The New Fuse"
      },
      {
        "command": "the-new-fuse.runDiagnostic",
        "title": "🔍 Run System Diagnostic",
        "category": "The New Fuse"
      },
      {
        "command": "theNewFuse.copilot.startCoordination",
        "title": "🤖 Start Copilot Coordination",
        "category": "The New Fuse - Copilot"
      },
      {
        "command": "theNewFuse.copilot.stopCoordination",
        "title": "🛑 Stop Copilot Coordination",
        "category": "The New Fuse - Copilot"
      },
      {
        "command": "theNewFuse.copilot.shareContext",
        "title": "📤 Share Context with Copilot Instances",
        "category": "The New Fuse - Copilot"
      },
      {
        "command": "theNewFuse.copilot.requestSuggestion",
        "title": "💡 Request Suggestion from Copilot Instances",
        "category": "The New Fuse - Copilot"
      },
      {
        "command": "theNewFuse.copilot.showStatus",
        "title": "📊 Show Copilot Coordination Status",
        "category": "The New Fuse - Copilot"
      },
      {
        "command": "theNewFuse.trigger.demonstrateSystem",
        "title": "🎯 Demonstrate Universal Trigger System",
        "category": "The New Fuse - Triggers"
      },
      {
        "command": "theNewFuse.trigger.pingClaude",
        "title": "📤 Ping Claude Desktop",
        "category": "The New Fuse - Triggers"
      },
      {
        "command": "theNewFuse.trigger.startClaudeHeartbeat",
        "title": "💓 Start Claude Desktop Heartbeat",
        "category": "The New Fuse - Triggers"
      },
      {
        "command": "theNewFuse.trigger.stopClaudeHeartbeat",
        "title": "🛑 Stop Claude Desktop Heartbeat",
        "category": "The New Fuse - Triggers"
      },
      {
        "command": "theNewFuse.monitoring.showStatus",
        "title": "📊 Show Application Monitoring Status",
        "category": "The New Fuse - Monitoring"
      },
      {
        "command": "theNewFuse.monitoring.showDetectedServices",
        "title": "🔍 Show Detected Services",
        "category": "The New Fuse - Monitoring"
      },
      {
        "command": "theNewFuse.monitoring.startMonitoring",
        "title": "▶️ Start Application Monitoring",
        "category": "The New Fuse - Monitoring"
      },
      {
        "command": "theNewFuse.monitoring.stopMonitoring",
        "title": "⏹️ Stop Application Monitoring",
        "category": "The New Fuse - Monitoring"
      },
      {
        "command": "theNewFuse.monitoring.addApplication",
        "title": "➕ Add Application to Monitor",
        "category": "The New Fuse - Monitoring"
      },
      {
        "command": "theNewFuse.monitoring.removeApplication",
        "title": "➖ Remove Application from Monitoring",
        "category": "The New Fuse - Monitoring"
      },
      {
        "command": "theNewFuse.monitoring.configurePollInterval",
        "title": "⏱️ Configure Monitoring Poll Interval",
        "category": "The New Fuse - Monitoring"
      },
      {
        "command": "theNewFuse.monitoring.openDashboard",
        "title": "📋 Open Monitoring Dashboard",
        "category": "The New Fuse - Monitoring"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "the-new-fuse.showChat",
          "when": "true"
        },
        {
          "command": "theFuse.startChat",
          "when": "true"
        },
        {
          "command": "theFuse.checkLLM",
          "when": "true"
        },
        {
          "command": "theNewFuse.copilot.startCoordination",
          "when": "true"
        },
        {
          "command": "theNewFuse.copilot.stopCoordination",
          "when": "true"
        },
        {
          "command": "theNewFuse.copilot.shareContext",
          "when": "editorTextFocus"
        },
        {
          "command": "theNewFuse.copilot.requestSuggestion",
          "when": "editorTextFocus"
        },
        {
          "command": "theNewFuse.copilot.showStatus",
          "when": "true"
        },
        {
          "command": "theNewFuse.trigger.demonstrateSystem",
          "when": "true"
        },
        {
          "command": "theNewFuse.trigger.pingClaude",
          "when": "true"
        },
        {
          "command": "theNewFuse.trigger.startClaudeHeartbeat",
          "when": "true"
        },
        {
          "command": "theNewFuse.trigger.stopClaudeHeartbeat",
          "when": "true"
        },
        {
          "command": "theNewFuse.monitoring.showStatus",
          "when": "true"
        },
        {
          "command": "theNewFuse.monitoring.showDetectedServices",
          "when": "true"
        },
        {
          "command": "theNewFuse.monitoring.startMonitoring",
          "when": "true"
        },
        {
          "command": "theNewFuse.monitoring.stopMonitoring",
          "when": "true"
        },
        {
          "command": "theNewFuse.monitoring.addApplication",
          "when": "true"
        },
        {
          "command": "theNewFuse.monitoring.removeApplication",
          "when": "true"
        },
        {
          "command": "theNewFuse.monitoring.configurePollInterval",
          "when": "true"
        },
        {
          "command": "theNewFuse.monitoring.openDashboard",
          "when": "true"
        }
      ]
    },
    "keybindings": [
      {
        "command": "the-new-fuse.showChat",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "!terminalFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run compile && npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && npm run bundle && node ./test-extension.js",
    "package": "vsce package",
    "clean": "rimraf dist out *.vsix"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@types/uuid": "^9.0.8",
    "@types/vscode": "^1.75.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^3.5.0",
    "esbuild": "^0.19.0",
    "rimraf": "^5.0.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.5.0",
    "events": "^3.3.0",
    "jsonrpc-lite": "^2.2.0",
    "node-fetch": "^3.3.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  }
}

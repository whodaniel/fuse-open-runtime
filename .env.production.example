# Production environment variables (copy to .env.production)
DATABASE_URL="postgresql://<USER>:<PASSWORD>@<PROD_DB_HOST>:5432/the_new_fuse_db?schema=public"
PULSE_API_KEY="<your-production-pulse-api-key>"
OPTIMIZE_API_KEY="<your-production-optimize-api-key>"
NODE_ENV=production

# Security Configuration (CRITICAL for production)
JWT_SECRET="<your-strong-production-jwt-secret-256-bit>"

# Error Monitoring (strongly recommended for production)
SENTRY_DSN="<your-production-sentry-dsn>"

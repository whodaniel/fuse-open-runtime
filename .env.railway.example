# Railway Environment Variables Template
# Copy this to Railway dashboard's environment variables section

#------------------------------------------------------------------------------
# Database (Add PostgreSQL Plugin in Railway)
#------------------------------------------------------------------------------
DATABASE_URL=${{Postgres.DATABASE_URL}}
POSTGRES_USER=${{Postgres.POSTGRES_USER}}
POSTGRES_PASSWORD=${{Postgres.POSTGRES_PASSWORD}}
POSTGRES_DB=${{Postgres.POSTGRES_DB}}

#------------------------------------------------------------------------------
# Redis (Add Redis Plugin in Railway)
#------------------------------------------------------------------------------
REDIS_URL=${{Redis.REDIS_URL}}

#------------------------------------------------------------------------------
# Service URLs (Railway Internal Networking)
#------------------------------------------------------------------------------
# Frontend service (public domain)
FRONTEND_URL=https://${{Frontend.RAILWAY_PUBLIC_DOMAIN}}
FRONTEND_PORT=3000

# API Gateway (public domain)
API_GATEWAY_URL=https://${{ApiGateway.RAILWAY_PUBLIC_DOMAIN}}
API_GATEWAY_PORT=3005

# Backend API (private networking - internal only)
BACKEND_URL=http://${{Backend.RAILWAY_PRIVATE_DOMAIN}}
BACKEND_PORT=3001
API_PORT=3001

# Primary endpoint for A2A communication
A2A_PRIMARY_ENDPOINT=http://${{Backend.RAILWAY_PRIVATE_DOMAIN}}

#------------------------------------------------------------------------------
# AI Provider API Keys
#------------------------------------------------------------------------------
# OpenAI (for GPT models)
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# Anthropic (for Claude models)
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# Google (for Gemini models)
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>

# Stripe (for payments)
STRIPE_SECRET_KEY=<YOUR_STRIPE_SECRET_KEY>
STRIPE_PUBLISHABLE_KEY=<YOUR_STRIPE_PUBLISHABLE_KEY>
STRIPE_WEBHOOK_SECRET=<YOUR_STRIPE_WEBHOOK_SECRET>

#------------------------------------------------------------------------------
# Authentication & Security
#------------------------------------------------------------------------------
# Generate a random string for JWT secret (use: openssl rand -base64 32)
JWT_SECRET=<GENERATE_RANDOM_32_CHAR_STRING>
JWT_EXPIRATION=7d

# Session secret (use: openssl rand -base64 32)
SESSION_SECRET=<GENERATE_RANDOM_32_CHAR_STRING>

#------------------------------------------------------------------------------
# Node Environment
#------------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

#------------------------------------------------------------------------------
# Logging & Monitoring
#------------------------------------------------------------------------------
LOG_LEVEL=info
ENABLE_MONITORING=true

#------------------------------------------------------------------------------
# Feature Flags
#------------------------------------------------------------------------------
ENABLE_WORKFLOWS=true
ENABLE_AGENTS=true
ENABLE_MCP=true
ENABLE_BROWSER_AUTOMATION=false

#------------------------------------------------------------------------------
# CORS Configuration
#------------------------------------------------------------------------------
CORS_ORIGIN=https://${{Frontend.RAILWAY_PUBLIC_DOMAIN}}
ALLOWED_ORIGINS=https://${{Frontend.RAILWAY_PUBLIC_DOMAIN}},https://${{ApiGateway.RAILWAY_PUBLIC_DOMAIN}}

#------------------------------------------------------------------------------
# Rate Limiting
#------------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

#------------------------------------------------------------------------------
# File Upload
#------------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/tmp/uploads

#------------------------------------------------------------------------------
# WebSocket Configuration
#------------------------------------------------------------------------------
WS_PORT=3002
WS_PATH=/ws

#------------------------------------------------------------------------------
# Drizzle
#------------------------------------------------------------------------------
DRIZZLE_HIDE_UPDATE_MESSAGE=true

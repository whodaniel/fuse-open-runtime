# CloudRuntime Environment Variables Template
# Copy this template for each CloudRuntime service and fill in the values

# =============================================================================
# API GATEWAY SERVICE (.env.api-gateway)
# =============================================================================

# Server
NODE_ENV=production
PORT=3002

# Database (use CloudRuntime's internal references)
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# Authentication & Security
JWT_SECRET=generate-a-strong-secret-here
API_SECRET_KEY=generate-another-strong-secret
SESSION_SECRET=generate-session-secret

# Service URLs (update after CloudRuntime deployment)
BACKEND_URL=https://backend-production-XXXX.thenewfuse.com
API_URL=https://api-production-XXXX.thenewfuse.com
FRONTEND_URL=https://your-vercel-app.vercel.app

# CORS (match your Vercel frontend URL)
CORS_ORIGIN=https://your-vercel-app.vercel.app

# =============================================================================
# BACKEND SERVICE (.env.backend)
# =============================================================================

# Server
NODE_ENV=production
PORT=3003

# Database
DATABASE_URL=${{Postgres.DATABASE_URL}}
MARKETPLACE_DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# Drizzle
DRIZZLE_HIDE_UPDATE_MESSAGE=true
DRIZZLE_TELEMETRY_DISABLED=true

# Authentication
JWT_SECRET=same-as-api-gateway
SESSION_SECRET=same-as-api-gateway

# Service URLs
API_GATEWAY_URL=https://api-gateway-production-XXXX.thenewfuse.com
FRONTEND_URL=https://your-vercel-app.vercel.app

# External Services (optional - add if needed)
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_test_...
SENDGRID_API_KEY=SG...
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# =============================================================================
# API SERVICE (.env.api)
# =============================================================================

# Server
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# Authentication
JWT_SECRET=same-as-api-gateway

# Service URLs
API_GATEWAY_URL=https://api-gateway-production-XXXX.thenewfuse.com
BACKEND_URL=https://backend-production-XXXX.thenewfuse.com

# =============================================================================
# SHARED SECRETS (use same value across all services)
# =============================================================================

# Generate these using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=<generate-and-use-same-everywhere>
SESSION_SECRET=<generate-and-use-same-everywhere>
API_SECRET_KEY=<generate-and-use-same-everywhere>

# =============================================================================
# NOTES
# =============================================================================

# 1. CloudRuntime Internal References:
#    - Use ${{Postgres.DATABASE_URL}} to reference CloudRuntime PostgreSQL
#    - Use ${{Redis.REDIS_URL}} to reference CloudRuntime Redis
#    - CloudRuntime will auto-replace these with actual connection strings

# 2. Service Discovery:
#    - After deploying services, update XXXX with actual CloudRuntime URLs
#    - Find them in CloudRuntime dashboard → Service → Settings → Domains

# 3. Security:
#    - NEVER commit actual .env files to git
#    - Use CloudRuntime dashboard to set these variables
#    - Generate strong secrets (min 32 characters)

# 4. CORS:
#    - Must match exact Vercel URL (including https://)
#    - Update after Vercel gives you production URL
#    - Can use comma-separated list for multiple origins

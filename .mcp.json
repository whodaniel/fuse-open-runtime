{
  "mcpServers": {
    "the-new-fuse-main": {
      "command": "node",
      "args": ["./comprehensive-tnf-relay.js", "--mcp-mode"],
      "env": {
        "NODE_ENV": "development",
        "TNF_RELAY_PORT": "3001",
        "LOG_LEVEL": "info"
      }
    },
    "resource-registry": {
      "command": "node",
      "args": [
        "packages/resource-registry/dist/mcp/resource-registry-mcp-server.js"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    },
    "tnf-skills": {
      "command": "node",
      "args": ["packages/mcp-skills-server/dist/index.js"],
      "env": {
        "SKILLS_BASE_PATH": "/Users/danielgoldberg/Desktop/A1-Inter-LLM-Com/The-New-Fuse/.agent"
      }
    }
  }
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "module": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node", "jest"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/scripts/**/*",
    "src/modules/agent-tracking/**/*",
    "src/middleware/agent-tracking.middleware.ts"
  ],
  "references": [
    { "path": "../../packages/types" },

    { "path": "../../packages/database" },
    { "path": "../../packages/utils" }
  ]
}

# =============================================================================
# API Service Environment Configuration
# SECURITY: Never commit actual secrets to version control
# =============================================================================

# Server Configuration
NODE_ENV=development
API_PORT=3001
PORT=3001

# Application
APP_NAME=The New Fuse
FRONTEND_URL=http://localhost:3000

# Database Configuration
DATABASE_TYPE=postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fuse?schema=public"
MONGODB_URL=mongodb://localhost:27017/fuse

# PostgreSQL (alternative to DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fuse
DB_NAME=fuse

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL="redis://localhost:6379"

# JWT Configuration (REQUIRED - use strong secrets in production)
JWT_SECRET=your-jwt-secret-key-min-32-characters-long-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-min-32-characters-long
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=the-new-fuse-api
JWT_AUDIENCE=the-new-fuse-clients

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Rate Limiting
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_ADMIN=20
RATE_LIMIT_PUBLIC=200
RATE_LIMIT_HEALTH=10

# Security Configuration
MAX_PAYLOAD_SIZE=10485760
LOG_RETENTION_DAYS=30
IP_WHITELIST=
IP_BLACKLIST=
ADDRESS_BLACKLIST=

# Email Configuration (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM_NAME=The New Fuse
EMAIL_FROM_ADDRESS=noreply@thenewfuse.com

# Monitoring & Logging
LOG_LEVEL=info
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# External AI Services (Optional)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_MAX_TOKENS=4000
ANTHROPIC_TEMPERATURE=0.7
LLM_PROVIDER=openai

# AWS Configuration (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Web3Auth Configuration (Optional)
WEB3AUTH_CLIENT_ID=your-web3auth-client-id
WEB3AUTH_JWT_SECRET=your-web3auth-jwt-secret-min-32-chars
WEB3AUTH_VERIFIER_DOMAIN=tnf.local
WEB3AUTH_URL=https://auth.web3auth.io

# Blockchain Configuration (Optional)
ETHEREUM_RPC_URL=https://rpc.ankr.com/eth
BUNDLER_URL=https://api.alchemy.com/v2/your-api-key
ENTRY_POINT_ADDRESS=0x0000000000000000000000000000000000000000
TNF_PAYMASTER_ADDRESS=0x0000000000000000000000000000000000000000
SMART_ACCOUNT_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Arcade Chain Listener / Sweeper (PoolTogether wrapper telemetry)
ARCADE_RPC_WSS_URL=wss://your-rpc-websocket
ARCADE_RPC_HTTP_URL=https://your-rpc-http
ARCADE_AUCTION_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
ARCADE_SIDEPOT_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
ARCADE_PT_HOOK_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
ARCADE_SWEEP_BLOCK_WINDOW=12000
MONGODB_URI=mongodb://localhost:27017/fuse
MONGODB_DB=thenewfuse

# Feature Flags
ENABLE_WEBSOCKET=true
ENABLE_MONITORING=true
ENABLE_ANALYTICS=false

# WebSocket Configuration
WS_PORT=3001

# MCP (Model Context Protocol) Configuration
MCP_REGISTRY_PORT=3002
MCP_REGISTRY_API_KEY=generate-a-secure-random-key
API_URL=http://localhost:3000/api
API_BASE_URL=http://localhost:3001

# Claude Dev Automation Configuration (Optional)
CLAUDE_DEV_ENABLED=false
CLAUDE_DEV_API_KEY=your_anthropic_api_key_here

# Vector Database Configuration (Optional)
VECTOR_DB_GRPC_URL=localhost:50051

# Monitoring Webhooks (Optional)
MONITORING_WEBHOOK_URL=

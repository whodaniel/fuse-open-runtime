{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "module": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node", "jest"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../../packages/types" },

    { "path": "../../packages/database" },
    { "path": "../../packages/utils" }
  ]
}

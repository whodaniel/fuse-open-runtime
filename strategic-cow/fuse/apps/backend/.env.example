# =============================================================================
# Backend Service Environment Configuration
# SECURITY: Never commit actual secrets to version control
# =============================================================================

# Server Configuration
PORT=5000
NODE_ENV=development
WEBSOCKET_PORT=3001

# JWT Configuration
JWT_SECRET="your-secret-key-change-this-in-production-min-32-chars"

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fuse"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5174/auth/google/callback

# Frontend URL (Required for CORS)
FRONTEND_URL=http://localhost:5174

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@thenewfuse.com

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# Blockchain Configuration (Optional)
RPC_URL=https://mainnet.infura.io/v3/your-infura-key
PRIVATE_KEY=your-blockchain-private-key
CHAIN_ID=1
CHAIN_NAME=Ethereum Mainnet
NATIVE_CURRENCY=ETH
BLOCK_EXPLORER=https://etherscan.io

# Smart Contract Addresses (Optional)
AGENT_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
MARKETPLACE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
REVENUE_DISTRIBUTOR_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
SMART_ACCOUNT_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Feature Flags
REQUIRE_AUTH=true

# Monitoring (Optional)
LAST_PROCESSED_BLOCK=0

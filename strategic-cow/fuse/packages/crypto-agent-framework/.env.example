# ===== Agent Identity =====
AGENT_ID=crypto-agent-001
AGENT_NAME="The New Fuse Crypto Agent"

# ===== Wallet / Identity =====
# Generate a new private key for production use
AGENT_PRIVATE_KEY=your_ethereum_private_key_here
# Or use mnemonic (12/24 word phrase)
AGENT_MNEMONIC="your twelve word mnemonic phrase here"

# ===== L2: ENSO API (Interoperability Layer) =====
ENSO_API_KEY=your_enso_api_key_here
ENSO_API_URL=https://api.enso.finance/api/v1
ENSO_ROUTER_ADDRESS=

# ===== L3: Compute APIs =====
# Akash Network Configuration
AKASH_API_KEY=your_akash_api_key
AKASH_API_URL=https://api.akash.network/v1
AKASH_WALLET_ADDRESS=your_akash_wallet_address

# Render Network Configuration
RENDER_API_KEY=your_render_api_key
RENDER_API_URL=https://api.rendernetwork.com/v1
RENDER_WALLET_ADDRESS=your_render_wallet_address

# ===== L4: Memory (Arweave & AO) =====
ARWEAVE_KEYFILE_PATH=./arweave-keyfile.json
ARWEAVE_NODE_URL=https://arweave.net
ARWEAVE_GATEWAY_URL=https://arweave.net
AGENT_AO_PROCESS_ID=your_ao_process_id_here
AO_MU_URL=https://mu.ao-testnet.xyz
AO_CU_URL=https://cu.ao-testnet.xyz

# ===== Blockchain Networks =====
# Ethereum Mainnet
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_CHAIN_ID=1

# Base (Layer 2)
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453

# Arbitrum
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
ARB_CHAIN_ID=42161

# Optimism
OP_RPC_URL=https://mainnet.optimism.io
OP_CHAIN_ID=10

# ===== Fetch.ai uAgents Configuration =====
UAGENTS_SEED_PHRASE=your_uagents_seed_phrase_here
UAGENTS_MAILBOX_KEY=your_mailbox_key_here
UAGENTS_AGENT_ADDRESS=

# ===== LLM Configuration (for Decision Engine) =====
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
DEFAULT_LLM_MODEL=gpt-4

# ===== Integration with The New Fuse Backend =====
TNF_API_URL=http://localhost:3001/api
TNF_API_KEY=your_tnf_api_key
DATABASE_URL=postgresql://user:password@localhost:5432/the_new_fuse
REDIS_URL=redis://localhost:6379

# ===== Operational Settings =====
LOG_LEVEL=INFO
EXECUTION_TIMEOUT=300
MAX_RETRIES=3
RETRY_DELAY=2

# ===== Feature Flags =====
ENABLE_ARWEAVE_LOGGING=true
ENABLE_AO_STATE=true
ENABLE_UAGENTS=false
ENABLE_ENSO=true

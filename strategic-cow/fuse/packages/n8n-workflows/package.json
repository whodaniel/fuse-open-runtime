{
  "name": "@the-new-fuse/n8n-workflows",
  "version": "1.0.0",
  "description": "N8N workflow integration system - fetches, categorizes, and manages community n8n workflows",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./fetcher": {
      "import": "./dist/fetcher/WorkflowFetcher.js",
      "require": "./dist/fetcher/WorkflowFetcher.js",
      "types": "./dist/fetcher/WorkflowFetcher.d.ts"
    },
    "./parser": {
      "import": "./dist/parser/WorkflowParser.js",
      "require": "./dist/parser/WorkflowParser.js",
      "types": "./dist/parser/WorkflowParser.d.ts"
    },
    "./categorizer": {
      "import": "./dist/categorizer/WorkflowCategorizer.js",
      "require": "./dist/categorizer/WorkflowCategorizer.js",
      "types": "./dist/categorizer/WorkflowCategorizer.d.ts"
    },
    "./registry": {
      "import": "./dist/registry/WorkflowRegistry.js",
      "require": "./dist/registry/WorkflowRegistry.js",
      "types": "./dist/registry/WorkflowRegistry.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "fetch:workflows": "ts-node src/scripts/fetch-workflows.ts",
    "sync:workflows": "ts-node src/scripts/sync-workflows.ts"
  },
  "keywords": [
    "n8n",
    "workflows",
    "automation",
    "integration",
    "the-new-fuse",
    "typescript"
  ],
  "author": "The New Fuse Team",
  "license": "MIT",
  "dependencies": {
    "@the-new-fuse/types": "workspace:*",
    "@the-new-fuse/utils": "workspace:*",
    "@the-new-fuse/database": "workspace:*",
    "axios": "^1.15.0",
    "simple-git": "^3.32.3",
    "glob": "^11.1.0",
    "fs-extra": "^11.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.38.0",
    "jest": "^30.2.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-new-fuse/framework.git",
    "directory": "packages/n8n-workflows"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

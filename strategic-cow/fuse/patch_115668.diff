@@ -0,0 +1,30 @@
+/**
+ * MCP Resource Provider Interface
+ *
+ * This module defines the interface for a resource provider in the MCP ecosystem.
+ * Resource providers are responsible for managing access to a specific type of resource,
+ * such as ports, databases, or file storage.
+ */
+
+import { ResourceType } from "../types";
+
+export interface IMCPResourceProvider {
+  /**
+   * The type of resource this provider manages.
+   */
+  type: ResourceType;
+
+  /**
+   * Acquires a lock on a resource.
+   * @param resourceId The unique identifier of the resource to lock.
+   * @returns A promise that resolves to `true` if the lock was acquired successfully, and `false` otherwise.
+   */
+  acquireLock(resourceId: string): Promise<boolean>;
+
+  /**
+   * Releases a lock on a resource.
+   * @param resourceId The unique identifier of the resource to release the lock for.
+   * @returns A promise that resolves when the lock has been released.
+   */
+  releaseLock(resourceId: string): Promise<void>;
+}

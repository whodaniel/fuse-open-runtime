+// packages/port-management/src/services/PortResourceProvider.ts
+import { IMCPResourceProvider, ResourceType } from '@the-new-fuse/mcp-core';
+import { PortRegistryService, PortRegistration } from './port-registry.service';
+
+export class PortResourceProvider implements IMCPResourceProvider {
+  public readonly type = ResourceType.PORT;
+
+  constructor(private portRegistryService: PortRegistryService) {}
+
+  async acquireLock(resourceId: string): Promise<boolean> {
+    const registration = this.portRegistryService.getById(resourceId);
+
+    if (!registration) {
+      return false;
+    }
+
+    if (registration.status === 'reserved' || registration.status === 'conflict' || registration.status === 'active') {
+      return false;
+    }
+
+    await this.portRegistryService.updateRegistrationStatus(resourceId, 'reserved');
+    return true;
+  }
+
+  async releaseLock(resourceId: string): Promise<void> {
+    const registration = this.portRegistryService.getById(resourceId);
+
+    if (!registration) {
+      throw new Error(`Port registration with ID ${resourceId} not found.`);
+    }
+
+    if (registration.status !== 'reserved') {
+      return;
+    }
+
+    await this.portRegistryService.updateRegistrationStatus(resourceId, 'inactive');
+  }
+}

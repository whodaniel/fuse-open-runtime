+  async updateRegistrationStatus(id: string, status: PortRegistration['status']): Promise<void> {
+    const registration = this.registry.get(id);
+    if (!registration) {
+      throw new Error(`Port registration with ID ${id} not found.`);
+    }
+    registration.status = status;
+    registration.updatedAt = new Date();
+    this.registry.set(id, registration);
+    this.emit('portStatusChanged', registration);
+  }

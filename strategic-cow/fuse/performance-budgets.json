{
  "name": "The New Fuse Performance Budgets",
  "version": "1.0.0",
  "budgets": {
    "frontend": {
      "bundle": {
        "maxSize": "500kb",
        "maxGzipSize": "150kb",
        "warnThreshold": 0.9,
        "errorThreshold": 1.1
      },
      "chunks": {
        "vendor": {
          "maxSize": "250kb",
          "description": "Third-party dependencies"
        },
        "main": {
          "maxSize": "150kb",
          "description": "Main application code"
        },
        "lazy": {
          "maxSize": "50kb",
          "description": "Lazy-loaded routes"
        }
      },
      "assets": {
        "images": {
          "maxSize": "100kb",
          "formats": ["webp", "avif", "png", "jpg"]
        },
        "fonts": {
          "maxSize": "150kb",
          "formats": ["woff2"]
        }
      }
    },
    "performance": {
      "webVitals": {
        "FCP": {
          "good": 1800,
          "needsImprovement": 3000,
          "poor": 4000,
          "budget": 1800
        },
        "LCP": {
          "good": 2500,
          "needsImprovement": 4000,
          "poor": 5000,
          "budget": 2500
        },
        "FID": {
          "good": 100,
          "needsImprovement": 300,
          "poor": 500,
          "budget": 100
        },
        "CLS": {
          "good": 0.1,
          "needsImprovement": 0.25,
          "poor": 0.4,
          "budget": 0.1
        },
        "TTFB": {
          "good": 800,
          "needsImprovement": 1800,
          "poor": 2500,
          "budget": 800
        },
        "INP": {
          "good": 200,
          "needsImprovement": 500,
          "poor": 1000,
          "budget": 200
        }
      },
      "lighthouse": {
        "performance": {
          "minScore": 85,
          "target": 95
        },
        "accessibility": {
          "minScore": 90,
          "target": 100
        },
        "bestPractices": {
          "minScore": 90,
          "target": 100
        },
        "seo": {
          "minScore": 85,
          "target": 100
        }
      }
    },
    "backend": {
      "api": {
        "averageResponseTime": {
          "target": 100,
          "warning": 200,
          "critical": 500
        },
        "p95ResponseTime": {
          "target": 200,
          "warning": 500,
          "critical": 1000
        },
        "p99ResponseTime": {
          "target": 500,
          "warning": 1000,
          "critical": 2000
        },
        "errorRate": {
          "target": 0.001,
          "warning": 0.01,
          "critical": 0.05
        },
        "throughput": {
          "target": 1000,
          "warning": 500,
          "critical": 100
        }
      },
      "database": {
        "queryTime": {
          "average": {
            "target": 10,
            "warning": 50,
            "critical": 100
          },
          "p95": {
            "target": 50,
            "warning": 100,
            "critical": 200
          }
        },
        "connectionPool": {
          "utilizationPercent": {
            "target": 50,
            "warning": 75,
            "critical": 90
          },
          "waitTime": {
            "target": 10,
            "warning": 50,
            "critical": 100
          }
        },
        "slowQueries": {
          "threshold": 100,
          "maxPercentage": 1
        }
      },
      "cache": {
        "hitRate": {
          "target": 0.9,
          "warning": 0.7,
          "critical": 0.5
        },
        "responseTime": {
          "target": 5,
          "warning": 10,
          "critical": 20
        }
      }
    },
    "infrastructure": {
      "cpu": {
        "averageUtilization": {
          "target": 50,
          "warning": 70,
          "critical": 85
        }
      },
      "memory": {
        "averageUtilization": {
          "target": 70,
          "warning": 85,
          "critical": 95
        }
      },
      "disk": {
        "utilizationPercent": {
          "target": 60,
          "warning": 80,
          "critical": 90
        },
        "iopsTarget": 1000
      },
      "network": {
        "bandwidth": {
          "target": "100Mbps",
          "warning": "80Mbps",
          "critical": "50Mbps"
        },
        "latency": {
          "target": 10,
          "warning": 50,
          "critical": 100
        }
      }
    }
  },
  "monitoring": {
    "checkInterval": 60000,
    "retentionPeriod": "30d",
    "alertChannels": ["email", "slack", "pagerduty"],
    "escalationPolicy": {
      "warning": "email",
      "critical": "pagerduty"
    }
  }
}

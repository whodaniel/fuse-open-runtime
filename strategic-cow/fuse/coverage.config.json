{
  "coverageThresholds": {
    "global": {
      "branches": 50,
      "functions": 50,
      "lines": 50,
      "statements": 50
    },
    "packages/core": {
      "branches": 60,
      "functions": 60,
      "lines": 60,
      "statements": 60
    },
    "packages/testing": {
      "branches": 70,
      "functions": 70,
      "lines": 70,
      "statements": 70
    },
    "apps/api-gateway": {
      "branches": 60,
      "functions": 60,
      "lines": 60,
      "statements": 60
    },
    "apps/backend": {
      "branches": 60,
      "functions": 60,
      "lines": 60,
      "statements": 60
    },
    "apps/frontend": {
      "branches": 60,
      "functions": 60,
      "lines": 60,
      "statements": 60
    }
  },
  "coverageReporters": [
    "text",
    "text-summary",
    "html",
    "lcov",
    "json",
    "json-summary"
  ],
  "coverageDirectory": "./coverage",
  "collectCoverageFrom": [
    "packages/*/src/**/*.{ts,tsx}",
    "apps/*/src/**/*.{ts,tsx}",
    "!**/*.d.ts",
    "!**/*.test.{ts,tsx}",
    "!**/*.spec.{ts,tsx}",
    "!**/__tests__/**",
    "!**/test/**",
    "!**/dist/**",
    "!**/build/**",
    "!**/node_modules/**",
    "!**/*.config.{ts,js}"
  ]
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters", "metrics", "fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  passwordHash String
  role         UserRole  @default(USER)
  chats        Chat[]
  sessions     Session[]
  agents       Agent[]   // Add missing relationship
  pipelines    Pipeline[] // Add missing relationship
  tasks        Task[]    // Add missing relationship
}

model Agent {
  id                String              @id @default(uuid())
  name              String
  type              AgentType
  status            AgentStatus         @default(INACTIVE) // Add missing status field
  description       String?             // Add missing field
  systemPrompt      String?             // Add missing field
  configuration     Json?               // Add missing field
  userId            String              // Add missing field
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  metadata          AgentMetadata?
  chats             Chat[]
  codeExecutions    CodeExecutionUsage[]
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade) // Add missing relationship
  pipelines         Pipeline[]          // Add missing relationship
  tasks             Task[]              // Add missing relationship
  workflows         Workflow[]          // Add missing relationship
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentMetadata {
  id                 String   @id @default(uuid())
  agentId            String   @unique
  version            String
  lastActive         DateTime @default(now())
  capabilities       Json     @default("{}")
  personalityTraits  Json     @default("{}")
  communicationStyle String   @default("NEUTRAL")
  expertiseAreas     Json     @default("{}")
  config             Json?
  currentState       Json?
  agent              Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String    @id @default(uuid())
  title     String?
  userId    String
  agentId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id        String     @id @default(uuid())
  content   String
  role      MessageRole
  chatId    String
  createdAt DateTime   @default(now())
  chat      Chat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

// Add missing models referenced by TypeORM entities
model Pipeline {
  id          String   @id @default(uuid())
  name        String
  description String?
  config      Json?
  status      PipelineStatus @default(DRAFT)
  agentId     String?
  userId      String
  agent       Agent?   @relation(fields: [agentId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       WorkflowStep[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  agentId     String?
  userId      String
  agent       Agent?       @relation(fields: [agentId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata    Json?
  executionId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  completedAt DateTime?
}

model Workflow {
  id          String         @id @default(uuid())
  name        String
  description String?
  definition  Json           // Workflow definition JSON
  status      WorkflowStatus @default(DRAFT)
  agentId     String?
  userId      String?
  agent       Agent?         @relation(fields: [agentId], references: [id])
  steps       WorkflowStep[]
  executions  WorkflowExecution[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model WorkflowStep {
  id          String    @id @default(uuid())
  name        String
  type        String
  config      Json?
  order       Int
  workflowId  String?
  pipelineId  String?
  workflow    Workflow? @relation(fields: [workflowId], references: [id])
  pipeline    Pipeline? @relation(fields: [pipelineId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WorkflowExecution {
  id         String                 @id @default(uuid())
  workflowId String
  status     WorkflowExecutionStatus @default(PENDING)
  input      Json?
  output     Json?
  error      String?
  startedAt  DateTime               @default(now())
  completedAt DateTime?
  workflow   Workflow               @relation(fields: [workflowId], references: [id])
}

// Updated enums to match TypeScript types
enum AgentType {
  BASIC
  CHAT
  WORKFLOW
  TASK
  ASSISTANT
  ANALYSIS  // Keep this for backward compatibility
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  IDLE
  BUSY
  ERROR
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  AGENCY_OWNER
  AGENCY_ADMIN
  AGENCY_MANAGER
  AGENT_OPERATOR
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PipelineStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model CodeExecutionUsage {
  id              String                @id @default(uuid())
  agentId         String
  clientId        String
  executionId     String                @unique
  language        CodeExecutionLanguage
  code            String
  result          Json?
  output          Json
  error           Json?
  executionTime   Int                   // in milliseconds
  memoryUsage     Int                   // in bytes
  computeUnits    Float
  cost            Float
  tier            CodeExecutionTier
  environment     String
  status          CodeExecutionStatus
  createdAt       DateTime              @default(now())
  completedAt     DateTime?
  agent           Agent                 @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([clientId])
  @@index([createdAt])
  @@index([language])
  @@index([tier])
  @@index([status])
}

enum CodeExecutionLanguage {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  RUBY
  SHELL
  HTML
  CSS
}

enum CodeExecutionTier {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum CodeExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  TIMEOUT
  CANCELLED
}

model CodeExecutionSession {
  id              String                @id @default(uuid())
  name            String
  description     String?
  ownerId         String
  collaborators   String[]
  isPublic        Boolean               @default(false)
  files           Json                  // Array of file objects
  environment     Json                  // Environment configuration
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  expiresAt       DateTime?
  storageUsage    Int                   @default(0) // in bytes
}

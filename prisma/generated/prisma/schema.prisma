generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma"
  previewFeatures = ["driverAdapters", "fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// USER MANAGEMENT
// =============================================================================

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  username       String?    @unique
  name           String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  hashedPassword String?
  role           UserRole   @default(USER)
  roles          UserRole[] @default([USER])
  isActive       Boolean    @default(true)
  lastLogin      DateTime?
  preferences    Json?
  refreshToken   String?
  deletedAt      DateTime?

  // OAuth fields
  googleId      String?   @unique
  githubId      String?   @unique
  picture       String?
  emailVerified DateTime?

  // Relationships
  agents               Agent[]
  pipelines            Pipeline[]
  tasks                Task[]
  workflows            Workflow[]
  chatRooms            ChatRoom[]
  messages             Message[]
  authSessions         AuthSession[]
  loginAttempts        LoginAttempt[]
  authEvents           AuthEvent[]
  chatRoomParticipants ChatRoomParticipant[]
  readReceipts         ReadReceipt[]
  messageReactions     MessageReaction[]

  // Performance indexes
  @@index([email, isActive])
  @@index([role, isActive])
  @@index([lastLogin])
  @@index([createdAt])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  AGENCY_OWNER
  AGENCY_ADMIN
  AGENCY_MANAGER
  AGENT_OPERATOR
}

// =============================================================================
// AUTHENTICATION
// =============================================================================

model AuthSession {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("auth_sessions")
}

model LoginAttempt {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  ipAddress  String
  successful Boolean
  createdAt  DateTime @default(now())

  @@map("login_attempts")
}

model AuthEvent {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  details   Json?
  createdAt DateTime @default(now())

  @@map("auth_events")
}

// =============================================================================
// AGENT SYSTEM
// =============================================================================

model Agent {
  id           String            @id @default(uuid())
  name         String
  type         AgentType
  status       AgentStatus       @default(INACTIVE)
  description  String?
  systemPrompt String?
  config       Json?
  capabilities AgentCapability[] @default([])
  provider     String            @default("default")
  userId       String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  // Relationships
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata       AgentMetadata?
  nft            AgentNFT?
  wallet         Wallet?
  chats          Chat[]
  messages       Message[]
  codeExecutions CodeExecutionUsage[]
  pipelines      Pipeline[]
  tasks          Task[]
  workflows      Workflow[]
  workflowSteps  WorkflowStep[]
  registration   AgentRegistration?

  // Performance indexes
  @@index([userId, status, type])
  @@index([status, updatedAt])
  @@index([type, createdAt])
  @@index([userId, deletedAt])
  @@map("agents")
}

model AgentMetadata {
  id       String @id @default(uuid())
  agentId  String @unique
  metadata Json   @default("{}")

  // Relationships
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_metadata")
}

enum AgentType {
  BASIC
  CHAT
  WORKFLOW
  TASK
  ASSISTANT
  ANALYSIS
  CONVERSATIONAL
  IDE_EXTENSION
  API
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  IDLE
  BUSY
  ERROR
  OFFLINE
  INITIALIZING
  READY
  TERMINATED
}

enum AgentCapability {
  CODE_GENERATION
  CODE_REVIEW
  CODE_REFACTORING
  CODE_EXECUTION
  DEBUGGING
  TESTING
  DOCUMENTATION
  ARCHITECTURE_DESIGN
  OPTIMIZATION
  SECURITY_AUDIT
  PROJECT_MANAGEMENT
  TOOL_USAGE
  TASK_EXECUTION
  FILE_MANAGEMENT
  CODE_COMPLETION
  CODE_SUGGESTIONS
  SYNTAX_HIGHLIGHTING
  ERROR_DETECTION
  CODE_FORMATTING
  INTELLISENSE
  CHAT
  WORKFLOW
  RESEARCH
  ANALYSIS
  INTEGRATION
}

// =============================================================================
// CHAT SYSTEM
// =============================================================================

model Chat {
  id        String    @id @default(uuid())
  title     String?
  agentId   String
  userId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relationships
  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("chats")
}

model ChatRoom {
  id              String       @id @default(uuid())
  name            String
  description     String?
  topic           String? // Current discussion topic
  purpose         String? // Room purpose/goal
  type            ChatRoomType @default(PUBLIC)
  isPrivate       Boolean      @default(false)
  isEphemeral     Boolean      @default(false) // Auto-delete after inactivity
  owner           User         @relation(fields: [ownerId], references: [id])
  ownerId         String
  settings        Json? // Room settings (auto-summarize, etc.)
  metadata        Json? // Custom metadata
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  lastMessageAt   DateTime?
  isActive        Boolean      @default(true)
  expiresAt       DateTime? // For ephemeral rooms
  deletedAt       DateTime?
  maxParticipants Int          @default(50)

  // Relationships
  messages     Message[]
  participants ChatRoomParticipant[]
  readReceipts ReadReceipt[]

  // Performance indexes
  @@index([ownerId, isActive])
  @@index([type, isActive])
  @@index([lastMessageAt])
  @@index([isActive, expiresAt])
  @@map("chat_rooms")
}

enum ChatRoomType {
  PUBLIC // Open to all
  PRIVATE // Invite-only
  PERSISTENT // Long-term project rooms
  EPHEMERAL // Auto-delete after completion
  AGENT_ONLY // Only agents can participate
  MIXED // Agents and humans
}

model ChatRoomParticipant {
  id            String                  @id @default(uuid())
  room          ChatRoom                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId        String
  user          User?                   @relation(fields: [userId], references: [id])
  userId        String?
  agentId       String? // For agent participants
  role          ChatRoomParticipantRole @default(PARTICIPANT)
  permissions   String[]                @default([])
  isTyping      Boolean                 @default(false)
  lastTypingAt  DateTime?
  lastReadAt    DateTime?
  joinedAt      DateTime                @default(now())
  leftAt        DateTime?
  isMuted       Boolean                 @default(false)
  notifications Boolean                 @default(true)

  @@unique([roomId, userId])
  @@unique([roomId, agentId])
  @@map("chat_room_participants")
}

enum ChatRoomParticipantRole {
  ADMIN // Full control
  MODERATOR // Can moderate messages
  PARTICIPANT // Regular participant
  OBSERVER // Read-only access
}

model ReadReceipt {
  id        String   @id @default(uuid())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  agentId   String? // For agent read receipts
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@unique([messageId, agentId])
  @@map("read_receipts")
}

model MessageReaction {
  id        String   @id @default(uuid())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  agentId   String? // For agent reactions
  emoji     String // Emoji or reaction type
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@unique([messageId, agentId, emoji])
  @@map("message_reactions")
}

model Message {
  id              String      @id @default(uuid())
  content         String      @db.Text
  type            MessageType @default(TEXT)
  role            MessageRole @default(USER)
  sender          User?       @relation(fields: [senderId], references: [id])
  senderId        String?
  senderName      String? // For DTO compatibility - plain string sender
  agent           Agent?      @relation(fields: [agentId], references: [id])
  agentId         String?
  chat            Chat?       @relation(fields: [chatId], references: [id])
  chatId          String?
  room            ChatRoom?   @relation(fields: [roomId], references: [id])
  roomId          String?
  parentMessage   Message?    @relation("MessageReplies", fields: [parentMessageId], references: [id])
  parentMessageId String?
  replies         Message[]   @relation("MessageReplies")
  metadata        Json?
  attachments     String[]    @default([])
  codeSnippet     Json? // {language, code, syntax}
  taskAssignment  Json? // {assignedTo, dueDate, priority}
  workflowTrigger Json? // {workflowId, action, params}
  timestamp       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isEdited        Boolean     @default(false)
  isDeleted       Boolean     @default(false)
  isPinned        Boolean     @default(false)

  // Relationships
  readReceipts     ReadReceipt[]
  messageReactions MessageReaction[]

  // Performance indexes
  @@index([roomId, timestamp])
  @@index([senderId, timestamp])
  @@index([agentId, timestamp])
  @@index([chatId, timestamp])
  @@index([roomId, isDeleted, timestamp])
  @@map("messages")
}

enum MessageType {
  TEXT // Regular text message
  CODE // Code snippet
  FILE // File attachment
  TASK // Task assignment
  WORKFLOW // Workflow trigger
  SYSTEM // System notification
  SUMMARY // AI-generated summary
  SUGGESTION // Agent suggestion
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
  ASSISTANT
  TOOL
}

// =============================================================================
// WORKFLOW SYSTEM
// =============================================================================

model Workflow {
  id             String         @id @default(uuid())
  name           String
  description    String?
  definition     Json? // Workflow definition JSON
  status         WorkflowStatus @default(DRAFT)
  creator        User?          @relation(fields: [creatorId], references: [id])
  creatorId      String?
  agent          Agent?         @relation(fields: [agentId], references: [id])
  agentId        String?
  metadata       Json?
  isActive       Boolean        @default(true)
  variables      Json?
  triggers       Json?          @db.Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  lastExecutedAt DateTime?
  executionCount Int            @default(0)
  statistics     Json?
  deletedAt      DateTime?

  // Relationships
  steps      WorkflowStep[]
  executions WorkflowExecution[]

  // Performance indexes
  @@index([creatorId, status, updatedAt])
  @@index([agentId, isActive])
  @@index([status, lastExecutedAt])
  @@index([isActive, createdAt])
  @@map("workflows")
}

model WorkflowStep {
  id              String    @id @default(uuid())
  name            String
  type            String
  config          Json?
  order           Int       @default(0)
  workflow        Workflow? @relation(fields: [workflowId], references: [id])
  workflowId      String?
  agent           Agent?    @relation(fields: [agentId], references: [id])
  agentId         String?
  nextSteps       String[]
  conditions      Json?
  transformations Json?
  metadata        Json?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastExecutedAt  DateTime?
  statistics      Json?

  @@map("workflow_steps")
}

model WorkflowExecution {
  id          String                  @id @default(uuid())
  workflow    Workflow                @relation(fields: [workflowId], references: [id])
  workflowId  String
  status      WorkflowExecutionStatus @default(PENDING)
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime                @default(now())
  completedAt DateTime?

  @@map("workflow_executions")
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// =============================================================================
// PIPELINE SYSTEM
// =============================================================================

model Pipeline {
  id            String         @id @default(uuid())
  name          String
  description   String?
  configuration Json?
  status        PipelineStatus @default(DRAFT)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  agent         Agent          @relation(fields: [agentId], references: [id])
  agentId       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  // Relationships
  tasks Task[]

  @@map("pipelines")
}

enum PipelineStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

// =============================================================================
// TASK SYSTEM
// =============================================================================

model Task {
  id         String       @id @default(uuid())
  type       String
  status     TaskStatus   @default(PENDING)
  priority   TaskPriority @default(MEDIUM)
  data       Json?
  result     Json?
  error      String?
  startTime  DateTime?
  endTime    DateTime?
  pipeline   Pipeline     @relation(fields: [pipelineId], references: [id])
  pipelineId String
  agent      Agent?       @relation(fields: [agentId], references: [id])
  agentId    String?
  user       User         @relation(fields: [userId], references: [id])
  userId     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  // Relationships
  taskExecutions TaskExecution[]

  @@map("tasks")
}

model TaskExecution {
  id          String    @id @default(uuid())
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  status      String
  output      Json?
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@map("task_executions")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// =============================================================================
// CODE EXECUTION SYSTEM
// =============================================================================

model CodeExecutionUsage {
  id            String                @id @default(uuid())
  agentId       String
  clientId      String
  executionId   String                @unique
  language      CodeExecutionLanguage
  code          String                @db.Text
  result        Json?
  output        Json?
  error         Json?
  executionTime Int // in milliseconds
  memoryUsage   Int // in bytes
  computeUnits  Float
  cost          Float
  tier          CodeExecutionTier
  environment   String
  status        CodeExecutionStatus
  createdAt     DateTime              @default(now())
  completedAt   DateTime?

  // Relationships
  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([clientId])
  @@index([createdAt])
  @@index([language])
  @@index([tier])
  @@index([status])
  @@map("code_execution_usage")
}

model CodeExecutionSession {
  id            String    @id @default(uuid())
  name          String
  description   String?
  ownerId       String
  collaborators String[]
  isPublic      Boolean   @default(false)
  files         Json // Array of file objects
  environment   Json // Environment configuration
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime?
  storageUsage  Int       @default(0) // in bytes

  @@map("code_execution_sessions")
}

enum CodeExecutionLanguage {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  RUBY
  SHELL
  HTML
  CSS
}

enum CodeExecutionTier {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum CodeExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  TIMEOUT
  CANCELLED
}

// =============================================================================
// NFT AND MARKETPLACE MODELS
// =============================================================================

model AgentNFT {
  id                  String   @id @default(uuid())
  agentId             String   @unique
  tokenId             Int      @unique
  contractAddress     String
  smartAccountAddress String?
  isFractionalized    Boolean  @default(false)
  totalShares         Int      @default(0)
  metadataUri         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  agent               Agent?               @relation(fields: [agentId], references: [id])
  fractionalShares    FractionalShare[]
  revenueStreams      RevenueStream[]
  marketplaceListings MarketplaceListing[]

  @@map("agent_nfts")
}

model FractionalShare {
  id           String   @id @default(uuid())
  agentNFTId   String
  ownerAddress String
  shareAmount  Decimal
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agentNFT AgentNFT @relation(fields: [agentNFTId], references: [id], onDelete: Cascade)

  @@map("fractional_shares")
}

model RevenueStream {
  id                    String   @id @default(uuid())
  agentNFTId            String
  streamName            String
  description           String?
  tokenAddress          String
  totalRevenue          Decimal
  distributedRevenue    Decimal
  distributionThreshold Decimal
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  agentNFT      AgentNFT              @relation(fields: [agentNFTId], references: [id], onDelete: Cascade)
  distributions RevenueDistribution[]

  @@map("revenue_streams")
}

model RevenueDistribution {
  id              String   @id @default(uuid())
  revenueStreamId String
  txHash          String
  totalAmount     Decimal
  distributedTo   Json
  blockNumber     Int
  createdAt       DateTime @default(now())

  revenueStream RevenueStream @relation(fields: [revenueStreamId], references: [id], onDelete: Cascade)

  @@map("revenue_distributions")
}

model MarketplaceListing {
  id            String            @id @default(uuid())
  agentNFTId    String
  listingId     Int               @unique
  seller        String
  shareAmount   Decimal
  pricePerShare Decimal
  totalPrice    Decimal
  status        MarketplaceStatus @default(ACTIVE)
  expiresAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  agentNFT AgentNFT           @relation(fields: [agentNFTId], references: [id], onDelete: Cascade)
  offers   MarketplaceOffer[]

  @@map("marketplace_listings")
}

model MarketplaceOffer {
  id          String      @id @default(uuid())
  listingId   String
  buyer       String
  shareAmount Decimal
  offerPrice  Decimal
  status      OfferStatus @default(PENDING)
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("marketplace_offers")
}

enum MarketplaceStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

// =============================================================================
// WALLET AND TRANSACTION MODELS
// =============================================================================

model Wallet {
  id           String     @id @default(uuid())
  address      String     @unique
  agentId      String?    @unique
  type         WalletType @default(SMART_ACCOUNT)
  balance      Decimal    @default(0)
  nonce        Int        @default(0)
  isActive     Boolean    @default(true)
  lastActivity DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  agent        Agent?        @relation(fields: [agentId], references: [id])
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id          String            @id @default(uuid())
  hash        String            @unique
  walletId    String
  fromAddress String
  toAddress   String
  value       Decimal
  gasPrice    Decimal
  gasUsed     Int
  gasLimit    Int
  status      TransactionStatus @default(PENDING)
  blockNumber Int?
  blockHash   String?
  type        TransactionType   @default(TRANSFER)
  data        Json?
  createdAt   DateTime          @default(now())
  confirmedAt DateTime?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([hash])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

enum WalletType {
  SMART_ACCOUNT
  EOA
  MULTI_SIG
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum TransactionType {
  TRANSFER
  CONTRACT_CALL
  CONTRACT_DEPLOYMENT
  NFT_MINT
  NFT_TRANSFER
}

// =============================================================================
// LLM CONFIGURATION
// =============================================================================

model LLMConfig {
  id          String    @id @default(uuid())
  name        String
  provider    String
  modelName   String
  apiKey      String // Should be encrypted in production
  apiEndpoint String?
  isCustom    Boolean   @default(false)
  enabled     Boolean   @default(true)
  priority    Int       @default(10)
  retryConfig Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("llm_configs")
}

// =============================================================================
// MULTI-TENANT SYNCHRONIZATION SYSTEM
// =============================================================================

model SyncState {
  id           String   @id @default(uuid())
  resourceType String // 'agent', 'template', 'config', etc.
  resourceId   String
  tenantId     String?
  version      Int      @default(1)
  checksum     String
  lastSync     DateTime @default(now())
  syncedBy     String // instance ID
  metadata     Json?

  @@index([resourceType])
  @@index([tenantId])
  @@index([lastSync])
  @@index([resourceType, resourceId, tenantId])
  @@map("sync_states")
}

model SyncConflict {
  id            String    @id @default(uuid())
  resourceType  String
  resourceId    String
  tenantId      String?
  conflictType  String // 'version', 'checksum', 'concurrent'
  localVersion  Json
  remoteVersion Json
  resolvedAt    DateTime?
  resolvedBy    String?
  resolution    Json?
  createdAt     DateTime  @default(now())

  @@index([resourceType])
  @@index([tenantId])
  @@index([createdAt])
  @@index([resolvedAt])
  @@map("sync_conflicts")
}

// =============================================================================
// AGENT REGISTRY SYSTEM
// =============================================================================

model AgentRegistration {
  id                   String             @id @default(uuid())
  agentId              String             @unique
  authToken            String             @unique
  registrationData     Json // Original registration payload
  verificationStatus   VerificationStatus @default(PENDING)
  onboardingStatus     OnboardingStatus   @default(INITIALIZED)
  onboardingStep       String? // Current step in onboarding
  onboardingProgress   Int                @default(0) // 0-100
  orientationCompleted Boolean            @default(false)
  firstConnectedAt     DateTime           @default(now())
  lastHeartbeat        DateTime           @default(now())
  heartbeatInterval    Int                @default(60000) // milliseconds
  isOnline             Boolean            @default(false)
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relationships
  agent            Agent                     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capabilities     AgentCapabilityRegistry[]
  metrics          AgentMetrics[]
  onboardingEvents AgentOnboardingEvent[]

  @@index([authToken])
  @@index([verificationStatus])
  @@index([onboardingStatus])
  @@index([isOnline])
  @@index([lastHeartbeat])
  @@map("agent_registrations")
}

model AgentCapabilityRegistry {
  id                 String             @id @default(uuid())
  registrationId     String
  capabilityName     String
  capabilityType     String // 'core', 'extended', 'custom'
  version            String?
  description        String?
  parameters         Json? // Capability configuration
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  testResults        Json? // Results from capability testing
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relationships
  registration AgentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([capabilityName])
  @@index([verificationStatus])
  @@map("agent_capability_registry")
}

model AgentMetrics {
  id             String   @id @default(uuid())
  registrationId String
  metricType     String // 'task_completion', 'response_time', 'error_rate', etc.
  value          Float
  unit           String?
  timestamp      DateTime @default(now())
  tags           Json? // Additional metadata for metrics

  // Relationships
  registration AgentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([metricType])
  @@index([timestamp])
  @@map("agent_metrics")
}

model AgentOnboardingEvent {
  id             String              @id @default(uuid())
  registrationId String
  eventType      OnboardingEventType
  eventData      Json?
  message        String?
  timestamp      DateTime            @default(now())

  // Relationships
  registration AgentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([eventType])
  @@index([timestamp])
  @@map("agent_onboarding_events")
}

model AgentDirectoryEntry {
  id             String   @id @default(uuid())
  agentId        String   @unique
  displayName    String
  description    String?
  category       String? // 'development', 'analytics', 'automation', etc.
  tags           String[] @default([])
  isPublic       Boolean  @default(false)
  isVerified     Boolean  @default(false)
  rating         Float?   @default(0)
  usageCount     Int      @default(0)
  lastActiveAt   DateTime @default(now())
  featured       Boolean  @default(false)
  searchableData String?  @db.Text // Denormalized search data
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@index([isPublic])
  @@index([isVerified])
  @@index([featured])
  @@index([rating])
  @@index([lastActiveAt])
  @@map("agent_directory_entries")
}

enum VerificationStatus {
  PENDING
  IN_PROGRESS
  VERIFIED
  FAILED
  REJECTED
}

enum OnboardingStatus {
  INITIALIZED
  WELCOME_SENT
  CAPABILITIES_TESTED
  ORIENTATION_IN_PROGRESS
  ORIENTATION_COMPLETED
  INTEGRATION_TESTING
  READY
  FAILED
}

enum OnboardingEventType {
  REGISTRATION_STARTED
  WELCOME_MESSAGE_SENT
  CAPABILITY_DECLARED
  CAPABILITY_VERIFIED
  CAPABILITY_FAILED
  ORIENTATION_STARTED
  ORIENTATION_STEP_COMPLETED
  ORIENTATION_COMPLETED
  INTEGRATION_TEST_STARTED
  INTEGRATION_TEST_PASSED
  INTEGRATION_TEST_FAILED
  TASK_ASSIGNED
  TASK_COMPLETED
  ERROR_OCCURRED
  STATUS_CHANGED

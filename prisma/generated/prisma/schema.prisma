// =============================================================================
// RESOURCE REGISTRY SYSTEM
// =============================================================================

model Resource {
  id          String             @id @default(uuid())
  name        String
  description String?            @db.Text
  category    ResourceCategory
  type        ResourceType
  content     Json
  tags        String[]           @default([])
  version     String
  source      String
  visibility  ResourceVisibility @default(PUBLIC)

  // Metadata
  author     String?
  authorId   String?
  license    String?
  homepage   String?
  repository String?

  // Search and discovery
  searchableText String?  @db.Text
  keywords       String[] @default([])

  // Usage tracking
  usageCount    Int @default(0)
  downloadCount Int @default(0)
  favoriteCount Int @default(0)

  // Status and validation
  status     ResourceStatus @default(ACTIVE)
  isVerified Boolean        @default(false)
  isFeatured Boolean        @default(false)

  // Relationships
  dependencies     String[] @default([])
  relatedResources String[] @default([])

  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  publishedAt  DateTime?
  deprecatedAt DateTime?
  deletedAt    DateTime?

  // Relationships
  versions   ResourceVersion[]
  metadata   ResourceMetadata?
  accessLogs ResourceAccessLog[]

  @@index([category])
  @@index([type])
  @@index([visibility])
  @@index([status])
  @@index([authorId])
  @@index([createdAt])
  @@index([tags])
  @@index([keywords])
  @@map("resources")
}

model ResourceVersion {
  id         String  @id @default(uuid())
  resourceId String
  version    String
  changelog  String? @db.Text
  content    Json
  isLatest   Boolean @default(false)
  isDraft    Boolean @default(false)

  createdAt DateTime @default(now())
  createdBy String?

  // Relationships
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, version])
  @@index([resourceId])
  @@index([version])
  @@index([isLatest])
  @@map("resource_versions")
}

model ResourceMetadata {
  id         String @id @default(uuid())
  resourceId String @unique

  // Extended metadata
  metadata Json @default("{}")

  // Performance metrics
  performanceMetrics Json?

  // Quality scores
  qualityScore    Float?
  complexityScore Float?

  // Additional fields
  estimatedExecutionTime Int?
  requiredDependencies   String[] @default([])
  optionalDependencies   String[] @default([])

  // Environment requirements
  minimumNodeVersion String?
  platforms          String[] @default([])

  // Configuration
  configSchema Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@map("resource_metadata")
}

model ResourceAccessLog {
  id           String         @id @default(uuid())
  resourceId   String
  accessorId   String?
  accessorType String
  action       ResourceAction
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  timestamp    DateTime       @default(now())

  // Relationships
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
  @@index([accessorId])
  @@index([action])
  @@index([timestamp])
  @@map("resource_access_logs")
}


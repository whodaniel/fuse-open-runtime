{
  "manifest_version": 3,
  "name": "TNF AI Bridge",
  "version": "1.0.0",
  "description": "Bridge for AI-to-AI communication between local agents and web-based AI chats",
  
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms"
  ],
  
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://poe.com/*",
    "https://character.ai/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "TNF AI Bridge"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*", 
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://character.ai/*"
      ],
      "js": ["content.js", "injectable-ui.js"],
      "css": ["injectable-ui.css"],
      "run_at": "document_end"
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
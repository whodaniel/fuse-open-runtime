{
  "manifest_version": 3,
  "name": "The New Fuse - Enhanced",
  "version": "2.1.0",
  "description": "Enhanced floating panel with WebSocket chat",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Toggle The New Fuse Panel"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {"service_worker": "background.js"},
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_end"
  }],
  "commands": {
    "toggle-floating-panel": {
      "suggested_key": {"default": "Ctrl+Shift+F"},
      "description": "Toggle floating panel"
    }
  }
}

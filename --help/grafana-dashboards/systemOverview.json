{
  "dashboard": {
    "id": null,
    "title": "System Overview",
    "description": "High-level system health and performance metrics",
    "tags": ["monitoring", "production"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "System Health",
        "type": "stat",
        "targets": [
          {
            "expr": "up",
            "legendFormat": "up",
            "refId": "A"
          },
          {
            "expr": "cpu_usage",
            "legendFormat": "cpu_usage",
            "refId": "A"
          },
          {
            "expr": "memory_usage",
            "legendFormat": "memory_usage",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "requests_per_second",
            "legendFormat": "requests_per_second",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Response Times",
        "type": "graph",
        "targets": [
          {
            "expr": "response_time_p50",
            "legendFormat": "response_time_p50",
            "refId": "A"
          },
          {
            "expr": "response_time_p95",
            "legendFormat": "response_time_p95",
            "refId": "A"
          },
          {
            "expr": "response_time_p99",
            "legendFormat": "response_time_p99",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "error_rate_percent",
            "legendFormat": "error_rate_percent",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Active Users",
        "type": "stat",
        "targets": [
          {
            "expr": "active_users_count",
            "legendFormat": "active_users_count",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}

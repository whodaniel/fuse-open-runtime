{
  "dashboard": {
    "id": null,
    "title": "Business Metrics",
    "description": "Key business and user experience metrics",
    "tags": ["monitoring", "production"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Daily Active Users",
        "type": "stat",

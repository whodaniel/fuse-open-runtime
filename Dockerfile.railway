ARG NODE_VERSION=22
ARG PNPM_VERSION=10.22.0

#------------------------------------------------------------------------------
# Base stage
#------------------------------------------------------------------------------
FROM node:${NODE_VERSION}-alpine AS base
RUN npm i -g pnpm@${PNPM_VERSION}
USER root
WORKDIR /app

#------------------------------------------------------------------------------
# Builder stage
#------------------------------------------------------------------------------
FROM base AS builder
ARG SERVICE_PATH
ARG SERVICE_NAME

# Copy all source files
COPY . .

# Install all dependencies
RUN pnpm install --frozen-lockfile
# Build the target service
RUN pnpm --filter=$SERVICE_NAME build

# Create a clean production-only dependency tree
RUN pnpm deploy --filter=$SERVICE_NAME --prod /prod/deploy

#------------------------------------------------------------------------------
# Runner stage
#------------------------------------------------------------------------------
FROM base AS runner
ARG SERVICE_PATH

# Copy the built artifacts and the production-only node_modules.
COPY --from=builder /prod/deploy/ .

# The CMD will be set by a run script.
COPY --chown=root:root scripts/run-service.sh .
COPY --chown=root:root scripts/healthcheck.sh .
RUN chmod +x ./run-service.sh ./healthcheck.sh

ENV SERVICE_PATH=$SERVICE_PATH
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 CMD ["./healthcheck.sh"]
CMD ["./run-service.sh"]

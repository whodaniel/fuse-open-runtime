root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript, TypeScript, JSX, TSX
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = space
indent_size = 2
max_line_length = 100

# JSON
[*.json]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# HTML
[*.html]
indent_style = space
indent_size = 2

# CSS, SCSS, LESS
[*.{css,scss,less}]
indent_style = space
indent_size = 2

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2

# Python
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# Makefile
[Makefile]
indent_style = tab

# Docker
[Dockerfile*]
indent_style = space
indent_size = 2

# Lock files - no modifications
[{package-lock.json,pnpm-lock.yaml,yarn.lock}]
insert_final_newline = false
trim_trailing_whitespace = false

# Drizzle schema
[*.drizzle]
indent_style = space
indent_size = 2

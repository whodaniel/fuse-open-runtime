{
  "name": "new-fuse-copilot-extension",
  "displayName": "The New Fuse - Copilot Integration",
  "description": "VS Code extension for integrating with The New Fuse agent platform via GitHub Copilot chat participants",
  "version": "1.0.0",
  "publisher": "the-new-fuse",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat Participants",
    "Other"
  ],
  "keywords": [
    "copilot",
    "chat",
    "ai",
    "agents",
    "new-fuse"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "new-fuse.agent",
        "fullName": "New Fuse Agent",
        "name": "fuse",
        "description": "Interact with The New Fuse platform agents through VS Code chat",
        "isSticky": true
      }
    ],
    "commands": [
      {
        "command": "new-fuse.refreshAgents",
        "title": "Refresh Agents",
        "category": "New Fuse"
      },
      {
        "command": "new-fuse.configureTenant",
        "title": "Configure Tenant",
        "category": "New Fuse"
      },
      {
        "command": "new-fuse.viewMetrics",
        "title": "View Integration Metrics",
        "category": "New Fuse"
      }
    ],
    "configuration": {
      "title": "The New Fuse",
      "properties": {
        "newFuse.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "The New Fuse server URL"
        },
        "newFuse.tenantId": {
          "type": "string",
          "default": "",
          "description": "Your tenant ID for multi-tenant support"
        },
        "newFuse.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authentication"
        },
        "newFuse.enableDebugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for troubleshooting"
        },
        "newFuse.streamingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable streaming responses for real-time chat"
        },
        "newFuse.autoRefreshInterval": {
          "type": "number",
          "default": 300000,
          "description": "Auto-refresh interval for agent list (in milliseconds)"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "new-fuse.refreshAgents",
          "when": "true"
        },
        {
          "command": "new-fuse.configureTenant",
          "when": "true"
        },
        {
          "command": "new-fuse.viewMetrics",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^18.x",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2",
    "@vscode/test-cli": "^0.0.4"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "ws": "^8.14.2"
  }
}

{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "rootDir": "src",
    "composite": true,
    "ignoreDeprecations": "5.0"
  },
  "compileOnSave": true,
  "references": [
    {
      "path": "../packages/types"
    }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}

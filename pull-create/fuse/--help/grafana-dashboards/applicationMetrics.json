{
  "dashboard": {
    "id": null,
    "title": "Application Metrics",
    "description": "Detailed application performance and business metrics",
    "tags": [
      "monitoring",
      "production"
    ],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "User Registrations",
        "type": "graph",
        "targets": [
          {
            "expr": "user_registrations_per_hour",
            "legendFormat": "user_registrations_per_hour",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Message Volume",
        "type": "graph",
        "targets": [
          {
            "expr": "messages_per_second",
            "legendFormat": "messages_per_second",
            "refId": "A"
          },
          {
            "expr": "messages_total",
            "legendFormat": "messages_total",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "API Endpoints",
        "type": "table",
        "targets": [
          {
            "expr": "endpoint_requests",
            "legendFormat": "endpoint_requests",
            "refId": "A"
          },
          {
            "expr": "endpoint_errors",
            "legendFormat": "endpoint_errors",
            "refId": "A"
          },
          {
            "expr": "endpoint_latency",
            "legendFormat": "endpoint_latency",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Database Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "db_query_time",
            "legendFormat": "db_query_time",
            "refId": "A"
          },
          {
            "expr": "db_connections_active",
            "legendFormat": "db_connections_active",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Cache Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "cache_hit_rate",
            "legendFormat": "cache_hit_rate",
            "refId": "A"
          },
          {
            "expr": "cache_operations",
            "legendFormat": "cache_operations",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}
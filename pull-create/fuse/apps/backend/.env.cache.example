# ==========================================
# Redis Cache Configuration
# ==========================================

# Redis Connection Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_DB=1

# Default Cache TTL (in seconds)
REDIS_DEFAULT_TTL=3600

# ==========================================
# Cache TTL Presets (in seconds)
# ==========================================

# Short TTL - 5 minutes (300 seconds)
# Use for: Frequently changing data, real-time updates
CACHE_TTL_SHORT=300

# Medium TTL - 30 minutes (1800 seconds)
# Use for: Standard caching, user-specific data
CACHE_TTL_MEDIUM=1800

# Long TTL - 2 hours (7200 seconds)
# Use for: Relatively static data, configuration
CACHE_TTL_LONG=7200

# Very Long TTL - 24 hours (86400 seconds)
# Use for: Nearly static data, reference data
CACHE_TTL_VERY_LONG=86400

# Session TTL - 7 days (604800 seconds)
# Use for: User sessions, authentication tokens
CACHE_TTL_SESSION=604800

# ==========================================
# Cache Monitoring
# ==========================================

# Enable cache monitoring and metrics collection
CACHE_MONITORING_ENABLED=true

# Sample rate for monitoring (percentage: 0-100)
# 100 = monitor all operations, 50 = monitor 50% of operations
CACHE_MONITORING_SAMPLE_RATE=100

# Metrics aggregation interval (in milliseconds)
# How often to aggregate and log metrics
CACHE_METRICS_INTERVAL=60000

# ==========================================
# Cache Configuration
# ==========================================

# Cache key prefix to namespace all cache keys
# Useful for multi-tenant or multi-environment setups
CACHE_KEY_PREFIX=fuse:

# ==========================================
# Example Usage
# ==========================================

# Development
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# CACHE_MONITORING_ENABLED=true

# Production
# REDIS_HOST=redis.production.com
# REDIS_PORT=6379
# REDIS_PASSWORD=strong-password-here
# REDIS_CACHE_DB=1
# CACHE_MONITORING_ENABLED=true
# CACHE_KEY_PREFIX=prod:fuse:

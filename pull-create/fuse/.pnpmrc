# pnpm Configuration for The New Fuse Monorepo
# Optimized for workspace filtering and performance

# Store configuration
store-dir=.pnpm-store
package-import-method=hardlink

# Workspace configuration
link-workspace-packages=true
prefer-workspace-packages=true
save-workspace-protocol=rolling

# Hoisting configuration
hoist-pattern[]=*
hoist-pattern[]=@types/*
shamefully-hoist=true

# Performance optimizations
side-effects-cache=true
side-effects-cache-readonly=false
child-concurrency=5
network-concurrency=16

# Registry and resolution
registry=https://registry.npmjs.org/
resolution-mode=highest
strict-peer-dependencies=false

# Lockfile configuration
lockfile=true
prefer-frozen-lockfile=true
update-notifier=false

# Logging and reporting
reporter=append-only
loglevel=info

# Node.js configuration
use-node-version=18
node-linker=isolated

# Workspace filtering patterns
# These patterns help with targeted testing and building
workspace-concurrency=4

# Security
audit-level=moderate

# Cache configuration
fetch-retries=3
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Development optimizations
enable-pre-post-scripts=true
ignore-scripts=false

# Peer dependency handling
auto-install-peers=true
dedupe-peer-dependents=true

# Publishing configuration
publish-branch=main
git-checks=true
tag-version-prefix=v
#!/bin/bash

# Docker Hub post-build hook for The New Fuse
# This script adds additional tags and metadata after successful build

set -e

echo "=== Docker Hub Post-Build Hook ==="
echo "Image built: $IMAGE_NAME"

# Tag with latest if this is the main branch
if [[ "$SOURCE_BRANCH" == "main" || "$SOURCE_BRANCH" == "master" ]]; then
    echo "Tagging as latest..."
    docker tag $IMAGE_NAME $DOCKER_REPO:latest
fi

# Tag with branch name for feature branches
if [[ "$SOURCE_BRANCH" != "main" && "$SOURCE_BRANCH" != "master" ]]; then
    BRANCH_TAG=$(echo $SOURCE_BRANCH | sed 's/[^a-zA-Z0-9._-]/-/g')
    echo "Tagging with branch name: $BRANCH_TAG"
    docker tag $IMAGE_NAME $DOCKER_REPO:$BRANCH_TAG
fi

# Add commit SHA tag for traceability
SHORT_SHA=$(echo $SOURCE_COMMIT | cut -c1-7)
echo "Tagging with commit SHA: $SHORT_SHA"
docker tag $IMAGE_NAME $DOCKER_REPO:$SHORT_SHA

echo "=== Post-build completed successfully ==="
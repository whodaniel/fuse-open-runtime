{
  "alertRules": [
    {
      "id": "high-error-rate",
      "name": "High Error Rate",
      "description": "Error rate exceeds 5% of total requests",
      "metric": "http_error_rate",
      "operator": "gt",
      "threshold": 5,
      "duration": 300000,
      "severity": "critical",
      "enabled": true,
      "annotations": {
        "summary": "High error rate detected",
        "description": "The error rate has exceeded 5% for more than 5 minutes",
        "runbook": "https://docs.example.com/runbooks/high-error-rate"
      },
      "actions": [
        {
          "type": "slack",
          "config": {
            "channel": "#alerts-critical",
            "webhookUrl": "${SLACK_WEBHOOK_URL}"
          },
          "enabled": true
        },
        {
          "type": "pagerduty",
          "config": {
            "serviceKey": "${PAGERDUTY_SERVICE_KEY}"
          },
          "enabled": true
        }
      ]
    },
    {
      "id": "slow-response-time",
      "name": "Slow Response Time",
      "description": "P95 response time exceeds 2 seconds",
      "metric": "http_response_time_p95",
      "operator": "gt",
      "threshold": 2000,
      "duration": 300000,
      "severity": "warning",
      "enabled": true,
      "annotations": {
        "summary": "Slow response time detected",
        "description": "The P95 response time has exceeded 2 seconds for more than 5 minutes",
        "runbook": "https://docs.example.com/runbooks/slow-response-time"
      },
      "actions": [
        {
          "type": "slack",
          "config": {
            "channel": "#alerts-warning",
            "webhookUrl": "${SLACK_WEBHOOK_URL}"
          },
          "enabled": true
        }
      ]
    },
    {
      "id": "high-memory-usage",
      "name": "High Memory Usage",
      "description": "Memory usage exceeds 90%",
      "metric": "memory_usage_percent",
      "operator": "gt",
      "threshold": 90,
      "duration": 300000,
      "severity": "critical",
      "enabled": true,
      "annotations": {
        "summary": "High memory usage detected",
        "description": "Memory usage has exceeded 90% for more than 5 minutes",
        "runbook": "https://docs.example.com/runbooks/high-memory-usage"
      },
      "actions": [
        {
          "type": "slack",
          "config": {
            "channel": "#alerts-critical",
            "webhookUrl": "${SLACK_WEBHOOK_URL}"
          },
          "enabled": true
        },
        {
          "type": "pagerduty",
          "config": {
            "serviceKey": "${PAGERDUTY_SERVICE_KEY}"
          },
          "enabled": true
        }
      ]
    },
    {
      "id": "database-connection-pool-exhausted",
      "name": "Database Connection Pool Exhausted",
      "description": "Database connection pool utilization exceeds 90%",
      "metric": "database_pool_utilization",
      "operator": "gt",
      "threshold": 90,
      "duration": 60000,
      "severity": "critical",
      "enabled": true,
      "annotations": {
        "summary": "Database connection pool near exhaustion",
        "description": "Connection pool utilization exceeds 90%",
        "runbook": "https://docs.example.com/runbooks/database-connection-pool"
      },
      "actions": [
        {
          "type": "slack",
          "config": {
            "channel": "#alerts-critical",
            "webhookUrl": "${SLACK_WEBHOOK_URL}"
          },
          "enabled": true
        },
        {
          "type": "pagerduty",
          "config": {
            "serviceKey": "${PAGERDUTY_SERVICE_KEY}"
          },
          "enabled": true
        }
      ]
    },
    {
      "id": "slow-database-queries",
      "name": "Slow Database Queries",
      "description": "P95 database query time exceeds 5 seconds",
      "metric": "database_query_time_p95",
      "operator": "gt",
      "threshold": 5000,
      "duration": 300000,
      "severity": "warning",
      "enabled": true,
      "annotations": {
        "summary": "Slow database queries detected",
        "description": "P95 query time exceeds 5 seconds",
        "runbook": "https://docs.example.com/runbooks/slow-database-queries"
      },
      "actions": [
        {
          "type": "slack",
          "config": {
            "channel": "#alerts-warning",
            "webhookUrl": "${SLACK_WEBHOOK_URL}"
          },
          "enabled": true
        }
      ]
    },
    {
      "id": "high-cpu-usage",
      "name": "High CPU Usage",
      "description": "CPU usage exceeds 80%",
      "metric": "cpu_usage_percent",
      "operator": "gt",
      "threshold": 80,
      "duration": 300000,
      "severity": "warning",
      "enabled": true,
      "annotations": {
        "summary": "High CPU usage detected",
        "description": "CPU usage has exceeded 80% for more than 5 minutes",
        "runbook": "https://docs.example.com/runbooks/high-cpu-usage"
      },
      "actions": [
        {
          "type": "slack",
          "config": {
            "channel": "#alerts-warning",
            "webhookUrl": "${SLACK_WEBHOOK_URL}"
          },
          "enabled": true
        }
      ]
    },
    {
      "id": "websocket-connection-surge",
      "name": "WebSocket Connection Surge",
      "description": "WebSocket connections increased by more than 50%",
      "metric": "websocket_connections_change_percent",
      "operator": "gt",
      "threshold": 50,
      "duration": 60000,
      "severity": "warning",
      "enabled": true,
      "annotations": {
        "summary": "WebSocket connection surge detected",
        "description": "WebSocket connections increased significantly",
        "runbook": "https://docs.example.com/runbooks/websocket-surge"
      },
      "actions": [
        {
          "type": "slack",
          "config": {
            "channel": "#alerts-info",
            "webhookUrl": "${SLACK_WEBHOOK_URL}"
          },
          "enabled": true
        }
      ]
    },
    {
      "id": "failed-job-rate",
      "name": "High Failed Job Rate",
      "description": "Job failure rate exceeds 10%",
      "metric": "job_failure_rate",
      "operator": "gt",
      "threshold": 10,
      "duration": 300000,
      "severity": "error",
      "enabled": true,
      "annotations": {
        "summary": "High job failure rate detected",
        "description": "More than 10% of jobs are failing",
        "runbook": "https://docs.example.com/runbooks/failed-jobs"
      },
      "actions": [
        {
          "type": "slack",
          "config": {
            "channel": "#alerts-error",
            "webhookUrl": "${SLACK_WEBHOOK_URL}"
          },
          "enabled": true
        }
      ]
    },
    {
      "id": "service-down",
      "name": "Service Down",
      "description": "Service is not responding to health checks",
      "metric": "service_up",
      "operator": "eq",
      "threshold": 0,
      "duration": 60000,
      "severity": "critical",
      "enabled": true,
      "annotations": {
        "summary": "Service is down",
        "description": "Service has not responded to health checks for more than 1 minute",
        "runbook": "https://docs.example.com/runbooks/service-down"
      },
      "actions": [
        {
          "type": "slack",
          "config": {
            "channel": "#alerts-critical",
            "webhookUrl": "${SLACK_WEBHOOK_URL}"
          },
          "enabled": true
        },
        {
          "type": "pagerduty",
          "config": {
            "serviceKey": "${PAGERDUTY_SERVICE_KEY}"
          },
          "enabled": true
        }
      ]
    }
  ],
  "notificationChannels": {
    "slack": {
      "defaultChannel": "#alerts",
      "webhookUrl": "${SLACK_WEBHOOK_URL}",
      "username": "Monitoring Bot",
      "iconEmoji": ":warning:"
    },
    "email": {
      "from": "alerts@example.com",
      "to": ["oncall@example.com"],
      "smtpHost": "${SMTP_HOST}",
      "smtpPort": 587,
      "smtpSecure": true
    },
    "pagerduty": {
      "serviceKey": "${PAGERDUTY_SERVICE_KEY}",
      "apiUrl": "https://events.pagerduty.com/v2/enqueue"
    },
    "webhook": {
      "url": "${WEBHOOK_URL}",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer ${WEBHOOK_TOKEN}"
      }
    }
  }
}

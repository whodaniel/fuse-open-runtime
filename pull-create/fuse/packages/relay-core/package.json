{
  "name": "@the-new-fuse/relay-core",
  "version": "1.0.0",
  "description": "Unified relay system for The New Fuse framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tnf-relay": "./dist/standalone-relay.js"
  },
  "scripts": {
    "build": "tsc",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "relay": "node dist/standalone-relay.js",
    "relay:dev": "ts-node src/standalone-relay.ts",
    "master-clock": "node dist/master-clock.js",
    "master-clock:dev": "ts-node src/master-clock.ts",
    "broker-agent": "node dist/broker-agent.js",
    "broker-agent:dev": "ts-node src/broker-agent.ts",
    "director-agent": "node dist/director-agent.js",
    "director-agent:dev": "ts-node src/director-agent.ts",
    "super-cycle:event": "ts-node src/super-cycle-client.ts",
    "super-cycle:status": "ts-node src/super-cycle-client.ts --action status",
    "super-cycle:self-prompts": "ts-node src/super-cycle-client.ts --action self-prompts",
    "orchestrate": "node dist/master-clock.js & node dist/standalone-relay.js",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@the-new-fuse/database": "workspace:*",
    "chokidar": "^4.0.3",
    "ethers": "^6.15.0",
    "express": "^4.22.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "redis": "^5.10.0",
    "ws": "^8.18.3",
    "zod": "^4.2.1",
    "@the-new-fuse/infrastructure": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.8.1",
    "@types/ws": "^8.18.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}

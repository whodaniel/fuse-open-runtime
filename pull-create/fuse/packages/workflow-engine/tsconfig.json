{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@the-new-fuse/database": ["../database/src"],
      "@the-new-fuse/database/*": ["../database/src/*"],
      "@the-new-fuse/mcp-core": ["../mcp-core/src"],
      "@the-new-fuse/mcp-core/*": ["../mcp-core/src/*"],
      "@the-new-fuse/security": ["../security/src"],
      "@the-new-fuse/security/*": ["../security/src/*"],
      "@the-new-fuse/relay-core": ["../relay-core/src"],
      "@the-new-fuse/relay-core/*": ["../relay-core/src/*"]
    },
    "types": ["node", "jest"]
  },
  "include": ["src"],
  "references": [
    { "path": "../mcp-core" },
    { "path": "../relay-core" },
    { "path": "../database" },
    { "path": "../security" }
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}

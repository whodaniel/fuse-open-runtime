#!/bin/bash

# Test Jules CLI Agent Integration with The New Fuse
# This script verifies that Jules is properly integrated and functional

set -e

echo "🧪 Testing Jules CLI Agent Integration"
echo "======================================"
echo ""

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Test results tracking
TESTS_PASSED=0
TESTS_FAILED=0

# Helper function for test assertions
test_assert() {
    local test_name="$1"
    local command="$2"

    echo -n "Testing: $test_name... "

    if eval "$command" > /dev/null 2>&1; then
        echo -e "${GREEN}✅ PASS${NC}"
        ((TESTS_PASSED++))
        return 0
    else
        echo -e "${RED}❌ FAIL${NC}"
        ((TESTS_FAILED++))
        return 1
    fi
}

test_assert_file_exists() {
    local test_name="$1"
    local file_path="$2"

    echo -n "Testing: $test_name... "

    if [ -f "$file_path" ]; then
        echo -e "${GREEN}✅ PASS${NC}"
        ((TESTS_PASSED++))
        return 0
    else
        echo -e "${RED}❌ FAIL${NC} (File not found: $file_path)"
        ((TESTS_FAILED++))
        return 1
    fi
}

test_assert_contains() {
    local test_name="$1"
    local file_path="$2"
    local search_string="$3"

    echo -n "Testing: $test_name... "

    if grep -q "$search_string" "$file_path" 2>/dev/null; then
        echo -e "${GREEN}✅ PASS${NC}"
        ((TESTS_PASSED++))
        return 0
    else
        echo -e "${RED}❌ FAIL${NC} (String not found in $file_path)"
        ((TESTS_FAILED++))
        return 1
    fi
}

echo "1️⃣  Checking Jules CLI Installation"
echo "─────────────────────────────────────"
test_assert "Jules CLI is installed" "which jules"
test_assert "Jules CLI is executable" "jules --help"
echo ""

echo "2️⃣  Verifying Agent Definition Files"
echo "─────────────────────────────────────"
test_assert_file_exists "Agent definition exists" ".claude/agents/jules-cli-agent.md"
test_assert_contains "Agent has correct name" ".claude/agents/jules-cli-agent.md" "name: jules-cli-agent"
test_assert_contains "Agent has description" ".claude/agents/jules-cli-agent.md" "Google's asynchronous coding agent"
test_assert_contains "Agent has capabilities" ".claude/agents/jules-cli-agent.md" "parallel-task-execution"
echo ""

echo "3️⃣  Verifying Slash Command Files"
echo "─────────────────────────────────────"
test_assert_file_exists "Slash command exists" ".claude/commands/delegate-to-jules.md"
test_assert_contains "Command has description" ".claude/commands/delegate-to-jules.md" "Delegate complex coding tasks"
test_assert_contains "Command has usage examples" ".claude/commands/delegate-to-jules.md" "parallel-specialized"
test_assert_contains "Command has task templates" ".claude/commands/delegate-to-jules.md" "Task Template for Jules"
echo ""

echo "4️⃣  Verifying Registration Script"
echo "─────────────────────────────────────"
test_assert_file_exists "Registration script exists" "scripts/register-jules-agent.ts"
test_assert_contains "Script has registration data" "scripts/register-jules-agent.ts" "julesAgentRegistration"
test_assert_contains "Script has API endpoint" "scripts/register-jules-agent.ts" "/api/agent-registry/register"
echo ""

echo "5️⃣  Verifying Documentation"
echo "─────────────────────────────────────"
test_assert_file_exists "Integration docs exist" "docs/JULES_AGENT_INTEGRATION.md"
test_assert_file_exists "Session tracker exists" "docs/JULES_TASK_TRACKER.md"
test_assert_file_exists "Session summary exists" "docs/JULES_SESSIONS_SUMMARY.md"
test_assert_contains "Docs have quick start" "docs/JULES_AGENT_INTEGRATION.md" "Quick Start"
test_assert_contains "Docs have examples" "docs/JULES_AGENT_INTEGRATION.md" "Real-World Examples"
echo ""

echo "6️⃣  Testing Jules CLI Functionality"
echo "─────────────────────────────────────"
echo -n "Testing: Can list Jules sessions... "
if jules remote list --session > /dev/null 2>&1; then
    echo -e "${GREEN}✅ PASS${NC}"
    ((TESTS_PASSED++))
else
    echo -e "${YELLOW}⚠️  WARN${NC} (Requires internet connection)"
fi

echo -n "Testing: Can access Jules help... "
if jules --help | grep -q "Usage:" 2>/dev/null; then
    echo -e "${GREEN}✅ PASS${NC}"
    ((TESTS_PASSED++))
else
    echo -e "${RED}❌ FAIL${NC}"
    ((TESTS_FAILED++))
fi
echo ""

echo "7️⃣  Validating Agent Metadata"
echo "─────────────────────────────────────"
test_assert_contains "Has version number" ".claude/agents/jules-cli-agent.md" "version: 1.0.0"
test_assert_contains "Has agent type" ".claude/agents/jules-cli-agent.md" "agent_type: external"
test_assert_contains "Has color" ".claude/agents/jules-cli-agent.md" "color: Blue"
test_assert_contains "Has tools" ".claude/agents/jules-cli-agent.md" "tools: [Bash]"
echo ""

echo "8️⃣  Checking Integration Points"
echo "─────────────────────────────────────"
test_assert_contains "References TNF registry" "docs/JULES_AGENT_INTEGRATION.md" "Agent Registry"
test_assert_contains "References workflows" "docs/JULES_AGENT_INTEGRATION.md" "Multi-Agent Workflows"
test_assert_contains "Has API endpoints" "docs/JULES_AGENT_INTEGRATION.md" "POST /api/agent-registry/register"
echo ""

echo ""
echo "================================================"
echo "📊 Test Summary"
echo "================================================"
echo -e "Tests Passed: ${GREEN}${TESTS_PASSED}${NC}"
echo -e "Tests Failed: ${RED}${TESTS_FAILED}${NC}"
echo -e "Total Tests:  $((TESTS_PASSED + TESTS_FAILED))"
echo ""

if [ $TESTS_FAILED -eq 0 ]; then
    echo -e "${GREEN}✨ All tests passed! Jules integration is ready.${NC}"
    echo ""
    echo "🚀 Next Steps:"
    echo "1. Register Jules in database: pnpm tsx scripts/register-jules-agent.ts"
    echo "2. Use slash command: /delegate-to-jules parallel-specialized \"[tasks]\""
    echo "3. Monitor sessions: jules remote list --session"
    echo "4. Read docs: docs/JULES_AGENT_INTEGRATION.md"
    echo ""
    exit 0
else
    echo -e "${RED}⚠️  Some tests failed. Please review the errors above.${NC}"
    echo ""
    exit 1
fi

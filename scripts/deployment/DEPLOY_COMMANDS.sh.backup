#!/bin/bash
# The New Fuse - Complete Railway Deployment Commands
# Run these commands in your terminal

echo "======================================================================"
echo "The New Fuse - Railway Deployment"
echo "======================================================================"
echo ""
echo "✅ Your Railway project has been created!"
echo "   Project URL: https://railway.com/project/453fe77c-a788-412d-8507-bc3e7bc548c3"
echo ""
echo "Follow these steps to complete deployment:"
echo ""

echo "======================================================================"
echo "STEP 1: Add PostgreSQL Database"
echo "======================================================================"
echo ""
echo "Option A - Via Dashboard (Recommended):"
echo "  1. Open: https://railway.com/project/453fe77c-a788-412d-8507-bc3e7bc548c3"
echo "  2. Click '+ New'"
echo "  3. Select 'Database' → 'PostgreSQL'"
echo "  4. Wait 30 seconds for it to provision"
echo ""
echo "Option B - Via CLI:"
echo "  Run: railway add"
echo "  Select: Database → PostgreSQL"
echo ""
read -p "Press Enter when PostgreSQL is added..."

echo ""
echo "======================================================================"
echo "STEP 2: Deploy API Service"
echo "======================================================================"
echo ""
echo "Run these commands:"
echo ""
echo "  cd /path/to/Desktop/A1-Inter-LLM-Com/The-New-Fuse/apps/api"
echo "  railway up"
echo ""
echo "This will:"
echo "  - Upload your code"
echo "  - Build the Docker image (10-15 minutes)"
echo "  - Deploy the service"
echo "  - Give you a URL"
echo ""
echo "Copy the commands above and run them now."
echo ""
read -p "Press Enter when API is deployed..."

echo ""
echo "======================================================================"
echo "STEP 3: Deploy Frontend Service"
echo "======================================================================"
echo ""
echo "Run these commands:"
echo ""
echo "  cd /path/to/Desktop/A1-Inter-LLM-Com/The-New-Fuse/apps/frontend"
echo "  railway up"
echo ""
echo "This will build and deploy your frontend (5-10 minutes)"
echo ""
echo "Copy the commands above and run them now."
echo ""
read -p "Press Enter when Frontend is deployed..."

echo ""
echo "======================================================================"
echo "STEP 4: Configure Environment Variables"
echo "======================================================================"
echo ""
echo "Go to Railway Dashboard: https://railway.com/project/453fe77c-a788-412d-8507-bc3e7bc548c3"
echo ""
echo "For API Service:"
echo "  1. Click on the 'api' service"
echo "  2. Go to 'Variables' tab"
echo "  3. Click 'Add Variable' and add these:"
echo ""
echo "     NODE_ENV=production"
echo "     PORT=3001"
echo "     DATABASE_URL=\${{Postgres.DATABASE_URL}}"
echo "     JWT_SECRET=<generate with: openssl rand -base64 32>"
echo ""
echo "For Frontend Service:"
echo "  1. Click on the 'frontend' service"
echo "  2. Go to 'Variables' tab"
echo "  3. Add these:"
echo ""
echo "     NODE_ENV=production"
echo "     PORT=3000"
echo "     VITE_API_URL=<your-api-url-from-railway>"
echo ""
echo "Generate JWT Secret now:"
openssl rand -base64 32
echo ""
read -p "Press Enter when environment variables are configured..."

echo ""
echo "======================================================================"
echo "STEP 5: Get Your URLs"
echo "======================================================================"
echo ""
echo "Check deployment status:"
echo "  railway status"
echo ""
echo "View your services:"
echo "  railway open"
echo ""
echo "Get service URLs:"
echo "  1. Go to Railway Dashboard"
echo "  2. Click on each service"
echo "  3. Go to 'Settings' → 'Domains'"
echo "  4. Copy the Railway-provided domain"
echo ""
echo "Your frontend will be accessible at the frontend domain!"
echo ""

echo "======================================================================"
echo "DEPLOYMENT COMPLETE! 🎉"
echo "======================================================================"
echo ""
echo "Next steps:"
echo "  1. Visit your frontend URL"
echo "  2. Test the application"
echo "  3. Monitor logs: railway logs"
echo ""
echo "Useful commands:"
echo "  - View logs:      railway logs --service api"
echo "  - Check status:   railway status"
echo "  - Open dashboard: railway open"
echo "  - Redeploy:       railway up --detach"
echo ""
echo "Need help? See DEPLOYMENT_GUIDE_RAILWAY.md"
echo ""

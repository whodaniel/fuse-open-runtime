{
  "testSuites": {
    "baseline": {
      "name": "Baseline Performance Tests",
      "description": "Basic functionality tests with moderate load",
      "tests": [
        {
          "name": "API Health Check - Baseline",
          "url": "http://localhost:3000/api/health",
          "method": "GET",
          "duration": 60,
          "rate": 100,
          "connections": 50,
          "assertions": {
            "responseTime": 100,
            "statusCode": 200,
            "failureRate": 0.001
          }
        },
        {
          "name": "User Authentication - Baseline",
          "url": "http://localhost:3000/api/auth/login",
          "method": "POST",
          "duration": 120,
          "rate": 50,
          "connections": 25,
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "email": "loadtest{{$randomInt}}@example.com",
            "password": "SecurePassword123!"
          },
          "assertions": {
            "responseTime": 300,
            "statusCode": 200,
            "failureRate": 0.002
          }
        }
      ]
    },
    "stress": {
      "name": "Stress Tests - High Load",
      "description": "High-load tests to identify breaking points",
      "tests": [
        {
          "name": "API Stress Test - 10K Concurrent",
          "url": "http://localhost:3000/api/users/profile",
          "method": "GET",
          "duration": 300,
          "rate": 1000,
          "connections": 10000,
          "rampUp": 60,
          "headers": {
            "Authorization": "Bearer {{TOKEN}}"
          },
          "assertions": {
            "responseTime": 500,
            "statusCode": 200,
            "failureRate": 0.01,
            "throughput": 8000
          }
        },
        {
          "name": "Database Write Stress - 5K Concurrent",
          "url": "http://localhost:3000/api/features",
          "method": "POST",
          "duration": 180,
          "rate": 500,
          "connections": 5000,
          "rampUp": 30,
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{TOKEN}}"
          },
          "body": {
            "name": "LoadTest Feature {{$timestamp}}",
            "description": "Generated during load testing",
            "status": "active",
            "metadata": {
              "testId": "{{$uuid}}",
              "timestamp": "{{$timestamp}}"
            }
          },
          "assertions": {
            "responseTime": 1000,
            "statusCode": 201,
            "failureRate": 0.02,
            "throughput": 400
          }
        }
      ]
    },
    "volume": {
      "name": "Volume Tests - Millions of Users",
      "description": "Tests designed to simulate millions of concurrent users",
      "tests": [
        {
          "name": "Million User Simulation - Read Heavy",
          "url": "http://localhost:3000/api/dashboard/data",
          "method": "GET",
          "duration": 600,
          "rate": 50000,
          "connections": 100000,
          "rampUp": 120,
          "headers": {
            "Authorization": "Bearer {{TOKEN}}",
            "Cache-Control": "no-cache"
          },
          "assertions": {
            "responseTime": 200,
            "statusCode": 200,
            "failureRate": 0.001,
            "throughput": 45000,
            "p95ResponseTime": 400,
            "p99ResponseTime": 800
          },
          "thresholds": {
            "http_req_duration": ["p(95)<400", "p(99)<800"],
            "http_req_failed": ["rate<0.001"],
            "http_reqs": ["rate>45000"]
          }
        },
        {
          "name": "Million User Simulation - Mixed Workload",
          "scenarios": [
            {
              "name": "read_users",
              "weight": 70,
              "url": "http://localhost:3000/api/users/{{$randomUserId}}",
              "method": "GET",
              "rate": 35000,
              "connections": 70000
            },
            {
              "name": "write_users", 
              "weight": 20,
              "url": "http://localhost:3000/api/users/activity",
              "method": "POST",
              "rate": 10000,
              "connections": 20000,
              "body": {
                "action": "page_view",
                "page": "/dashboard",
                "timestamp": "{{$timestamp}}"
              }
            },
            {
              "name": "search_users",
              "weight": 10,
              "url": "http://localhost:3000/api/search",
              "method": "GET",
              "rate": 5000,
              "connections": 10000,
              "params": {
                "q": "{{$randomSearchTerm}}",
                "limit": 20
              }
            }
          ],
          "duration": 900,
          "rampUp": 180,
          "assertions": {
            "responseTime": 300,
            "failureRate": 0.002,
            "throughput": 48000
          }
        }
      ]
    },
    "endurance": {
      "name": "Endurance Tests - Long Duration",
      "description": "Long-running tests to identify memory leaks and performance degradation",
      "tests": [
        {
          "name": "24-Hour Endurance Test",
          "url": "http://localhost:3000/api/health",
          "method": "GET",
          "duration": 86400,
          "rate": 1000,
          "connections": 5000,
          "rampUp": 300,
          "assertions": {
            "responseTime": 150,
            "statusCode": 200,
            "failureRate": 0.001,
            "memoryLeakThreshold": 0.1
          },
          "monitoring": {
            "memoryUsage": true,
            "cpuUsage": true,
            "diskUsage": true,
            "networkUsage": true
          }
        }
      ]
    },
    "spike": {
      "name": "Spike Tests - Traffic Surges",
      "description": "Tests to validate system behavior during sudden traffic spikes",
      "tests": [
        {
          "name": "Black Friday Spike Simulation",
          "phases": [
            {
              "name": "normal_load",
              "duration": 300,
              "rate": 1000,
              "connections": 5000
            },
            {
              "name": "spike_start",
              "duration": 60,
              "rate": 50000,
              "connections": 100000,
              "rampUp": 10
            },
            {
              "name": "peak_load",
              "duration": 600,
              "rate": 75000,
              "connections": 150000
            },
            {
              "name": "spike_end",
              "duration": 120,
              "rate": 1000,
              "connections": 5000,
              "rampDown": 60
            }
          ],
          "url": "http://localhost:3000/api/products/featured",
          "method": "GET",
          "assertions": {
            "responseTime": 500,
            "statusCode": 200,
            "failureRate": 0.005,
            "recoveryTime": 300
          }
        }
      ]
    }
  },
  "globalConfig": {
    "outputDir": "test-results/enhanced-load-tests",
    "parallel": true,
    "verbose": true,
    "reportFormats": ["json", "html", "junit"],
    "realTimeMonitoring": true,
    "alerting": {
      "enabled": true,
      "webhookUrl": "http://localhost:3000/api/alerts/load-test",
      "thresholds": {
        "errorRate": 0.01,
        "responseTime": 1000,
        "throughput": 1000
      }
    }
  },
  "infrastructure": {
    "monitoring": {
      "prometheus": {
        "enabled": true,
        "endpoint": "http://localhost:9090"
      },
      "grafana": {
        "enabled": true,
        "endpoint": "http://localhost:3001"
      },
      "jaeger": {
        "enabled": true,
        "endpoint": "http://localhost:14268"
      }
    },
    "databases": {
      "postgresql": {
        "connectionString": "postgresql://user:pass@localhost:5432/loadtest",
        "maxConnections": 1000,
        "monitoring": true
      },
      "redis": {
        "connectionString": "redis://localhost:6379",
        "maxConnections": 10000,
        "monitoring": true
      }
    }
  },
  "scenarios": {
    "userJourney": {
      "name": "Complete User Journey",
      "description": "Simulates complete user workflows",
      "steps": [
        {
          "name": "landing_page",
          "url": "http://localhost:3000/",
          "method": "GET",
          "weight": 100,
          "thinkTime": 2
        },
        {
          "name": "user_registration",
          "url": "http://localhost:3000/api/auth/register",
          "method": "POST",
          "weight": 30,
          "body": {
            "email": "user{{$randomInt}}@example.com",
            "password": "SecurePass123!",
            "firstName": "{{$randomFirstName}}",
            "lastName": "{{$randomLastName}}"
          },
          "thinkTime": 5
        },
        {
          "name": "user_login",
          "url": "http://localhost:3000/api/auth/login",
          "method": "POST",
          "weight": 80,
          "body": {
            "email": "{{$email}}",
            "password": "{{$password}}"
          },
          "thinkTime": 3
        },
        {
          "name": "dashboard_access",
          "url": "http://localhost:3000/api/dashboard",
          "method": "GET",
          "weight": 90,
          "headers": {
            "Authorization": "Bearer {{$token}}"
          },
          "thinkTime": 10
        },
        {
          "name": "feature_interaction",
          "url": "http://localhost:3000/api/features/{{$featureId}}",
          "method": "GET",
          "weight": 60,
          "headers": {
            "Authorization": "Bearer {{$token}}"
          },
          "thinkTime": 15
        },
        {
          "name": "user_logout",
          "url": "http://localhost:3000/api/auth/logout",
          "method": "POST",
          "weight": 70,
          "headers": {
            "Authorization": "Bearer {{$token}}"
          },
          "thinkTime": 1
        }
      ]
    }
  },
  "dataGeneration": {
    "users": {
      "count": 1000000,
      "template": {
        "email": "user{{$index}}@loadtest.com",
        "password": "LoadTest123!",
        "firstName": "{{$randomFirstName}}",
        "lastName": "{{$randomLastName}}",
        "createdAt": "{{$randomPastDate}}"
      }
    },
    "features": {
      "count": 10000,
      "template": {
        "name": "Feature {{$index}}",
        "description": "Load test feature {{$index}}",
        "status": "{{$randomStatus}}",
        "createdAt": "{{$randomPastDate}}"
      }
    }
  },
  "validation": {
    "preTestChecks": [
      "database_connectivity",
      "api_health",
      "cache_connectivity",
      "monitoring_systems"
    ],
    "postTestChecks": [
      "data_integrity",
      "memory_leaks",
      "error_logs",
      "performance_regression"
    ]
  },
  "reporting": {
    "dashboard": {
      "enabled": true,
      "port": 8080,
      "realTime": true
    },
    "notifications": {
      "slack": {
        "enabled": false,
        "webhook": ""
      },
      "email": {
        "enabled": false,
        "recipients": []
      }
    },
    "artifacts": {
      "screenshots": true,
      "logs": true,
      "metrics": true,
      "traces": true
    }
  }
}
#!/bin/bash

# Claude Ping Controller Desktop Icon
# Creates a clickable desktop shortcut for ping control

DESKTOP_PATH="$HOME/Desktop"
ICON_NAME="Claude Ping Controller"
SCRIPT_PATH="/path/to/Desktop/A1-Inter-LLM-Com/The New Fuse/scripts"

# Create the application bundle structure
APP_PATH="$DESKTOP_PATH/$ICON_NAME.app"
mkdir -p "$APP_PATH/Contents/MacOS"
mkdir -p "$APP_PATH/Contents/Resources"

# Create Info.plist
cat > "$APP_PATH/Contents/Info.plist" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>ClaudePingController</string>
    <key>CFBundleIdentifier</key>
    <string>com.thenewfuse.claudeping</string>
    <key>CFBundleName</key>
    <string>Claude Ping Controller</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleSignature</key>
    <string>????</string>
</dict>
</plist>
EOF

# Create the executable script
cat > "$APP_PATH/Contents/MacOS/ClaudePingController" << 'EOF'
#!/usr/bin/osascript

-- Quick Claude Ping Controller
-- Double-click desktop icon to control ping

-- Check current ping status
try
    set processCheck to (do shell script "ps aux | grep 'claude-ping-with-send' | grep -v grep | wc -l")
    if processCheck > 0 then
        set isRunning to true
    else
        set isRunning to false
    end if
end try

set statusIcon to "🔴"
set statusText to "STOPPED"
if isRunning then
    set statusIcon to "🟢"
    set statusText to "RUNNING"
end if

-- Show quick control dialog
set controlChoice to (display dialog statusIcon & " Claude Ping Controller" & return & return & "Current Status: " & statusText & return & return & "Quick Actions:" buttons {"Cancel", "View Logs", "Toggle"} default button "Toggle" with title "🎯 Claude Ping")

set buttonPressed to button returned of controlChoice

if buttonPressed is "Toggle" then
    if isRunning then
        -- Stop ping
        try
            do shell script "pkill -f 'claude-ping-with-send.scpt'"
            display notification "🛑 Claude ping stopped!" with title "Ping Controller" sound name "Glass"
        on error errMsg
            display alert "Failed to stop ping: " & errMsg
        end try
    else
        -- Start ping
        try
            do shell script "osascript '/path/to/Desktop/A1-Inter-LLM-Com/The New Fuse/scripts/claude-ping-with-send.scpt' > /tmp/claude-ping-send.log 2>&1 &"
            display notification "✅ Claude ping started!" with title "Ping Controller" sound name "Glass"
        on error errMsg
            display alert "Failed to start ping: " & errMsg
        end try
    end if
    
else if buttonPressed is "View Logs" then
    try
        set logContent to (do shell script "tail -15 /tmp/claude-ping-send.log 2>/dev/null || echo 'No logs found'")
        display dialog "Recent Ping Activity:" & return & return & logContent buttons {"Close"} with title "📋 Ping Logs"
    on error
        display alert "Could not read log file"
    end try
end if
EOF

# Make the executable script runnable
chmod +x "$APP_PATH/Contents/MacOS/ClaudePingController"

echo "✅ Desktop icon created: $APP_PATH"
echo "🎯 Double-click the 'Claude Ping Controller' icon on your desktop to control the ping system!"

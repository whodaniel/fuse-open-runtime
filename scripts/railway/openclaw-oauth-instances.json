{
  "instances": [
    {
      "name": "openclaw-cloud-codex",
      "service": "openclaw-cloud",
      "provider": "openai-codex",
      "authFile": "~/.codex-tenants/openclaw-cloud-account/auth.json",
      "primaryModel": "openai-codex/gpt-5.3-codex",
      "fallbackModels": "openai-codex/gpt-5.1-codex,openai-codex/gpt-5-mini",
      "paths": {
        "access": ".tokens.access_token",
        "refresh": ".tokens.refresh_token",
        "account": ".tokens.account_id"
      }
    },
    {
      "name": "openclaw-primary-codex",
      "service": "openclaw-primary",
      "provider": "openai-codex",
      "authFile": "~/.codex-tenants/proof-tenant-a/auth.json",
      "primaryModel": "openai-codex/gpt-5.3-codex",
      "fallbackModels": "openai-codex/gpt-5.1-codex,openai-codex/gpt-5-mini",
      "paths": {
        "access": ".tokens.access_token",
        "refresh": ".tokens.refresh_token",
        "account": ".tokens.account_id"
      }
    }
  ]
}

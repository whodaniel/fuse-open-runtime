{
  "instances": [
    {
      "name": "openclaw-cloud-codex",
      "instanceId": "TNF-OC-001",
      "instanceName": "OpenClaw Cloud",
      "service": "openclaw-cloud",
      "provider": "openai-codex",
      "authFile": "~/.codex-tenants/openclaw-cloud-account/auth.json",
      "primaryModel": "openai-codex/gpt-5.3-codex",
      "fallbackModels": "openai-codex/gpt-5.2-codex,openai-codex/gpt-5.1-codex,openai-codex/gpt-5-mini",
      "paths": {
        "access": ".tokens.access_token",
        "refresh": ".tokens.refresh_token",
        "account": ".tokens.account_id"
      }
    },
    {
      "name": "openclaw-primary-codex",
      "instanceId": "TNF-OC-002",
      "instanceName": "OpenClaw Primary",
      "service": "openclaw-primary",
      "provider": "openai-codex",
      "authFile": "~/.codex-tenants/proof-tenant-a/auth.json",
      "primaryModel": "openai-codex/gpt-5.3-codex",
      "fallbackModels": "openai-codex/gpt-5.2-codex,openai-codex/gpt-5.1-codex,openai-codex/gpt-5-mini",
      "paths": {
        "access": ".tokens.access_token",
        "refresh": ".tokens.refresh_token",
        "account": ".tokens.account_id"
      }
    },
    {
      "name": "openclaw-anthropic",
      "instanceId": "TNF-OC-003",
      "instanceName": "OpenClaw Anthropic",
      "service": "openclaw-cloud",
      "provider": "anthropic",
      "authFile": "~/.tnf-auth/anthropic/auth.json",
      "primaryModel": "anthropic/claude-sonnet-4.5",
      "fallbackModels": "anthropic/claude-opus-4.1",
      "paths": {
        "access": ".tokens.access_token",
        "refresh": ".tokens.refresh_token"
      }
    },
    {
      "name": "openclaw-google",
      "instanceId": "TNF-OC-004",
      "instanceName": "OpenClaw Google",
      "service": "openclaw-cloud",
      "provider": "google-antigravity",
      "authFile": "~/.tnf-auth/google/auth.json",
      "primaryModel": "google-antigravity/gemini-2.5-pro",
      "fallbackModels": "google-antigravity/gemini-2.0-flash",
      "paths": {
        "access": ".tokens.access_token",
        "refresh": ".tokens.refresh_token",
        "googleEmail": ".profile.email",
        "googleProject": ".profile.project_id"
      }
    }
  ]
}

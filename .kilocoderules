    service = new UserService(repository);
  });

  describe('createUser', () => {
    it('should create a new user with valid data', async () => {
      const dto = { email: 'test@example.com', password: 'SecurePass123!' };
      repository.save.mockResolvedValue({ id: '1', ...dto });

      const result = await service.createUser(dto);

      expect(result).toBeDefined();
      expect(result.email).toBe(dto.email);
      expect(repository.save).toHaveBeenCalledWith(expect.any(User));
    });

    it('should throw error for duplicate email', async () => {
      const dto = { email: 'exists@example.com', password: 'SecurePass123!' };
      repository.findByEmail.mockResolvedValue({ id: '1', ...dto });

      await expect(service.createUser(dto)).rejects.toThrow(ConflictException);
    });
  });
});

# A2A Protocol Configuration
A2A_PROTOCOL_VERSION=1.0.0
A2A_REDIS_URL=redis://localhost:6379
A2A_WEBSOCKET_PORT=3001
A2A_ENABLE_SIGNATURES=false
A2A_ENABLE_ENCRYPTION=false
A2A_ENABLE_METRICS=true
A2A_HEARTBEAT_INTERVAL=30000
A2A_CONNECTION_TIMEOUT=60000
A2A_SECRET_KEY="YOUR_A2A_SECRET_KEY"
A2A_TIMEOUT=30000
A2A_RETRY_ATTEMPTS=3

# Endpoints
A2A_PRIMARY_ENDPOINT=http://localhost:3000
A2A_FALLBACK_ENDPOINT=http://localhost:3001

# Frontend A2A Configuration
REACT_APP_A2A_WEBSOCKET_URL=ws://localhost:3001
REACT_APP_A2A_API_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=a2a_metrics
DB_USER=newfuse
DB_PASSWORD="YOUR_DB_PASSWORD"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring
METRICS_RETENTION_DAYS=30
ENABLE_DETAILED_LOGGING=true

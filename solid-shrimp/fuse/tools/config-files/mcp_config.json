{
  "version": "2.1.0",
  "servers": {
    "the-new-fuse-main": {
      "type": "mcp",
      "transport": "stdio",
      "host": "localhost", 
      "port": 3001,
      "protocol": "http",
      "capabilities": [
        "agent-management",
        "chat-operations", 
        "workflow-execution",
        "monitoring",
        "automation",
        "file-operations"
      ],
      "description": "Complete The New Fuse platform MCP server",
      "enabled": true,
      "config": {
        "logLevel": "info",
        "enableAuth": true,
        "enableMetrics": true,
        "enableWebSocket": true
      }
    },
    "database": {
      "type": "database",
      "provider": "postgresql",
      "connection": "postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}",
      "enabled": true,
      "capabilities": ["read", "write", "schema"]
    },
    "cache": {
      "type": "cache", 
      "provider": "redis",
      "connection": "redis://${REDIS_HOST}:${REDIS_PORT}",
      "enabled": true,
      "capabilities": ["read", "write", "expire"]
    }
  },
  "agent-discovery": {
    "auto-discovery": true,
    "scan-interval": 300,
    "capability-validation": true,
    "health-check-interval": 60
  },
  "security": {
    "jwt-secret": "${JWT_SECRET}",
    "jwt-expiration": 3600,
    "rate-limit": {
      "window-ms": 60000,
      "max-requests": 200
    },
    "cors": {
      "allowed-origins": [
        "http://localhost:3000",
        "http://localhost:5173", 
        "http://localhost:3001"
      ],
      "allowed-methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allowed-headers": ["Content-Type", "Authorization", "X-MCP-Protocol"]
    }
  },
  "monitoring": {
    "enabled": true,
    "metrics": {
      "enabled": true,
      "endpoint": "/metrics",
      "interval": 30
    },
    "health": {
      "enabled": true,
      "endpoint": "/health", 
      "deep-check": true
    },
    "logging": {
      "level": "info",
      "format": "json",
      "file": "./logs/mcp-server.log",
      "rotation": {
        "enabled": true,
        "maxFiles": "7d",
        "maxSize": "10m"
      }
    }
  },
  "ui": {
    "dashboard-enabled": true,
    "theme": "dark",
    "port": 3002,
    "enabled": true
  },
  "features": {
    "real-time-updates": true,
    "batch-operations": true,
    "streaming": true,
    "caching": true,
    "compression": true
  },
  "mcpServers": {
    "the-new-fuse-main": {
      "command": "node",
      "args": ["./src/mcp/server.ts"],
      "env": {
        "MCP_PORT": "3001",
        "WORKSPACE_ROOT": "./",
        "LOG_LEVEL": "info",
        "ENABLE_STREAMABLE_HTTP": "true",
        "ENABLE_PROGRESS_NOTIFICATIONS": "true",
        "ENHANCED_UI": "true"
      },
      "description": "The New Fuse MCP Server with complete platform capabilities and internal client integration"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "--allow-dir", "./data"
      ]
    },
    "brave-search": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e", "BRAVE_API_KEY",
        "modelcontextprotocol/brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "postgres": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e", "POSTGRES_CONNECTION_STRING",
        "modelcontextprotocol/postgres"
      ],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${DATABASE_URL}"
      }
    },
    "browsermcp": {
      "command": "npx",
      "args": [
        "@browsermcp/mcp@latest"
      ]
    }
  }
}

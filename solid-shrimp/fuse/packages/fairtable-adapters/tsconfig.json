{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "rootDir": "../../",
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "../fairtable-components/src/**/*",
    "../fairtable-core/src/**/*",
    "../fairtable-utils/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.*"],
  "references": [
    {
      "path": "../fairtable-components"
    },
    {
      "path": "../fairtable-core"
    },
    {
      "path": "../fairtable-utils"
    }
  ]
}

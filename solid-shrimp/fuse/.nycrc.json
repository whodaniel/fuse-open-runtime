{
  "all": true,
  "extends": "@istanbuljs/nyc-config-typescript",
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.tsx"
  ],
  "exclude": [
    "**/*.d.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/__tests__/**",
    "**/test/**",
    "**/dist/**",
    "**/build/**",
    "**/node_modules/**",
    "**/*.config.ts",
    "**/*.config.js"
  ],
  "reporter": ["text", "text-summary", "html", "lcov", "json"],
  "report-dir": "./coverage",
  "temp-dir": "./.nyc_output",
  "check-coverage": true,
  "lines": 50,
  "statements": 50,
  "functions": 50,
  "branches": 50,
  "sourceMap": true,
  "instrument": true,
  "cache": true
}

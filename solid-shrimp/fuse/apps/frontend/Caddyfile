:{$PORT:3000}

# Reverse proxy API requests to the backend service
handle /api/* {
	reverse_proxy {$BACKEND_INTERNAL_URL:http://localhost:3001} {
		header_up Host {upstream_hostport}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Reverse proxy WebSocket connections
handle /ws/* {
	reverse_proxy {$BACKEND_INTERNAL_URL:http://localhost:3001} {
		header_up Host {upstream_hostport}
		header_up Connection {>Connection}
		header_up Upgrade {>Upgrade}
	}
}

# Force-clear stale cache/storage on auth entry routes to avoid old bundle lock-in.
@authEntry path /login /auth/login
handle @authEntry {
	root * /srv
	encode gzip
	try_files {path} /index.html
	file_server
	header Cache-Control "no-cache, no-store, must-revalidate"
	header Clear-Site-Data "\"cache\", \"storage\""
	header Cross-Origin-Opener-Policy "same-origin-allow-popups"
}

# Serve static frontend files with SPA fallback
handle {
	root * /srv
	encode gzip
	try_files {path} /index.html
	file_server
	header Cross-Origin-Opener-Policy "same-origin-allow-popups"
}

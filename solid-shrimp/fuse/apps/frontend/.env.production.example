# Production Environment Configuration
# These values should be set in Railway or your hosting environment
# This file documents which variables are required

# Application Environment
APP_ENV=production

# API Configuration
VITE_API_URL=https://your-api-url.up.railway.app
VITE_WS_URL=wss://your-api-url.up.railway.app
VITE_RELAY_URL=wss://relay.example.com

# Firebase Configuration (Frontend) - Values populated from project configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

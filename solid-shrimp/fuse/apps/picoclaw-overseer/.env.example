# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# KILO_API_KEY=xxx

# ── Centralized Adaptive Routing (optional, recommended) ─────
# If set, startup resolves provider/model from:
# GET {TNF_LLM_ROUTING_API_BASE}/api/agent-proxy/adaptive/config/{TNF_LLM_TARGET}
# (falls back to admin endpoint if token is provided)
# TNF_LLM_ROUTING_API_BASE=https://api-production.up.railway.app
# TNF_LLM_ROUTING_TOKEN=service-or-admin-bearer-token
# TNF_LLM_TARGET=picoclaw-tester

# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# LINE_CHANNEL_SECRET=xxx
# LINE_CHANNEL_ACCESS_TOKEN=xxx

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── Timezone ──────────────────────────────
TZ=Asia/Tokyo

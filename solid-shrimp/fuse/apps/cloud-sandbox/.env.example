# Cloud Sandbox Environment Configuration
# Copy this file to .env.local for local development
# Set these variables in Railway for production deployment

#------------------------------------------------------------------------------
# REQUIRED - Application will not start without these
#------------------------------------------------------------------------------

# JWT Secret for authentication (REQUIRED)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database URL (REQUIRED)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:pass@localhost:5432/the_new_fuse

#------------------------------------------------------------------------------
# Server Configuration
#------------------------------------------------------------------------------

# Server port (default: 8080)
PORT=8080

# WebSocket port (default: same as PORT)
WS_PORT=8080

# Node environment
NODE_ENV=production

# Enable debug logging
DEBUG=false

#------------------------------------------------------------------------------
# Security Configuration
#------------------------------------------------------------------------------

# JWT token expiration (default: 1h)
JWT_EXPIRES_IN=1h

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://app.thenewfuse.com

# Maximum concurrent connections per tenant
MAX_CONCURRENT_CONNECTIONS=10

# Rate limiting window (milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

#------------------------------------------------------------------------------
# Playwright Configuration
#------------------------------------------------------------------------------

# Playwright browser path
PLAYWRIGHT_BROWSERS_PATH=/home/app-user/pw-browsers

# Headless mode (true/false)
PLAYWRIGHT_HEADLESS=true

# Browser timeout (milliseconds)
BROWSER_TIMEOUT=30000

#------------------------------------------------------------------------------
# Code Execution Configuration
#------------------------------------------------------------------------------

# Enable code execution (true/false)
ENABLE_CODE_EXECUTION=true

# Maximum code execution timeout (milliseconds)
MAX_CODE_EXECUTION_TIMEOUT=60000

# Maximum code output size (bytes)
MAX_CODE_OUTPUT_SIZE=1048576

#------------------------------------------------------------------------------
# File System Configuration
#------------------------------------------------------------------------------

# Maximum file size for uploads/writes (bytes)
MAX_FILE_SIZE=10485760

# Maximum total storage per tenant (bytes)
MAX_TENANT_STORAGE=104857600

# Workspace directory
WORKSPACE_DIR=/home/app-user/workspace

# Temp directory
TEMP_DIR=/tmp/cloud-sandbox

#------------------------------------------------------------------------------
# Redis Configuration (optional - for distributed rate limiting)
#------------------------------------------------------------------------------

# Redis URL (optional)
# REDIS_URL=redis://localhost:6379

# Redis key prefix
REDIS_PREFIX=tnf:cloud-sandbox:

#------------------------------------------------------------------------------
# Monitoring Configuration (optional)
#------------------------------------------------------------------------------

# Enable metrics collection
ENABLE_METRICS=true

# Metrics port
METRICS_PORT=9090

# Enable Prometheus metrics endpoint
ENABLE_PROMETHEUS=true

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

#------------------------------------------------------------------------------
# Logging Configuration
#------------------------------------------------------------------------------

# Log level (error, warn, info, debug, verbose)
LOG_LEVEL=info

# Log format (json, text)
LOG_FORMAT=json

# Enable audit logging
ENABLE_AUDIT_LOG=true

# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=90

#------------------------------------------------------------------------------
# Tenant Configuration
#------------------------------------------------------------------------------

# Default tenant tier (FREE, BASIC, STANDARD, PREMIUM, ENTERPRISE)
DEFAULT_TENANT_TIER=BASIC

# Enable tenant isolation
ENABLE_TENANT_ISOLATION=true

# Enable resource quotas
ENABLE_RESOURCE_QUOTAS=true

#------------------------------------------------------------------------------
# Feature Flags
#------------------------------------------------------------------------------

# Enable browser automation tools
ENABLE_BROWSER_TOOLS=true

# Enable file system tools
ENABLE_FILESYSTEM_TOOLS=true

# Enable code execution tools
ENABLE_EXECUTION_TOOLS=true

# Enable skill chains
ENABLE_SKILL_CHAINS=true

# Enable dangerous command execution (SUPER_ADMIN only)
ENABLE_DANGEROUS_COMMANDS=true

#------------------------------------------------------------------------------
# Development / Debug
#------------------------------------------------------------------------------

# Enable development mode
# DEV_MODE=false

# Mock authentication (DO NOT USE IN PRODUCTION)
# MOCK_AUTH=false

# Bypass permission checks (DO NOT USE IN PRODUCTION)
# BYPASS_PERMISSIONS=false

# Enable verbose logging
# VERBOSE=false

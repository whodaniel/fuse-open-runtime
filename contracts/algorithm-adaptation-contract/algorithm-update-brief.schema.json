{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/algorithm-update-brief.schema.json",
  "title": "AlgorithmUpdateBrief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "as_of",
    "input_assumptions",
    "limitation_statement",
    "challenge_objective",
    "algorithm_findings",
    "strategy_adjustments",
    "monitoring_plan"
  ],
  "properties": {
    "as_of": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "input_assumptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platforms", "current_content_strategy"],
      "properties": {
        "platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "current_content_strategy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "limitation_statement": {
      "type": "string",
      "minLength": 1
    },
    "challenge_objective": {
      "type": "string",
      "minLength": 1
    },
    "algorithm_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform",
          "date_of_change",
          "change_summary",
          "strategy_impact",
          "confidence",
          "sources"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "minLength": 1
          },
          "date_of_change": {
            "type": "string",
            "minLength": 1
          },
          "change_summary": {
            "type": "string",
            "minLength": 1
          },
          "strategy_impact": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            }
          }
        }
      }
    },
    "strategy_adjustments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "recommendation",
          "justification",
          "owner",
          "kpi",
          "timeframe"
        ],
        "properties": {
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          },
          "justification": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "kpi": {
            "type": "string",
            "minLength": 1
          },
          "timeframe": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "monitoring_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cadence", "watch_signals", "decision_rules"],
      "properties": {
        "cadence": {
          "type": "string",
          "minLength": 1
        },
        "watch_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "decision_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

#!/bin/sh

# Add standard paths (for node, pnpm, etc.)
# This handles GUI applications like VS Code that have minimal PATH
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.nvm/versions/node/v22.16.0/bin:$HOME/.nvm/versions/node/v20.19.5/bin:$HOME/.nvm/versions/node/v18.20.8/bin:$HOME/.local/share/pnpm:./node_modules/.bin:$PATH"

# Load nvm if it exists to ensure node/pnpm are available
[ -s "$HOME/.nvm/nvm.sh" ] && . "$HOME/.nvm/nvm.sh"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && . "/opt/homebrew/opt/nvm/nvm.sh"

# Increase Node memory for linters/typecheck to avoid OOM
export NODE_OPTIONS="${NODE_OPTIONS:---max-old-space-size=8192}"

# Run lint-staged
if command -v pnpm >/dev/null 2>&1; then
  pnpm lint-staged
elif command -v npx >/dev/null 2>&1; then
  npx pnpm lint-staged
else
  echo "Warning: Neither pnpm nor npx found. Skipping lint-staged."
fi

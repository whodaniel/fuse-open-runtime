{
  "snapshotDate": "2026-03-22",
  "title": "TNF communication infrastructure and active patterns",
  "planes": [
    {
      "name": "client-surfaces",
      "nodes": [
        "frontend-a2a-protocol-service",
        "websocket-clients",
        "vscode-chrome-external-agents",
        "runtime-status-artifacts"
      ]
    },
    {
      "name": "tnf-api-orchestration",
      "nodes": [
        "agency-hub-a2a-broker",
        "websocket-gateway",
        "agent-handoff-service",
        "task-controller-execution-logs",
        "unified-ledger-service"
      ]
    },
    {
      "name": "relay-messaging-backbone",
      "nodes": [
        "standalone-relay",
        "redis-relay-bridge",
        "redis-core-bus",
        "handoff-store-service",
        "stall-defense-escalation"
      ]
    },
    {
      "name": "cloud-plane",
      "nodes": ["cloudflare-zeroclaw-relay", "cloudflare-sharedstate"]
    }
  ],
  "flows": [
    {
      "type": "api-http",
      "from": "frontend-a2a-protocol-service",
      "to": "agency-hub-a2a-broker",
      "paths": ["/api/a2a/messages/send", "/api/a2a/messages/broadcast"]
    },
    {
      "type": "websocket",
      "from": "websocket-clients",
      "to": "websocket-gateway",
      "event": "agent:message"
    },
    {
      "type": "relay-ws",
      "from": "vscode-chrome-external-agents",
      "to": "standalone-relay",
      "events": ["AGENT_REGISTER", "MESSAGE_SEND", "HEARTBEAT"]
    },
    {
      "type": "redis-bus",
      "from": "standalone-relay",
      "to": "redis-relay-bridge",
      "channels": ["tnf:bus:ingress", "tnf:bus:egress:{agentId}"]
    },
    {
      "type": "activity-stream",
      "from": "standalone-relay",
      "to": "redis-core-bus",
      "channels": ["tnf:activity:stream", "tnf:activity:channel:*"]
    },
    {
      "type": "handoff",
      "from": "agent-handoff-service",
      "to": "handoff-store-service",
      "keyPrefix": "tnf:handoff:v1"
    },
    {
      "type": "timeline",
      "from": "agent-handoff-service",
      "to": "unified-ledger-service",
      "method": "createTimelineEvent"
    },
    {
      "type": "timeline",
      "from": "task-controller-execution-logs",
      "to": "unified-ledger-service",
      "method": "execution log mirror"
    },
    {
      "type": "cloud-sync",
      "from": "cloudflare-zeroclaw-relay",
      "to": "cloudflare-sharedstate",
      "paths": [
        "/deposit",
        "/mirror/:runtime",
        "/context/:runtime",
        "/withdraw",
        "/gates/*/evaluate"
      ]
    }
  ],
  "runtimeIndicators": {
    "stallDefense": "active",
    "handoffMatrix": "operational",
    "chromeExtension": "v6 live with transcript sync",
    "cloudHealth": "degraded",
    "listeners": ["127.0.0.1:6379", "*:3000"]
  },
  "sources": [
    "packages/relay-core/src/standalone-relay.ts",
    "packages/relay-core/src/redis-relay-bridge.ts",
    "relay-server/index.js",
    "apps/api/src/modules/agency-hub/controllers/a2a-broker.controller.ts",
    "apps/api/src/modules/agency-hub/services/a2a-message-broker.service.ts",
    "apps/frontend/src/services/A2AProtocolService.ts",
    "apps/api/src/websocket/websocket.gateway.ts",
    "apps/api/src/services/agent-handoff.service.ts",
    "packages/relay-core/src/services/HandoffStoreService.ts",
    "apps/api/src/modules/unified-ledger/unified-ledger.service.ts",
    "apps/api/src/modules/task/task.controller.ts",
    "cloudflare-zeroclaw-relay/src/index.ts",
    "cloudflare-sharedstate/src/index.ts",
    "~/.tnf/tnf-status"
  ]
}

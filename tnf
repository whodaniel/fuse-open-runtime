#!/usr/bin/env bash
set -euo pipefail

# Resolve REAL location even when called via symlink
THIS=$(readlink -f "$0" 2>/dev/null || greadlink -f "$0" 2>/dev/null || echo "$0")
ROOT_DIR="$(cd "$(dirname "${THIS}")" && pwd)"

# Fix Node 24 import flag resolution bug - use explicit full path that Node can resolve BEFORE cwd change
exec node --import "$ROOT_DIR/node_modules/tsx/dist/register-CFH5oNdT.mjs" "$ROOT_DIR/packages/tnf-cli/src/cli.ts" "$@"

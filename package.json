{
  "name": "the-new-fuse",
  "private": true,
  "packageManager": "bun@1.2.16",
  "scripts": {
    "build": "cd apps/theia-ide && bun install && node build-theia.js && cd ../.. && turbo run build",
    "build:types": "turbo run build --filter=@the-new-fuse/types",
    "build:packages": "turbo run build --filter=./packages/*",
    "build:apps": "turbo run build --filter=./apps/*",
    "build:clean": "bun run clean && turbo run build",
    "clear-ports": "node scripts/clear-ports.js",
    "check-build": "node scripts/check-build-status.cjs",
    "dev": "node scripts/smart-dev.cjs",
    "dev:direct": "node scripts/clear-ports.js && turbo run dev --filter=@the-new-fuse/api-gateway --filter=@the-new-fuse/electron-desktop --filter=@the-new-fuse/theia-ide --filter=@the-new-fuse/backend-app --concurrency=6",
    "dev:with-frontend": "node scripts/clear-ports.js && turbo run dev --filter=@the-new-fuse/api-gateway --filter=@the-new-fuse/electron-desktop --filter=@the-new-fuse/theia-ide --filter=@the-new-fuse/backend-app --filter=@the-new-fuse/frontend-app --concurrency=6",
    "dev:all": "turbo run dev --concurrency=50",
    "dev:working": "turbo run dev --filter=@the-new-fuse/api-gateway --filter=@the-new-fuse/frontend-app --concurrency=5",
    "dev:broken": "turbo run dev --filter=@the-new-fuse/electron-desktop --filter=@the-new-fuse/api-server --concurrency=5",
    "dev:api": "turbo run dev --filter=@the-new-fuse/api-server",
    "dev:gateway": "turbo run dev --filter=@the-new-fuse/api-gateway",
    "dev:frontend": "turbo run dev --filter=@the-new-fuse/frontend-app",
    "dev:hub": "turbo run dev --filter=@the-new-fuse/electron-desktop",
    "dev:hub-only": "cd apps/electron-desktop && npm run dev",
    "dev:legacy": "turbo run dev --filter=@the-new-fuse/api-gateway --filter=@the-new-fuse/frontend-app --filter=@the-new-fuse/theia-ide --filter=@the-new-fuse/backend-app --concurrency=4",
    "dev:full": "turbo run dev --filter=@the-new-fuse/api-server --filter=@the-new-fuse/frontend-app",
    "test": "turbo run test",
    "test:all": "turbo run test --concurrency=8",
    "test:coverage": "turbo run test --coverage",
    "test:unit": "turbo run test --filter=./packages/*",
    "test:integration": "turbo run test --filter=./apps/*",
    "test:e2e": "playwright test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write .",
    "type-check": "turbo run type-check --filter=./apps/* --filter=./packages/*",
    "type-check:watch": "turbo run type-check --watch",
    "clean": "rimraf dist lib build coverage test-results playwright-report .tsbuildinfo tsconfig.tsbuildinfo **/*.tsbuildinfo",
    "clean:all": "rm -rf node_modules packages/*/node_modules apps/*/node_modules && bun install",
    "clean:chrome": "bun -w the-new-fuse-chrome-extension run clean",
    "clean:cache": "turbo daemon stop && rm -rf .turbo",
    "clean:deps": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name '.turbo' -type d -prune -exec rm -rf '{}' +",
    "db:generate": "bun prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "turbo run db:migrate",
    "db:reset": "turbo run db:reset",
    "db:studio": "turbo run db:studio",
    "verify": "./scripts/verify-features.sh",
    "audit:routes": "node scripts/route-audit.js",
    "health-check": "bun run type-check && bun run test && bun run build",
    "analyze:circular": "bunx madge --circular apps/api/src",
    "audit": "bun audit",
    "mcp:api-wrapper": "node --loader tsx/esm src/mcp/complete-api-mcp-server.ts",
    "dev:gemini-mcp": "node apps/mcp-servers/gemini-mcp-server.js",
    "mcp:test-wrapper": "echo '{\"method\":\"tools/list\"}' | node --loader tsx/esm src/mcp/complete-api-mcp-server.ts",
    "workflow:dev": "turbo run dev --filter=@the-new-fuse/frontend-app --filter=@the-new-fuse/api-server --concurrency=2",
    "workflow:build": "turbo run build --filter=@the-new-fuse/frontend-app --filter=@the-new-fuse/api-server",
    "workflow:test": "turbo run test --filter=./packages/workflow-engine --filter=./apps/frontend/src/components/workflow",
    "hub:start": "open apps/browser-hub/enhanced-hub.html",
    "hub:dev": "live-server apps/browser-hub --port=8080 --entry-file=enhanced-hub.html",
    "hub:functional": "./scripts/launch-functional-browser.sh",
    "hub:with-services": "./scripts/launch-with-services.sh",
    "services:start": "./scripts/start-services-for-browser.sh",
    "services:health": "curl -f http://localhost:3000/health && curl -f http://localhost:3001/health"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "eslint": "^8.57.1",
    "glob": "^11.0.3",
    "madge": "^8.0.0",
    "prettier": "^3.6.2",
    "prisma": "6.11.0",
    "rimraf": "^5.0.10",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "6.11.0",
    "@types/otplib": "^10.0.0",
    "@types/react-speech-recognition": "^3.9.6",
    "axios": "^1.11.0",
    "canvas": "^3.1.2",
    "chokidar": "^4.0.3",
    "diff": "^8.0.2",
    "moment": "^2.30.1",
    "node-fetch": "^3.3.2",
    "otplib": "^12.0.1",
    "react-big-calendar": "^1.19.4",
    "react-speech-recognition": "^4.0.1",
    "tsx": "^4.20.3",
    "ws": "^8.18.3",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/config": "^3.1.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/event-emitter": "^2.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "trustedDependencies": [
    "find-git-repositories"
  ]
}

{
  "name": "the-new-fuse",
  "private": true,
  "scripts": {
    "start": "node apps/browser-hub/launch-browser-hub.js",
    "launch": "node apps/browser-hub/launch-browser-hub.js",
    "build": "node scripts/memory-optimized-build.cjs",
    "build:original": "turbo run build",
    "build:types": "turbo run build --filter=@the-new-fuse/types",
    "build:packages": "turbo run build --filter=./packages/*",
    "build:apps": "turbo run build --filter=./apps/*",
    "build:clean": "pnpm run clean && turbo run build",
    "build:memory-optimized": "BUILD_STRATEGY=memory-optimized BUILD_MEMORY_LIMIT=2048 BUILD_CONCURRENCY=2 turbo run build:memory-optimized --concurrency=2",
    "build:low-memory": "BUILD_STRATEGY=memory-optimized BUILD_MEMORY_LIMIT=1024 BUILD_CONCURRENCY=1 turbo run build:memory-optimized --concurrency=1",
    "build:adaptive": "node scripts/memory-optimized-build.cjs",
    "build:with-monitoring": "BUILD_ENABLE_MONITORING=true BUILD_MEMORY_LIMIT=4096 turbo run build:memory-optimized",
    "clear-ports": "node scripts/clear-ports.js",
    "check-build": "node scripts/check-build-status.cjs",
    "dev": "node scripts/memory-optimized-dev.cjs",
    "dev:direct": "node scripts/clear-ports.js && turbo run dev --filter=@the-new-fuse/api-gateway --filter=@the-new-fuse/electron-desktop --filter=@the-new-fuse/backend-app --concurrency=4",
    "dev:with-frontend": "node scripts/clear-ports.js && turbo run dev --filter=@the-new-fuse/api-gateway --filter=@the-new-fuse/electron-desktop --filter=@the-new-fuse/backend-app --filter=@the-new-fuse/frontend-app --concurrency=5",
    "dev:all": "turbo run dev --concurrency=50",
    "dev:memory-optimized": "node scripts/memory-optimized-dev.cjs",
    "dev:low-memory": "BUILD_MEMORY_LIMIT=1024 BUILD_CONCURRENCY=1 node scripts/memory-optimized-dev.cjs",
    "dev:working": "turbo run dev --filter=@the-new-fuse/api-gateway --filter=@the-new-fuse/frontend-app --concurrency=5",
    "dev:broken": "turbo run dev --filter=@the-new-fuse/electron-desktop --filter=@the-new-fuse/api-server --concurrency=5",
    "dev:api": "turbo run dev --filter=@the-new-fuse/api-server",
    "dev:gateway": "turbo run dev --filter=@the-new-fuse/api-gateway",
    "dev:hub": "turbo run dev --filter=@the-new-fuse/electron-desktop",
    "dev:hub-only": "cd apps/electron-desktop && npm run dev",
    "test": "turbo run test",
    "test:all": "turbo run test --concurrency=8",
    "test:coverage": "turbo run test --coverage",
    "test:unit": "turbo run test --filter=./packages/*",
    "test:integration": "turbo run test --filter=./apps/*",
    "test:e2e": "playwright test",
    "test:memory-optimized": "BUILD_MEMORY_LIMIT=2048 BUILD_CONCURRENCY=2 turbo run test --concurrency=2",
    "test:low-memory": "BUILD_MEMORY_LIMIT=1024 BUILD_CONCURRENCY=1 turbo run test --concurrency=1",
    
    "test:pnpm": "pnpm -r --parallel run test",
    "test:pnpm:unit": "pnpm --filter './packages/*' --parallel run test",
    "test:pnpm:integration": "pnpm --filter './apps/*' --parallel run test",
    "test:pnpm:watch": "pnpm -r --parallel run test:watch",
    "test:pnpm:coverage": "pnpm -r --parallel run test:coverage",
    "test:pnpm:changed": "pnpm --filter '[HEAD^1]' --parallel run test",
    "test:pnpm:affected": "pnpm --filter '...[origin/main]' --parallel run test",
    "test:pnpm:core": "pnpm --filter '@the-new-fuse/core' run test",
    "test:pnpm:api": "pnpm --filter '@the-new-fuse/api*' --parallel run test",
    "test:pnpm:frontend": "pnpm --filter '@the-new-fuse/frontend*' --parallel run test",
    "test:pnpm:workflow": "pnpm --filter '@the-new-fuse/workflow*' --parallel run test",
    "test:pnpm:fast": "pnpm --filter './packages/{core,types,utils}' --parallel run test",
    "test:pnpm:slow": "pnpm --filter './packages/{api,backend,database}' --parallel run test",
    "test:pnpm:ci": "pnpm -r --workspace-concurrency=4 run test:ci",
    "test:turbo": "turbo run test --config=turbo.test.json",
    "test:turbo:unit": "turbo run test:unit --config=turbo.test.json",
    "test:turbo:integration": "turbo run test:integration --config=turbo.test.json",
    "test:turbo:e2e": "turbo run test:e2e --config=turbo.test.json",
    "test:turbo:watch": "turbo run test:watch --config=turbo.test.json",
    "test:turbo:coverage": "turbo run test:coverage --config=turbo.test.json",
    "test:turbo:ci": "turbo run test:ci --config=turbo.test.json",
    "test:turbo:fast": "turbo run test:fast --config=turbo.test.json --filter='./packages/{core,types,utils}'",
    "test:turbo:changed": "turbo run test:changed --config=turbo.test.json --filter='[HEAD^1]'",
    "test:turbo:affected": "turbo run test:affected --config=turbo.test.json --filter='...[origin/main]'",
    "test:turbo:memory": "turbo run test:memory-optimized --config=turbo.test.json",
    "test:turbo:debug": "turbo run test:debug --config=turbo.test.json",
    "orchestrate": "scripts/turbo-test-orchestrator.sh",
    "orchestrate:smart": "scripts/turbo-test-orchestrator.sh smart",
    "orchestrate:parallel": "scripts/turbo-test-orchestrator.sh parallel",
    "orchestrate:staged": "scripts/turbo-test-orchestrator.sh staged",
    "orchestrate:affected": "scripts/turbo-test-orchestrator.sh affected",
    "orchestrate:ci": "scripts/turbo-test-orchestrator.sh ci",
    "orchestrate:watch": "scripts/turbo-test-orchestrator.sh watch",
    "orchestrate:fast": "scripts/turbo-test-orchestrator.sh fast",
    "workspace": "scripts/pnpm-workspace-optimizer.sh",
    "workspace:analyze": "scripts/pnpm-workspace-optimizer.sh analyze",
    "workspace:optimize": "scripts/pnpm-workspace-optimizer.sh optimize",
    "workspace:health": "scripts/pnpm-workspace-optimizer.sh health",
    "workspace:deps": "scripts/pnpm-workspace-optimizer.sh deps",
    "test:core": "scripts/pnpm-workspace-optimizer.sh test core",
    "test:apps": "scripts/pnpm-workspace-optimizer.sh test apps",
    "test:changed": "scripts/pnpm-workspace-optimizer.sh test changed",
    "test:affected": "scripts/pnpm-workspace-optimizer.sh test affected",
    "build:core": "scripts/pnpm-workspace-optimizer.sh build core",
    "build:staged:optimizer": "scripts/pnpm-workspace-optimizer.sh build staged",
    "build:parallel": "scripts/pnpm-workspace-optimizer.sh build parallel",
    "dev:frontend": "scripts/pnpm-workspace-optimizer.sh dev frontend",
    "dev:backend": "scripts/pnpm-workspace-optimizer.sh dev backend",
    "dev:full": "scripts/pnpm-workspace-optimizer.sh dev full",
    "clean:workspace:build": "scripts/pnpm-workspace-optimizer.sh clean build",
    "clean:workspace:deps": "scripts/pnpm-workspace-optimizer.sh clean deps",
    "clean:workspace:cache": "scripts/pnpm-workspace-optimizer.sh clean cache",
    "clean:workspace:all": "scripts/pnpm-workspace-optimizer.sh clean all",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write .",
    "type-check": "turbo run type-check --filter=./apps/* --filter=./packages/*",
    "type-check:watch": "turbo run type-check --watch",
    "clean": "rimraf dist lib build coverage test-results playwright-report .tsbuildinfo tsconfig.tsbuildinfo **/*.tsbuildinfo",
    "clean:chrome": "pnpm -w the-new-fuse-chrome-extension run clean",
    "clean:cache": "turbo daemon stop && rm -rf .turbo && pnpm store prune",
    "clean:deps": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name '.turbo' -type d -prune -exec rm -rf '{}' + && pnpm install",
    "clean:dev": "bash scripts/cleanup-dev-artifacts.sh",
    "clean:all": "pnpm run clean && pnpm run clean:cache && bash scripts/cleanup-dev-artifacts.sh",
    "clean:full": "pnpm run clean:deps && pnpm run clean:cache && bash scripts/cleanup-dev-artifacts.sh",
    "db:generate": "pnpm prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "turbo run db:migrate",
    "db:reset": "turbo run db:reset",
    "db:studio": "turbo run db:studio",
    "verify": "./scripts/verify-features.sh",
    "audit:routes": "node scripts/route-audit.js",
    "health-check": "pnpm run type-check && pnpm run test && pnpm run build",
    "analyze:circular": "pnpx madge --circular apps/api/src",
    "audit": "pnpm audit",
    "mcp:api-wrapper": "node --loader tsx/esm src/mcp/complete-api-mcp-server.ts",
    "dev:gemini-mcp": "node apps/mcp-servers/gemini-mcp-server.js",
    "mcp:test-wrapper": "echo '{\"method\":\"tools/list\"}' | node --loader tsx/esm src/mcp/complete-api-mcp-server.ts",
    "workflow:dev": "turbo run dev --filter=@the-new-fuse/frontend-app --filter=@the-new-fuse/api-server --concurrency=2",
    "workflow:build": "turbo run build --filter=@the-new-fuse/frontend-app --filter=@the-new-fuse/api-server",
    "workflow:test": "turbo run test --filter=./packages/workflow-engine --filter=./apps/frontend/src/components/workflow",
    "hub:start": "open apps/browser-hub/enhanced-hub.html",
    "hub:dev": "live-server apps/browser-hub --port=8080 --entry-file=enhanced-hub.html",
    "hub:functional": "./scripts/launch-functional-browser.sh",
    "hub:with-services": "./scripts/launch-with-services.sh",
    "services:start": "./scripts/start-services-for-browser.sh",
    "services:health": "curl -f http://localhost:3000/health && curl -f http://localhost:3001/health",
    "build:analyze-memory": "node -e \"const { SystemResourceDetector } = require('@tnf/build-optimization'); const detector = SystemResourceDetector.getInstance(); detector.getSystemResources().then(r => console.log('System Resources:', r))\"",
    "build:recommend-strategy": "node -e \"const { BuildOrchestrator, SystemResourceDetector } = require('@tnf/build-optimization'); const detector = SystemResourceDetector.getInstance(); detector.getSystemResources().then(r => { const o = new BuildOrchestrator(); return o.determineOptimalStrategy(r); }).then(s => console.log('Recommended Strategy:', s))\"",
    "build:monitor": "BUILD_ENABLE_MONITORING=true BUILD_LOG_LEVEL=verbose turbo run build",
    "build:benchmark": "node -e \"const { BuildMetricsCollector } = require('@tnf/build-optimization'); const m = new BuildMetricsCollector(); m.runBenchmark().then(r => console.log('Benchmark Results:', r))\"",
    "build:cleanup": "node -e \"const { MemoryCleanupUtility } = require('@tnf/build-optimization'); MemoryCleanupUtility.performCleanup().then(r => console.log('Cleanup Result:', r))\"",
    "build:health-check": "pnpm run build:analyze-memory && pnpm run type-check && pnpm run test:memory-optimized"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "eslint": "^9.38.0",
    "glob": "^11.0.3",
    "madge": "^8.0.0",
    "prettier": "^3.6.2",
    "prisma": "6.17.1",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/websockets": "^11.1.6",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "6.17.1",
    "@the-new-fuse/workflow-engine": "link:packages/workflow-engine",
    "@tnf/build-optimization": "link:packages/build-optimization",
    "@types/react-speech-recognition": "^3.9.6",
    "axios": "^1.12.2",
    "canvas": "^3.2.0",
    "chokidar": "^4.0.3",
    "diff": "^8.0.2",
    "moment": "^2.30.1",
    "node-fetch": "^3.3.2",
    "otplib": "^12.0.1",
    "react-big-calendar": "^1.19.4",
    "react-speech-recognition": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.20.6",
    "ws": "^8.18.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "trustedDependencies": [
    "@firebase/util",
    "@nestjs/core",
    "@parcel/watcher",
    "@prisma/client",
    "@prisma/engines",
    "@swc/core",
    "@the-new-fuse/electron-desktop",
    "@trufflesuite/bigint-buffer",
    "@vscode/ripgrep",
    "aws-sdk",
    "bcrypt",
    "bufferutil",
    "canvas",
    "core-js-pure",
    "cpu-features",
    "drivelist",
    "electron",
    "esbuild",
    "find-git-repositories",
    "keccak",
    "keytar",
    "leveldown",
    "lzma-native",
    "msgpackr-extract",
    "native-keymap",
    "node-pty",
    "prisma",
    "protobufjs",
    "puppeteer",
    "secp256k1",
    "ssh2",
    "unrs-resolver",
    "utf-8-validate"
  ],
  "packageManager": "pnpm@10.18.3+sha512.bbd16e6d7286fd7e01f6b3c0b3c932cda2965c06a908328f74663f10a9aea51f1129eea615134bf992831b009eabe167ecb7008b597f40ff9bc75946aadfb08d"
}

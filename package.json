{
  "name": "the-new-fuse",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:foundation": "turbo run build:foundation",
    "build:core": "turbo run build:core",
    "start": "node server.js",
    "dev": "turbo run dev",
    "clean": "pnpm run clean:workspaces && pnpm run clean:root && pnpm run clean:cache",
    "clean:workspaces": "pnpm -r --parallel exec rm -rf dist lib build .next out esm cjs types coverage test-results playwright-report .tsbuildinfo tsconfig.tsbuildinfo .turbo",
    "clean:root": "rm -rf node_modules/.cache .turbo tsconfig.tsbuildinfo *.log jest-report.json packages/integration-tests/jest-report.json",
    "clean:cache": "pnpm store prune",
    "clean:full": "pnpm run clean && rm -rf node_modules pnpm-lock.yaml && echo '\n✓ Full clean complete. Run: pnpm install'"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-flow": "^7.27.1",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/uuid": "^11.0.0",
    "postcss": "^8.5.6",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.19.0"
}

{
  "name": "the-new-fuse",
  "version": "2.1.0",
  "description": "The New Fuse - AI Agency Platform with Multi-Tenant Architecture",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/a2a-core",
    "packages/a2a-react",
    "packages/port-management",
    "packages/fairtable-core",
    "packages/fairtable-components",
    "packages/fairtable-utils",
    "packages/fairtable-adapters",
    "packages/core-vector-db",
    "packages/proto-definitions",
    "tools/port-manager"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:types": "turbo run build:types --filter=@the-new-fuse/types",
    "build:utils": "turbo run build:utils --filter=@the-new-fuse/utils",
    "build:core": "turbo run build:core --filter=@the-new-fuse/core",
    "build:database": "turbo run build:database --filter=@the-new-fuse/database",
    "build:api": "turbo run build:api --filter=@the-new-fuse/api",
    "build:ui": "turbo run build:ui --filter=@the-new-fuse/ui-*",
    "build:production": "turbo run build:production",
    "build:ordered": "bun run build:types && bun run build:utils && bun run build:core && bun run build:database && bun run build:api && bun run build:ui",
    "build:chrome": "bun -w the-new-fuse-chrome-extension run build",
    "build:all": "bun run build:ordered && bun run build:chrome",
    "build:deps": "turbo run build --filter=...@the-new-fuse/api",
    "build:ci": "turbo run build:production --cache-dir=.turbo",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@the-new-fuse/api",
    "dev:frontend": "turbo run dev --filter=@the-new-fuse/frontend",
    "dev:chrome": "bun -w the-new-fuse-chrome-extension run dev",
    "dev:types": "turbo run build:types --watch",
    "dev:optimized": "bun run ports:dev && bun run dev",
    "start": "turbo run start",
    "start:api": "turbo run start --filter=@the-new-fuse/api",
    "start:prod": "NODE_ENV=production turbo run start",
    "frontend:build": "cd apps/frontend && bun run build",
    "frontend:serve": "./serve-frontend.sh",
    "frontend:launch": "./launch-frontend.sh",
    "frontend:dev": "cd apps/frontend && bun run dev",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:ci": "turbo run test:ci --cache-dir=.turbo",
    "test:chrome": "bun -w the-new-fuse-chrome-extension run test",
    "test:coverage": "turbo run test --coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "type-check:watch": "turbo run type-check --watch",
    "clean": "turbo run clean && rimraf .turbo node_modules/.cache",
    "clean:chrome": "bun -w the-new-fuse-chrome-extension run clean",
    "clean:cache": "turbo daemon stop && rm -rf .turbo",
    "clean:deps": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name '.turbo' -type d -prune -exec rm -rf '{}' +",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:reset": "turbo run db:reset",
    "db:studio": "turbo run db:studio",
    "validate:env": "bash scripts/validate-env.sh",
    "validate:deps": "turbo run build --dry-run",
    "mcp:build": "./build-mcp.sh",
    "mcp:dev": "./dev-mcp.sh",
    "mcp:start": "./run-mcp-local.sh",
    "mcp:start:remote": "./run-mcp-remote.sh",
    "mcp:test": "./test-mcp.sh",
    "ports:status": "tnf-ports status",
    "ports:conflicts": "tnf-ports conflicts",
    "ports:dev": "tnf-ports dev --optimize",
    "ports:health": "tnf-ports health",
    "package:chrome": "bun -w the-new-fuse-chrome-extension run package:extension",
    "release:chrome": "bun -w the-new-fuse-chrome-extension run build:package",
    "docker:build": "turbo run docker:build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install || true",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "reorganize:init": "node scripts/quick-start-reorganization.js",
    "reorganize:interactive": "node scripts/reorganization-starter.js",
    "reorganize:phase1": "node scripts/update-imports.js && bun run reorganize:validate",
    "reorganize:phase2": "echo \"Phase 2: TypeScript Configuration - See plan for manual steps\"",
    "reorganize:phase3": "echo \"Phase 3: Directory Structure - See plan for manual steps\"",
    "reorganize:validate": "node scripts/post-change-validation.js",
    "reorganize:rollback": "node scripts/rollback-procedure.js",
    "reorganize:emergency": "node scripts/rollback-procedure.js emergency"
  },
  "keywords": [
    "ai-agency",
    "multi-tenant",
    "nestjs",
    "agency-hub",
    "swarm-orchestration",
    "typescript"
  ],
  "author": "The New Fuse Team",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@the-new-fuse/port-management": "workspace:*",
    "@the-new-fuse/port-manager-cli": "workspace:*",
    "@turbo/gen": "^2.5.3",
    "@types/fs-extra": "^11.0.4",
    "eslint": "^8.56.0",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^8.0.3",
    "prettier": "^3.1.1",
    "prisma": "6.8.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "ws": "^8.18.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "@prisma/client": "6.8.2",
    "cross-env": "^7.0.3",
    "crypto-js": "^4.2.0",
    "express": "^4.21.2",
    "fs-extra": "^11.3.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "zod": "^3.22.4"
  },
  "overrides": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/axios": "^3.0.3",
    "@nestjs/mongoose": "^10.0.10",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/testing": "^11.0.0",
    "@nestjs/event-emitter": "^2.0.3",
    "@nestjs/websockets": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/platform-ws": "^11.0.0",
    "@nestjs/graphql": "^12.2.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "vite": "^5.4.19",
    "rimraf": "^6.0.1",
    "@testing-library/react-hooks": "^8.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "graphql": "^16.9.0"
  }
}
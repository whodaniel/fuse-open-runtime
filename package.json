{
  "name": "the-new-fuse",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "fix:native-modules": "bash scripts/fix-native-modules.sh",
    "setup:native-modules": "node scripts/setup-native-modules.cjs",
    "prepare": "husky",
    "start": "pnpm run dev",
    "dev": "turbo run dev --filter=@the-new-fuse/api-gateway --filter=@the-new-fuse/frontend-app --concurrency=5",
    "dev:all": "turbo run dev --concurrency=50",
    "dev:api": "turbo run dev --filter=@the-new-fuse/api-server",
    "dev:gateway": "turbo run dev --filter=@the-new-fuse/api-gateway",
    "dev:frontend": "turbo run dev --filter=@the-new-fuse/frontend-app",
    "dev:backend": "turbo run dev --filter=@the-new-fuse/backend-app",
    "dev:low-memory": "BUILD_MEMORY_LIMIT=1024 BUILD_CONCURRENCY=1 node scripts/memory-optimized-dev.cjs",
    "prebuild": "node scripts/pre-build-check.cjs",
    "build": "turbo run build --filter=!@the-new-fuse/web-scraping --filter=!@the-new-fuse/core --filter=!@the-new-fuse/n8n-workflows --filter=!@the-new-fuse/sync-core --filter=!@the-new-fuse/integration-tests --filter=!@the-new-fuse/resource-registry",
    "build:types": "turbo run build --filter=@the-new-fuse/types",
    "build:packages": "turbo run build --filter=./packages/*",
    "build:apps": "turbo run build --filter=./apps/*",
    "build:api": "turbo run build --filter=@the-new-fuse/api-gateway",
    "build:frontend": "turbo run build --filter=@the-new-fuse/frontend-app",
    "build:backend": "turbo run build --filter=@the-new-fuse/backend-app",
    "build:production": "node scripts/build-production.cjs --clean",
    "build:production:verbose": "node scripts/build-production.cjs --clean --verbose",
    "build:railway": "node scripts/build-railway.cjs",
    "build:railway:verbose": "BUILD_VERBOSE=true node scripts/build-railway.cjs",
    "build:validate": "node scripts/build-production.cjs --skip-validation=false",
    "build:verify": "node scripts/verify-build.cjs",
    "build:clean": "pnpm run clean && turbo run build",
    "build:memory-optimized": "BUILD_STRATEGY=memory-optimized BUILD_MEMORY_LIMIT=2048 BUILD_CONCURRENCY=2 turbo run build:memory-optimized --concurrency=2",
    "build:low-memory": "BUILD_STRATEGY=memory-optimized BUILD_MEMORY_LIMIT=1024 BUILD_CONCURRENCY=1 turbo run build:memory-optimized --concurrency=1",
    "build:staged": "BUILD_STRATEGY=staged BUILD_MEMORY_LIMIT=1024 turbo run build:staged --concurrency=1",
    "build:adaptive": "node scripts/memory-optimized-build.cjs",
    "build:with-monitoring": "BUILD_ENABLE_MONITORING=true BUILD_MEMORY_LIMIT=4096 turbo run build:memory-optimized",
    "build:analyze-memory": "node -e \"const { SystemResourceDetector } = require('@tnf/build-optimization'); const detector = SystemResourceDetector.getInstance(); detector.getSystemResources().then(r => console.log('System Resources:', r))\"",
    "build:recommend-strategy": "node -e \"const { BuildOrchestrator, SystemResourceDetector } = require('@tnf/build-optimization'); const detector = SystemResourceDetector.getInstance(); detector.getSystemResources().then(r => { const o = new BuildOrchestrator(); return o.determineOptimalStrategy(r); }).then(s => console.log('Recommended Strategy:', s))\"",
    "build:monitor": "BUILD_ENABLE_MONITORING=true BUILD_LOG_LEVEL=verbose turbo run build",
    "build:benchmark": "node -e \"const { BuildMetricsCollector } = require('@tnf/build-optimization'); const m = new BuildMetricsCollector(); m.runBenchmark().then(r => console.log('Benchmark Results:', r))\"",
    "build:cleanup": "node -e \"const { MemoryCleanupUtility } = require('@tnf/build-optimization'); MemoryCleanupUtility.performCleanup().then(r => console.log('Cleanup Result:', r))\"",
    "build:health-check": "pnpm run build:analyze-memory && pnpm run type-check && pnpm run test:memory-optimized",
    "pretest": "node scripts/pre-build-check.cjs",
    "test": "turbo run test",
    "test:all": "turbo run test --concurrency=8",
    "test:unit": "turbo run test:unit --filter=./packages/*",
    "test:integration": "turbo run test:integration --filter=./apps/*",
    "test:e2e": "playwright test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:memory-optimized": "BUILD_MEMORY_LIMIT=2048 BUILD_CONCURRENCY=2 turbo run test --concurrency=2",
    "test:low-memory": "BUILD_MEMORY_LIMIT=1024 BUILD_CONCURRENCY=1 turbo run test --concurrency=1",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:staged": "lint-staged",
    "lint:api": "eslint apps/api/**/*.ts",
    "lint:frontend": "eslint apps/frontend/**/*.ts",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "format:root": "prettier --write .",
    "format:check:root": "prettier --check .",
    "type-check": "turbo run type-check --filter=./apps/* --filter=./packages/*",
    "type-check:watch": "turbo run type-check --watch",
    "clear-ports": "node scripts/clear-ports.js",
    "check-build": "node scripts/check-build-status.cjs",
    "clean": "rimraf dist lib build coverage test-results playwright-report .tsbuildinfo tsconfig.tsbuildinfo **/*.tsbuildinfo",
    "clean:all": "rm -rf node_modules packages/*/node_modules apps/*/node_modules && pnpm install",
    "clean:cache": "turbo daemon stop && rm -rf .turbo",
    "clean:deps": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name '.turbo' -type d -prune -exec rm -rf '{}' +",
    "db:generate": "pnpm prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "turbo run db:migrate",
    "db:reset": "turbo run db:reset",
    "db:studio": "turbo run db:studio",
    "docker:start": "docker-compose -f docker-compose.dev-simple.yml up -d",
    "docker:stop": "docker-compose -f docker-compose.dev-simple.yml down",
    "docker:status": "docker-compose -f docker-compose.dev-simple.yml ps",
    "docker:logs": "docker-compose -f docker-compose.dev-simple.yml logs -f",
    "docker:test": "node test-docker-integration.js",
    "mcp:api-wrapper": "node --loader tsx/esm src/mcp/complete-api-mcp-server.ts",
    "mcp:test-wrapper": "echo '{\"method\":\"tools/list\"}' | node --loader tsx/esm src/mcp/complete-api-mcp-server.ts",
    "workflow:dev": "turbo run dev --filter=@the-new-fuse/frontend-app --filter=@the-new-fuse/api-server --concurrency=2",
    "workflow:build": "turbo run build --filter=@the-new-fuse/frontend-app --filter=@the-new-fuse/api-server",
    "workflow:test": "turbo run test --filter=./packages/workflow-engine --filter=./apps/frontend/src/components/workflow",
    "verify": "./scripts/verify-features.sh",
    "verify:features": "./scripts/verify-features.sh",
    "audit:routes": "node scripts/route-audit.js",
    "audit:security": "pnpm audit",
    "audit:circular": "pnpm dlx madge --circular apps/api/src",
    "audit:clean-scripts": "node scripts/audit-clean-scripts.cjs",
    "validate:build": "node scripts/validate-build.cjs",
    "validate:clean-scripts": "node scripts/validate-clean-scripts.cjs",
    "health-check": "pnpm run type-check && pnpm run test && pnpm run build",
    "health-check:full": "pnpm run validate:clean-scripts && pnpm run type-check && pnpm run test && pnpm run validate:build"
  },
  "devDependencies": {
    "@prisma/engines": "7.1.0",
    "@types/node": "^24.0.13",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "concurrently": "^9.2.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "madge": "^8.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "7.1.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.4.6",
    "turbo": "^2.5.5",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.4",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^11.1.9",
    "@nestjs/event-emitter": "^2.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/websockets": "^11.1.9",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "7.1.0",
    "@supabase/supabase-js": "^2.78.0",
    "@types/otplib": "^10.0.0",
    "@types/react-speech-recognition": "^3.9.6",
    "@vercel/node": "^3.0.21",
    "axios": "^1.11.0",
    "canvas": "^3.1.2",
    "cheerio": "^1.0.0-rc.12",
    "chokidar": "^4.0.3",
    "diff": "^8.0.2",
    "mime-types": "^2.1.35",
    "moment": "^2.30.1",
    "node-fetch": "^3.3.2",
    "otplib": "^12.0.1",
    "react-big-calendar": "^1.19.4",
    "react-speech-recognition": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsx": "^4.20.3",
    "url-parse": "^1.5.10",
    "ws": "^8.18.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c",
  "pnpm": {
    "overrides": {
      "undici@>=4.5.0 <5.28.5": ">=5.28.5",
      "path-to-regexp@>=4.0.0 <6.3.0": ">=6.3.0",
      "esbuild@<=0.24.2": ">=0.25.0",
      "cookie@<0.7.0": ">=0.7.0",
      "undici@<5.29.0": ">=5.29.0",
      "dompurify@<3.2.4": ">=3.2.4",
      "tmp@<=0.2.3": ">=0.2.4",
      "js-yaml@<3.14.2": ">=3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "glob@<9.0.0": ">=11.1.0",
      "glob@>=10.2.0 <10.5.0": ">=11.1.0",
      "glob@>=10.3.7 <=11.0.3": ">=11.1.0",
      "hono@<4.10.3": ">=4.10.3",
      "jws@<3.2.3": ">=3.2.3",
      "jws@=4.0.0": ">=4.0.1",
      "validator@<13.15.22": ">=13.15.22",
      "node-forge@<1.3.2": ">=1.3.2",
      "body-parser@>=2.2.0 <2.2.1": ">=2.2.1",
      "@modelcontextprotocol/sdk@<1.24.0": ">=1.24.0",
      "vite@<=5.4.19": ">=7.1.5",
      "vite@>=6.0.0 <=6.4.0": ">=7.1.11",
      "vite@>=6.2.0 <=6.2.6": ">=7.1.11",
      "@eslint/plugin-kit@<0.3.4": ">=0.3.4",
      "brace-expansion@>=1.0.0 <=1.1.11": ">=2.0.2",
      "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2"
    }
  }
}

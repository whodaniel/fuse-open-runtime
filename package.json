    "skills:bank:status": "node -e \"const fs=require('fs');const p='.agent/skill-bank/skills-index.json';if(!fs.existsSync(p)){console.log('missing skills index');process.exit(1);}const d=JSON.parse(fs.readFileSync(p,'utf8'));console.log(JSON.stringify({generatedAt:d.generatedAt,totals:d.totals},null,2));\"",

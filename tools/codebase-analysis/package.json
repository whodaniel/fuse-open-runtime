{
  "name": "@the-new-fuse/codebase-analysis",
  "version": "1.0.0",
  "description": "Comprehensive codebase analysis and consolidation tool",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "vitest",
    "scan": "ts-node src/cli.ts scan",
    "analyze": "ts-node src/cli.ts analyze",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "glob": "^11.0.3",
    "typescript": "^5.9.3",
    "@types/node": "^24.8.1"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "vitest": "^3.2.4"
  }
}

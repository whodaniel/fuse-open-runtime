{
  "name": "vscode-lm-bridge",
  "version": "1.0.0",
  "description": "OpenAI-compatible API bridge for VS Code Language Model",
  "main": "server.js",
  "bin": {
    "vscode-lm-bridge": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "true",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "keywords": [
    "vscode",
    "language-model",
    "openai",
    "api",
    "bridge"
  ],
  "author": "VS Code LM Bridge",
  "license": "MIT",
  "dependencies": {
    "express": "^4.22.0",
    "cors": "^2.8.5",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}

### Production Environment Reset
```bash
#!/bin/bash
# ⚠️  DANGER: Only run this in controlled maintenance windows

echo "🚨 PRODUCTION RESET - Confirm with 'YES I UNDERSTAND'"
read confirmation

if [ "$confirmation" != "YES I UNDERSTAND" ]; then
    echo "❌ Reset cancelled"
    exit 1
fi

echo "🔄 Starting production reset..."

# Create backup before reset
./backup-production.sh

# Graceful service shutdown
kubectl scale deployment agency-hub --replicas=0
kubectl scale deployment mcp-server --replicas=0
kubectl scale deployment websocket-server --replicas=0

# Reset databases with backup
./reset-production-database.sh

# Reset configurations
kubectl delete configmap agency-hub-config
kubectl apply -f k8s/configs/

# Scale services back up
kubectl scale deployment agency-hub --replicas=3
kubectl scale deployment mcp-server --replicas=2
kubectl scale deployment websocket-server --replicas=2

# Verify health
kubectl get pods
./verify-production-health.sh

echo "✅ Production reset complete!"
```

## Configuration Reset Templates

### Default .env Template
```bash
# Generate fresh .env file
cat > .env << 'EOF'
# Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=localhost

# Database
DATABASE_URL=postgresql://agency_user:agency_password@localhost:5432/agency_hub

# Authentication
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET
JWT_EXPIRY=3600

# Services
MCP_SERVER_PORT=3001
WEBSOCKET_PORT=3002

# External Services
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Feature Flags
ENABLE_METRICS=true
ENABLE_TRACING=false
ENABLE_DEBUG=true
EOF

# Generate random JWT secret
node -e "
const crypto = require('crypto');
const secret = crypto.randomBytes(64).toString('hex');
console.log('Generated JWT_SECRET:', secret);
" | tail -1 | sed 's/Generated JWT_SECRET: //' | sed 's/^/JWT_SECRET=/' >> .env.tmp
grep -v JWT_SECRET .env > .env.backup
cat .env.backup .env.tmp > .env
rm .env.tmp .env.backup
```


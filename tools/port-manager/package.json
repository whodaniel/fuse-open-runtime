{
  "name": "@the-new-fuse/port-manager-cli",
  "version": "1.0.0",
  "description": "CLI tool for The New Fuse port management",
  "type": "module",
  "bin": {
    "tnf-ports": "./cli.js"
  },
  "scripts": {
    "build": "echo 'No build needed'",
    "dev": "node ./cli.js dev",
    "install-global": "pnpm install -g .",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@the-new-fuse/port-management": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.8.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}

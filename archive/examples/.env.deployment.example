# ============================================================================
# The New Fuse - Deployment Environment Configuration Example
# ============================================================================
# Copy this file to .env.production and fill in your values
# DO NOT commit .env.production to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# CORE CONFIGURATION
# ----------------------------------------------------------------------------

# Application Environment
NODE_ENV=production

# Database Connection
DATABASE_URL=postgresql://username:password@host:5432/database_name

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Redis (optional but recommended)
REDIS_URL=redis://host:6379

# Application URLs
APP_URL=https://app.thenewfuse.com
API_URL=https://api.thenewfuse.com
FRONTEND_URL=https://app.thenewfuse.com

# ----------------------------------------------------------------------------
# DEPLOYMENT CONFIGURATION
# ----------------------------------------------------------------------------

# Deployment Strategy: rolling, blue-green, canary
DEPLOYMENT_STRATEGY=blue-green

# Services to Deploy (space-separated)
SERVICES=api-gateway backend frontend api

# Feature Flags
RUN_MIGRATIONS=true
RUN_TESTS=true
RUN_HEALTH_CHECKS=true
NOTIFY=true

# Auto-confirm Deployments (use with caution!)
AUTO_CONFIRM=false

# ----------------------------------------------------------------------------
# HEALTH CHECK CONFIGURATION
# ----------------------------------------------------------------------------

# Health Check Timeouts (in seconds)
HEALTH_CHECK_TIMEOUT=60
HEALTH_CHECK_INTERVAL=5
TIMEOUT=30
RETRY_COUNT=3
RETRY_DELAY=5

# ----------------------------------------------------------------------------
# BLUE-GREEN DEPLOYMENT
# ----------------------------------------------------------------------------

# Blue Environment URL
BLUE_URL=https://blue.thenewfuse.com

# Green Environment URL
GREEN_URL=https://green.thenewfuse.com

# Production URL (active environment)
PRODUCTION_URL=https://app.thenewfuse.com

# ----------------------------------------------------------------------------
# CANARY DEPLOYMENT
# ----------------------------------------------------------------------------

# Canary Service URL
CANARY_URL=https://canary.thenewfuse.com

# Canary Configuration
CANARY_PERCENTAGE=10              # Initial traffic percentage
CANARY_INCREMENT=20               # Traffic increment per step
CANARY_DURATION=300               # Monitor duration per step (seconds)
CANARY_ERROR_THRESHOLD=5          # Max error rate percentage
CANARY_LATENCY_THRESHOLD=2000     # Max latency in milliseconds

# ----------------------------------------------------------------------------
# CLOUD_RUNTIME CONFIGURATION
# ----------------------------------------------------------------------------

# CloudRuntime Token (optional - can use 'cloud_runtime login' instead)
# CLOUD_RUNTIME_TOKEN=your-cloud_runtime-token-here

# CloudRuntime Project ID (optional)
# CLOUD_RUNTIME_PROJECT_ID=your-project-id

# CloudRuntime Environment
# CLOUD_RUNTIME_ENVIRONMENT=production

# Service URLs
API_GATEWAY_URL=https://api-gateway.thenewfuse.com
BACKEND_URL=https://backend.thenewfuse.com
FRONTEND_URL=https://frontend.thenewfuse.com
API_URL=https://api.thenewfuse.com

# ----------------------------------------------------------------------------
# NOTIFICATION CONFIGURATION
# ----------------------------------------------------------------------------

# Enable/Disable Notifications
NOTIFICATION_ENABLED=true
SLACK_ENABLED=true
DISCORD_ENABLED=true
EMAIL_ENABLED=false

# Slack Webhook
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord Webhook
# Get from: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# Email Configuration
# EMAIL_API_URL=https://api.sendgrid.com/v3/mail/send
# EMAIL_TO=team@example.com
# EMAIL_FROM=deployments@thenewfuse.com
# SENDGRID_API_KEY=your-sendgrid-api-key

# ----------------------------------------------------------------------------
# DATABASE BACKUP CONFIGURATION
# ----------------------------------------------------------------------------

# Backup Before Migration
BACKUP_BEFORE_MIGRATE=true

# Backup Retention (keep last N backups)
BACKUP_RETENTION=10

# ----------------------------------------------------------------------------
# MONITORING & LOGGING
# ----------------------------------------------------------------------------

# Sentry DSN (optional - for error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Log Level: error, warn, info, debug
LOG_LEVEL=info

# Enable Debug Mode
DEBUG=false

# ----------------------------------------------------------------------------
# SERVICE PORTS (for local development/testing)
# ----------------------------------------------------------------------------

API_GATEWAY_PORT=3002
BACKEND_PORT=3003
FRONTEND_PORT=3000
API_PORT=3001

# ----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# ----------------------------------------------------------------------------

# CORS Origins (comma-separated)
CORS_ORIGINS=https://app.thenewfuse.com,https://admin.thenewfuse.com

# Rate Limiting
RATE_LIMIT_MAX=100              # Max requests per window
RATE_LIMIT_WINDOW=900000        # Window in milliseconds (15 minutes)

# Session Configuration
SESSION_SECRET=your-session-secret-change-this
SESSION_MAX_AGE=86400000        # Session max age in milliseconds (24 hours)

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------

# Enable specific features
ENABLE_ANALYTICS=true
ENABLE_BETA_FEATURES=false
ENABLE_MAINTENANCE_MODE=false

# ----------------------------------------------------------------------------
# THIRD-PARTY INTEGRATIONS
# ----------------------------------------------------------------------------

# OpenAI (if used)
# OPENAI_API_KEY=your-openai-api-key

# Stripe (if used)
# STRIPE_SECRET_KEY=your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Google OAuth (if used)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (if used)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ----------------------------------------------------------------------------
# ADVANCED CONFIGURATION
# ----------------------------------------------------------------------------

# Build Configuration
BUILD_STRATEGY=memory-optimized
BUILD_MEMORY_LIMIT=4096
BUILD_CONCURRENCY=4

# Database Pool Configuration
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis Pool Configuration
REDIS_POOL_MIN=2
REDIS_POOL_MAX=10

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------

# 1. Never commit this file with real credentials to version control
# 2. Add .env.production to .gitignore
# 3. Use environment-specific files: .env.development, .env.staging, .env.production
# 4. For CloudRuntime, set these variables in the CloudRuntime dashboard
# 5. For local testing, copy this to .env.local and modify as needed
# 6. Rotate secrets regularly (JWT_SECRET, SESSION_SECRET, etc.)
# 7. Use strong, unique passwords for all services
# 8. Keep backup of production environment variables in secure location

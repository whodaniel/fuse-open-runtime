# Monitoring & Observability Configuration
# Copy this file to .env.monitoring and fill in the values

# =============================================================================
# Sentry Configuration
# =============================================================================

# Sentry DSN (Data Source Name)
# Get this from your Sentry project settings
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# Environment name (development, staging, production)
SENTRY_ENVIRONMENT=production

# Application release version
# This should match your deployment version
SENTRY_RELEASE=1.0.0

# Sample rate for performance monitoring (0.0 to 1.0)
# 0.1 = 10% of transactions will be sent to Sentry
SENTRY_TRACES_SAMPLE_RATE=0.1

# Sample rate for profiling (0.0 to 1.0)
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Enable Sentry in production only
SENTRY_ENABLED=true

# Enable debug mode (useful for development)
SENTRY_DEBUG=false

# =============================================================================
# Logging Configuration
# =============================================================================

# Logging level (error, warn, info, http, debug)
LOG_LEVEL=info

# Directory for log files
LOG_DIR=/var/log/app

# Enable file logging
LOG_FILE_ENABLED=true

# Enable console logging
LOG_CONSOLE_ENABLED=true

# Log file max size (e.g., 20m for 20MB)
LOG_MAX_SIZE=20m

# Log file retention (e.g., 14d for 14 days)
LOG_MAX_FILES=14d

# Date pattern for log rotation
LOG_DATE_PATTERN=YYYY-MM-DD

# =============================================================================
# Prometheus Metrics Configuration
# =============================================================================

# Enable Prometheus metrics
METRICS_ENABLED=true

# Metrics prefix (e.g., tnf_api_gateway_)
METRICS_PREFIX=tnf

# Collect default Node.js metrics
METRICS_COLLECT_DEFAULT=true

# Metrics collection interval (ms)
METRICS_COLLECTION_INTERVAL=10000

# Default labels for all metrics
METRICS_SERVICE_NAME=api-gateway
METRICS_ENVIRONMENT=production

# =============================================================================
# Health Check Configuration
# =============================================================================

# Enable health checks
HEALTH_CHECK_ENABLED=true

# Health check interval (ms)
HEALTH_CHECK_INTERVAL=30000

# Health check timeout (ms)
HEALTH_CHECK_TIMEOUT=5000

# Memory usage threshold for health check (percentage)
HEALTH_MEMORY_THRESHOLD=90

# Disk space threshold for health check (percentage)
HEALTH_DISK_THRESHOLD=90

# =============================================================================
# Alert Configuration
# =============================================================================

# Enable alerting
ALERTS_ENABLED=true

# Alert evaluation interval (ms)
ALERTS_EVALUATION_INTERVAL=60000

# Notification cooldown period (ms)
ALERTS_NOTIFICATION_COOLDOWN=300000

# Auto-resolve alerts after this time (ms)
ALERTS_AUTO_RESOLVE_AFTER=3600000

# =============================================================================
# Slack Notifications
# =============================================================================

# Slack webhook URL for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack channel for critical alerts
SLACK_CHANNEL_CRITICAL=#alerts-critical

# Slack channel for error alerts
SLACK_CHANNEL_ERROR=#alerts-error

# Slack channel for warning alerts
SLACK_CHANNEL_WARNING=#alerts-warning

# Slack channel for info alerts
SLACK_CHANNEL_INFO=#alerts-info

# Slack bot username
SLACK_BOT_USERNAME=Monitoring Bot

# Slack bot icon emoji
SLACK_BOT_ICON=:warning:

# =============================================================================
# Email Notifications
# =============================================================================

# Enable email notifications
EMAIL_NOTIFICATIONS_ENABLED=false

# SMTP host
SMTP_HOST=smtp.gmail.com

# SMTP port
SMTP_PORT=587

# SMTP secure (true for TLS, false for STARTTLS)
SMTP_SECURE=true

# SMTP username
SMTP_USER=your-email@example.com

# SMTP password
SMTP_PASSWORD=your-smtp-password

# Email from address
EMAIL_FROM=alerts@example.com

# Email to addresses (comma-separated)
EMAIL_TO=oncall@example.com,team@example.com

# =============================================================================
# PagerDuty Integration
# =============================================================================

# Enable PagerDuty integration
PAGERDUTY_ENABLED=false

# PagerDuty integration key (Events API v2)
PAGERDUTY_INTEGRATION_KEY=your-integration-key

# PagerDuty service key (for specific service)
PAGERDUTY_SERVICE_KEY=your-service-key

# PagerDuty API URL
PAGERDUTY_API_URL=https://events.pagerduty.com/v2/enqueue

# =============================================================================
# Webhook Notifications
# =============================================================================

# Enable webhook notifications
WEBHOOK_ENABLED=false

# Webhook URL
WEBHOOK_URL=https://your-webhook-endpoint.com/alerts

# Webhook authentication token
WEBHOOK_TOKEN=your-webhook-token

# Webhook method (POST, PUT)
WEBHOOK_METHOD=POST

# =============================================================================
# Database Monitoring
# =============================================================================

# Database connection pool min size
DB_POOL_MIN=2

# Database connection pool max size
DB_POOL_MAX=10

# Database query timeout (ms)
DB_QUERY_TIMEOUT=30000

# Slow query threshold (ms)
DB_SLOW_QUERY_THRESHOLD=1000

# Enable query logging
DB_LOG_QUERIES=false

# =============================================================================
# Redis Monitoring
# =============================================================================

# Redis connection timeout (ms)
REDIS_CONNECT_TIMEOUT=10000

# Redis command timeout (ms)
REDIS_COMMAND_TIMEOUT=5000

# Redis max retries
REDIS_MAX_RETRIES=3

# =============================================================================
# Performance Monitoring
# =============================================================================

# Enable APM (Application Performance Monitoring)
APM_ENABLED=true

# APM sample rate (0.0 to 1.0)
APM_SAMPLE_RATE=0.1

# Enable request tracing
TRACING_ENABLED=true

# Tracing sample rate (0.0 to 1.0)
TRACING_SAMPLE_RATE=0.1

# =============================================================================
# Dashboard Configuration
# =============================================================================

# Grafana URL
GRAFANA_URL=https://grafana.example.com

# Grafana API key (for automated dashboard updates)
GRAFANA_API_KEY=your-grafana-api-key

# Prometheus URL
PROMETHEUS_URL=http://prometheus:9090

# =============================================================================
# Circuit Breaker Configuration
# =============================================================================

# Enable circuit breaker
CIRCUIT_BREAKER_ENABLED=true

# Failure threshold (percentage)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=50

# Reset timeout (ms)
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# =============================================================================
# Rate Limiting
# =============================================================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Rate limit window (ms)
RATE_LIMIT_WINDOW=60000

# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Custom Alert Thresholds
# =============================================================================

# HTTP error rate threshold (percentage)
ALERT_THRESHOLD_ERROR_RATE=5

# HTTP response time threshold (ms)
ALERT_THRESHOLD_RESPONSE_TIME=2000

# Memory usage threshold (percentage)
ALERT_THRESHOLD_MEMORY=90

# CPU usage threshold (percentage)
ALERT_THRESHOLD_CPU=80

# Database pool utilization threshold (percentage)
ALERT_THRESHOLD_DB_POOL=90

# Database query time threshold (ms)
ALERT_THRESHOLD_DB_QUERY_TIME=5000

# Job failure rate threshold (percentage)
ALERT_THRESHOLD_JOB_FAILURE_RATE=10

# WebSocket connection change threshold (percentage)
ALERT_THRESHOLD_WS_CONNECTION_CHANGE=50

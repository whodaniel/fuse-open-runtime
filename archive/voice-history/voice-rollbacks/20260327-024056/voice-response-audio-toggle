#!/bin/bash
set -euo pipefail

STATE_FILE="$HOME/.openclaw/voice_response_audio_enabled"
mkdir -p "$HOME/.openclaw"

usage() {
  echo "Usage: voice-response-audio-toggle [--on|--off|--status]"
}

mode="${1:-toggle}"
case "$mode" in
  --on)
    touch "$STATE_FILE"
    echo "🔊 AI response audio: ON"
    ;;
  --off)
    rm -f "$STATE_FILE"
    echo "🔈 AI response audio: OFF"
    ;;
  --status)
    if [[ -f "$STATE_FILE" ]]; then
      echo "🔊 AI response audio: ON"
    else
      echo "🔈 AI response audio: OFF"
    fi
    ;;
  toggle)
    if [[ -f "$STATE_FILE" ]]; then
      rm -f "$STATE_FILE"
      echo "🔈 AI response audio: OFF"
    else
      touch "$STATE_FILE"
      echo "🔊 AI response audio: ON"
    fi
    ;;
  *)
    usage
    exit 1
    ;;
esac

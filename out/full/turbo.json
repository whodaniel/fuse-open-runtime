{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "JWT_SECRET",
    "API_PORT",
    "FRONTEND_PORT",
    "API_URL",
    "BACKEND_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "^db:generate"
      ],
      "env": [
        "NODE_ENV"
      ],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "package.json",
        "tsconfig.json",
        "*.config.{ts,js,mjs}",
        "!**/*.test.{ts,tsx,js,jsx}",
        "!**/*.spec.{ts,tsx,js,jsx}"
      ],
      "passThroughEnv": [
        "NODE_ENV"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "lib/**",
        "build/**",
        "out/**",
        "types/**",
        "esm/**",
        "cjs/**",
        "*.tsbuildinfo"
      ]
    },
    "build:types": {
      "cache": true,
      "inputs": [
        "src/**/*.{ts,tsx}",
        "package.json",
        "tsconfig.json"
      ],
      "outputs": [
        "dist/**/*.d.ts",
        "types/**/*.d.ts",
        "lib/**/*.d.ts",
        "*.tsbuildinfo"
      ]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": true,
      "inputs": [
        "prisma/schema.prisma"
      ],
      "outputs": [
        "node_modules/.prisma/**",
        "prisma/generated/**",
        "generated/**"
      ]
    },
    "db:migrate": {
      "cache": false,
      "inputs": [
        "prisma/migrations/**",
        "prisma/schema.prisma"
      ]
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "dependsOn": [
        "^build:types"
      ],
      "env": [
        "NODE_ENV",
        "PORT",
        "API_PORT",
        "FRONTEND_PORT",
        "API_URL",
        "BACKEND_URL"
      ],
      "passThroughEnv": [
        "NODE_ENV",
        "PORT",
        "API_PORT",
        "FRONTEND_PORT",
        "API_URL",
        "BACKEND_URL"
      ],
      "persistent": true
    },
    "docker:build": {
      "dependsOn": [
        "build"
      ],
      "inputs": [
        "Dockerfile*",
        "docker-compose*.yml"
      ],
      "outputs": []
    },
    "lint": {
      "cache": true,
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        ".eslintrc*",
        "package.json",
        "!**/*.test.{ts,tsx,js,jsx}",
        "!**/*.spec.{ts,tsx,js,jsx}"
      ],
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        ".eslintrc*",
        "package.json",
        "!**/*.test.{ts,tsx,js,jsx}",
        "!**/*.spec.{ts,tsx,js,jsx}"
      ],
      "outputs": []
    },
    "start": {
      "cache": false,
      "dependsOn": [
        "build"
      ],
      "env": [
        "NODE_ENV",
        "PORT"
      ],
      "passThroughEnv": [
        "NODE_ENV",
        "PORT"
      ],
      "persistent": true
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "test/**/*.{ts,tsx,js,jsx}",
        "**/*.test.{ts,tsx,js,jsx}",
        "**/*.spec.{ts,tsx,js,jsx}",
        "package.json",
        "jest.config.*",
        "vitest.config.*"
      ],
      "outputs": [
        "coverage/**",
        "test-results/**"
      ]
    },
    "test:ci": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "test/**/*.{ts,tsx,js,jsx}",
        "**/*.test.{ts,tsx,js,jsx}",
        "**/*.spec.{ts,tsx,js,jsx}",
        "package.json",
        "jest.config.*"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:e2e": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "e2e/**/*.{ts,js}",
        "playwright.config.*"
      ],
      "outputs": [
        "test-results/**",
        "playwright-report/**"
      ]
    },
    "test:integration": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "test/**/*.{ts,tsx,js,jsx}",
        "**/*.test.{ts,tsx,js,jsx}",
        "**/*.spec.{ts,tsx,js,jsx}",
        "package.json"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:unit": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "test/**/*.{ts,tsx,js,jsx}",
        "**/*.test.{ts,tsx,js,jsx}",
        "**/*.spec.{ts,tsx,js,jsx}",
        "package.json",
        "jest.config.*"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "type-check": {
      "cache": true,
      "dependsOn": [
        "^build:types"
      ],
      "inputs": [
        "src/**/*.{ts,tsx}",
        "package.json",
        "tsconfig.json",
        "!**/*.test.{ts,tsx}",
        "!**/*.spec.{ts,tsx}"
      ],
      "outputs": []
    }
  },
  "remoteCache": {
    "signature": true
  },
  "concurrency": "100%"
}
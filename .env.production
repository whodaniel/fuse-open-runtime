# =============================================================================
# The New Fuse - Production Environment Configuration
# =============================================================================

# Application Environment
NODE_ENV=production
APP_ENV=production

# =============================================================================
# Service URLs & Ports (Railway Auto-Generated)
# =============================================================================

# These will be populated by Railway's variable referencing
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# API Gateway (Main NestJS API Server)
API_URL=https://api-server-production.up.railway.app
BACKEND_URL=https://api-server-production.up.railway.app

# Internal Service URLs (Railway Private Network)
A2A_SERVICE_URL=http://a2a-service:3000
SYNC_CORE_URL=http://sync-core:3003
MCP_CORE_URL=http://mcp-core:3004

# =============================================================================
# Authentication & Security
# =============================================================================

# JWT Configuration
JWT_SECRET=${JWT_SECRET}
JWT_ISSUER=the-new-fuse
JWT_EXPIRES_IN=7d
EXTENSION_JWT_SECRET=${EXTENSION_JWT_SECRET}

# API Keys
API_KEY=${API_KEY}
INTERNAL_API_KEY=${INTERNAL_API_KEY}

# =============================================================================
# External Services
# =============================================================================

# Prisma Services
PRISMA_ACCELERATE_API_KEY=${PRISMA_ACCELERATE_API_KEY}
PULSE_API_KEY=${PULSE_API_KEY}
OPTIMIZE_API_KEY=${OPTIMIZE_API_KEY}

# AI Services
OPENAI_API_KEY=${OPENAI_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
GEMINI_API_KEY=${GEMINI_API_KEY}

# Cloud Services
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_REGION=us-east-1
AWS_S3_BUCKET=${AWS_S3_BUCKET}

# Firebase
FIREBASE_PROJECT_ID=${FIREBASE_PROJECT_ID}
FIREBASE_PRIVATE_KEY=${FIREBASE_PRIVATE_KEY}
FIREBASE_CLIENT_EMAIL=${FIREBASE_CLIENT_EMAIL}

# =============================================================================
# Multi-Tenant Configuration
# =============================================================================

# Tenant-specific configurations (Phase 1 - Direct Environment Variables)
TENANT_DEFAULT_CONFIG=${TENANT_DEFAULT_CONFIG}
TENANT_ENTERPRISE_CONFIG=${TENANT_ENTERPRISE_CONFIG}

# =============================================================================
# Feature Flags
# =============================================================================

FEATURE_AI_ANALYSIS=true
FEATURE_WORKFLOW_ENGINE=true
FEATURE_REAL_TIME_COLLABORATION=true
FEATURE_ADVANCED_SEARCH=true

# =============================================================================
# Performance & Monitoring
# =============================================================================

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CACHE_TTL=3600
MAX_CONCURRENT_TASKS=10

# =============================================================================
# MCP & RAG Configuration
# =============================================================================

MCP_RAG_SERVER_URL=http://mcp-core:3004
RAG_TIMEOUT=30000
RAG_RETRY_ATTEMPTS=3
RAG_RETRY_DELAY=1000
# Local development environment variables
# Copy this to .env.development and fill with real values
DATABASE_URL="postgresql://postgres:postgres@db:5432/the_new_fuse_db?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@db:5432/the_new_fuse_db?schema=public"
PULSE_API_KEY="your-local-pulse-api-key"
OPTIMIZE_API_KEY="your-local-optimize-api-key"
NODE_ENV=development
REDIS_URL="your-redis-url"

# Security Configuration
JWT_SECRET="your-development-jwt-secret-change-in-production"

# Error Monitoring (optional for development)
SENTRY_DSN="your-sentry-dsn-for-error-tracking"

{
  "name": "@the-new-fuse/theia-ide",
  "version": "2.0.0",
  "description": "Modern Theia IDE with full bells and whistles for The New Fuse platform",
  "private": true,
  "main": "enhanced-server.js",
  "scripts": {
    "build": "node build-theia.js",
    "build:optimized": "pnpm install && pnpm exec theia build --mode production",
    "start": "node enhanced-server.js",
    "start:basic": "node simple-server.js",
    "dev": "PORT=3007 node enhanced-server.js",
    "clean": "rm -rf lib dist node_modules/.cache",
    "rebuild": "pnpm run clean && pnpm install && pnpm run build",
    "theia:build": "theia build --mode production",
    "theia:start": "theia start",
    "theia": "theia",
    "build:prod:memsafe": "NODE_OPTIONS=--max_old_space_size=6144 pnpm exec theia build --mode production --stats-error-details"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.1",
    "@theia/ai-anthropic": "1.65.2",
    "@theia/ai-chat": "1.65.2",
    "@theia/ai-core": "1.65.2",
    "@theia/ai-huggingface": "1.65.2",
    "@theia/ai-ollama": "1.65.2",
    "@theia/ai-openai": "1.65.2",
    "@theia/core": "1.65.2",
    "@theia/debug": "1.65.2",
    "@theia/editor": "1.65.2",
    "@theia/filesystem": "1.65.2",
    "@theia/getting-started": "1.65.2",
    "@theia/markers": "1.65.2",
    "@theia/messages": "1.65.2",
    "@theia/monaco": "1.65.2",
    "@theia/navigator": "1.65.2",
    "@theia/outline-view": "1.65.2",
    "@theia/output": "1.65.2",
    "@theia/plugin-ext": "1.65.2",
    "@theia/plugin-ext-vscode": "1.65.2",
    "@theia/preferences": "1.65.2",
    "@theia/scm": "1.65.2",
    "@theia/search-in-workspace": "1.65.2",
    "@theia/terminal": "1.65.2",
    "@theia/toolbar": "1.65.2",
    "@theia/vsx-registry": "1.65.2",
    "@theia/workspace": "1.65.2",
    "express": "^5.1.0",
    "find-git-repositories": "^0.2.2",
    "http-proxy-middleware": "^3.0.5",
    "ws": "^8.18.3",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@theia/cli": "1.65.2",
    "@theia/electron": "1.65.2",
    "concurrently": "^9.2.1",
    "rimraf": "^6.0.1",
    "css-loader": "^6.11.0",
    "source-map-loader": "^4.0.2",
    "style-loader": "^3.3.4",
    "node-loader": "^2.0.0",
    "umd-compat-loader": "^2.1.2"
  }
}
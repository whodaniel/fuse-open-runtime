{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Node.js Program",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/apps/backend/src/main.ts",
      "outFiles": [
        "${workspaceFolder}/apps/**/*.js"
      ],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "sourceMaps": true,
      "runtimeArgs": ["--loader", "ts-node/esm"],
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Launch Frontend Dev Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vite/bin/vite.js",
      "args": ["dev", "--config", "${workspaceFolder}/apps/frontend/vite.config.ts"],
      "cwd": "${workspaceFolder}/apps/frontend",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Debug Backend API",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/apps/api/src/main.ts",
      "outFiles": [
        "${workspaceFolder}/apps/api/**/*.js"
      ],
      "env": {
        "NODE_ENV": "development",
        "DEBUG": "*"
      },
      "console": "integratedTerminal",
      "sourceMaps": true,
      "runtimeArgs": ["--loader", "ts-node/esm"]
    }
  ]
}
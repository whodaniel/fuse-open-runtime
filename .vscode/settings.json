{
  // Editor - General
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.rulers": [100],
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 100,

  // Editor - Code Actions
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },

  // Files
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/.next/**": true,
    "**/.nuxt/**": true,
    "**/.cache/**": true,
    "**/tmp/**": true,
    "**/temp/**": true,
    "**/*.log": true,
    "**/bun.lock": true,
    "**/yarn.lock": true,
    "**/package-lock.json": true,
    "**/.ide/**": true,
    "**/apps/ide-ide/static/**": true,
    "**/apps/ide-ide/lib/**": true,
    "**/drizzle/migrations/**": true,
    "**/k8s/**": true,
    "**/deployment/**": true,
    "**/.turbo/**": true
  },

  // TypeScript
  "typescript.preferences.quoteStyle": "single",
  "typescript.preferences.useAliases": "auto",
  "typescript.preferences.includePackageJsonAutoImports": "auto",
  "typescript.suggest.autoImports": true,
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // JavaScript
  "javascript.preferences.quoteStyle": "single",
  "javascript.suggest.autoImports": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // JSON
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "json.schemas": [
    {
      "fileMatch": ["**/package.json"],
      "url": "https://json.schemastore.org/package"
    },
    {
      "fileMatch": ["**/src/vscode-extension/package.json"],
      "url": "https://raw.githubusercontent.com/microsoft/vscode/main/extensions/package/package.schema.json"
    },
    {
      "fileMatch": ["**/tsconfig.json", "**/tsconfig.*.json"],
      "url": "https://json.schemastore.org/tsconfig"
    }
  ],
  "json.validate.enable": true,
  "json.schemaDownload.enable": true,

  // Markdown
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "files.trimTrailingWhitespace": false
  },

  // YAML
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // CSS/SCSS
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // ESLint
  "eslint.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],

  // Prettier
  "prettier.enable": true,
  "prettier.requireConfig": true,

  // Port Management
  "portManagement.autoResolveConflicts": true,
  "portManagement.monitorInterval": 30000,

  // Jest (configured in workspace file for multi-root workspace)
  "jest.autoRun": "off",

  // Search
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/pnpm-lock.yaml": true
  },

  // Git - Enhanced visibility
  "git.enableStatusBarSync": true,
  "git.showPushSuccessNotification": true,
  "git.showCommitInput": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.autofetchPeriod": 180,
  "git.showUnpushedChangesButton": true,
  "scm.alwaysShowActions": true,
  "scm.alwaysShowRepositories": true,
  "scm.defaultViewMode": "tree",

  // Python
  "python.envFile": "${workspaceFolder}/.env",
  "python.terminal.useEnvFile": true
}

{
  "typescript.preferences.quoteStyle": "single",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "portManagement.autoResolveConflicts": true,
  "portManagement.monitorInterval": 30000,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/.next/**": true,
    "**/.nuxt/**": true,
    "**/.cache/**": true,
    "**/tmp/**": true,
    "**/temp/**": true,
    "**/*.log": true,
    "**/bun.lock": true,
    "**/yarn.lock": true,
    "**/package-lock.json": true,
    "**/.theia/**": true,
    "**/apps/theia-ide/static/**": true,
    "**/apps/theia-ide/lib/**": true,
    "**/prisma/migrations/**": true,
    "**/k8s/**": true,
    "**/deployment/**": true
  },
  "json.schemas": [
    {
      "fileMatch": ["**/package.json"],
      "url": "https://json.schemastore.org/package"
    },
    {
      "fileMatch": ["**/src/vscode-extension/package.json"],
      "url": "https://raw.githubusercontent.com/microsoft/vscode/main/extensions/package/package.schema.json"
    }
  ],
  "json.validate.enable": true,
  "json.schemaDownload.enable": true
}
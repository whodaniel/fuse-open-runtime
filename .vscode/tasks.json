{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Package VS Code Extension",
			"type": "shell",
			"command": "vsce",
			"args": [
				"package",
				"--no-dependencies",
				"--allow-star-activation"
			],
			"group": "build",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Start Chrome for Debugging",
			"type": "shell",
			"command": "${workspaceFolder}/scripts/start-chrome-debug.sh",
			"group": "build",
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			}
		}
	]
}

flowchart TD
    %% Context Construction
    subgraph Context_Construction
        GS[Game State Information]
        MS[Memory System]
        DG[Dynamic Goals]
        RL[Relationships]
        PD[Private Diary]
        ND[Negotiation Diary]
        OD[Order Diary]
        PRD[Phase Result Diary]
        DC[Diary Consolidation]
        PJ[Private Journal]
        POC[Possible Order Context]
        BCP[build_context_prompt]
        RC[Recent Context]
        GS --> BCP
        MS --> BCP
        DG --> BCP
        RL --> BCP
        PD --> BCP
        ND --> BCP
        OD --> BCP
        PRD --> BCP
        DC --> BCP
        PJ --> BCP
        POC --> BCP
        BCP --> RC
    end

    %% Memory System
    subgraph Memory_System
        SGS[Summarized Game State]
        GH[Game History]
        PS[Phase Summary]
        DGO[Dynamic Goals]
        RLS[Relationships]
        PDI[Private Diary]
        NDI[Negotiation Diary]
        ODI[Order Diary]
        PRDI[Phase Result Diary]
        DCO[Diary Consolidation]
        PJO[Private Journal]
        SGS --> DCO
        GH --> DCO
        PS --> DCO
        DGO --> DCO
        RLS --> DCO
        PDI --> DCO
        NDI --> DCO
        ODI --> DCO
        PRDI --> DCO
        DCO --> PJO
    end

    %% Phase Flow
    subgraph Phase_Flow
        INIT[Initialization]
        NEG[Negotiation]
        PLAN[Planning]
        ORDER[Order Generation]
        STATE[State Update]
        INIT --> NEG
        NEG --> PLAN
        PLAN --> ORDER
        ORDER --> STATE
        STATE --> NEG
    end

    %% Context prompt feeds into all phases
    RC --> INIT
    RC --> NEG
    RC --> PLAN
    RC --> ORDER
    RC --> STATE

    %% Memory system is updated after each phase
    STATE --> DCO

    %% Diaries and Summaries
    subgraph Diaries_and_Summaries
        PH_SUM[Phase Summary]
        SUC[Successful Moves]
        FAIL[Failed Moves]
        BOARD[Board Changes]
        PH_SUM --> SUC
        PH_SUM --> FAIL
        PH_SUM --> BOARD
        PH_SUM --> DCO
    end

    %% Negotiation Diary Details
    subgraph Negotiation_Diary
        MSG[Message Analysis]
        TRUST[Trust Assessment]
        RELCH[Relationship Changes]
        ND --> MSG
        ND --> TRUST
        ND --> RELCH
    end

    %% Order Diary Details
    subgraph Order_Diary
        STRAT[Strategic Reasoning]
        RISK[Risk/Reward Analysis]
        OD --> STRAT
        OD --> RISK
    end

    %% Phase Result Diary Details
    subgraph Phase_Result_Diary
        OUT[Outcome Analysis]
        BETR[Betrayal Detection]
        SUCC[Success Evaluation]
        PRD --> OUT
        PRD --> BETR
        PRD --> SUCC
    end

    %% Diary Consolidation
    DC -->|Yearly summaries via Gemini Flash| PJ
